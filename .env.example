# MinerU Configuration (Multimodal Document Parsing)
# ============================================================================
# MinerU uses HuggingFace models for computer vision tasks (tables, images, equations)
# 
# First-time setup:
# - Models auto-download on first PDF processing (~2-5GB, 10-30 minutes)
# - Cached to: %USERPROFILE%\.cache\huggingface\hub (Windows)
# - No HF_TOKEN required for public models (PDF-Extract-Kit)
#
# Optional: HuggingFace authentication token (if needed for private models)
# Get token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
#
# ============================================================================
# MinerU Parser Configuration (Multimodal Document Parsing)
# ============================================================================
# Parser type: mineru (multimodal) or text (text-only fallback)
# Default: mineru (requires models cached, see setup above)
PARSER=mineru
PARSE_METHOD=auto

# Enable/disable multimodal features (true/false)
# Default: all enabled for full multimodal extraction
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

# Optional: Disable symlinks warning on Windows
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
