# ═══════════════════════════════════════════════════════════════════════════════
# GovCon Capture Vibe - Environment Configuration Template
# https://github.com/BdM-15/govcon-capture-vibe
# ═══════════════════════════════════════════════════════════════════════════════
#
# USAGE:
# 1. Copy this file to .env: cp .env.example .env
# 2. Add your API keys (xAI and OpenAI)
# 3. Set your Neo4j password
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# WORKSPACE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Single workspace identifier used for both RAG storage and Neo4j graph isolation.
# Each RFP should have its own workspace (e.g., navy_mbos_2025, army_comms_2025).
# Change this ONE value when switching between RFPs.
WORKSPACE=default

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
HOST=localhost
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# WebUI Branding (LightRAG 1.4.9.7+)
# https://github.com/HKUDS/LightRAG
WEBUI_TITLE=Project Theseus
WEBUI_DESCRIPTION=Government Contracting Intelligence Platform - Navigate the labyrinth of federal RFPs

# ═══════════════════════════════════════════════════════════════════════════════
# LLM CONFIGURATION (xAI Grok via OpenAI-compatible API)
# https://docs.x.ai/docs
# ═══════════════════════════════════════════════════════════════════════════════
# Using OpenAI-compatible binding to access xAI's API at api.x.ai/v1
# MUST be "openai" (not "xai-sdk") for LightRAG to load OpenAI binding options
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.x.ai/v1
LLM_BINDING_API_KEY=xai-your-key-here  # Get from https://console.x.ai

# Tri-LLM Architecture: Separate models for extraction, post-processing, and query
# - Extraction: Fast non-reasoning model for entity extraction (high throughput)
# - Post-Processing: Fast reasoning model for inference algorithms (throughput + reasoning)
# - Reasoning: Full reasoning model for queries (lowest hallucination + strict adherence)
EXTRACTION_LLM_NAME=grok-4-1-fast-non-reasoning
POST_PROCESSING_LLM_NAME=grok-4-1-fast-reasoning
REASONING_LLM_NAME=grok-4-1-fast-reasoning

# LLM Parameters
LLM_MODEL_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=128000
LLM_TIMEOUT_SECONDS=300

# OpenAI LLM Options (read by LightRAG's OpenAILLMOptions binding)
# https://github.com/HKUDS/LightRAG/blob/main/lightrag/llm/binding_options.py
OPENAI_LLM_MAX_COMPLETION_TOKENS=128000

# ═══════════════════════════════════════════════════════════════════════════════
# EMBEDDING CONFIGURATION (OpenAI)
# CRITICAL: Must use OpenAI endpoint - xAI doesn't provide embeddings
# https://platform.openai.com/docs/guides/embeddings
# ═══════════════════════════════════════════════════════════════════════════════
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=sk-your-openai-key-here  # Get from https://platform.openai.com
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# ═══════════════════════════════════════════════════════════════════════════════
# CHUNKING CONFIGURATION
# Read by LightRAG at dataclass initialization time
# https://github.com/HKUDS/LightRAG/blob/main/lightrag/lightrag.py
# ═══════════════════════════════════════════════════════════════════════════════
CHUNK_SIZE=4096
CHUNK_OVERLAP_SIZE=600

# ═══════════════════════════════════════════════════════════════════════════════
# PARALLELISM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
MAX_ASYNC=16
EMBEDDING_FUNC_MAX_ASYNC=16
MAX_GLEANING=0

# ═══════════════════════════════════════════════════════════════════════════════
# RAG-ANYTHING CONTEXT CONFIGURATION
# Pass-through variables read directly by RAGAnythingConfig
# https://github.com/HKUDS/RAG-Anything/blob/main/raganything/config.py
# ═══════════════════════════════════════════════════════════════════════════════
CONTEXT_WINDOW=2
CONTEXT_MODE=page
CONTENT_FORMAT=minerU
MAX_CONTEXT_TOKENS=3000
INCLUDE_HEADERS=true
INCLUDE_CAPTIONS=true
CONTEXT_FILTER_CONTENT_TYPES=text,table

# ═══════════════════════════════════════════════════════════════════════════════
# MINERU DOCUMENT PARSING CONFIGURATION
# https://github.com/opendatalab/MinerU
# ═══════════════════════════════════════════════════════════════════════════════
PARSER=mineru
PARSE_METHOD=auto
MINERU_BACKEND=pipeline
MINERU_LANG=en
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

# ═══════════════════════════════════════════════════════════════════════════════
# GPU CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
CUDA_VISIBLE_DEVICES=0
MINERU_DEVICE_MODE=cuda

# ═══════════════════════════════════════════════════════════════════════════════
# NEO4J GRAPH DATABASE CONFIGURATION
# https://neo4j.com/docs/
# ═══════════════════════════════════════════════════════════════════════════════
GRAPH_STORAGE=Neo4JStorage
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

# ═══════════════════════════════════════════════════════════════════════════════
# SEMANTIC POST-PROCESSING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
BATCH_TIMEOUT_SECONDS=30

# ═══════════════════════════════════════════════════════════════════════════════
# HUGGINGFACE HUB CONFIGURATION
# https://huggingface.co/docs/huggingface_hub
# ═══════════════════════════════════════════════════════════════════════════════
HF_HUB_DISABLE_SYMLINKS=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL MCP SERVER API KEYS (1102tools/federal-contracting-mcps)
# Theseus vendors MCPs under tools/mcps/<name>/. Each MCP that requires a key
# declares it in env_required[]; the runtime injects only the declared vars
# into that subprocess (closed allowlist). Leave any unused key blank.
#
# No-key MCPs (work out of the box, nothing to set):
#   - usaspending  (Phase 4c) — federal awards / subawards / recipients
#   - ecfr         (Phase 4f) — current CFR text, FAR/DFARS/agency supplements
#   - gsa_calc     (Phase 4f.3) — GSA CALC+ awarded NTE hourly rates
#   - gsa_perdiem  (Phase 4f.4) — federal travel lodging + M&IE rates (DEMO_KEY mode)
#   - federal_register (Phase 4f.5) — proposed/final rules, EOs, FAR cases
#
# Key-gated MCPs (set the matching var when you vendor that MCP):
# ═══════════════════════════════════════════════════════════════════════════════

# SAM.gov — entity registration, exclusions, opportunities, contract awards
# (FPDS replacement), federal hierarchy, FFATA subawards.
# Free key: https://sam.gov/  (Account Details → Request Public API Key)
SAM_GOV_API_KEY=

# BLS OEWS — Bureau of Labor Statistics Occupational Employment & Wage Stats
# (~830 occupations × 530+ metros). Used by future price-to-win skill.
# Free key: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# api.data.gov — single key covers GSA Per Diem and Regulations.gov MCPs.
# Free key: https://api.data.gov/signup/
# Setting this lifts gsa_perdiem from the shared DEMO_KEY tier
# (~10 req/hr globally) to your personal 1,000 req/hr tier.
API_DATA_GOV_KEY=

# gsa-perdiem-mcp reads PERDIEM_API_KEY specifically — auto-derived from
# the single api.data.gov key above so you only ever set one value.
# (python-dotenv expands ${VAR} references at load time.)
PERDIEM_API_KEY=${API_DATA_GOV_KEY}

# === Agent Skills (Phase 1) ===
# Char-budget for the JSON-serialized entity_payload injected into a skill
# prompt. xAI Grok handles 200k+ comfortably; lower if you switch to a
# smaller-context model or want to cut token costs.
SKILL_MAX_PAYLOAD_CHARS=200000
# Default per-entity-type slice cap when the UI does not pin a value.
SKILL_MAX_ENTITIES_PER_TYPE=40
# Phase 1.5 source-grounding caps. The skill briefing book attaches verbatim
# RFP chunks + KG relationships per entity so the model can quote sources
# instead of paraphrasing. Set either to 0 to disable that block entirely.
SKILL_MAX_CHUNKS_PER_ENTITY=2
SKILL_MAX_RELATIONSHIPS_PER_ENTITY=5

# Phase 1.6 chat-grade retrieval for skills. When SKILL_RETRIEVAL_MODE is not
# 'off', the user prompt + skill description run through LightRAG aquery_data
# and only the resulting entities populate the briefing book (same retrieval
# pipeline the chat uses). Valid modes: mix|hybrid|local|global|naive|off. Default 'mix' matches the chat default so skills and chat use the same retrieval contract.
SKILL_RETRIEVAL_MODE=mix
SKILL_RETRIEVAL_TOP_K=60
