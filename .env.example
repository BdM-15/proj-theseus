# Production (use strong passwords):
# AUTH_ACCOUNTS={"capture_lead": "Str0ng!Pass123", "analyst": "An@lyst!456", "admin": "Adm!n789Secure"}
#
# Authentication Settings:
# AUTH_ACCOUNTS={}  # Empty = guest mode (current default)
# TOKEN_SECRET=your-secret-key-change-this-in-production  # CRITICAL: Change in production!
# JWT_ALGORITHM=HS256  # JWT signing algorithm
# TOKEN_EXPIRE_HOURS=24  # Regular user token expiration
# GUEST_TOKEN_EXPIRE_HOURS=720  # Guest token expiration (30 days)
#
# Features when enabled:
# - JWT bearer token authentication
# - Role-based access (admin, user, guest)
# - Token expiration and refresh
# - Protected API endpoints
# - WebUI login interface
