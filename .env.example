# ============================================================================
# GovCon Capture Vibe - Environment Configuration Template
# Branch 003: Hybrid Cloud + Local Architecture
# ============================================================================
#
# USAGE:
# 1. Copy this file to .env: cp .env.example .env
# 2. Choose configuration: Branch 002 (Local) or Branch 003 (Cloud)
# 3. For cloud: Add your xAI API key
#
# ============================================================================

# ============================================================================
# Server Configuration (Same for both branches)
# ============================================================================
HOST=localhost
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# ============================================================================
# BRANCH 002: Fully Local Configuration (100% Private)
# ============================================================================
# Use this for:
# - 100% privacy (no cloud exposure)
# - Zero API costs
# - Air-gapped environments
# - Proprietary proposal analysis
#
# Performance: 6-8 hours for large RFPs (71-page Navy MBOS: 8 hours)
# ============================================================================

# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://localhost:11434
# LLM_MODEL=mistral-nemo:latest
# OLLAMA_LLM_NUM_CTX=32768
# LLM_TIMEOUT=1800
# OLLAMA_LLM_NUM_PREDICT=45000
# OPENAI_LLM_TEMPERATURE=0.1

# ============================================================================
# BRANCH 003: Cloud Configuration (Fast Public RFP Processing)
# ============================================================================
# Use this for:
# - Fast processing of PUBLIC RFPs (20-30x faster)
# - Production capture team workflows
# - Cost-effective processing ($0.03-$0.10 per RFP)
#
# Performance: 30-60 minutes for large RFPs (71-page Navy MBOS: 10-15 min)
#
# SECURITY: Only use for PUBLIC government documents!
# Proprietary queries should still use local Ollama (see Branch 002 config)
# ============================================================================

# xAI Grok LLM Configuration (OpenAI-compatible API)
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.x.ai/v1
LLM_MODEL=grok-beta
LLM_BINDING_API_KEY=xai-your-key-here  # Get from https://console.x.ai

# Cloud LLM Timeout: 300 seconds (5 minutes - cloud is much faster)
LLM_TIMEOUT=300

# Temperature: Low for deterministic extraction
OPENAI_LLM_TEMPERATURE=0.1

# Max Async: Higher parallelism with cloud models
MAX_ASYNC=5

# ============================================================================
# Embedding Configuration (Local - Same for Both Branches)
# ============================================================================
# Embeddings stay local for both branches (faster, free, no privacy concerns)
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=300
OLLAMA_EMBEDDING_NUM_CTX=8192

# ============================================================================
# Document Processing Configuration (Same for Both Branches)
# ============================================================================
CHUNK_SIZE=800
CHUNK_OVERLAP_SIZE=100
SUMMARY_MAX_TOKENS=1200
SUMMARY_LENGTH_RECOMMENDED=600
SUMMARY_CONTEXT_SIZE=12000
FORCE_LLM_SUMMARY_ON_MERGE=8

# ============================================================================
# Worker Management (Branch 002 Only - Not Needed for Cloud)
# ============================================================================
# Ollama worker refresh prevents memory leaks in local processing
# Not needed for Branch 003 cloud processing
OLLAMA_REFRESH_INTERVAL=3

# ============================================================================
# Query Configuration (Same for Both Branches)
# ============================================================================
TOP_K=40
CHUNK_TOP_K=20
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000
COSINE_THRESHOLD=0.2
RELATED_CHUNK_NUMBER=5
KG_CHUNK_PICK_METHOD=VECTOR

# LLM Cache
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true

# ============================================================================
# Storage Configuration (Same for Both Branches)
# ============================================================================
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# ============================================================================
# Logging Configuration (Same for Both Branches)
# ============================================================================
LOG_LEVEL=INFO
LOG_CONSOLE=true

# Server Timeout
TIMEOUT=1800

# ============================================================================
# Configuration Summary
# ============================================================================
#
# BRANCH 002 (Local):
# - LLM: Ollama mistral-nemo:latest (12B, 128K context)
# - Embeddings: Ollama bge-m3:latest (1024-dim)
# - Processing: 6-8 hours per large RFP
# - Cost: Free (zero API costs)
# - Privacy: 100% local (no cloud exposure)
#
# BRANCH 003 (Cloud):
# - LLM: xAI Grok (grok-beta via OpenAI-compatible API)
# - Embeddings: Ollama bge-m3:latest (still local)
# - Processing: 30-60 minutes per large RFP (20-30x faster)
# - Cost: $0.03-$0.10 per public RFP
# - Privacy: PUBLIC documents only (proprietary stays local)
#
# Security Boundary:
# - Public RFPs → Cloud processing (xAI Grok)
# - Proprietary queries → Local processing (Ollama)
# - Knowledge graph queries → Local (100% private)
#
# ============================================================================
