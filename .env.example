# ============================================================================
# GovCon Capture Vibe - Environment Configuration Template
# Branch 003: Hybrid Cloud + Local Architecture
# ============================================================================
#
# USAGE:
# 1. Copy this file to .env: cp .env.example .env
# 2. Choose configuration: Branch 002 (Local) or Branch 003 (Cloud)
# 3. For cloud: Add your xAI API key
#
# ============================================================================

# ============================================================================
# Server Configuration (Same for both branches)
# ============================================================================
HOST=localhost
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# WebUI Branding (LightRAG 1.4.9.7+)
# Custom title appears in header next to default "LightRAG" logo
WEBUI_TITLE=Project Theseus
WEBUI_DESCRIPTION=Government Contracting Intelligence Platform - Navigate the labyrinth of federal RFPs

# Workspace Configuration (Branch 010+ Multi-Workspace Support)
# WORKSPACE: Logical namespace for data isolation
# - Each RFP should have its own workspace (e.g., navy_mbos_2025, army_comms_2025)
# - Event sourcing uses workspace suffixes (e.g., navy_mbos_2025_amendment_001)
# - Default: "default" (for backwards compatibility with pre-workspace data)
# 
# IMPORTANT: This is overridden by WebUI workspace dropdown when uploading documents.
# Set this for command-line processing or as fallback default.
#
# CHANGE BOTH VALUES TOGETHER when switching RFPs:
WORKSPACE=default
NEO4J_WORKSPACE=default

# ============================================================================
# BRANCH 002: Fully Local Configuration (ARCHIVED - Available as fallback)
# ============================================================================
# Branch 002 remains available on git branch: 002-lighRAG-govcon-ontology
#
# Use this for:
# - 100% privacy (no cloud exposure)
# - Zero API costs
# - Air-gapped environments
# - Proprietary proposal analysis
#
# Performance: 6-8 hours for large RFPs (71-page Navy MBOS: 8 hours vs 69s cloud)
#
# To use Branch 002:
# 1. git checkout 002-lighRAG-govcon-ontology
# 2. Uncomment the settings below
# 3. Ensure Ollama is running: ollama serve
# ============================================================================

# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://localhost:11434
# LLM_MODEL=mistral-nemo:latest
# OLLAMA_LLM_NUM_CTX=32768
# LLM_TIMEOUT=1800
# OLLAMA_LLM_NUM_PREDICT=45000
# OPENAI_LLM_TEMPERATURE=0.1

# ============================================================================
# BRANCH 003: Cloud Configuration (Fast Public RFP Processing)
# ============================================================================
# Use this for:
# - Fast processing of PUBLIC RFPs (417x faster than local)
# - Production capture team workflows
# - Cost-effective processing ($0.042 per RFP actual)
#
# Validated Performance: 71-page Navy MBOS RFP = 69 seconds, 594 entities
#
# SECURITY: Only use for PUBLIC government documents!
# Proprietary queries stay 100% local (zero cloud exposure)
# ============================================================================

# xAI Grok LLM Configuration (OpenAI-compatible API)
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.x.ai/v1
LLM_MODEL=grok-4-fast-reasoning
LLM_BINDING_API_KEY=xai-your-key-here  # Get from https://console.x.ai

# Dual-LLM split (ingestion vs query)
# UNIFIED MODEL: Use reasoning model for all operations (extraction + query)
# Rationale: Deep domain ontology requires reasoning for accurate entity detection
# Non-reasoning model struggles with nuanced government contracting relationships
EXTRACTION_LLM_NAME=grok-4-fast-reasoning
REASONING_LLM_NAME=grok-4-fast-reasoning

# OpenAI Embeddings Configuration (CRITICAL: Use OpenAI endpoint, not xAI)
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_BINDING_API_KEY=sk-proj-your-openai-key-here  # Get from https://platform.openai.com

# Cloud-Optimized Chunking (Branch 005)
# CHUNK_SIZE: Document chunking for BOTH LLM entity extraction and embeddings
# CRITICAL: 50K chunks caused catastrophic extraction failure (63 entities vs 400-600 expected)
# Issue: LLM attention decay at large context - misses most entities in single 50K pass
# Solution: 8K chunks = multiple focused extraction passes = comprehensive coverage
# - LLM makes 5-6 passes over 71-page doc (vs 1 pass with 50K)
# - Each pass extracts 80-100 entities with high precision
# - LightRAG merges entities across chunks automatically
# CHUNK_OVERLAP_SIZE: 15% overlap (1200 tokens) ensures context preservation
CHUNK_SIZE=8192
CHUNK_OVERLAP_SIZE=1200

# Maximum Concurrency
# LLM (xAI Grok): 32 workers - high rate limits, no issues
# Embeddings (OpenAI): 32 workers - LightRAG doubles during merge phase
MAX_ASYNC=32
EMBEDDING_FUNC_MAX_ASYNC=32

# Temperature: Low for deterministic extraction
LLM_MODEL_TEMPERATURE=0.1

# LightRAG Extraction Configuration
# Gleaning: Additional LLM passes to catch missed entities (default: 1)
# For dense RFP content, 2 passes improve coverage without excessive cost
ENTITY_EXTRACT_MAX_GLEANING=2

# ============================================================================
# Embedding Configuration (Branch 002 - Archived)
# ============================================================================
# Branch 002 used local Ollama embeddings. Branch 003 uses OpenAI for better quality.
# Uncomment below if using Branch 002:
#
# EMBEDDING_BINDING=ollama
# EMBEDDING_BINDING_HOST=http://localhost:11434
# EMBEDDING_MODEL=bge-m3:latest
# EMBEDDING_DIM=1024
# EMBEDDING_TIMEOUT=300
# OLLAMA_EMBEDDING_NUM_CTX=8192

# ============================================================================
# Document Processing Configuration (Branch 002 - Archived)
# ============================================================================
# Branch 002 used smaller 800-token chunks. Branch 003 uses 4096-token chunks.
# These settings are for Branch 002 only:
#
# CHUNK_SIZE=800
# CHUNK_OVERLAP_SIZE=100
# SUMMARY_MAX_TOKENS=1200
# SUMMARY_LENGTH_RECOMMENDED=600
# SUMMARY_CONTEXT_SIZE=12000
# FORCE_LLM_SUMMARY_ON_MERGE=8
# OLLAMA_REFRESH_INTERVAL=3  # Worker refresh (Branch 002 memory management)

# ============================================================================
# Government Contracting Ontology (Hardcoded in src/raganything_server.py)
# ============================================================================
# Entity types are defined in code to ensure consistency across all processing.
# These 12 entity types transform generic LightRAG into domain-specific
# government contracting intelligence:
#
# ORGANIZATION - Contractors, agencies, departments
# CONCEPT - CLINs, budget, technical concepts
# EVENT - Milestones, deliveries, reviews
# TECHNOLOGY - Systems, tools, platforms
# PERSON - POCs, contracting officers
# LOCATION - Delivery sites, performance locations
# REQUIREMENT - Explicit must/should/may requirements
# CLAUSE - FAR clauses, contract provisions
# SECTION - RFP sections (A-M, J attachments)
# DOCUMENT - Referenced documents, attachments
# DELIVERABLE - Contract deliverables, work products
# EVALUATION_FACTOR - Section M factors, Section L instructions
#
# These types enable:
# - Section L↔M relationship mapping (critical for proposal compliance)
# - Requirement→Deliverable traceability
# - FAR clause applicability analysis
# - Uniform Contract Format (UCF) structure preservation
# ============================================================================

# ============================================================================
# Query Configuration (Branch 002 - May need adjustment for Branch 003)
# ============================================================================
# These settings control how queries search the knowledge graph
# Branch 003 may benefit from different tuning given larger chunks
#
# TOP_K=40
# CHUNK_TOP_K=20
# MAX_ENTITY_TOKENS=6000
# MAX_RELATION_TOKENS=8000
# MAX_TOTAL_TOKENS=30000
# COSINE_THRESHOLD=0.2
# RELATED_CHUNK_NUMBER=5
# KG_CHUNK_PICK_METHOD=VECTOR
#
# LLM Cache
# ENABLE_LLM_CACHE=true
# ENABLE_LLM_CACHE_FOR_EXTRACT=true

# ============================================================================
# Storage Configuration (Default - Managed by RAG-Anything/LightRAG)
# ============================================================================
# Storage backends are automatically configured. Override only if needed:
#
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
# LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# ============================================================================
# MinerU Configuration (Multimodal Document Parsing)
# ============================================================================
# Parser type: mineru (multimodal) or text (text-only fallback)
PARSER=mineru
PARSE_METHOD=auto

# Language optimization (improves OCR accuracy, reduces word adhesion)
MINERU_LANG=en

# Enable multimodal features
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

# ============================================================================
# GPU Optimization (MinerU Performance)
# ============================================================================
# CRITICAL: Ensure PyTorch with CUDA support is installed:
#   uv pip install torch torchvision --index-url https://download.pytorch.org/whl/cu124
# Verify GPU: python -c "import torch; print('CUDA:', torch.cuda.is_available())"

# PyTorch GPU Settings (maximize RTX 4060 utilization)
CUDA_VISIBLE_DEVICES=0                    # Use first GPU (RTX 4060)
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True  # Not supported on Windows

# MinerU Device Selection (auto-detects GPU if CUDA available)
# Options: cuda, cpu, auto (default)
# IMPORTANT: MinerU uses MINERU_DEVICE_MODE (not MINERU_DEVICE)
MINERU_DEVICE_MODE=cuda                   # Force GPU (RTX 4060)

# Batch Processing (for multiple document uploads)
# MINERU_BATCH_SIZE=1                     # Process 1 document at a time (default, safe for 8GB VRAM)

# Optional: HuggingFace authentication token (not required for public PDF-Extract-Kit models)
# Get token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# Disable symlinks warning on Windows (harmless filesystem limitation)
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# MinerU 2.6.2+ Advanced Configuration (Optional - Use defaults unless needed)
# ============================================================================

# Formula Recognition (MinerU 2.6.2+)
# MINERU_FORMULA_ENABLE: Enable/disable LaTeX formula detection (default: 1 = enabled)
# Set to 0 to disable if formula recognition causes issues (e.g., $6000→$60000 bug)
# Note: Disabling may help with financial data extraction accuracy
# MINERU_FORMULA_ENABLE=1

# Chinese Formula Support (Experimental - MinerU 2.6.2+)
# Enable only if parsing Chinese formulas (may reduce speed/accuracy for Latin scripts)
# MINERU_FORMULA_CH_SUPPORT=0

# Table Merging (MinerU 2.6.2+)
# Cross-page table merging for continuation tables (default: 1 = enabled)
# Set to 0 to disable if tables are incorrectly merged across pages
# MINERU_TABLE_MERGE_ENABLE=1

# PDF Rendering Timeout (MinerU 2.6.4+)
# Timeout for PDF image rendering in seconds (default: 300 = 5 minutes)
# Increase for complex PDFs that timeout during rendering
# MINERU_PDF_RENDER_TIMEOUT=300

# ONNX Model CPU Threads (MinerU 2.6.4+)
# Control CPU thread usage for OCR models (default: system CPU core count)
# Reduce in high-concurrency scenarios to avoid CPU contention
# MINERU_INTRA_OP_NUM_THREADS=auto
# MINERU_INTER_OP_NUM_THREADS=auto

# ============================================================================
# Neo4j Configuration (Branch 010+ Enterprise Knowledge Graph)
# ============================================================================
# CRITICAL: Neo4j provides enterprise-grade graph storage with:
# - Multi-workspace isolation via labels (no cross-contamination)
# - APOC subgraph queries for multi-RFP intelligence
# - Full-text indexing for fast entity search
# - 417x faster than local NetworkX processing

# Graph Storage Backend (default: NetworkXStorage for local files)
# Options: NetworkXStorage (JSON/GraphML), Neo4JStorage (enterprise)
GRAPH_STORAGE=Neo4JStorage

# Neo4j Connection
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password  # Change this!

# Neo4j Database Name (default: neo4j)
# Use default for Community Edition, can customize for Enterprise
NEO4J_DATABASE=neo4j

# Neo4j Connection Pool Settings (optional, use defaults for most cases)
# NEO4J_MAX_CONNECTION_POOL_SIZE=100
# NEO4J_CONNECTION_TIMEOUT=30.0
# NEO4J_MAX_TRANSACTION_RETRY_TIME=30.0

# ============================================================================
# Debug Configuration (for MinerU troubleshooting)
# ============================================================================
LOG_LEVEL=INFO
LIGHTRAG_LOG_LEVEL=INFO
# Enable per-call LLM logging (prints model, temp, prompt length for each LLM call)
# Set to true to capture extraction vs reasoning routing in logs. Requires server restart.
# For regular use keep this disabled to avoid noisy logs and potential PII leakage.
LOG_LLM_CALLS=false

# ============================================================================
# Logging Configuration (Current: Terminal output only)
# ============================================================================
# Branch 003 logs to terminal (stdout/stderr) only.
# No file logging configured in current code.
#
# LOG_LEVEL=INFO
# LOG_CONSOLE=true

# Server Timeout (adjust for large RFP processing if needed)
# TIMEOUT=1800

# ============================================================================
# Configuration Summary
# ============================================================================
#
# BRANCH 002 (Local - ARCHIVED):
# - LLM: Ollama mistral-nemo:latest (12B, 128K context)
# - Embeddings: Ollama bge-m3:latest (1024-dim)
# - Processing: 6-8 hours per large RFP (71-page Navy MBOS: 8 hours)
# - Cost: Free (zero API costs)
# - Privacy: 100% local (no cloud exposure)
# - Status: Available on branch 002-lighRAG-govcon-ontology
#
# BRANCH 003 (Cloud - CURRENT):
# - LLM: xAI Grok (grok-4-fast-reasoning, 2M context)
# - Embeddings: OpenAI text-embedding-3-large (3072-dim)
# - Processing: 69 seconds for 71-page RFP (417x faster than Branch 002)
# - Entities: 594 entities extracted (3.5x more than Branch 002)
# - Cost: $0.042 per public RFP (4.2 cents actual)
# - Privacy: PUBLIC documents only (queries stay 100% local)
#
# Validated Performance (Navy MBOS RFP, 71 pages):
# - Time: 69 seconds (vs 8 hours local)
# - Entities: 594 (vs 172 local)
# - Relationships: 584
# - Cost: $0.042 (4.2 cents)
# - Speedup: 417x faster
#
# Security Boundary:
# - Public RFPs → Cloud processing (xAI Grok + OpenAI embeddings)
# - Proprietary queries → 100% local (zero cloud exposure)
# - Knowledge graph storage → Local only (never sent to cloud)
#
# ============================================================================
