# ============================================================================
# GovCon Capture Vibe - Environment Configuration Template
# Branch 003: Hybrid Cloud + Local Architecture
# ============================================================================
#
# USAGE:
# 1. Copy this file to .env: cp .env.example .env
# 2. Choose configuration: Branch 002 (Local) or Branch 003 (Cloud)
# 3. For cloud: Add your xAI API key
#
# ============================================================================

# ============================================================================
# Server Configuration (Same for both branches)
# ============================================================================
HOST=localhost
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# ============================================================================
# BRANCH 002: Fully Local Configuration (ARCHIVED - Available as fallback)
# ============================================================================
# Branch 002 remains available on git branch: 002-lighRAG-govcon-ontology
#
# Use this for:
# - 100% privacy (no cloud exposure)
# - Zero API costs
# - Air-gapped environments
# - Proprietary proposal analysis
#
# Performance: 6-8 hours for large RFPs (71-page Navy MBOS: 8 hours vs 69s cloud)
#
# To use Branch 002:
# 1. git checkout 002-lighRAG-govcon-ontology
# 2. Uncomment the settings below
# 3. Ensure Ollama is running: ollama serve
# ============================================================================

# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://localhost:11434
# LLM_MODEL=mistral-nemo:latest
# OLLAMA_LLM_NUM_CTX=32768
# LLM_TIMEOUT=1800
# OLLAMA_LLM_NUM_PREDICT=45000
# OPENAI_LLM_TEMPERATURE=0.1

# ============================================================================
# BRANCH 003: Cloud Configuration (Fast Public RFP Processing)
# ============================================================================
# Use this for:
# - Fast processing of PUBLIC RFPs (417x faster than local)
# - Production capture team workflows
# - Cost-effective processing ($0.042 per RFP actual)
#
# Validated Performance: 71-page Navy MBOS RFP = 69 seconds, 594 entities
#
# SECURITY: Only use for PUBLIC government documents!
# Proprietary queries stay 100% local (zero cloud exposure)
# ============================================================================

# xAI Grok LLM Configuration (OpenAI-compatible API)
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.x.ai/v1
LLM_MODEL=grok-4-fast-reasoning
LLM_BINDING_API_KEY=xai-your-key-here  # Get from https://console.x.ai

# OpenAI Embeddings Configuration (CRITICAL: Use OpenAI endpoint, not xAI)
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BINDING_API_KEY=sk-proj-your-openai-key-here  # Get from https://platform.openai.com

# Cloud-Optimized Chunking (Branch 005 - Enhanced for semantic coherence)
# 4096 tokens: 2x larger chunks for better Section L↔M detection
# 512 overlap: Maintains 12.5% overlap ratio for relationship capture
# Benefits: 50% fewer API calls, better context window, improved L↔M relationships
CHUNK_SIZE=4096
CHUNK_OVERLAP_SIZE=512

# Maximum Concurrency (32 parallel requests for speed)
MAX_ASYNC=32
EMBEDDING_FUNC_MAX_ASYNC=32

# Temperature: Low for deterministic extraction
LLM_MODEL_TEMPERATURE=0.1

# ============================================================================
# Embedding Configuration (Branch 002 - Archived)
# ============================================================================
# Branch 002 used local Ollama embeddings. Branch 003 uses OpenAI for better quality.
# Uncomment below if using Branch 002:
#
# EMBEDDING_BINDING=ollama
# EMBEDDING_BINDING_HOST=http://localhost:11434
# EMBEDDING_MODEL=bge-m3:latest
# EMBEDDING_DIM=1024
# EMBEDDING_TIMEOUT=300
# OLLAMA_EMBEDDING_NUM_CTX=8192

# ============================================================================
# Document Processing Configuration (Branch 002 - Archived)
# ============================================================================
# Branch 002 used smaller 800-token chunks. Branch 003 uses 4096-token chunks.
# These settings are for Branch 002 only:
#
# CHUNK_SIZE=800
# CHUNK_OVERLAP_SIZE=100
# SUMMARY_MAX_TOKENS=1200
# SUMMARY_LENGTH_RECOMMENDED=600
# SUMMARY_CONTEXT_SIZE=12000
# FORCE_LLM_SUMMARY_ON_MERGE=8
# OLLAMA_REFRESH_INTERVAL=3  # Worker refresh (Branch 002 memory management)

# ============================================================================
# Government Contracting Ontology (Hardcoded in src/raganything_server.py)
# ============================================================================
# Entity types are defined in code to ensure consistency across all processing.
# These 12 entity types transform generic LightRAG into domain-specific
# government contracting intelligence:
#
# ORGANIZATION - Contractors, agencies, departments
# CONCEPT - CLINs, budget, technical concepts
# EVENT - Milestones, deliveries, reviews
# TECHNOLOGY - Systems, tools, platforms
# PERSON - POCs, contracting officers
# LOCATION - Delivery sites, performance locations
# REQUIREMENT - Explicit must/should/may requirements
# CLAUSE - FAR clauses, contract provisions
# SECTION - RFP sections (A-M, J attachments)
# DOCUMENT - Referenced documents, attachments
# DELIVERABLE - Contract deliverables, work products
# EVALUATION_FACTOR - Section M factors, Section L instructions
#
# These types enable:
# - Section L↔M relationship mapping (critical for proposal compliance)
# - Requirement→Deliverable traceability
# - FAR clause applicability analysis
# - Uniform Contract Format (UCF) structure preservation
# ============================================================================

# ============================================================================
# Query Configuration (Branch 002 - May need adjustment for Branch 003)
# ============================================================================
# These settings control how queries search the knowledge graph
# Branch 003 may benefit from different tuning given larger chunks
#
# TOP_K=40
# CHUNK_TOP_K=20
# MAX_ENTITY_TOKENS=6000
# MAX_RELATION_TOKENS=8000
# MAX_TOTAL_TOKENS=30000
# COSINE_THRESHOLD=0.2
# RELATED_CHUNK_NUMBER=5
# KG_CHUNK_PICK_METHOD=VECTOR
#
# LLM Cache
# ENABLE_LLM_CACHE=true
# ENABLE_LLM_CACHE_FOR_EXTRACT=true

# ============================================================================
# Storage Configuration (Default - Managed by RAG-Anything/LightRAG)
# ============================================================================
# Storage backends are automatically configured. Override only if needed:
#
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
# LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

