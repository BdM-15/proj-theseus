{
  "skill": "competitive-intel",
  "version": "0.4.0",
  "notes": "Phase 4e — black-hat plus contract-number obligation mode, now requiring period-of-performance breakdowns, richer by-transaction metadata, cumulative running totals, inferred POP segment labels, and rate_analysis block for manual rate analysis. Run from a workspace whose KG has at least program/agency/NAICS context OR provide contract number inputs directly. Live MCP eval requires THESEUS_LIVE_MCP=1.",
  "evals": [
    {
      "id": "eval-001-incumbent-active-window",
      "prompt": "Who is the incumbent on this contract and when does their period of performance end?",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel.json"
        },
        {
          "kind": "json_path_set",
          "path": "incumbent.name"
        },
        {
          "kind": "json_path_in_set",
          "path": "incumbent.incumbent_status",
          "values": ["current", "prior", "unknown"]
        },
        {
          "kind": "json_path_set",
          "path": "incumbent.flagship_award_id"
        },
        {
          "kind": "transcript_tool_called",
          "tool": "mcp__usaspending__search_awards"
        }
      ]
    },
    {
      "id": "eval-002-top-three-competitors",
      "prompt": "Give me a black-hat read on the top three likely competitors for this opportunity. I need predicted themes and ghost language hooks I can hand to my proposal lead.",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel.json"
        },
        {
          "kind": "json_path_array_min_length",
          "path": "competitors",
          "min": 3
        },
        {
          "kind": "json_path_array_min_length_each",
          "path": "competitors[*].predicted_themes",
          "min": 1
        },
        {
          "kind": "json_path_array_min_length_each",
          "path": "competitors[*].ghost_language_hooks",
          "min": 1
        },
        {
          "kind": "json_path_array_contains",
          "path": "competitors[*].claim_gaps",
          "value_substring": "CPARS"
        }
      ]
    },
    {
      "id": "eval-003-pricing-benchmark",
      "prompt": "What's the typical award value range for this NAICS at this magnitude over the last 5 years? Be honest if the sample is too small to give a real range.",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel.json"
        },
        {
          "kind": "json_path_in_set",
          "path": "pricing_benchmark.pricing_band",
          "values": ["valid", "insufficient sample"]
        },
        {
          "kind": "json_path_set",
          "path": "pricing_benchmark.sample_size"
        },
        {
          "kind": "transcript_tool_called",
          "tool": "mcp__usaspending__search_awards"
        }
      ]
    },
    {
      "id": "eval-004-missing-naics-fail-loud",
      "prompt": "Run competitive intel on this opportunity.",
      "workspace_hint": "use a workspace with NO regulatory_reference entities for NAICS/PSC",
      "expectations": [
        {
          "kind": "response_contains",
          "value": "GAP"
        },
        {
          "kind": "transcript_no_invention",
          "rule": "no competitor name should appear that wasn't returned by mcp__usaspending__search_awards"
        }
      ]
    },
    {
      "id": "competitive-intel-grounding-floor",
      "name": "Grounding-audit floor",
      "prompt": "Who is the incumbent on this contract and when does their period of performance end?",
      "expected_signals": [
        "tools/audit_skill_grounding.py --skill competitive-intel reports grounding_ratio >= 0.65 (black-hat envelope is mostly KG-grounded incumbent claims, but ~25% of cover-note prose is competitive-strategy reasoning; the on-disk JSON envelope source_chunks are the citation-of-record, the chat narrative is the human-readable digest).",
        "tools/audit_skill_grounding.py reports claims_exempt is at least 0.40 of (claims_total + claims_exempt).",
        "No regression below 0.6 across at least three consecutive runs of the same prompt."
      ]
    },
    {
      "id": "eval-005-obligation-standalone-contract",
      "prompt": "Start from contract number N00024-24-C-0085 and produce obligation intel. Tell me if this is standalone, parent IDIQ, or order, and give me by-year and by-modification obligations.",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel_obligation.json"
        },
        {
          "kind": "transcript_tool_called",
          "tool": "mcp__usaspending__lookup_piid"
        },
        {
          "kind": "transcript_tool_called",
          "tool": "mcp__usaspending__get_award_detail"
        },
        {
          "kind": "transcript_tool_called",
          "tool": "mcp__usaspending__get_transactions"
        },
        {
          "kind": "json_path_in_set",
          "path": "resolved.scenario",
          "values": ["standalone_contract", "parent_idiq", "idiq_order"]
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_fiscal_year"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_transaction"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_period_of_performance"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_transaction[0].cumulative_obligated_usd",
          "notes": "Every by_transaction row must carry a running cumulative total"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_transaction[0].inferred_pop_segment",
          "notes": "Every row must carry a POP segment label: base_year, option_year_N, supplemental, admin, or unknown"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.rate_analysis",
          "notes": "rate_analysis block with monthly_burn_usd and by_option_year must be present"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.rate_analysis.monthly_burn_usd"
        },
        {
          "kind": "json_path_set",
          "path": "obligations.rate_analysis.by_option_year"
        }
      ]
    },
    {
      "id": "eval-006-obligation-parent-idiq-rollup",
      "prompt": "Analyze this parent IDIQ for obligation burn and competitor completeness. Roll up all child orders, give a per-order breakdown, and tell me all order-holder competitors.",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel_obligation.json"
        },
        {
          "kind": "transcript_tool_called_any",
          "tools": [
            "mcp__usaspending__get_idv_children",
            "mcp__usaspending__get_idv_activity"
          ]
        },
        {
          "kind": "json_path_in_set",
          "path": "resolved.scenario",
          "values": ["parent_idiq"]
        },
        {
          "kind": "json_path_array_min_length",
          "path": "hierarchy.child_award_ids",
          "min": 1
        },
        {
          "kind": "json_path_array_min_length",
          "path": "obligations.by_child_order",
          "min": 1
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_period_of_performance"
        },
        {
          "kind": "json_path_array_min_length",
          "path": "competitor_discovery.order_holder_recipients",
          "min": 1
        },
        {
          "kind": "json_path_in_set",
          "path": "competitor_discovery.completeness_status",
          "values": ["high", "medium", "low"]
        }
      ]
    },
    {
      "id": "eval-007-obligation-idiq-order-sibling-competitors",
      "prompt": "I only have this order number. Resolve parent IDIQ, calculate this order's obligations, then tally full sibling-order vehicle obligations and identify competitors tied to the parent vehicle.",
      "expectations": [
        {
          "kind": "artifact_exists",
          "path": "competitive_intel_obligation.json"
        },
        {
          "kind": "json_path_in_set",
          "path": "resolved.scenario",
          "values": ["idiq_order", "parent_idiq"]
        },
        {
          "kind": "json_path_set",
          "path": "hierarchy.parent_award_id"
        },
        {
          "kind": "json_path_array_min_length",
          "path": "hierarchy.child_award_ids",
          "min": 1
        },
        {
          "kind": "json_path_set",
          "path": "obligations.by_period_of_performance"
        },
        {
          "kind": "json_path_array_min_length",
          "path": "competitor_discovery.parent_holder_recipients",
          "min": 1
        },
        {
          "kind": "json_path_in_set",
          "path": "competitor_discovery.linkage_method_used",
          "values": ["parent_child", "piid_family", "solicitation_fallback"]
        }
      ]
    }
  ]
}
