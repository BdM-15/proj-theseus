# ============================================================================
# LightRAG Server Configuration (Optimized for Navy MBOS RFP Processing)
# Based on: https://github.com/HKUDS/LightRAG/blob/main/env.example
# Date: 2025-10-03
# ============================================================================

# Server Configuration
HOST=localhost
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs

# ============================================================================
# LLM Configuration (Ollama - Mistral Nemo 12B)
# Recommendations: 32B+ params, 32K-64K context (LightRAG README)
# Mistral Nemo: 12B params, 128K context (we use 64K for reliability)
# ============================================================================
LLM_BINDING=ollama
LLM_BINDING_HOST=http://localhost:11434
LLM_MODEL=mistral-nemo:latest

# Context Window: 32K tokens (increased for ontology-enhanced prompts)
# Ontology injection adds ~800 tokens + chunk content + output space
# Mistral Nemo supports up to 128K context
OLLAMA_LLM_NUM_CTX=32768

# LLM Timeout: 1800 seconds (30 minutes per chunk extraction)
# Increased for complex ontology-guided extraction with larger context
LLM_TIMEOUT=1800

# Max Output Tokens: Prevents endless generation
# Formula: LLM_TIMEOUT * output_tokens_per_second (900s * 50 tokens/s = 45000)
OLLAMA_LLM_NUM_PREDICT=45000

# Temperature: Low for deterministic extraction (LightRAG default: 0.9 for some models)
# We use 0.1 for consistent entity extraction
OPENAI_LLM_TEMPERATURE=0.1

# ============================================================================
# Embedding Configuration (Ollama - BGE-M3)
# Recommendation: BAAI/bge-m3 or text-embedding-3-large (LightRAG README)
# ============================================================================
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=300

# Ollama Embedding Context: 8192 tokens (LightRAG default)
OLLAMA_EMBEDDING_NUM_CTX=8192

# ============================================================================
# Document Processing Configuration
# Optimized for large RFP documents (500+ pages)
# ============================================================================

# Chunk Size: 800 tokens (reduced for faster processing)
# Smaller chunks = more granular but more chunks to process
# Navy MBOS RFP: ~240 chunks at 800 tokens vs 157 at 1200 tokens
CHUNK_SIZE=800

# Chunk Overlap: 100 tokens (LightRAG default)
# Maintains context continuity across chunks
CHUNK_OVERLAP_SIZE=100

# Summary Configuration
SUMMARY_MAX_TOKENS=1200
SUMMARY_LENGTH_RECOMMENDED=600
SUMMARY_CONTEXT_SIZE=12000
FORCE_LLM_SUMMARY_ON_MERGE=8

# Entity Types: Government Contracting Ontology (injected via addon_params)
# Defined in src/core/ontology.py - not configured here
# ENTITY_TYPES set by lightrag_integration.py

# ============================================================================
# Concurrency Configuration
# Balanced for RTX 4060 (8GB VRAM) + i9-14900HX (24 cores)
# ============================================================================

# Max Async LLM Requests: 3 (reduced from 4 for stability)
# Controls parallel entity extraction during document processing
MAX_ASYNC=3

# Ollama Worker Refresh: 3 chunks (matches MAX_ASYNC for optimal memory management)
# Refreshes Ollama workers after N chunks to prevent model fatigue
# Setting to MAX_ASYNC ensures refresh happens after each full batch completes
OLLAMA_REFRESH_INTERVAL=3

# Max Parallel Document Processing: 2 (LightRAG recommends: MAX_ASYNC/3 ≈ 2)
# Navy MBOS RFP: Single document, so this doesn't apply
MAX_PARALLEL_INSERT=2

# Embedding Concurrency: 8 (LightRAG default)
EMBEDDING_FUNC_MAX_ASYNC=8
EMBEDDING_BATCH_NUM=10

# ============================================================================
# Query Configuration
# Controls context sent to LLM during queries
# ============================================================================

# Entity Retrieval Count: 40 entities (LightRAG default)
# TOP_K represents entities in 'local' mode, relationships in 'global' mode
TOP_K=40

# Chunk Retrieval: 20 chunks (LightRAG default)
CHUNK_TOP_K=20

# Token Budget Control (LightRAG unified token system)
# MAX_ENTITY_TOKENS + MAX_RELATION_TOKENS < MAX_TOTAL_TOKENS
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000

# Cosine Similarity Threshold: 0.2 (LightRAG default)
# Lower = more permissive matching
COSINE_THRESHOLD=0.2

# Related Chunks Per Entity/Relation: 5 (LightRAG default)
RELATED_CHUNK_NUMBER=5

# Chunk Selection Strategy: VECTOR (LightRAG default)
# VECTOR = similarity-based (like naive RAG)
# WEIGHT = KG-based (more graph-focused)
KG_CHUNK_PICK_METHOD=VECTOR

# LLM Cache: Enabled (speeds up repeated queries)
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true

# ============================================================================
# Reranking Configuration
# Disabled for initial clean extraction (can enable later)
# ============================================================================
RERANK_BINDING=null
RERANK_BY_DEFAULT=False
MIN_RERANK_SCORE=0.0

# ============================================================================
# Storage Configuration
# Using default local file storage for development
# ============================================================================
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# Workspace: Isolated data storage (optional)
# WORKSPACE=navy_mbos_rfp

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_CONSOLE=true
# LOG_DIR=./logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# ============================================================================
# Server Timeout (Gunicorn worker timeout)
# ============================================================================
TIMEOUT=1800

# ============================================================================
# Configuration Summary for Path B Clean Extraction:
#
# Context Window: 64K tokens (sufficient for complex RFP processing)
# Chunk Size: 1200 tokens (LightRAG sweet spot for quality)
# LLM Timeout: 900s (15 min - prevents extraction timeouts)
# Concurrency: 4 async LLM, 2 parallel docs (balanced for RTX 4060)
# Entity Types: 11 types from ontology.py (government contracting specific)
#
# Expected Navy MBOS Processing:
# - Document: ~220KB, 157 chunks at 1200 tokens
# - Target: 500-700 quality entities (95%+ precision)
# - Processing time: 3-4 hours
# - Zero Path A artifacts (no "RFP Section J-Line" fictitious entities)
# ============================================================================
