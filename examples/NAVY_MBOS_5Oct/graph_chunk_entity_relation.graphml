  <data key="d0">Section M - Evaluation Factors for Award</data>
  <data key="d1">section</data>
  <data key="d2">Section M outlines the basis for award, evaluation factors, and pricing discrepancies for the solicitation.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 1 - Corporate Experience">
  <data key="d0">Factor 1 - Corporate Experience</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 1 evaluates corporate experience based on types, volume, size, scope, and complexity of comparable work.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 2 - Management Approach">
  <data key="d0">Factor 2 - Management Approach</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 2 assesses the management approach as part of the non-cost/price factors.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 3 - Technical Approach">
  <data key="d0">Factor 3 - Technical Approach</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 3 evaluates the technical approach as part of the non-cost/price factors.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 4 - Small Business Utilization">
  <data key="d0">Factor 4 - Small Business Utilization</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 4 assesses small business utilization as part of the non-cost/price factors.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 5 - Safety">
  <data key="d0">Factor 5 - Safety</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 5 evaluates safety as part of the non-cost/price factors.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
<node id="Factor 6 - Past Performance">
  <data key="d0">Factor 6 - Past Performance</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 6 assesses past performance and performance confidence, equal in importance to combined technical factors.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711349</data>
</node>
