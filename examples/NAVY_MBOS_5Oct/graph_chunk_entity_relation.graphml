<node id="Section G Contract Administration Data">
  <data key="d0">Section G Contract Administration Data</data>
  <data key="d1">section</data>
  <data key="d2">Section G Contract Administration Data outlines contract administration details, including assignment to Navfac Southeast Pwd Mayport and appointment of a Contracting Officer's Representative.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Contracting Officer'S Representative">
  <data key="d0">Contracting Officer'S Representative</data>
  <data key="d1">concept</data>
  <data key="d2">Contracting Officer'S Representative is appointed to assist in contract administration, providing instructions on limitations, deadlines, and handling inspection and acceptance of deliverables.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Blanket Task Order">
  <data key="d0">Blanket Task Order</data>
  <data key="d1">deliverable</data>
  <data key="d2">Blanket Task Order is a mechanism for issuing bulk funding for non-recurring work, requiring Contracting Officer authorization before performance commences, with firm fixed-price not-to-exceed amounts.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Cpars">
  <data key="d0">Cpars</data>
  <data key="d1">technology</data>
  <data key="d2">Cpars is the Contractor Performance Assessment Reporting System used for evaluating contractor performance, accessible at http://www.cpars.gov/.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
