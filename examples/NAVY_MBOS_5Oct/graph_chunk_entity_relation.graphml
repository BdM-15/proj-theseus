  <data key="d0">Dfars 252.232-7006 Wide Area Workflow Payment Instructions</data>
  <data key="d1">clause</data>
  <data key="d2">Dfars 252.232-7006 Wide Area Workflow Payment Instructions is a clause incorporated by full text, effective Jan 2023, detailing procedures for electronic invoicing via Wawf.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Wide Area Workflow">
  <data key="d0">Wide Area Workflow</data>
  <data key="d1">technology</data>
  <data key="d2">Wide Area Workflow is an electronic system for processing vendor payment requests and receiving reports, requiring contractor registration and use of specific document types and routing data.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Fedmall">
  <data key="d0">Fedmall</data>
  <data key="d1">technology</data>
  <data key="d2">Fedmall is a U.S. Government web-based ordering system for searching and ordering goods and services, requiring contractor registration and acceptance of Gcpc orders for Iq services.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="DoDAAC N68732">
  <data key="d0">DoDAAC N68732</data>
  <data key="d1">other</data>
  <data key="d2">DoDAAC N68732 is the Pay Official code specified in the Wide Area Workflow routing data table for payment processing.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="DoDAAC N69450">
  <data key="d0">DoDAAC N69450</data>
  <data key="d1">other</data>
  <data key="d2">DoDAAC N69450 is the Issue By and Admin code specified in the Wide Area Workflow routing data table for contract issuance and administration.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Section H Special Contract Requirements">
  <data key="d0">Section H Special Contract Requirements</data>
  <data key="d1">section</data>
  <data key="d2">Section H Special Contract Requirements outlines special provisions including protection of historical and archaeological resources and requirements for Fedmall registration and usage.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Governmentwide Commercial Purchase Card">
  <data key="d0">Governmentwide Commercial Purchase Card</data>
  <data key="d1">concept</data>
  <data key="d2">Governmentwide Commercial Purchase Card is a program enabling authorized Government personnel to order indefinite quantity pre-priced line item services directly through Fedmall without additional markup.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="External Certification Authority Program">
  <data key="d0">External Certification Authority Program</data>
  <data key="d1">concept</data>
  <data key="d2">External Certification Authority Program is a DoD initiative providing approved certificates to contractors for secure communication and authentication to DoD information systems.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Small Business Subcontracting Plan (SBSP)">
  <data key="d0">Small Business Subcontracting Plan (SBSP)</data>
  <data key="d1">document</data>
  <data key="d2">The SBSP must be negotiated within the time specified by the Contracting Officer and incorporated into the resulting contract, consistent with small business commitments in proposals.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Small Business (SB)">
  <data key="d0">Small Business (SB)</data>
  <data key="d1">concept</data>
  <data key="d2">Small Business target is set at 40% of total planned subcontract dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Small Disadvantaged Business (SDB)">
  <data key="d0">Small Disadvantaged Business (SDB)</data>
  <data key="d1">concept</data>
  <data key="d2">Small Disadvantaged Business target is set at 5% of total planned subcontract dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="HUBZone SB">
  <data key="d0">HUBZone SB</data>
  <data key="d1">concept</data>
  <data key="d2">HUBZone Small Business target is set at 3% of total planned subcontract dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Woman-Owned Small Business (WOSB)">
  <data key="d0">Woman-Owned Small Business (WOSB)</data>
  <data key="d1">concept</data>
  <data key="d2">Woman-Owned Small Business target is set at 9% of total planned subcontract dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Service-Disabled Veteran-Owned Small Business (SDVOSB)">
  <data key="d0">Service-Disabled Veteran-Owned Small Business (SDVOSB)</data>
  <data key="d1">concept</data>
  <data key="d2">Service-Disabled Veteran-Owned Small Business target is set at 5% of total planned subcontract dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Small Business Utilization and Participation Factor">
  <data key="d0">Small Business Utilization and Participation Factor</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">The Small Business Utilization and Participation factor assesses commitments to small businesses in proposals, with identified small businesses listed in the SBSP.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
<node id="Small Business Participation Commitment Document (SBPCD)">
  <data key="d0">Small Business Participation Commitment Document (SBPCD)</data>
  <data key="d1">document</data>
  <data key="d2">The SBPCD provides participation requirements as percentages of total contract value, differing from SBSP goals which are percentages of planned subcontracting dollars.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711348</data>
</node>
