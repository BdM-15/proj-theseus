  <data key="d1">document</data>
  <data key="d2">Section J ELIN Attachment provides details used in evaluating proposal pricing for inconsistencies.</data>
  <data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711353</data>
</node>
