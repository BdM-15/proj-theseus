  <data key="d0">Small Business Utilization And Participation Factor</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">The Small Business Utilization And Participation Factor is assessed for small business identification in proposals, consistent with the SBSP.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711345</data>
</node>
<node id="Small Business Participation Commitment Document">
  <data key="d0">Small Business Participation Commitment Document</data>
  <data key="d1">document</data>
  <data key="d2">The Small Business Participation Commitment Document provides participation requirements as percentages of the total contract value.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711345</data>
</node>
<node id="Attachment JM-2">
  <data key="d0">Attachment JM-2</data>
  <data key="d1">document</data>
  <data key="d2">Attachment JM-2 demonstrates historical small business utilization for projects under Factor 1 Corporate Experience.&lt;SEP&gt;Attachment JM-2 is referenced in the Small Business Utilization and Participation factor for accordance with DFARS 215.304(c)(i).&lt;SEP&gt;Attachment JM-2 is for the Small Business Utilization and Participation factor commitments.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711345</data>
</node>
<node id="ELIN Pricing Attachment">
  <data key="d0">ELIN Pricing Attachment</data>
  <data key="d1">document</data>
  <data key="d2">The ELIN Pricing Attachment is a multi-worksheet file provided in Section J for submitting Section B and ELIN data in electronic format.&lt;SEP&gt;The ELIN Pricing Attachment is provided in Section J for submitting pricing spreadsheet data in the specified format.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711345</data>
</node>
<node id="Section L.4">
  <data key="d0">Section L.4</data>
  <data key="d1">section</data>
  <data key="d2">Section L.4 is the Pre-Award Inquiry Form for submitting questions.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759711345</data>
</node>
