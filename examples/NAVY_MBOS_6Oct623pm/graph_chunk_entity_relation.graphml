  <data key="d1">concept</data>
  <data key="d2">Indefinite Delivery/Indefinite Quantity (IDIQ) Contracts are evaluated based on specific relevant task orders rather than the overall contract.</data>
  <data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790165</data>
