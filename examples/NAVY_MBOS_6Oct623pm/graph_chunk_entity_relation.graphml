  <data key="d11">1759790184</data>
</edge>
<edge source="Liquidated Damages" target="Watchstanding Services">
  <data key="d6">1.0</data>
  <data key="d7">Failure in Watchstanding Services, such as unmanned posts, results in payment withholding and liquidated damages at 10 percent of computed costs.</data>
  <data key="d8">non-performance,penalty</data>
  <data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759790188</data>
</edge>
<edge source="Liquidated Damages" target="FAR 52.211-11">
  <data key="d6">1.0</data>
  <data key="d7">FAR 52.211-11 allows for liquidated damages in cases of unsatisfactory or non-performed services.</data>
  <data key="d8">assessment,compensation</data>
  <data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759790189</data>
</edge>
<edge source="Liquidated Damages" target="Consequences of Contractor's Failure to Perform">
  <data key="d6">1.0</data>
  <data key="d7">Liquidated damages at 10 percent of defect value compensate for administrative costs from non-performed or unsatisfactory work.</data>
  <data key="d8">assessment,compensation</data>
  <data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759790189</data>
</edge>
