  <data key="d0">J-1502000 Facility Investment</data>
  <data key="d1">document</data>
  <data key="d2">J-1502000 (MCSF-BI) Facility Investment.xlxs is an Excel file providing investment details for various MCSF-BI systems including cathodic protection, compressed air, crane and railroad, irrigation, backflow prevention, lighting, roofing, lift stations, portable toilets, sewage holding tanks, and fuel storage.</data>
  <data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790158</data>
</node>
