  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 2 - Management Approach is one of the technical factors evaluated equally with others in importance to past performance.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790159</data>
</node>
