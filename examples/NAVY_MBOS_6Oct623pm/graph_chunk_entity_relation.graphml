  <data key="d0">Request for Proposal (RFP)</data>
  <data key="d1">document</data>
  <data key="d2">The Request for Proposal (RFP) includes requirements for base operations support services and evaluation criteria.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790160</data>
</node>
<node id="DFARS 215.304(c)(i)">
  <data key="d0">DFARS 215.304(c)(i)</data>
  <data key="d1">clause</data>
  <data key="d2">DFARS 215.304(c)(i) requires that small businesses identified in proposals for evaluation be listed in the SBSP.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
