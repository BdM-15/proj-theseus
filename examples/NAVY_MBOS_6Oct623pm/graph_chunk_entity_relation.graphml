<node id="Factor 5">
  <data key="d0">Factor 5</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">An evaluation factor assessing safety, including DART and TCR rates and safety management approach.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
<node id="DART Rate">
  <data key="d0">DART Rate</data>
  <data key="d1">requirement</data>
  <data key="d2">DART Rate is calculated by multiplying the number of DART incidents by 200,000 and dividing by total employee labor hours, used to assess safety performance over five years with risk levels from Very Low Risk less than 1.0 to Extremely High Risk greater than 4.0.&lt;SEP&gt;Days Away from Work, Restricted Duty, or Job Transfer rate calculated for five calendar years based on incidents and labor hours.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
<node id="TCR Rate">
  <data key="d0">TCR Rate</data>
  <data key="d1">requirement</data>
  <data key="d2">TCR Rate is calculated by multiplying the number of TCR incidents by 200,000 and dividing by total employee labor hours, requiring submission of five previous calendar years' data with risk levels from Very Low Risk less than 2.49 to Extremely High Risk greater than 6.0.&lt;SEP&gt;Total Case Rate calculated for five calendar years based on incidents including medical treatment and loss of consciousness.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
<node id="Safety Management System (SMS)">
  <data key="d0">Safety Management System (SMS)</data>
  <data key="d1">concept</data>
  <data key="d2">A system for implementing safety including management involvement, hazard control, worksite analysis, and training, benchmarked against standards.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
<node id="Transportation Equipment">
  <data key="d0">Transportation Equipment</data>
  <data key="d1">technology</data>
  <data key="d2">Vehicles and equipment that must be maintained and repaired within specified time frames with minimal downtime as per Annex 1700000.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
<node id="Efficient Labor Approach">
  <data key="d0">Efficient Labor Approach</data>
  <data key="d1">concept</data>
  <data key="d2">An approach ensuring best industry practices are applied to accomplish all requirements efficiently.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790156</data>
</node>
