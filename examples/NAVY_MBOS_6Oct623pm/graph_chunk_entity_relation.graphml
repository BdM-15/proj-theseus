<edge source="Liquidated Damages" target="52.211-11 Liquidated Damages-Supplies, Services, Or Research And Development">
  <data key="d6">1.0</data>
  <data key="d7">52.211-11 specifies the application and calculation of liquidated damages for supplies, services, or research and development.</data>
  <data key="d8">application,specification</data>
  <data key="d9">chunk-96e30762ee04dbe2af303802d3d2a936</data>
