  <data key="d1">organization</data>
  <data key="d2">NAVFAC SOUTHEAST ACQUISITION CORE is the office designated for receiving copies of protests, located in Jacksonville, FL.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790160</data>
</node>
<node id="Government Accountability Office (GAO)">
  <data key="d0">Government Accountability Office (GAO)</data>
  <data key="d1">organization</data>
  <data key="d2">The Government Accountability Office (GAO) receives protests filed against the agency.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759790160</data>
</node>
