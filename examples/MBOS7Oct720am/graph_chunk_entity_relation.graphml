<ns0:node id="Jacksonville, Florida">
  <ns0:data key="d0">Jacksonville, Florida</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Jacksonville, Florida is the location hosting Naval Station Mayport and Marine Corps Support Facility - Blount Island.&lt;SEP&gt;Jacksonville, Florida, is the location hosting Naval Station Mayport and Marine Corps Support Facility - Blount Island.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
