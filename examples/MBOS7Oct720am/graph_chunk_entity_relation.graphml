  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Inspection and acceptance locations align with the place of performance specified for deliveries at NAVFAC Southeast PWD Mayport.</ns0:data>
  <ns0:data key="d8">delivery destination,site alignment</ns0:data>
