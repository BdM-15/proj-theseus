<ns0:edge source="Contractor" target="FedMall">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor registers on FedMall, uploads catalogs, and processes electronic orders for IQ services.</ns0:data>
