<ns0:edge source="DART Rate" target="TCR Rate">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">DART Rate and TCR Rate are both evaluated for trends over five years to assess safety history and risk levels.</ns0:data>
  <ns0:data key="d8">safety metrics,trend evaluation</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838919</ns0:data>
</ns0:edge>
<ns0:edge source="DART Rate" target="Very Low Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Very Low Risk is assigned to DART Rates less than 1.0, reflecting low safety incidents.</ns0:data>
  <ns0:data key="d8">performance indicator,risk correlation</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838922</ns0:data>
</ns0:edge>
<ns0:edge source="DART Rate" target="Moderate Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Moderate Risk applies to DART Rates from 2.0 to 2.99, with negative trends requiring corrective action explanations.</ns0:data>
  <ns0:data key="d8">risk correlation,trend analysis</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838922</ns0:data>
</ns0:edge>
<ns0:edge source="DART Rate" target="Offeror">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Offeror submits five years of DART rate data and provides explanations for negative trends or missing information.</ns0:data>
  <ns0:data key="d8">submission requirement,trend explanation</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
