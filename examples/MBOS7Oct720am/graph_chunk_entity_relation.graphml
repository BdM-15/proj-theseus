  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor must complete orders issued during the contract period within specified times and is not required to make deliveries after the contract completion date under the Contract Order Completion Requirement.</ns0:data>
  <ns0:data key="d8">delivery limitation,performance obligation</ns0:data>
