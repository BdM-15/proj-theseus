</ns0:node>
<ns0:node id="NAICS 561210">
  <ns0:data key="d0">NAICS 561210</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NAICS 561210 classifies Facilities Support Services, applicable to this Base Operations Support contract.&lt;SEP&gt;NAICS 561210 classifies the acquisition as Facilities Support Services with a small business size standard of $47,000,000.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Water Annex">
  <ns0:data key="d0">Water Annex</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Water Annex specifies recurring Base Operations Support services related to water, priced separately in dedicated Contract Line Item Numbers for base and option periods.&lt;SEP&gt;The Water Annex specifies recurring base operations support services for water-related operations in accordance with the Performance Work Statement.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
