<ns0:edge source="Contract Term" target="Far 52.217-9">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Far 52.217-9 serves as the basis for the government to extend the contract term beyond the standard periods outlined in the contract term.</ns0:data>
  <ns0:data key="d8">extension mechanism,regulatory authority</ns0:data>
  <ns0:data key="d9">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
<ns0:edge source="Contract Term" target="Far 52.217-8">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Far 52.217-8 allows extension of the performance period up to six months beyond the 96-month contract term.</ns0:data>
  <ns0:data key="d8">additional duration,extension provision</ns0:data>
  <ns0:data key="d9">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
