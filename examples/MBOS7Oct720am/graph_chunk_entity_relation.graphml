  <ns0:data key="d2">NAVFAC Maximo Data includes critical fields for Service Provider, Asset, Specification, and Characteristic Meter Reading, requiring maintenance throughout the Performance Work Statement.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838893</ns0:data>
</ns0:node>
<ns0:node id="Transportation Equipment">
  <ns0:data key="d0">Transportation Equipment</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Transportation Equipment must be maintained and repaired within specified time frames with minimal downtime, as per Annex 1700000 Sections C and J.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Unit Price Labor">
  <ns0:data key="d0">Unit Price Labor</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Unit Price Labor requires a rate for one hour of work-in-place for work over Limits of Liability and other over-and-above work, encompassing all applicable costs without post-award renegotiation.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Risk Mitigation">
  <ns0:data key="d0">Risk Mitigation</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Risk Mitigation involves practical contingency plans to address shortages of material, equipment, and workers to perform the contract successfully.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Annex 1700000">
  <ns0:data key="d0">Annex 1700000</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 1700000 addresses transportation requirements, including maintenance and repair of vehicles within specified timeframes and limits of liability.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Factor 4 Small Business Utilization and Participation">
  <ns0:data key="d0">Factor 4 Small Business Utilization and Participation</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 4 assesses historical achievements and proposed commitment to small business participation, requiring at least 20% of total contract value.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Attachment JM-3">
  <ns0:data key="d0">Attachment JM-3</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Attachment JM-3 is the Small Business Participation Commitment Document requiring identification of subcontractors and proposed participation levels.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Small Business Participation">
  <ns0:data key="d0">Small Business Participation</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Small Business Participation requires maximum practicable opportunities for small businesses, including SDB, WOSB, HUBZone SB, VOSB, and SDVOSB, with a minimum of 20% of total contract value.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Factor 5 Safety">
  <ns0:data key="d0">Factor 5 Safety</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 5 evaluates safety through DART Rate, TCR Rate, and a technical approach to Safety Management System.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="DART Rate">
  <ns0:data key="d0">DART Rate</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">DART Rate is calculated by multiplying the number of DART incidents by 200,000 and dividing by total employee labor hours worked, used to assess safety performance over five calendar years.&lt;SEP&gt;DART Rate measures injuries or illnesses resulting in days away from work, restricted duty, or job transfer, calculated for five calendar years.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="TCR Rate">
  <ns0:data key="d0">TCR Rate</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">TCR Rate is calculated by multiplying the number of TCR incidents by 200,000 and dividing by total employee labor hours worked, requiring submission of data for five previous calendar years.&lt;SEP&gt;TCR Rate measures total recordable cases including death, days away, restricted work, medical treatment, or loss of consciousness, calculated for five calendar years.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Safety Management System">
  <ns0:data key="d0">Safety Management System</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Safety Management System encompasses management and leadership involvement, employee involvement, hazard prevention, hazard control, worksite analysis, and safety and health training, benchmarked against standards.&lt;SEP&gt;Safety Management System includes management leadership involvement, employee involvement, hazard prevention, hazard control, worksite analysis, and safety training, benchmarked against standards.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="OEM Specifications">
  <ns0:data key="d0">OEM Specifications</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">OEM Specifications are original equipment manufacturer guidelines ensuring systems are maintained fully functional in accordance with design parameters.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Reliability-Centered Maintenance Program">
  <ns0:data key="d0">Reliability-Centered Maintenance Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Reliability-Centered Maintenance Program is a state-of-the-art approach involving inspection, testing, maintenance, and repair to keep systems operational per design and OEM specifications.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Solicitation N69450-25-R-0003">
  <ns0:data key="d0">Solicitation N69450-25-R-0003</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Solicitation N69450-25-R-0003 is the contract solicitation document outlining submittal requirements and evaluation criteria.&lt;SEP&gt;Solicitation N69450-25-R-0003 is the procurement document containing annexes, sub-annexes, spec items, evaluation factors, and submittal requirements for the contract.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="PM Requirements">
  <ns0:data key="d0">PM Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">PM Requirements refer to preventive maintenance tasks for systems in applicable sub-annexes as part of the performance methodology.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="IMP Requirements">
  <ns0:data key="d0">IMP Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">IMP Requirements refer to inspection, maintenance, and preservation tasks for systems in applicable sub-annexes as part of the performance methodology.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Contractor Incident Reporting System">
  <ns0:data key="d0">Contractor Incident Reporting System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Contractor Incident Reporting System is a NAVFAC system providing incident data for Government review.&lt;SEP&gt;Contractor Incident Reporting System is NAVFAC's system for reporting contractor incidents, which may be reviewed by the Government for safety evaluation.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Contractor Performance Assessment Reporting System">
  <ns0:data key="d0">Contractor Performance Assessment Reporting System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Contractor Performance Assessment Reporting System is a database of performance evaluations submitted with proposals when available.&lt;SEP&gt;Contractor Performance Assessment Reporting System is a system for assessing contractor performance, potentially reviewed for safety.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="Electronic Contract Management System">
  <ns0:data key="d0">Electronic Contract Management System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Electronic Contract Management System is a source of contract information reviewed by the Government.&lt;SEP&gt;Electronic Contract Management System is a contract management tool that may be reviewed by the Government for safety information.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="OSHA">
  <ns0:data key="d0">OSHA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">OSHA is a source of public information reviewed by the Government for safety evaluations.&lt;SEP&gt;OSHA provides data on occupational safety that the Government may review as part of Factor 5 evaluation.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="NAVSTA">
  <ns0:data key="d0">NAVSTA</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">NAVSTA is a site-specific location for sub-annexes in facility management, facility investment, and environmental requirements under various annexes.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC Southeast PWD Mayport">
  <ns0:data key="d0">NAVFAC Southeast PWD Mayport</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVFAC Southeast PWD Mayport is the organization responsible for inspection and acceptance at Building 1966, Bon Homme Richard St, Mayport, FL 32228-0073, United States.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
<ns0:node id="52.246-4">
  <ns0:data key="d0">52.246-4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-4 is the FAR clause for Inspection of Services-Fixed-Price, effective August 1996.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838894</ns0:data>
</ns0:node>
