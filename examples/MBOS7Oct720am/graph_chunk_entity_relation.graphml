  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Non-Price Proposal Binder contains non-price factor requirements, limited to 150 pages, for technical evaluation.</ns0:data>
  <ns0:data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838892</ns0:data>
</ns0:node>
<ns0:node id="L.14 Small Business Subcontracting Plan">
  <ns0:data key="d0">L.14 Small Business Subcontracting Plan</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">L.14 Small Business Subcontracting Plan requires submission of SBSP using Attachment JL-8 for other than small businesses.</ns0:data>
  <ns0:data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838893</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC">
  <ns0:data key="d0">NAVFAC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVFAC maintains the Contractor Incident Reporting System used in safety assessments.&lt;SEP&gt;NAVFAC sets command-wide small business subcontracting targets including 40% for small businesses.&lt;SEP&gt;NAVFAC is the Naval Facilities Engineering Systems Command responsible for setting command-wide small business subcontracting targets based on a percentage of total planned subcontract dollars.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838893</ns0:data>
</ns0:node>
