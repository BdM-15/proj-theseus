  <ns0:data key="d0">Price Proposal Binder</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Price Proposal Binder includes pricing data, ELIN spreadsheets, and team identification for price evaluation.</ns0:data>
  <ns0:data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838892</ns0:data>
</ns0:node>
