  <ns0:data key="d0">L.13 Content Of Proposals</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">L.13 Content Of Proposals specifies requirements for responsibility determination, price proposal, and non-price proposal submissions.</ns0:data>
  <ns0:data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
