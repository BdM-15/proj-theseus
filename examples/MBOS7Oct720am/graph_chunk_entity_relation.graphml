<ns0:key id="d0" for="node" attr.name="entity_id" attr.type="string" />
<ns0:graph edgedefault="undirected"><ns0:node id="Government">
  <ns0:data key="d0">Government</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Government is the contracting party that may exercise options, issue notices, evaluate offers, and limit obligations in the contract.&lt;SEP&gt;Government evaluates price proposals, corporate experience, management approach, and technical approach.&lt;SEP&gt;The Government estimates the Contractor's overhead and profit rates, material costs if applicable, and receives compensation through liquidated damages for administrative costs and expenses from nonperformed or unsatisfactory performance.&lt;SEP&gt;Government evaluates offeror submissions including safety rates, technical approaches, and past performance to determine best value for contract award.&lt;SEP&gt;The Government owns historical and archaeological resources, provides facilities and utilities in as-is condition, inspects performance, and assesses liquidated damages.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Contractor">
  <ns0:data key="d0">Contractor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Contractor is the party obligated to perform services, complete orders, rerepresent status, certify costs, and comply with small business requirements in the contract.&lt;SEP&gt;The Contractor is subject to Government estimates of overhead, profit rates, and material costs, and faces liquidated damages for nonperformance or unsatisfactory performance of required services.&lt;SEP&gt;The Contractor performs contract requirements, registers on FedMall, uploads catalogs, accepts GCPC orders, protects resources, and maintains quality control.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-bafeb026eba657c5147474a89dc0e6f9&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC SE Contracting Officer">
  <ns0:data key="d0">NAVFAC SE Contracting Officer</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The NAVFAC SE Contracting Officer provides written approval required for the contract to become binding.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Liquidated Damages">
  <ns0:data key="d0">Liquidated Damages</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Liquidated damages compensate the Government for costs resulting from the Contractor's nonperformed or unsatisfactory performance and are calculated in accordance with Section H special requirement.&lt;SEP&gt;Liquidated damages are assessed at 10 percent of the value of observed defects or non-performed work to compensate the Government for administrative costs and expenses.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Overhead And Profit Rates">
  <ns0:data key="d0">Overhead And Profit Rates</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Overhead and profit rates of the Contractor are estimated by the Government and included in the contract.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Material Costs">
  <ns0:data key="d0">Material Costs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Material costs are estimated by the Government if applicable and included in the contract.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Section H">
  <ns0:data key="d0">Section H</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H contains the special requirement on consequences of the Contractor's failure to perform required services, used for calculating liquidated damages.&lt;SEP&gt;Section H covers Special Contract Requirements.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Consequences Of Contractor's Failure To Perform Required Services">
  <ns0:data key="d0">Consequences Of Contractor's Failure To Perform Required Services</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">This special requirement in Section H outlines the calculation of liquidated damages for the Contractor's nonperformance or unsatisfactory performance.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="N6945025R0003">
  <ns0:data key="d0">N6945025R0003</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">N6945025R0003 is the solicitation number for the Base Operations Support contract at Naval Station Mayport.&lt;SEP&gt;N6945025R0003 is the contract solicitation number associated with the sections and clauses described.&lt;SEP&gt;N6945025R0003 is the solicitation number for the contract opportunity involving base operations support services.&lt;SEP&gt;N6945025R0003 is the contract identifier for a performance-based contract involving base operations support services.&lt;SEP&gt;N6945025R0003 is the contract number referenced throughout the document.&lt;SEP&gt;N6945025R0003 is the contract document that includes sections on clauses and requirements, spanning at least 71 pages.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1&lt;SEP&gt;chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Section I - Contract Clauses">
  <ns0:data key="d0">Section I - Contract Clauses</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section I lists FAR and DFARS clauses incorporated by reference and provides full text for specific clauses applicable to the contract.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="FAR Clauses Incorporated By Reference">
  <ns0:data key="d0">FAR Clauses Incorporated By Reference</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">This section incorporates various FAR clauses by reference, including 52.202-1 Definitions effective Jun 2020, 52.203-3 Gratuities effective Apr 1984, and others related to ethics, reporting, subcontracting, labor standards, payments, and disputes.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="DFARS Clauses Incorporated By Reference">
  <ns0:data key="d0">DFARS Clauses Incorporated By Reference</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">This section incorporates various DFARS clauses by reference, including 252.203-7000 Requirements Relating to Compensation of Former DoD Officials effective Sep 2011, 252.204-7012 Safeguarding Covered Defense Information effective May 2024, and others on subcontracting, restrictions, and pricing.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.204-1 Approval Of Contract">
  <ns0:data key="d0">52.204-1 Approval Of Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Dec 1989, states that the contract requires written approval by the NAVFAC SE Contracting Officer to be binding.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.211-11 Liquidated Damages-Supplies, Services, Or Research And Development">
  <ns0:data key="d0">52.211-11 Liquidated Damages-Supplies, Services, Or Research And Development</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Sep 2000, specifies that the Contractor pays liquidated damages of $ per calendar day of delay or 10 percent of all observed defects if failing to deliver supplies or perform services on time, with provisions for termination and excusable delays.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.215-21 Requirements For Certified Cost Or Pricing Data And Data Other Than Certified Cost Or Pricing Data-Modifications Alternate I">
  <ns0:data key="d0">52.215-21 Requirements For Certified Cost Or Pricing Data And Data Other Than Certified Cost Or Pricing Data-Modifications Alternate I</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This Alternate I version of the FAR clause, effective Nov 2021, requires the Contractor to submit certified cost or pricing data and supporting attachments in a format to be determined (TBD).</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.215-21 Requirements For Certified Cost Or Pricing Data And Data Other Than Certified Cost Or Pricing Data-Modifications Alternate III">
  <ns0:data key="d0">52.215-21 Requirements For Certified Cost Or Pricing Data And Data Other Than Certified Cost Or Pricing Data-Modifications Alternate III</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This Alternate III version of the FAR clause, effective Nov 2021, requires the Contractor to submit the cost portion of proposals via CD electronic media.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.216-18 Ordering">
  <ns0:data key="d0">52.216-18 Ordering</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Aug 2020, governs the issuance of delivery orders or task orders by designated individuals or activities from contract award through completion, subject to contract terms, with specific methods for issuance considered official.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.216-19 Order Limitations">
  <ns0:data key="d0">52.216-19 Order Limitations</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Oct 1995, sets a minimum order amount of $2,500.00, maximum single item order of $250,000.00, maximum combination order of $1,000,000.00 excluding certain task orders, and provisions for requirements contracts and honoring excess orders with notice.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.216-22 Indefinite Quantity">
  <ns0:data key="d0">52.216-22 Indefinite Quantity</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Oct 1995, defines the contract as indefinite-quantity for specified supplies or services, with estimated quantities not purchased outright, requiring performance only on ordered basis up to maximum and at least minimum quantities, allowing multiple orders and destinations.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.217-8 Option To Extend Services">
  <ns0:data key="d0">52.217-8 Option To Extend Services</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Nov 1999, allows the Government to require continued performance of services within contract limits and rates, adjustable only for labor rate revisions, exercisable multiple times up to a total of 6 months extension.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.217-9 Option To Extend The Term Of The Contract">
  <ns0:data key="d0">52.217-9 Option To Extend The Term Of The Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Mar 2000, permits the Government to extend the contract term by written notice, with preliminary notice 30 days before expiration, including the option clause in extensions, not exceeding 96 months total duration.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.219-4 Notice Of Price Evaluation Preference For Hubzone Small Business Concerns">
  <ns0:data key="d0">52.219-4 Notice Of Price Evaluation Preference For Hubzone Small Business Concerns</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Oct 2022, provides a 10 percent price evaluation preference added to non-HUBZone offers, except for HUBZone small business concerns that have not waived the preference and otherwise successful offers.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="HUBZone Small Business Concerns">
  <ns0:data key="d0">HUBZone Small Business Concerns</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">HUBZone small business concerns are eligible for a 10 percent price evaluation preference in contract offers unless waived.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Federal Acquisition Regulation">
  <ns0:data key="d0">Federal Acquisition Regulation</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Federal Acquisition Regulation provides cost principles applicable to contracts, with clauses incorporated by reference and deviations indicated.&lt;SEP&gt;48 CFR Chapter 1, source of clauses incorporated by reference or used with deviations in the contract.&lt;SEP&gt;The Federal Acquisition Regulation (FAR) provides the clauses incorporated by reference and in full text within the contract.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-516b1e6efecfd543f141d1e1135ec455&lt;SEP&gt;chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Defense Federal Acquisition Regulation Supplement">
  <ns0:data key="d0">Defense Federal Acquisition Regulation Supplement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Source of clauses like 252.232-7007 used in the contract, with deviations indicated by "(DEVIATION)".&lt;SEP&gt;The Defense Federal Acquisition Regulation Supplement (DFARS) provides the clauses incorporated by reference within the contract for DoD-related requirements.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Department Of Defense">
  <ns0:data key="d0">Department Of Defense</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Department of Defense (DoD) is referenced in DFARS clauses related to compensation, fraud, whistleblower rights, and subcontracting plans.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Kaspersky Lab Covered Entities">
  <ns0:data key="d0">Kaspersky Lab Covered Entities</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Kaspersky Lab covered entities are prohibited from providing hardware, software, and services under FAR clause 52.204-23.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="ByteDance Covered Application">
  <ns0:data key="d0">ByteDance Covered Application</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">ByteDance covered applications are prohibited under FAR clause 52.204-27.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="People's Republic Of China">
  <ns0:data key="d0">People's Republic Of China</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">The People's Republic of China is referenced in DFARS clause 252.225-7058 regarding postaward disclosure of employment of individuals working there.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Xinjiang Uyghur Autonomous Region">
  <ns0:data key="d0">Xinjiang Uyghur Autonomous Region</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Procurements from the Xinjiang Uyghur Autonomous Region are prohibited under DFARS clause 252.225-7060.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Maduro Regime">
  <ns0:data key="d0">Maduro Regime</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Business operations with the Maduro Regime are prohibited under DFARS clause 252.225-7056.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Default-Fixed-Price Supply And Service">
  <ns0:data key="d0">Default-Fixed-Price Supply And Service</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The Default-Fixed-Price Supply and Service clause defines excusable delays and is referenced in the liquidated damages clause for termination and liability.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Small Business Subcontracting Plan">
  <ns0:data key="d0">Small Business Subcontracting Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Small Business Subcontracting Plan must align with small business goals and be incorporated into the contract.&lt;SEP&gt;The Small Business Subcontracting Plan is required under FAR clauses 52.219-9 and its Alternate II, with liquidated damages for non-compliance under 52.219-16.</ns0:data>
  <ns0:data key="d3">chunk-96e30762ee04dbe2af303802d3d2a936&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.217-8 Option to Extend Services">
  <ns0:data key="d0">52.217-8 Option to Extend Services</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.217-8 Option to Extend Services allows the Government to require continued performance of services within contract limits and rates, adjustable only for prevailing labor rates by the Secretary of Labor, exercisable multiple times but not exceeding 6 months total extension, with notice by the Contracting Officer prior to expiration.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.217-9 Option to Extend the Term of the Contract">
  <ns0:data key="d0">52.217-9 Option to Extend the Term of the Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.217-9 Option to Extend the Term of the Contract permits the Government to extend the contract term by written notice to the Contractor prior to completion of the current period, with preliminary notice at least 30 days before expiration, and total duration not exceeding 96 months including options.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.219-4 Notice of Price Evaluation Preference for HUBZone Small Business Concerns">
  <ns0:data key="d0">52.219-4 Notice of Price Evaluation Preference for HUBZone Small Business Concerns</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.219-4 Notice of Price Evaluation Preference for HUBZone Small Business Concerns evaluates offers by adding 10 percent to prices except for HUBZone small business concerns not waiving preference and certain small business offers, applied on line item basis, with award preference to HUBZone when tied with large business after evaluation.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="HUBZone Small Business Concern">
  <ns0:data key="d0">HUBZone Small Business Concern</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HUBZone Small Business Concern is a qualified small business eligible for price evaluation preference, required to perform at least 40 percent of joint venture work beyond administrative functions if in a joint venture.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.219-28 Postaward Small Business Program Rerepresentation">
  <ns0:data key="d0">52.219-28 Postaward Small Business Program Rerepresentation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.219-28 Postaward Small Business Program Rerepresentation requires the Contractor to rerepresent size and socioeconomic status upon events like novation, merger, or for long-term contracts within specified periods, using SAM or specific formats, for NAICS codes assigned to the contract or orders.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Small Business Concern">
  <ns0:data key="d0">Small Business Concern</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Business Concern is an independently owned and operated entity not dominant in its field, qualified under 13 CFR part 121 size standards, including affiliates determined by common ownership, management, or control factors.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.222-42 Statement of Equivalent Rates for Federal Hires">
  <ns0:data key="d0">52.222-42 Statement of Equivalent Rates for Federal Hires</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.222-42 Statement of Equivalent Rates for Federal Hires identifies classes of service employees expected under the contract and states equivalent wages and fringe benefits as if employed by the contracting agency under 5 U.S.C. 5341 or 5332, for information only and not a wage determination.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.242-4 Certification of Final Indirect Costs">
  <ns0:data key="d0">52.242-4 Certification of Final Indirect Costs</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.242-4 Certification of Final Indirect Costs requires the Contractor to certify proposals for final indirect cost rates using a specified format signed by a vice president or chief financial officer level, with failure leading to unilateral rates by the Contracting Officer, ensuring costs are allowable under FAR principles.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.252-2 Clauses Incorporated by Reference">
  <ns0:data key="d0">52.252-2 Clauses Incorporated by Reference</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.252-2 Clauses Incorporated by Reference incorporates clauses into the contract with full force and effect, making full text available upon request or electronically via specified addresses including acquisition.gov and others.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.232-7007 Limitation of Government's Obligation">
  <ns0:data key="d0">DFARS 252.232-7007 Limitation of Government's Obligation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.232-7007 Limitation of Government's Obligation applies to incrementally funded contract line items, with specified amounts available for payment on individual task orders, and the Contractor agrees to perform up to the point of total payable amount by the Government.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officer">
  <ns0:data key="d0">Contracting Officer</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Contracting Officer directs work resumption after discoveries, retains ownership of resources, receives notifications, and approves identifications and substitutions.&lt;SEP&gt;The Contracting Officer specifies time limits for negotiating subcontracting plans and determines eligibility for contract award based on compliance.&lt;SEP&gt;Contracting Officer exercises options, issues notices, requires rerepresentations, and establishes unilateral rates if certifications are not submitted.&lt;SEP&gt;Contracting Officer determines appropriate methodologies for price evaluation consistent with regulations.&lt;SEP&gt;Contracting Officer is the government official responsible for scheduling the pre-performance conference and administering the contract work.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-bafeb026eba657c5147474a89dc0e6f9&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Small Business Administration">
  <ns0:data key="d0">Small Business Administration</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Small Business Administration maintains the List of Qualified HUBZone Small Business Concerns, determines affiliations under 13 CFR 121.103, and sets size standards.&lt;SEP&gt;Small Business Administration approves Mentor-Protege Agreements for JV exceptions.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Contract Order Completion Requirement">
  <ns0:data key="d0">Contract Order Completion Requirement</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Any order issued during the effective period of the contract and not completed within that period shall be completed by the Contractor within the time specified in the order, with the contract governing rights and obligations as if completed during the effective period, and no deliveries required after the contract completion date or final task order completion date.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.252-4 Alterations in Contract">
  <ns0:data key="d0">52.252-4 Alterations in Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.252-4 Alterations in Contract specifies that portions of the contract are altered as indicated in the blank provided.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.252-6 Authorized Deviations in Clauses">
  <ns0:data key="d0">52.252-6 Authorized Deviations in Clauses</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.252-6 Authorized Deviations in Clauses indicates the use of any FAR clause or DFARS clause with an authorized deviation by adding (DEVIATION) after the date of the clause or after the name of the regulation.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="52.219-28 Postaward Small Business Program Rerepresentation Alternate I">
  <ns0:data key="d0">52.219-28 Postaward Small Business Program Rerepresentation Alternate I</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.219-28 Postaward Small Business Program Rerepresentation Alternate I substitutes paragraph (h)(1) to require the Contractor to represent small business size status for each NAICS code assigned to the contract, with an example for NAICS Code 561210.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Long-term Contract">
  <ns0:data key="d0">Long-term Contract</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Long-term Contract means a contract of more than five years in duration, including options, but excluding extensions for a cumulative period not exceeding six months under 52.217-8 Option to Extend Services or other authority.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Affiliates">
  <ns0:data key="d0">Affiliates</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Affiliates means business concerns where one directly or indirectly controls or has the power to control the others, or a third party controls them, considering factors like common ownership, management, and contractual relationships per 13 CFR 121.103.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="NAICS Code">
  <ns0:data key="d0">NAICS Code</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NAICS Code refers to the North American Industry Classification System code assigned to the contract or order, used to determine small business size standards per SBA criteria.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="System for Award Management">
  <ns0:data key="d0">System for Award Management</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The System for Award Management is the federal platform for offeror registration and submission of representations and certifications in the solicitation.&lt;SEP&gt;System for Award Management (SAM) is the platform where the Contractor validates or updates representations and certifications to reflect current size and socioeconomic status.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9&lt;SEP&gt;chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Service Contract Labor Standards">
  <ns0:data key="d0">Service Contract Labor Standards</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Statute referenced in wage determinations, particularly section 4(c), applying to service employees under collective bargaining agreements regardless of contractor or subcontractor employment.&lt;SEP&gt;Service Contract Labor Standards is the statute and 29 CFR Part 4 regulations requiring identification of service employee classes and equivalent wages and fringe benefits for federal hires.&lt;SEP&gt;Service Contract Labor Standards Wage Determinations are incorporated, prohibiting escalation of wage and fringe benefit rates in option periods for covered employees.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455&lt;SEP&gt;chunk-bafeb026eba657c5147474a89dc0e6f9&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="HUBZone Joint Venture">
  <ns0:data key="d0">HUBZone Joint Venture</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HUBZone Joint Venture requires at least 40 percent of the aggregate work performed by the joint venture to be completed by the HUBZone small business parties, exceeding administrative functions.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Novation Agreement">
  <ns0:data key="d0">Novation Agreement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Novation Agreement is a contract modification event triggering rerepresentation of small business status within 30 days after execution.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Merger or Acquisition">
  <ns0:data key="d0">Merger or Acquisition</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Merger or Acquisition is an event that does not require novation but triggers rerepresentation of small business status within 30 days.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Secretary of Labor">
  <ns0:data key="d0">Secretary of Labor</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Secretary of Labor provides revisions to prevailing labor rates that may adjust rates under option provisions.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Wage Determination">
  <ns0:data key="d0">Wage Determination</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Wage Determination is referenced but the statement in 52.222-42 is for information only and not an actual wage determination.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Federal Supply Schedule">
  <ns0:data key="d0">Federal Supply Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Federal Supply Schedule is a multiple-award contract under subpart 8.4 where certain rerepresentation rules do not apply to orders.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="Certificate of Final Indirect Costs">
  <ns0:data key="d0">Certificate of Final Indirect Costs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Certificate of Final Indirect Costs is a signed certification by a vice president or chief financial officer level official attesting that proposed final indirect cost rates are allowable under FAR cost principles and exclude unallowable costs.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="WG-10 Boiler Tender">
  <ns0:data key="d0">WG-10 Boiler Tender</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">WG-10 Boiler Tender is an employee class expected under the contract with specified monetary wage-fringe benefits equivalent for federal hires.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="WG-9 Carpenter Maintenance">
  <ns0:data key="d0">WG-9 Carpenter Maintenance</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">WG-9 Carpenter Maintenance is an employee class expected under the contract with specified monetary wage-fringe benefits equivalent for federal hires.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="WG-10 Electrician Maintenance">
  <ns0:data key="d0">WG-10 Electrician Maintenance</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">WG-10 Electrician Maintenance is an employee class expected under the contract with specified monetary wage-fringe benefits equivalent for federal hires.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838886</ns0:data>
</ns0:node>
<ns0:node id="WG-9 Electronic Technician Maintenance II">
  <ns0:data key="d0">WG-9 Electronic Technician Maintenance II</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">WG-9 Electronic Technician Maintenance II is an employee class expected under the contract with specified monetary wage-fringe benefits equivalent for federal hires.</ns0:data>
  <ns0:data key="d3">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838887</ns0:data>
</ns0:node>
<ns0:node id="WG-10 Elevator Repairer">
  <ns0:data key="d0">WG-10 Elevator Repairer</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">WG-10 Elevator Repairer is an employee class expected under the contract with specified monetary wage-fringe benefits equivalent for federal hires.</ns0:data>
