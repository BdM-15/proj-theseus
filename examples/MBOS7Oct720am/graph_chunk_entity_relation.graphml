  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates 52.229-11 by reference for foreign procurement tax representations.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
