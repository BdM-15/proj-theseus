  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Naval Station Mayport is a naval base in Jacksonville, Florida, requiring Base Operations Support services.&lt;SEP&gt;Naval Station Mayport is a facility in Jacksonville, Florida, requiring base operations support services.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
