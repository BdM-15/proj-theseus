<ns0:edge source="Contractor" target="Watchstanding Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor provides qualified personnel for watchstanding services, facing withholdings or liquidated damages for unmanned posts.</ns0:data>
