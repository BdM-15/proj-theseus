</ns0:node>
<ns0:node id="Section G Contract Administration Data">
  <ns0:data key="d0">Section G Contract Administration Data</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G Contract Administration Data outlines contract administration assignment to Navfac Southeast Pwd Mayport, appointment of a Contracting Officer's Representative, blanket task orders, performance assessment, and payment instructions.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officer's Representative">
  <ns0:data key="d0">Contracting Officer's Representative</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contracting Officer's Representative is appointed to assist in contract administration, providing instructions on limitations, deadlines, inspection, and acceptance of deliverables, with details to be determined.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Blanket Task Order">
  <ns0:data key="d0">Blanket Task Order</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Blanket Task Order allows the government to issue orders with bulk funding for non-recurring work, requiring contracting officer authorization before performance commences, including firm fixed-price amounts.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Section H Special Contract Requirements">
  <ns0:data key="d0">Section H Special Contract Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H Special Contract Requirements includes protections for historical and archaeological resources and requirements for Fedmall registration and usage.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Historical And Archaeological Resources">
  <ns0:data key="d0">Historical And Archaeological Resources</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Historical And Archaeological Resources must be protected in-place, reported immediately to the Contracting Officer, with work stopped in the discovery area until directed to resume, and government retains ownership.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Fedmall">
  <ns0:data key="d0">Fedmall</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Fedmall is a U.S. Government-owned web-based ordering system for Department of Defense and federal activities to search and order goods and services, requiring contractor registration, catalog upload, and acceptance of Governmentwide Commercial Purchase Card orders.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Wide Area Workflow">
  <ns0:data key="d0">Wide Area Workflow</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Wide Area Workflow is an electronic system for processing vendor payment requests and receiving reports, requiring contractor registration and use for submissions as per DFARS clauses.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Cpars">
  <ns0:data key="d0">Cpars</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Cpars is the contractor performance evaluation report entry system located at http://www.cpars.gov/, used for assessing contractor performance.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Dod AAC N68732">
  <ns0:data key="d0">Dod AAC N68732</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Dod AAC N68732 is the Pay Official DoDAAC specified in the WAWF Routing Data Table for payment processing.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="Dod AAC N69450">
  <ns0:data key="d0">Dod AAC N69450</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Dod AAC N69450 is the Issue By DoDAAC and Admin DoDAAC specified in the WAWF Routing Data Table for contract issuance and administration.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838895</ns0:data>
</ns0:node>
<ns0:node id="External Certification Authority Program">
