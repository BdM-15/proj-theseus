<ns0:edge source="Contractor" target="Blount Island">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor performs shoreline cleanup services at Blount Island as specified in ELIN X718.</ns0:data>
  <ns0:data key="d8">cleanup,service location</ns0:data>
