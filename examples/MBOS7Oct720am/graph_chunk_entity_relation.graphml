  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Dfars 252.232-7006 Wide Area Workflow Payment Instructions is a clause incorporated by full text, effective Jan 2023, detailing electronic invoicing procedures.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
