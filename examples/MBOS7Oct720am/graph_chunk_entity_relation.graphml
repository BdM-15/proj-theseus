<ns0:node id="Base Operations Support">
  <ns0:data key="d0">Base Operations Support</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Base Operations Support encompasses services including port operations, facility management, custodial, pest control, integrated solid waste management, grounds maintenance, utilities management, transportation, and environmental support at specified naval facilities.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Jacobs Technology Inc.">
  <ns0:data key="d0">Jacobs Technology Inc.</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Jacobs Technology Inc. is the previous contractor for contract N69450-18-D-1800, providing Base Operations Support services with specified periods of performance and costs.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="N69450-18-D-1800">
  <ns0:data key="d0">N69450-18-D-1800</ns0:data>
  <ns0:data key="d1">contract</ns0:data>
  <ns0:data key="d2">N69450-18-D-1800 is the prior contract for Base Operations Support services, set to expire on 31 December 2026, with detailed base and option period costs totaling $211,045,432.21.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Section A">
  <ns0:data key="d0">Section A</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section A describes the solicitation/contract form, type of contract as indefinite-quantity with firm fixed price and IDIQ provisions, service requirements for Base Operations Support at specified locations, competition under full and open, NAICS code 561210, and prior contract information.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0001">
  <ns0:data key="d0">CLIN 0001</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0001 covers the base period recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers A001 through A014, serving as the guaranteed minimum for the contract.&lt;SEP&gt;CLIN 0001 specifies inspection and acceptance at destination for overall contract services at NAVFAC Southeast PWD Mayport, with DoDAAC N46134.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0002">
  <ns0:data key="d0">CLIN 0002</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0002 covers the base period non-recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers A700 through A718.&lt;SEP&gt;CLIN 0002 specifies inspection and acceptance at destination for overall contract services at NAVFAC Southeast PWD Mayport, with DoDAAC N46134.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
