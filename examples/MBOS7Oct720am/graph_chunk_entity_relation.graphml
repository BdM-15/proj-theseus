  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.229-11 Tax on Certain Foreign Procurements-Notice and Representation">
  <ns0:data key="d0">52.229-11 Tax on Certain Foreign Procurements-Notice and Representation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This FAR clause, effective Jun 2020, addresses tax notices and representations for foreign procurements and is incorporated by reference.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="252.203-7005 Representation Relating to Compensation of Former DoD Officials">
  <ns0:data key="d0">252.203-7005 Representation Relating to Compensation of Former DoD Officials</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This DFARS clause, effective Sep 2022, requires representation on compensation of former DoD officials and is incorporated by reference.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="252.204-7008 Compliance with Safeguarding Covered Defense Information Controls">
  <ns0:data key="d0">252.204-7008 Compliance with Safeguarding Covered Defense Information Controls</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This DFARS clause, effective Oct 2016, mandates compliance with safeguarding controls for covered defense information and is incorporated by reference.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="252.204-7017 Prohibition on the Acquisition of Covered Defense Telecommunications Equipment or Services-Representation">
  <ns0:data key="d0">252.204-7017 Prohibition on the Acquisition of Covered Defense Telecommunications Equipment or Services-Representation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This DFARS clause, effective May 2021, prohibits acquisition of covered defense telecommunications equipment and requires representation, incorporated by reference.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="252.225-7055 Representation Regarding Business Operations with the Maduro Regime">
  <ns0:data key="d0">252.225-7055 Representation Regarding Business Operations with the Maduro Regime</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This DFARS clause, effective May 2022, requires representation on business operations with the Maduro Regime and is incorporated by reference.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.203-11 Certification and Disclosure Regarding Payments to Influence Certain Federal Transactions">
  <ns0:data key="d0">52.203-11 Certification and Disclosure Regarding Payments to Influence Certain Federal Transactions</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This provision applies to solicitations expected to exceed $150,000 and is applicable via SAM in clause 52.204-8.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.204-26 Covered Telecommunications Equipment or Services-Representation">
  <ns0:data key="d0">52.204-26 Covered Telecommunications Equipment or Services-Representation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This provision applies to all solicitations and is applicable via SAM in clause 52.204-8.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.209-5 Certification Regarding Responsibility Matters">
  <ns0:data key="d0">52.209-5 Certification Regarding Responsibility Matters</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This provision applies to solicitations exceeding the simplified acquisition threshold and is applicable via SAM.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.219-1 Small Business Program Representations">
  <ns0:data key="d0">52.219-1 Small Business Program Representations</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This provision applies to solicitations for supplies or services in the US and is applicable via SAM with alternates for DoD and multiple NAICS.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="52.222-22 Previous Contracts and Compliance Reports">
  <ns0:data key="d0">52.222-22 Previous Contracts and Compliance Reports</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This provision applies to solicitations including equal opportunity clauses and is applicable via SAM.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Small Business Subcontracting Plan (SBSP)">
  <ns0:data key="d0">Small Business Subcontracting Plan (SBSP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Small Business Subcontracting Plan is a required document that must be negotiated and incorporated into the contract, listing small businesses consistent with evaluation factors and based on planned subcontract dollars.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Small Business (SB)">
  <ns0:data key="d0">Small Business (SB)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Business represents a category with a 40% subcontracting target as part of NAVFAC's goals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Small Disadvantaged Business (SDB)">
  <ns0:data key="d0">Small Disadvantaged Business (SDB)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Disadvantaged Business is a category with a 5% subcontracting target under NAVFAC's small business goals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="HUBZone SB">
  <ns0:data key="d0">HUBZone SB</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HUBZone Small Business is a category with a 3% subcontracting target in NAVFAC's command-wide goals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Woman-Owned Small Business (WOSB)">
  <ns0:data key="d0">Woman-Owned Small Business (WOSB)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Woman-Owned Small Business is a category with a 9% subcontracting target within NAVFAC's subcontracting objectives.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Service-Disabled Veteran-Owned Small Business (SDVOSB)">
  <ns0:data key="d0">Service-Disabled Veteran-Owned Small Business (SDVOSB)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Service-Disabled Veteran-Owned Small Business is a category with a 5% subcontracting target as outlined in NAVFAC's goals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Small Business Utilization and Participation Factor">
  <ns0:data key="d0">Small Business Utilization and Participation Factor</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">The Small Business Utilization and Participation Factor is an evaluation criterion requiring commitments that align with the SBSP, assessing specific identification of small businesses in proposals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 215.304(c)(i)">
  <ns0:data key="d0">DFARS 215.304(c)(i)</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 215.304(c)(i) is a regulation clause mandating that small businesses identified in evaluations be listed in the SBSP.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Small Business Participation Commitment Document (SBPCD)">
  <ns0:data key="d0">Small Business Participation Commitment Document (SBPCD)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Small Business Participation Commitment Document provides participation requirements as percentages of total contract value, differing from SBSP goals but aligning in types of products/services and participation extent.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.215-20">
  <ns0:data key="d0">FAR 52.215-20</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.215-20 Requirements for Certified Cost or Pricing Data and Data Other Than Certified Cost or Pricing Data is incorporated by reference and full text with Alternates I and III effective November 2021.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.204-7019">
  <ns0:data key="d0">DFARS 252.204-7019</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.204-7019 Notice of NIST SP 800-171 DoD Assessment Requirements is a clause incorporated by reference effective November 2023.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.204-7024">
  <ns0:data key="d0">DFARS 252.204-7024</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.204-7024 Notice on the Use of the Supplier Performance Risk System is a clause incorporated by reference effective March 2023.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7009">
  <ns0:data key="d0">DFARS 252.215-7009</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7009 Proposal Adequacy Checklist is a clause incorporated by reference effective March 2023.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7013">
  <ns0:data key="d0">DFARS 252.215-7013</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7013 Supplies and Services Provided by Nontraditional Defense Contractors is a clause incorporated by reference effective January 2023.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7016">
  <ns0:data key="d0">DFARS 252.215-7016</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7016 Notification to Offerors-Postaward Debriefings is a clause incorporated by reference effective December 2022.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.225-7003">
  <ns0:data key="d0">DFARS 252.225-7003</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.225-7003 Report of Intended Performance Outside the United States is a clause incorporated by reference effective January 2025.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.216-1">
  <ns0:data key="d0">FAR 52.216-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.216-1 Type of Contract specifies a Firm-Fixed Price contract contemplated for award, effective April 1984.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.233-2">
  <ns0:data key="d0">FAR 52.233-2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.233-2 Service of Protest requires protests to be served on the Contracting Officer at NAVFAC SOUTHEAST ACQUISITION CORE, effective September 2006.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.252-1">
  <ns0:data key="d0">FAR 52.252-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.252-1 Solicitation Provisions Incorporated by Reference allows provisions to be referenced with access via specified websites, effective February 1998.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.252-3">
  <ns0:data key="d0">FAR 52.252-3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.252-3 Alterations in Solicitation notes alterations to portions of the solicitation, effective April 1984.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.252-5">
  <ns0:data key="d0">FAR 52.252-5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.252-5 Authorized Deviations in Provisions indicates deviations in FAR and DFARS provisions, effective November 2020.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7008">
  <ns0:data key="d0">DFARS 252.215-7008</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7008 Only One Offer requires submission of additional cost or pricing data if only one offer is received, effective December 2022.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Factor 1 - Corporate Experience">
  <ns0:data key="d0">Factor 1 - Corporate Experience</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 1 assesses the types and volume of comparable work completed by the contractor in terms of size, scope, and complexity.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838896</ns0:data>
</ns0:node>
<ns0:node id="Factor 2 - Management Approach">
  <ns0:data key="d0">Factor 2 - Management Approach</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 2 evaluates the offeror's management strategies for the contract requirements.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Factor 3 - Technical Approach">
  <ns0:data key="d0">Factor 3 - Technical Approach</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 3 reviews the technical methods and solutions proposed for meeting performance objectives.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Factor 4 - Small Business Utilization">
  <ns0:data key="d0">Factor 4 - Small Business Utilization</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 4 examines commitments to small business participation, aligning with SBSP and SBPCD.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Factor 5 - Safety">
  <ns0:data key="d0">Factor 5 - Safety</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 5 assesses safety plans and compliance in the proposal.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Factor 6 - Past Performance">
  <ns0:data key="d0">Factor 6 - Past Performance</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 6 evaluates the relevance and quality of recent contract performances, distinct from corporate experience.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Rebecca Jones">
  <ns0:data key="d0">Rebecca Jones</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Rebecca Jones is the attention contact for protests at NAVFAC SOUTHEAST ACQUISITION CORE.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC Southeast Acquisition Core">
  <ns0:data key="d0">NAVFAC Southeast Acquisition Core</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVFAC Southeast Acquisition Core is the office designated for receiving protest services, located in Jacksonville, FL.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Government Accountability Office (GAO)">
  <ns0:data key="d0">Government Accountability Office (GAO)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Government Accountability Office handles protests filed against agency decisions as per FAR provisions.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville, FL">
  <ns0:data key="d0">Jacksonville, FL</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Jacksonville, FL is the location of NAVFAC Southeast Acquisition Core at PO Box 30 NAS Jacksonville.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Federal Acquisition Regulation (FAR)">
  <ns0:data key="d0">Federal Acquisition Regulation (FAR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Federal Acquisition Regulation governs clauses incorporated by reference and full text in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Defense Federal Acquisition Regulation Supplement (DFARS)">
  <ns0:data key="d0">Defense Federal Acquisition Regulation Supplement (DFARS)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Defense Federal Acquisition Regulation Supplement provides clauses for DoD-specific requirements in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Base Operations Support (BOS)">
  <ns0:data key="d0">Base Operations Support (BOS)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Base Operations Support encompasses services similar to the RFP requirements, including port operations, facility investment, electrical, and water systems.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Canadian Commercial Corporation">
  <ns0:data key="d0">Canadian Commercial Corporation</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Canadian Commercial Corporation is exempt from certified cost or pricing data requirements and provides specific data under DFARS provisions when notified.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Public Works and Government Services Canada">
  <ns0:data key="d0">Public Works and Government Services Canada</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Public Works and Government Services Canada provides analysis to determine fair and reasonable pricing for the Canadian Commercial Corporation.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="NIST SP 800-171">
  <ns0:data key="d0">NIST SP 800-171</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NIST SP 800-171 is the standard for DoD assessment requirements notified under DFARS 252.204-7019.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Supplier Performance Risk System">
  <ns0:data key="d0">Supplier Performance Risk System</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">The Supplier Performance Risk System is used for notices under DFARS 252.204-7024.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Independent Government Estimate (IGE)">
  <ns0:data key="d0">Independent Government Estimate (IGE)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">The Independent Government Estimate is used in price evaluation comparisons to ensure fair and reasonable pricing.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.217-5">
  <ns0:data key="d0">FAR 52.217-5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.217-5 is the Evaluation of Options clause incorporated by reference, effective July 1990.&lt;SEP&gt;FAR 52.217-5 Evaluation of Options is included in the solicitation for evaluating all options without obligating exercise.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="CLIN">
  <ns0:data key="d0">CLIN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CLIN refers to Contract Line Item Number, used in pricing evaluation where unit prices prevail over extended totals in discrepancies.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Tradeoff Process">
  <ns0:data key="d0">Tradeoff Process</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The Tradeoff Process is selected for the acquisition to consider award to other than the lowest priced or highest technically rated offeror based on best value.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Competitive Range">
  <ns0:data key="d0">Competitive Range</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The Competitive Range includes proposals for potential negotiations, limited if necessary for efficient competition among highly rated proposals.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Significant Weakness">
  <ns0:data key="d0">Significant Weakness</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">A Significant Weakness is a flaw in the proposal that appreciably increases risk of unsuccessful performance, impacting factor or overall ratings.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Performance Confidence Assessment">
  <ns0:data key="d0">Performance Confidence Assessment</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">The Performance Confidence Assessment rates past performance and is significantly less important than combined technical factors but more than price when proposals are equal.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Technical Approach to Safety">
  <ns0:data key="d0">Technical Approach to Safety</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Technical Approach to Safety is a narrative submission limited to two single-sided pages or one double-sided page, describing SMS implementation, subcontractor selection, and oversight processes.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Federal Awardee Performance and Integrity Information System">
  <ns0:data key="d0">Federal Awardee Performance and Integrity Information System</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Federal Awardee Performance and Integrity Information System is a database used by the Government for past performance information.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Electronic Subcontract Reporting System">
  <ns0:data key="d0">Electronic Subcontract Reporting System</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Electronic Subcontract Reporting System is a source of subcontract data reviewed in past performance evaluations.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Very Low Risk">
  <ns0:data key="d0">Very Low Risk</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Very Low Risk corresponds to DART rates less than 1.0 and TCR rates less than 2.49, indicating strong safety performance.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Low Risk">
  <ns0:data key="d0">Low Risk</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Low Risk corresponds to DART rates from 1.0 to 1.99 and TCR rates from 2.5 to 3.49.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Moderate Risk">
  <ns0:data key="d0">Moderate Risk</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Moderate Risk corresponds to DART rates from 2.0 to 2.99 and TCR rates from 3.5 to 4.49, requiring explanations for negative trends.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="High Risk">
  <ns0:data key="d0">High Risk</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">High Risk corresponds to DART rates from 3.0 to 4.0 and TCR rates from 4.5 to 5.99, potentially indicating weaknesses without explanation.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Extremely High Risk">
  <ns0:data key="d0">Extremely High Risk</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Extremely High Risk corresponds to DART rates greater than 4.0 and TCR rates greater than 6.0.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Offeror">
  <ns0:data key="d0">Offeror</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Offeror submits required data on DART and TCR rates, technical narratives, and past performance information, with explanations for any missing data or trends.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Defense Contract Management Agency">
  <ns0:data key="d0">Defense Contract Management Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Defense Contract Management Agency provides past performance information through databases and interviews with program managers, contracting officers, and fee determining officials.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Attachment D">
  <ns0:data key="d0">Attachment D</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Attachment D is the first page of the Past Performance Questionnaire, submitted by offeror when full PPQ cannot be obtained before proposal closing.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Subcontractors">
  <ns0:data key="d0">Subcontractors</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Subcontractors are entities selected and overseen by the offeror for safety compliance during contract performance, including in-house workforce.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="DART Cases">
  <ns0:data key="d0">DART Cases</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">DART Cases are incidents involving days away from work, restricted work, or transfers to another job due to work-related injury or illness.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="TCR Cases">
  <ns0:data key="d0">TCR Cases</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">TCR Cases include injuries or illnesses resulting in death, days away from work, restricted work or transfer, medical treatment beyond first aid, or loss of consciousness.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Board">
  <ns0:data key="d0">Board</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Board evaluates DART and TCR rates, trends, technical approaches, and other information to assess offeror safety commitment and risk levels.</ns0:data>
  <ns0:data key="d3">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838897</ns0:data>
</ns0:node>
<ns0:node id="Option Period 1">
  <ns0:data key="d0">Option Period 1</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d2">CLIN 0004 covers recurring work for Option Period 1.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Option Period 2">
  <ns0:data key="d0">Option Period 2</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d2">CLIN 0007 covers recurring work for Option Period 2.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Unit Price Adjustments">
  <ns0:data key="d0">Unit Price Adjustments</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d2">Collective Bargaining Agreements may entitle the contractor to price adjustments in recurring work CLINs.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Construction Work">
  <ns0:data key="d0">Construction Work</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d2">Section H.5 applies specific FAR clauses to construction work, including wage rates, bonds, and inspection.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Inspection of Services">
  <ns0:data key="d0">Inspection of Services</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d2">Section H.8 uses unit prices for deductions under the Inspection of Services clause and non-performance consequences.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Contractor Performance">
  <ns0:data key="d0">Contractor Performance</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d2">Section H.12 outlines Government inspection, re-performance options, payment withholding, and liquidated damages for Contractor non-performance.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838907</ns0:data>
</ns0:node>
<ns0:node id="Non-Performed Work">
  <ns0:data key="d0">Non-Performed Work</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d2">Section H.13 uses estimating methods for non-performed work costs and calculates liquidated damages per Section H.12.</ns0:data>
