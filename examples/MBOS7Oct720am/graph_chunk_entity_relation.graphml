  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.208-9 Contractor Use of Mandatory Sources of Supply requires contractors to obtain specified supplies from nonprofit agencies under the program operated by the Committee.</ns0:data>
