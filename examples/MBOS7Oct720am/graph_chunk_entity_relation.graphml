  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.217-8 relates to the option for increased quantity.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Construction Wage Rate Requirements">
  <ns0:data key="d0">Construction Wage Rate Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Construction Wage Rate Requirements Wage Determinations are incorporated from the previous service provider.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Collective Bargaining Agreements">
  <ns0:data key="d0">Collective Bargaining Agreements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Collective Bargaining Agreements from the previous service provider are incorporated into the contract.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Transportation">
  <ns0:data key="d0">Transportation</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Transportation is a required service under Base Operations Support.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Environmental">
  <ns0:data key="d0">Environmental</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Environmental services are required under Base Operations Support.&lt;SEP&gt;Environmental aspects for MCSF-BI include SWPPP and stormwater management plans.</ns0:data>
  <ns0:data key="d3">chunk-9e005e41da996ebb18d009a4f87b0e3c&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0004">
  <ns0:data key="d0">CLIN 0004</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0004 covers Option Period 1 recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers B001 through B014.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0005">
  <ns0:data key="d0">CLIN 0005</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0005 covers Option Period 1 non-recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers B700 through B718.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0006">
  <ns0:data key="d0">CLIN 0006</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0006 covers Option Period 1 recurring firm fixed price services for the Water Annex, totaling Exhibit Line Item Number B015.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0007">
  <ns0:data key="d0">CLIN 0007</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0007 covers Option Period 2 recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers C001 through C014.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0008">
  <ns0:data key="d0">CLIN 0008</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0008 covers Option Period 2 non-recurring firm fixed price Base Operations Support services, totaling Exhibit Line Item Numbers C700 through C718.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Exhibit Line Item Numbers">
  <ns0:data key="d0">Exhibit Line Item Numbers</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Exhibit Line Item Numbers (ELINs) support the pricing of Contract Line Item Numbers in Section B, detailed in Attachment J-0200000-17.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Minimum Guarantee">
  <ns0:data key="d0">Minimum Guarantee</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The minimum guarantee is for CLIN 0001 Base Period Recurring Work, with no minimums applying to option periods.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Maximum NTE">
  <ns0:data key="d0">Maximum NTE</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The maximum Not To Exceed (NTE) value applies to ordering periods and the overall contract, not to be exceeded without modification.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="WAWF">
  <ns0:data key="d0">WAWF</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">WAWF is a system for electronic invoicing and receiving reports, with contact information provided for assistance.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="FedMall">
  <ns0:data key="d0">FedMall</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FedMall is a U.S. Government-owned web-based ordering system that enables Department of Defense and Federal activities to search for and order goods and services, requiring contractor registration and catalog upload.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="Governmentwide Commercial Purchase Card">
  <ns0:data key="d0">Governmentwide Commercial Purchase Card</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The Governmentwide Commercial Purchase Card program allows authorized Government personnel to order work directly via FedMall at pre-priced line items without additional markup.&lt;SEP&gt;Governmentwide Commercial Purchase Card is the program enabling authorized government personnel to order IQ pre-priced line item services directly via Fedmall without additional markup.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838890</ns0:data>
</ns0:node>
<ns0:node id="ELIN">
  <ns0:data key="d0">ELIN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">ELIN refers to Equipment Line Item Numbers used for ordering via FedMall, including specific items like Temporary HVAC units and services.&lt;SEP&gt;ELIN stands for Exhibit Line Item Number, requiring unit prices rounded to two decimal places for evaluation, with totals recomputed if necessary.&lt;SEP&gt;ELIN refers to line item numbers in the pricing proposal that must be allocated based on customer requirements and rounded to two decimal places.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.1">
  <ns0:data key="d0">Section H.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.1 requires protection and reporting of historical and archaeological resources discovered during work, with work stoppage until directed otherwise.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.2">
  <ns0:data key="d0">Section H.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.2 outlines requirements for FedMall registration, catalog upload, acceptance of GCPC orders, and use of encryption and certificates for electronic orders.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.3">
  <ns0:data key="d0">Section H.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.3 authorizes additional methods for issuing delivery or task orders, including orally, by facsimile, and electronic commerce.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.4">
  <ns0:data key="d0">Section H.4</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.4 incorporates order limitations from FAR clause 52.216-19, excluding applicability to recurring work, FedMall orders, and GCPC program.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.5">
  <ns0:data key="d0">Section H.5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.5 specifies that the contract includes some construction work subject to various FAR clauses on labor standards, bonds, and construction requirements.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.6">
  <ns0:data key="d0">Section H.6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.6 incorporates FAR clause 52.211-10 on commencement, prosecution, and completion of work, applicable to task orders as negotiated.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.7">
  <ns0:data key="d0">Section H.7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.7 requires contractors to furnish and display identification for employees as directed by the Contracting Officer.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.8">
  <ns0:data key="d0">Section H.8</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.8 uses unit prices as basis for deductions under inspection clauses and consequences for non-performance.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.9">
  <ns0:data key="d0">Section H.9</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.9 states that Government property is not included, but facilities, equipment, and utilities are made available in as-is condition for contract use.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.10">
  <ns0:data key="d0">Section H.10</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.10 limits authority to bind the Government to the Contracting Officer only, prohibiting modifications by others.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.11">
  <ns0:data key="d0">Section H.11</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.11 governs substitutions of key personnel, requiring resumes and comparable qualifications, with no price changes.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.12">
  <ns0:data key="d0">Section H.12</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.12 details consequences for failure to perform, including re-performance, payment withholding, liquidated damages, and termination rights.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Section H.13">
  <ns0:data key="d0">Section H.13</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H.13 provides methods for estimating costs of non-performed work using wage rates, overhead, and material estimates, plus liquidated damages.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.216-18">
  <ns0:data key="d0">FAR 52.216-18</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.216-18 authorizes ordering methods including oral, facsimile, and electronic commerce for delivery or task orders.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.216-19">
  <ns0:data key="d0">FAR 52.216-19</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.216-19 establishes order limitations, not applicable to recurring work, FedMall, or GCPC.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Department of Defense">
  <ns0:data key="d0">Department of Defense</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Department of Defense uses FedMall for ordering and establishes the External Certification Authority program for secure communications.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="External Certification Authority">
  <ns0:data key="d0">External Certification Authority</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The External Certification Authority program issues DoD-approved certificates to contractors for secure communication and authentication to DoD systems.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="PGP Personal Software">
  <ns0:data key="d0">PGP Personal Software</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">PGP Personal software, or comparable, is required for decrypting order notification emails from FedMall using 128-bit encryption.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Blount Island">
  <ns0:data key="d0">Blount Island</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Blount Island is referenced in ELIN for shoreline cleanup services.&lt;SEP&gt;Site associated with Marine Corps Support Facility (MCSF-BI), including site visits, inventories, and facility investments.&lt;SEP&gt;Blount Island is the site associated with MCSF-BI shoreline cleanup and grounds maintenance activities.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455&lt;SEP&gt;chunk-9e005e41da996ebb18d009a4f87b0e3c&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="DD 1155">
  <ns0:data key="d0">DD 1155</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD 1155 is an approved form for issuing orders, used by the Contractor to track and report total ordered quantities monthly and year-to-date to the Contracting Officer.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Historical and Archaeological Resources">
  <ns0:data key="d0">Historical and Archaeological Resources</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Historical and archaeological resources discovered during work must be protected in-place, reported immediately, and are owned and controlled by the Government.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Human Skeletal Remains">
  <ns0:data key="d0">Human Skeletal Remains</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Human skeletal remains discovered in the course of work must be reported immediately to the Contracting Officer, with work stopped in the area.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="DLA">
  <ns0:data key="d0">DLA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Defense Logistics Agency operates the FedMall website and provides the Supplier Registration for contractors.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Key Personnel">
  <ns0:data key="d0">Key Personnel</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Key personnel are identified in Section C, and the Contractor must provide resumes for proposed substitutes with comparable qualifications for Contracting Officer approval.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Watchstanding Services">
  <ns0:data key="d0">Watchstanding Services</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Watchstanding services require the Contractor to provide qualified personnel, with the Government withholding payment or assessing damages if posts are unmanned for 10 minutes.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Quality Control Program">
  <ns0:data key="d0">Quality Control Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Contractor must maintain an effective quality control program during the course of the contract, with failure potentially resulting in termination for default.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.211-10">
  <ns0:data key="d0">FAR 52.211-10</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.211-10 governs the commencement, prosecution, and completion of work and may be incorporated into task orders as applicable.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.246-4">
  <ns0:data key="d0">FAR 52.246-4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.246-4 provides for the inspection of services under fixed-price contracts and serves as the basis for deductions and assessments of performance.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.211-11">
  <ns0:data key="d0">FAR 52.211-11</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.211-11 allows for liquidated damages in supplies, services, or research and development, assessed against the Contractor for unsatisfactory or non-performed work.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Miller Act">
  <ns0:data key="d0">Miller Act</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Miller Act requires performance and payment bonds for construction task orders, incorporated in accordance with 40 U.S.C. 3131 et seq.</ns0:data>
  <ns0:data key="d3">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Navfac Southeast Pwd Mayport">
  <ns0:data key="d0">Navfac Southeast Pwd Mayport</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navfac Southeast Pwd Mayport is the organization overseeing inspection and acceptance at Building 1966, Bon Homme Richard St, Mayport, FL 32228-0073, United States, with DoDAAC N46134 and contact telephone 904-270-6716.&lt;SEP&gt;Navfac Southeast Pwd Mayport is the organization responsible for contract administration and inspection, located at BLDG 1966, Bon Homme Richard St, Mayport, FL 32228-0073, United States, with telephone 904-270-6716.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Mayport">
  <ns0:data key="d0">Mayport</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Mayport is a location in Florida, United States, serving as the site for inspection, acceptance, and performance under the contract.&lt;SEP&gt;Mayport is a location in Florida, United States, serving as the place of performance for option line items.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Building 1966">
  <ns0:data key="d0">Building 1966</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Building 1966 is situated at Bon Homme Richard St, Mayport, FL 32228-0073, United States, and is the address for deliveries and inspections.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="United States">
  <ns0:data key="d0">United States</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">United States is the country associated with CountryCode USA for all contract locations and activities.&lt;SEP&gt;United States is the country code and place of performance for all option line items.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Pwd Mayport">
  <ns0:data key="d0">Pwd Mayport</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Pwd Mayport is the public works department acting as the Inspector of Record for the contract, reachable at telephone 904-270-6716.&lt;SEP&gt;Pwd Mayport serves as the Inspector of Record for the contract, associated with Navfac Southeast.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Naval Station Mayport Jacksonville">
  <ns0:data key="d0">Naval Station Mayport Jacksonville</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Naval Station Mayport Jacksonville, Florida is a primary site for work performance under the contract.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Support Facility Blount Island">
  <ns0:data key="d0">Marine Corps Support Facility Blount Island</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Marine Corps Support Facility Blount Island, Jacksonville, Florida is an additional site for work performance and outlying areas supported by the commands.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Inspection And Acceptance Location">
  <ns0:data key="d0">Inspection And Acceptance Location</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Inspection And Acceptance Location is set at destination for both, with instructions in Section F, using DoDAAC N46134 and CountryCode USA at Navfac Southeast Pwd Mayport.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Contract Term">
  <ns0:data key="d0">Contract Term</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contract Term begins 01 January 2027 for an initial one-year period, extendable to eight years with seven one-year options, and further via FAR 52.217-8 and FAR 52.217-9.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Transition Period">
  <ns0:data key="d0">Transition Period</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Transition Period provides 90 days for mobilization after award by 30 September 2026 and 90 days for demobilization prior to contract end to support follow-on contractor.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Pre-Performance Conference">
  <ns0:data key="d0">Pre-Performance Conference</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Pre-Performance Conference is scheduled within 30 days of contract award with the Contracting Officer to discuss work scheduling and administration.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Deliverables">
  <ns0:data key="d0">Deliverables</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Deliverables include electronic files in Microsoft Office 365 format, submitted via email or CD-ROM to contacts in Section F attachment on SAM.gov.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Option Line Item">
  <ns0:data key="d0">Option Line Item</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Option Line Item covers items 0007 through 0027, each specifying identical inspection and acceptance locations at Navfac Southeast Pwd Mayport.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Delivery Period">
  <ns0:data key="d0">Delivery Period</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Delivery Period for line items 0001 through 0014 spans annual periods from 01 January 2027 to 31 December 2031, each for 1 each at place of performance with DoDAAC N46134.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Dod AAC N46134">
  <ns0:data key="d0">Dod AAC N46134</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Dod AAC N46134 is the Department of Defense Activity Address Code assigned to the inspection and delivery locations.&lt;SEP&gt;Dod AAC N46134 is the Department of Defense Activity Address Code assigned to the place of performance for option line items.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Far 52.217-9">
  <ns0:data key="d0">Far 52.217-9</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Far 52.217-9 provides the option to extend the term of the contract in accordance with its provisions incorporated into the resulting contract.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Far 52.217-8">
  <ns0:data key="d0">Far 52.217-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Far 52.217-8 authorizes the government to extend contract performance up to an additional six months beyond the established term.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Office 365">
  <ns0:data key="d0">Microsoft Office 365</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Office 365 is the most recent government-installed version required for compatibility with deliverable file formats.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Sam.Gov">
  <ns0:data key="d0">Sam.Gov</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Sam.Gov is the website hosting the attachment for Section F files, accessible at https://sam.gov/.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="N6945025R0003 Sectionf.Pdf">
  <ns0:data key="d0">N6945025R0003 Sectionf.Pdf</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">N6945025R0003 Sectionf.Pdf is the attachment file providing details on Section F deliverables, posted on Sam.Gov.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Inspector Of Record">
  <ns0:data key="d0">Inspector Of Record</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Inspector Of Record is the designated role at PWD Mayport responsible for overseeing inspection and acceptance, contactable via telephone at 904-270-6716.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Place Of Performance">
  <ns0:data key="d0">Place Of Performance</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Place Of Performance refers to the sites specified in Section C, including Naval Station Mayport Jacksonville, Florida, and Marine Corps Support Facility Blount Island, Jacksonville, Florida, along with supported outlying areas.</ns0:data>
  <ns0:data key="d3">chunk-729293c3f8703afb2cb5e31cb6ff90dd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Clauses Incorporated By Reference">
  <ns0:data key="d0">Clauses Incorporated By Reference</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">This contract incorporates one or more clauses by reference, with the same force and effect as if they were given in full text, and full text is available upon request or electronically at specified addresses.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Alterations In Contract">
  <ns0:data key="d0">Alterations In Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Portions of this contract are altered as specified in the clause.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Authorized Deviations In Clauses">
  <ns0:data key="d0">Authorized Deviations In Clauses</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The use of any Federal Acquisition Regulation clause or Defense Federal Acquisition Regulation Supplement clause with an authorized deviation is indicated by the addition of "(DEVIATION)" after the date or name of the regulation.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
<ns0:node id="Limitation Of Government's Obligation">
  <ns0:data key="d0">Limitation Of Government's Obligation</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Contract line items are incrementally funded, with specified amounts available for payment, and outlines contractor obligations, notifications, and government liabilities regarding funding and termination.</ns0:data>
  <ns0:data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838891</ns0:data>
</ns0:node>
