  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="FASCSA Order">
  <ns0:data key="d0">FASCSA Order</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">FASCSA order is a defined term referring to prohibitions set out under the Federal Acquisition Supply Chain Security Act.</ns0:data>
  <ns0:data key="d3">chunk-4bcb91b404a9ca74c18944c1ba7f80a2</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="IGE">
  <ns0:data key="d0">IGE</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">IGE refers to the Independent Government Estimate used in price proposal comparisons.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="FAR 15.404-1">
  <ns0:data key="d0">FAR 15.404-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 15.404-1 is a Federal Acquisition Regulation clause outlining appropriate methodologies for price evaluation.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Unbalanced Pricing">
  <ns0:data key="d0">Unbalanced Pricing</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Unbalanced Pricing occurs when line pricing is relatively and significantly overstated or understated, posing risk to the government.&lt;SEP&gt;Unbalanced Pricing occurs when line items are materially overstated or understated, potentially rendering a proposal unacceptable if representing risk to the government.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Section B">
  <ns0:data key="d0">Section B</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section B details supplies or services and prices or costs, including pricing of 27 Contract Line Item Numbers structured for base and option periods, with recurring and non-recurring work, supported by Exhibit Line Item Numbers in Attachment J-0200000-17.&lt;SEP&gt;Section B contains pricing information submitted within the proposal.&lt;SEP&gt;Section B requires completion for pricing submittal, including CLINs, and is evaluated for discrepancies with Section J.&lt;SEP&gt;Section B contains the schedule of supplies and services, including pre-priced line items supported by Section J ELINs, used for GCPC orders and tracking.&lt;SEP&gt;Section B details the contract supplies and services, supporting orders issued through Fedmall.&lt;SEP&gt;Section B contains line items for pricing in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-5874f638e9cb9ecd09e53d314b07e103&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-3b65cbb31e854658ff984a34247acde1&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Section J ELIN Attachment">
  <ns0:data key="d0">Section J ELIN Attachment</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Section J ELIN Attachment provides details for evaluating inconsistent pricing in proposals.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Section M.3">
  <ns0:data key="d0">Section M.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section M.3 outlines procedures for correcting pricing discrepancies through clarifications or discussions.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Relevant Project">
  <ns0:data key="d0">Relevant Project</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Relevant Project demonstrates capability for services similar in size, scope, and complexity to the RFP, with a contract value of $15,000,000.00 per year or greater, either ongoing with 12 months completed or completed within the last five years.&lt;SEP&gt;A Relevant Project is defined as one demonstrating capability for similar services with a contract value of $15,000,000 per year or greater, ongoing with at least 12 months performance or completed within the last five years, encompassing at least three specified BOS annexes plus one other.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Base Operations Support Services">
  <ns0:data key="d0">Base Operations Support Services</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">Base Operations Support Services encompass projects including at least three specific technical annexes and one additional technical annex.&lt;SEP&gt;Base Operations Support Services are the core outcomes to be achieved at specified naval facilities, including recurring and non-recurring elements.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-3e097b0647fa14f34c4ff76380ed4beb</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Port Operations">
  <ns0:data key="d0">Port Operations</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Port Operations (0600000) is a technical annex requiring similarity to RFP requirements for relevant project evaluation.&lt;SEP&gt;Port Operations (0600000) involves requirements similar to those in the RFP for evaluation of relevant experience.&lt;SEP&gt;Port Operations is a required service under Base Operations Support.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Facility Investment">
  <ns0:data key="d0">Facility Investment</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Facility Investment (1502000) includes service orders, HVAC, fire protection, and other spec items for BOS services evaluation.&lt;SEP&gt;Facility Investment (1502000) includes completion of service orders, HVAC Systems maintenance and repairs, Fire Protection Systems maintenance and repairs, and two other facility investment spec items.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Electrical">
  <ns0:data key="d0">Electrical</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Electrical (1602000) covers transmission, distribution, operations, maintenance, and repairs similar to RFP needs.&lt;SEP&gt;Electrical (1602000) covers Transmission &amp; Distributions operations, maintenance, and repairs similar to RFP requirements.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Water">
  <ns0:data key="d0">Water</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Water (1606000) is a technical area for BOS services in relevant project assessments.&lt;SEP&gt;Water (1606000) includes Raw Water Supply, Water Treatment Plant and Distribution System operation, Laboratory and Testing processes, maintenance, and repairs.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="BSVE">
  <ns0:data key="d0">BSVE</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">BSVE (1700000) involves operations, maintenance, and repair of Civil Engineering Support Equipment (CESE) and Weight Handling Equipment (WHE).</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="General Information">
  <ns0:data key="d0">General Information</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">General Information (0100000) is an annex not considered toward the minimum technical annex requirement for relevant projects.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Management and Administration">
  <ns0:data key="d0">Management and Administration</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Management and Administration (0200000) is an annex not considered toward the minimum technical annex requirement for relevant projects.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Factor 1">
  <ns0:data key="d0">Factor 1</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 1 evaluates Corporate Experience based on submission of two to five examples of recent, relevant projects as prime contractor.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Corporate Experience">
  <ns0:data key="d0">Corporate Experience</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Corporate Experience assesses the offeror's capability through relevant projects demonstrating size, scope, and complexity.&lt;SEP&gt;Corporate Experience is Factor 1 of the solicitation, used to assess relevancy of projects in the past performance evaluation.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Factor 2">
  <ns0:data key="d0">Factor 2</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 2 evaluates Management Approach, including workforce management, quality management system, scheduling, and phase-in plans.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Management Approach">
  <ns0:data key="d0">Management Approach</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Management Approach demonstrates control and management of the project, interfaces between functional areas, and administration structure.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Factor 3">
  <ns0:data key="d0">Factor 3</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor 3 evaluates the offeror's technical approach, including staffing levels, methodology for performance objectives, systems approach, limits of liability, supply chain management, and risk mitigation.&lt;SEP&gt;Factor 3 evaluates Technical Approach, including staffing levels, methodology for annexes, and understanding of requirements.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-b1019473eb9ce96e37dbd7a39cfdf02d</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Technical Approach">
  <ns0:data key="d0">Technical Approach</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Technical Approach describes methodology to achieve performance objectives across annexes and sub-annexes.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="JM-1 Corporate Experience Project Data Sheet">
  <ns0:data key="d0">JM-1 Corporate Experience Project Data Sheet</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">JM-1 Corporate Experience Project Data Sheet is a form for submitting project information, expandable beyond two pages.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Attachment JL-1">
  <ns0:data key="d0">Attachment JL-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Attachment JL-1 is a Microsoft Excel version required for total effort including prime contractor and subcontractors for the base period.&lt;SEP&gt;Attachment JL-1 details staffing levels and labor hours for the base period, submitted as an Excel spreadsheet.&lt;SEP&gt;Attachment JL-1 is submitted in hard copy and Excel format for the non-price proposal.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Joint Venture">
  <ns0:data key="d0">Joint Venture</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Joint Venture requires submission of relevant experience for the JV entity or partners, limited to five projects total.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Mentor-Protege Agreements">
  <ns0:data key="d0">Mentor-Protege Agreements</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Mentor-Protege Agreements approved by the Small Business Administration allow exceptions for JV experience requirements.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838888</ns0:data>
</ns0:node>
<ns0:node id="Quality Management System">
  <ns0:data key="d0">Quality Management System</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Quality Management System ensures compliance with management and administration requirements through processes, practices, resources, and controls.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Performance Work Statement">
  <ns0:data key="d0">Performance Work Statement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Performance Work Statement outlines the requirements for Base Operations Support services, including labor, supervision, management, tools, materials, equipment, and other necessary items.&lt;SEP&gt;Performance Work Statement outlines requirements for maintenance, data fields, and service performance across annexes and sections.&lt;SEP&gt;The Performance Work Statement defines the scope of services, including technical annexes for evaluation of relevant projects.&lt;SEP&gt;Performance Work Statement outlines specifications and requirements for services in the RFP.&lt;SEP&gt;The Performance Work Statement outlines recurring base operations support services and applicable attachments for the contract.&lt;SEP&gt;Performance Work Statement includes performance objectives that offerors must demonstrate understanding of beyond mere intent to perform.</ns0:data>
  <ns0:data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="NAVSTA Mayport">
  <ns0:data key="d0">NAVSTA Mayport</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">NAVSTA Mayport is a naval station that distributes its own electricity and produces and distributes its own water, requiring sufficient utility services.&lt;SEP&gt;NAVSTA Mayport is a location for sub-annexes involving facility management and utilities.&lt;SEP&gt;Naval Station Mayport, site for facility inventory, maps, historical work orders, and weight handling equipment.&lt;SEP&gt;NAVSTA Mayport is the Naval Station Mayport for which documents on weight handling equipment, cross connection control, and stormwater plans are provided.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-516b1e6efecfd543f141d1e1135ec455&lt;SEP&gt;chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI">
  <ns0:data key="d0">MCSF-BI</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">MCSF-BI is a site associated with multiple sub-annexes for facility management, custodial, pest control, solid waste management, grounds maintenance, and environmental requirements.&lt;SEP&gt;MCSF-BI is a location for sub-annexes including custodial, pest control, and grounds maintenance.&lt;SEP&gt;MCSF-BI is the Marine Corps Support Facility at Blount Island for which multiple system inventories, plans, and facility investment documents are provided.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-b1019473eb9ce96e37dbd7a39cfdf02d&lt;SEP&gt;chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="RFP">
  <ns0:data key="d0">RFP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">RFP is the Request for Proposals containing performance work statement, specifications, and evaluation criteria.&lt;SEP&gt;The RFP is the Request for Proposal describing performance work statement, specifications, and requirements for base operations support services evaluation.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Annex 6">
  <ns0:data key="d0">Annex 6</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 6 covers Port Operations as part of the technical approach requirements.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Annex 15">
  <ns0:data key="d0">Annex 15</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 15 includes Facilities Support with sub-annexes for facility management, investment, custodial, pest control, waste management, training pools, and grounds maintenance.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Annex 16">
  <ns0:data key="d0">Annex 16</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 16 covers Utilities including utilities management, electrical, and water.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Annex 17">
  <ns0:data key="d0">Annex 17</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 17 covers Transportation as part of the technical approach.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Annex 18">
  <ns0:data key="d0">Annex 18</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Annex 18 covers Environmental with sub-annexes for NAVSTA and MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838889</ns0:data>
</ns0:node>
<ns0:node id="Facility Management">
  <ns0:data key="d0">Facility Management</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Facility Management is a required service under Base Operations Support.&lt;SEP&gt;Facility Management (1501000) includes sub-annexes for NAVSTA and MCSF-BI as part of Facilities Support in Annex 15.</ns0:data>
  <ns0:data key="d3">chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
