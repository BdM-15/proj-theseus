<ns0:edge source="Contractor" target="Section H.6">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.6 allows the Government to negotiate task order performance periods with the Contractor.</ns0:data>
  <ns0:data key="d8">negotiation,performance period</ns0:data>
