  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Option Line Item 0003 specifies inspection and acceptance at destination at NAVFAC Southeast PWD Mayport, with DoDAAC N46134 and instructions to see Section F.</ns0:data>
