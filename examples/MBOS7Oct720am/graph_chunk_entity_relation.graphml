  <ns0:data key="d11">1759838920</ns0:data>
</ns0:edge>
<ns0:edge source="TCR Rate" target="Very Low Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Very Low Risk corresponds to TCR rates less than 2.49, indicating strong safety performance.</ns0:data>
  <ns0:data key="d8">risk correlation,safety indicator</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="TCR Rate" target="Low Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Low Risk corresponds to TCR rates from 2.5 to 3.49.</ns0:data>
  <ns0:data key="d8">risk correlation,safety indicator</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="TCR Rate" target="Moderate Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Moderate Risk corresponds to TCR rates from 3.5 to 4.49, with negative trends requiring detailed explanations and corrective actions.</ns0:data>
  <ns0:data key="d8">risk correlation,trend analysis</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="TCR Rate" target="High Risk">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">High Risk corresponds to TCR rates from 4.5 to 5.99, potentially a weakness without acceptable explanations for trends.</ns0:data>
  <ns0:data key="d8">risk correlation,weakness potential</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
