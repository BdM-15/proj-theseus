</ns0:node>
<ns0:node id="Pgp Personal Software">
  <ns0:data key="d0">Pgp Personal Software</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Pgp Personal Software, or a comparable solution, is required for contractors to decrypt 128-bit encrypted order notification emails from Fedmall.</ns0:data>
  <ns0:data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
