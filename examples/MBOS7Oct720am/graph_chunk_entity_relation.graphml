  <ns0:data key="d0">Responsibility Determination Binder</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Responsibility Determination Binder contains information such as SF-33, financial statements, and team details for responsibility assessment.</ns0:data>
  <ns0:data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d5">1759838892</ns0:data>
</ns0:node>
