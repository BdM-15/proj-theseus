  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="External Certification Authority">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor purchases, installs, and maintains a DoD-approved External Certification Authority certificate for secure communications.</ns0:data>
  <ns0:data key="d8">certification,security</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
