  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-30 Federal Acquisition Supply Chain Security Act Orders-Prohibition is a clause providing definitions and prohibiting the use of certain covered articles and sources under FASCSA orders.</ns0:data>
