<ns0:node id="Marine Corps Support Facility - Blount Island">
  <ns0:data key="d0">Marine Corps Support Facility - Blount Island</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Marine Corps Support Facility - Blount Island is a support facility in Jacksonville, Florida, primarily serviced for custodial, pest control, integrated solid waste management, and grounds maintenance.&lt;SEP&gt;Marine Corps Support Facility - Blount Island is a facility in Jacksonville, Florida, requiring base operations support services.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
