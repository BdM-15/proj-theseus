  <ns0:data key="d0">Covered Article</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Covered article is a defined term in 52.204-30 referring to items prohibited under applicable FASCSA orders.</ns0:data>
  <ns0:data key="d3">chunk-4bcb91b404a9ca74c18944c1ba7f80a2</ns0:data>
