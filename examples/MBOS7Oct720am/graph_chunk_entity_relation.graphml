<ns0:edge source="Contractor" target="PGP Personal Software">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor uses PGP Personal software to decrypt 128-bit encrypted order notifications from FedMall.</ns0:data>
  <ns0:data key="d8">email processing,encryption</ns0:data>
