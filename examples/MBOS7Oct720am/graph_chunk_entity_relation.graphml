  <ns0:data key="d0">CLIN 0003</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0003 covers the base period recurring firm fixed price services for the Water Annex, totaling Exhibit Line Item Number A015.</ns0:data>
  <ns0:data key="d3">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d4">_N6945025R0003.pdf</ns0:data>
