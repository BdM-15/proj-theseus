  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Naval Station Mayport Jacksonville and Marine Corps Support Facility Blount Island are interconnected sites for work performance and outlying areas.</ns0:data>
  <ns0:data key="d8">command support,performance sites</ns0:data>
