  <ns0:data key="d11">1759838901</ns0:data>
</ns0:edge>
<ns0:edge source="52.222-42 Statement of Equivalent Rates for Federal Hires" target="Wage Determination">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.222-42 Statement of Equivalent Rates for Federal Hires provides information on equivalent rates but is explicitly not a Wage Determination.</ns0:data>
  <ns0:data key="d8">informational purpose,non-determination</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
