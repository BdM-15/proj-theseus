<ns0:edge source="Limitation Of Government's Obligation" target="Termination for Convenience of the Government">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Limitation Of Government's Obligation references Termination for Convenience of the Government for handling reimbursement and obligations upon termination of incrementally funded items.</ns0:data>
  <ns0:data key="d8">reference,termination provisions</ns0:data>
  <ns0:data key="d9">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
<ns0:edge source="Limitation Of Government's Obligation" target="Disputes">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Limitation Of Government's Obligation invokes the Disputes clause for resolving disagreements on equitable adjustments due to funding failures.</ns0:data>
  <ns0:data key="d8">equitable adjustment,reference</ns0:data>
  <ns0:data key="d9">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
<ns0:edge source="Limitation Of Government's Obligation" target="Default">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Limitation Of Government's Obligation specifies that its termination provisions do not limit government rights under the Default clause.</ns0:data>
  <ns0:data key="d8">distinction,termination rights</ns0:data>
  <ns0:data key="d9">chunk-516b1e6efecfd543f141d1e1135ec455</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
