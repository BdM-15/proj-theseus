<ns0:node id="Firm Fixed Price">
  <ns0:data key="d0">Firm Fixed Price</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Firm Fixed Price is the pricing arrangement applied to all option line items in the contract.&lt;SEP&gt;FFP applies to recurring work in the base period and option periods of the contract.</ns0:data>
  <ns0:data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
