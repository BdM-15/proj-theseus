<ns0:edge source="DFARS 252.215-7008" target="Canadian Commercial Corporation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">DFARS 252.215-7008 exempts the Canadian Commercial Corporation from certified cost or pricing data but requires additional data submission upon notification if only one offer is received.</ns0:data>
  <ns0:data key="d8">data exemption,notification requirements</ns0:data>
