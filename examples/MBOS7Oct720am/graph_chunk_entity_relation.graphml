  <ns0:data key="d11">1759838916</ns0:data>
</ns0:edge>
<ns0:edge source="Section K" target="DFARS Clauses">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates multiple DFARS clauses by reference to ensure compliance with defense-specific requirements.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
