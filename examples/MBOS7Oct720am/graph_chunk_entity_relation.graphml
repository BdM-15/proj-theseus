  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates clause 52.204-24 by reference for representations on telecommunications and surveillance equipment.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
