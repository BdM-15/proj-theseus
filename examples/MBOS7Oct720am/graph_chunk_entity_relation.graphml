  <ns0:data key="d0">52.215-1 Instructions to Offerors Competitive Acquisition</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.215-1 Instructions to Offerors -- Competitive Acquisition (JAN 2004) governs the provisions for proposal receipt and evaluation in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-4bcb91b404a9ca74c18944c1ba7f80a2</ns0:data>
