<ns0:edge source="Small Business (SB)" target="Factor 4 - Small Business Utilization">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Factor 4 evaluates small business utilization, incorporating categories like Small Business with targets from the SBSP.</ns0:data>
