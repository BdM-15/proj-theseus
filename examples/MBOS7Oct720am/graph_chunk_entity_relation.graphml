<ns0:edge source="Contractor" target="DD 1155">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor processes orders and reports total quantities using approved DD 1155 forms to the Contracting Officer monthly.</ns0:data>
