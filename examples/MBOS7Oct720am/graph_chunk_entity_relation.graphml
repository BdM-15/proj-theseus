<ns0:edge source="Small Business Subcontracting Plan" target="L.14 Small Business Subcontracting Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">L.14 Small Business Subcontracting Plan requires submission of SBSP for other than small businesses using Attachment JL-8.</ns0:data>
  <ns0:data key="d8">plan submission,responsibility matter</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Subcontracting Plan" target="NAVFAC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Small Business Subcontracting Plan must align with NAVFAC's small business targets such as 40% for small businesses.</ns0:data>
  <ns0:data key="d8">goal alignment,subcontracting targets</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838910</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Subcontracting Plan" target="Attachment JL-8">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Attachment JL-8 serves as the template for the Small Business Subcontracting Plan.</ns0:data>
  <ns0:data key="d8">plan format,template utilization</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838911</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Subcontracting Plan" target="Small Business Participation Commitment Document">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Small Business Subcontracting Plan must list small businesses consistent with those in the Small Business Participation Commitment Document, though goals differ in basis.</ns0:data>
  <ns0:data key="d8">goal difference,participation alignment</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838911</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Subcontracting Plan" target="SSEB">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">SSEB reviews the Small Business Subcontracting Plan for acceptability along with other authorities.</ns0:data>
  <ns0:data key="d8">acceptability check,evaluation review</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838912</ns0:data>
</ns0:edge>
<ns0:edge source="52.217-8 Option to Extend Services" target="Contracting Officer">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer exercises the option in 52.217-8 Option to Extend Services by written notice to the Contractor.</ns0:data>
  <ns0:data key="d8">authority delegation,notice issuance</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838901</ns0:data>
</ns0:edge>
<ns0:edge source="52.217-8 Option to Extend Services" target="Secretary of Labor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Secretary of Labor's revisions to prevailing labor rates may adjust the rates for continued performance under 52.217-8 Option to Extend Services.</ns0:data>
  <ns0:data key="d8">labor revision,rate adjustment</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838901</ns0:data>
</ns0:edge>
<ns0:edge source="52.219-4 Notice of Price Evaluation Preference for HUBZone Small Business Concerns" target="HUBZone Small Business Concern">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.219-4 Notice of Price Evaluation Preference for HUBZone Small Business Concerns provides a 10 percent price evaluation advantage to HUBZone Small Business Concerns unless waived.</ns0:data>
  <ns0:data key="d8">award priority,evaluation preference</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838900</ns0:data>
</ns0:edge>
<ns0:edge source="HUBZone Small Business Concern" target="Small Business Administration">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Small Business Administration qualifies and lists HUBZone Small Business Concerns under 13 CFR part 126 for evaluation preferences.</ns0:data>
  <ns0:data key="d8">certification authority,qualification list</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838900</ns0:data>
</ns0:edge>
<ns0:edge source="HUBZone Small Business Concern" target="HUBZone Joint Venture">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">HUBZone Small Business Concern in a HUBZone Joint Venture must complete at least 40 percent of the aggregate work beyond administrative functions.</ns0:data>
  <ns0:data key="d8">aggregate percentage,work performance requirement</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838900</ns0:data>
</ns0:edge>
<ns0:edge source="52.219-28 Postaward Small Business Program Rerepresentation" target="Small Business Concern">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.219-28 Postaward Small Business Program Rerepresentation applies size standards for Small Business Concerns based on NAICS codes assigned to the contract.</ns0:data>
  <ns0:data key="d8">NAICS assignment,size standard application</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838901</ns0:data>
</ns0:edge>
<ns0:edge source="52.219-28 Postaward Small Business Program Rerepresentation" target="52.219-28 Postaward Small Business Program Rerepresentation Alternate I">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.219-28 Postaward Small Business Program Rerepresentation Alternate I substitutes a specific paragraph for the basic clause to address NAICS code representations.</ns0:data>
  <ns0:data key="d8">clause variation,substitution</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838902</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Concern" target="Affiliates">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Affiliates are considered in determining whether a Small Business Concern meets size standards based on control, ownership, and management per 13 CFR 121.103.</ns0:data>
  <ns0:data key="d8">affiliation factors,control determination</ns0:data>
  <ns0:data key="d9">chunk-bafeb026eba657c5147474a89dc0e6f9</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838900</ns0:data>
</ns0:edge>
<ns0:edge source="52.222-42 Statement of Equivalent Rates for Federal Hires" target="Service Contract Labor Standards">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.222-42 Statement of Equivalent Rates for Federal Hires complies with the Service Contract Labor Standards statute and 29 CFR Part 4 by identifying employee classes and equivalent rates.</ns0:data>
  <ns0:data key="d8">regulation reference,statute compliance</ns0:data>
