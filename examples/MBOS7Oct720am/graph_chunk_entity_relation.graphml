  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates 252.203-7005 by reference for DoD official compensation representations.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838918</ns0:data>
</ns0:edge>
<ns0:edge source="Section K" target="252.204-7008 Compliance with Safeguarding Covered Defense Information Controls">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates 252.204-7008 by reference for defense information safeguarding.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838919</ns0:data>
</ns0:edge>
<ns0:edge source="Section K" target="252.204-7017 Prohibition on the Acquisition of Covered Defense Telecommunications Equipment or Services-Representation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates 252.204-7017 by reference to prohibit certain telecommunications acquisitions.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="Section K" target="252.225-7055 Representation Regarding Business Operations with the Maduro Regime">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section K incorporates 252.225-7055 by reference for Maduro Regime business representations.</ns0:data>
  <ns0:data key="d8">incorporation,reference</ns0:data>
  <ns0:data key="d9">chunk-9e005e41da996ebb18d009a4f87b0e3c</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="Section L" target="FAR 52.214-7">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section L references FAR 52.214-7 for handling late submissions in sealed bid solicitations.</ns0:data>
  <ns0:data key="d8">provision reference</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838906</ns0:data>
</ns0:edge>
<ns0:edge source="Section L" target="FAR 52.215-1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section L references FAR 52.215-1 for handling late submissions in negotiated solicitations.</ns0:data>
  <ns0:data key="d8">provision reference</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="Factor 1 - Corporate Experience">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M defines Factor 1 as part of non-cost factors, equal in importance to other technical factors and combined with past performance over price.</ns0:data>
  <ns0:data key="d8">evaluation criteria,relative importance</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838918</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="Factor 6 - Past Performance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M distinguishes Factor 6 Past Performance, focusing on relevance and quality of recent efforts, as equal to combined technical factors in importance.</ns0:data>
  <ns0:data key="d8">distinction from experience,evaluation criteria</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838919</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="FAR 52.217-5">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M incorporates FAR 52.217-5 for evaluating all options in total price without obligating exercise, using techniques like IGE comparison.</ns0:data>
  <ns0:data key="d8">option evaluation,price analysis</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838920</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="Tradeoff Process">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M selects the tradeoff process for award, allowing consideration beyond lowest price or highest technical rating for best value to the government.</ns0:data>
  <ns0:data key="d8">award methodology,best value</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838921</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="Competitive Range">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M reserves the right to negotiate within the competitive range and limit its size for efficient competition if necessary.</ns0:data>
  <ns0:data key="d8">negotiation potential,proposal limitation</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838922</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="Significant Weakness">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M considers proposals with significant weaknesses or multiple weaknesses ineligible unless corrected, impacting individual or overall ratings.</ns0:data>
  <ns0:data key="d8">deficiency impact,proposal rating</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838922</ns0:data>
</ns0:edge>
<ns0:edge source="Section M" target="ELIN">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section M requires ELIN unit prices rounded to two decimal places, with extended totals recomputed for evaluation if not rounded by the offeror.</ns0:data>
  <ns0:data key="d8">pricing computation,rounding protocol</ns0:data>
  <ns0:data key="d9">chunk-9775b66c35e6cfe40c05dbf72803d6cd</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838923</ns0:data>
</ns0:edge>
<ns0:edge source="FAR 52.215-1" target="L.11 All Or None Offers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">L.11 All Or None Offers modifies FAR 52.215-1 Instructions To Offerors Competitive Acquisition in Section L.</ns0:data>
  <ns0:data key="d8">modification,submission rules</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838911</ns0:data>
</ns0:edge>
<ns0:edge source="FAR 52.222-32" target="Construction Wage Rate Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Construction Wage Rate Requirements are governed by FAR 52.222-32 for price adjustments.</ns0:data>
  <ns0:data key="d8">clause application</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Collective Bargaining Agreements" target="Unit Price Adjustments">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Collective Bargaining Agreements may entitle the contractor to price adjustments in recurring work CLINs.</ns0:data>
  <ns0:data key="d8">wage impact</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0004" target="Option Period 1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN 0004 covers recurring work for Option Period 1.</ns0:data>
  <ns0:data key="d8">period coverage</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0005" target="Option Period 1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN 0005 covers non-recurring work for Option Period 1.</ns0:data>
  <ns0:data key="d8">period coverage</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0007" target="Option Period 2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN 0007 covers recurring work for Option Period 2.</ns0:data>
  <ns0:data key="d8">period coverage</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0008" target="Option Period 2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN 0008 covers non-recurring work for Option Period 2.</ns0:data>
  <ns0:data key="d8">period coverage</ns0:data>
  <ns0:data key="d9">chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="FedMall" target="Governmentwide Commercial Purchase Card">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">FedMall facilitates direct ordering of pre-priced line items using the Governmentwide Commercial Purchase Card without markup.</ns0:data>
  <ns0:data key="d8">ordering method,payment</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="FedMall" target="Department of Defense">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Department of Defense owns and operates FedMall for ordering goods and services.</ns0:data>
  <ns0:data key="d8">operation,ownership</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838908</ns0:data>
</ns0:edge>
<ns0:edge source="Governmentwide Commercial Purchase Card" target="Fedmall">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Fedmall enables ordering of indefinite quantity pre-priced line item services using the Governmentwide Commercial Purchase Card.</ns0:data>
  <ns0:data key="d8">ordering,payment method</ns0:data>
  <ns0:data key="d9">chunk-5874f638e9cb9ecd09e53d314b07e103</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838916</ns0:data>
</ns0:edge>
<ns0:edge source="ELIN" target="Section H.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.2 requires uploading catalogs of Unit Price Tasks supported by ELINs to FedMall and tracking ordered quantities.</ns0:data>
  <ns0:data key="d8">catalog upload,tracking</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="ELIN" target="Price Proposal Binder">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">ELIN unit prices in the Price Proposal Binder must be rounded and allocated based on customer requirements to avoid unbalanced pricing.</ns0:data>
  <ns0:data key="d8">allocation rule,pricing calculation</ns0:data>
  <ns0:data key="d9">chunk-6266f048b10bdb8222f03b8f5e597d7e</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838916</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.3" target="FAR 52.216-18">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.3 incorporates FAR 52.216-18 to authorize oral, facsimile, and electronic methods for issuing orders.</ns0:data>
  <ns0:data key="d8">authorization,ordering</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.4" target="FAR 52.216-19">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.4 incorporates FAR 52.216-19 on order limitations, excluding certain programs.</ns0:data>
  <ns0:data key="d8">applicability,limitations</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.5" target="Construction Work">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.5 applies specific FAR clauses to construction work, including wage rates, bonds, and inspection.</ns0:data>
  <ns0:data key="d8">clauses application,labor standards</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.5" target="Miller Act">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.5 incorporates Miller Act requirements for performance and payment bonds in construction task orders.</ns0:data>
  <ns0:data key="d8">bonding,construction</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838908</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.6" target="FAR 52.211-10">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.6 incorporates FAR 52.211-10 into task orders for commencement, prosecution, and completion of work.</ns0:data>
  <ns0:data key="d8">applicability,incorporation</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838908</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.8" target="Inspection of Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.8 uses unit prices for deductions under the Inspection of Services clause and non-performance consequences.</ns0:data>
  <ns0:data key="d8">deductions,pricing</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.11" target="Key Personnel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.11 requires Contracting Officer approval for key personnel substitutions with comparable qualifications.</ns0:data>
  <ns0:data key="d8">approval,substitution</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.12" target="Contractor Performance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.12 outlines Government inspection, re-performance options, payment withholding, and liquidated damages for Contractor non-performance.</ns0:data>
  <ns0:data key="d8">inspection,remedies</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.12" target="FAR 52.246-4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.12 uses FAR 52.246-4 to inspect and assess Contractor performance, enabling re-performance or payment withholding.</ns0:data>
  <ns0:data key="d8">inspection,performance</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838908</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.12" target="FAR 52.211-11">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.12 assesses liquidated damages in accordance with FAR 52.211-11 for unsatisfactory or non-performed work.</ns0:data>
  <ns0:data key="d8">damages,non-performance</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838909</ns0:data>
</ns0:edge>
<ns0:edge source="Section H.13" target="Non-Performed Work">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.13 uses estimating methods for non-performed work costs and calculates liquidated damages per Section H.12.</ns0:data>
  <ns0:data key="d8">damages,estimation</ns0:data>
  <ns0:data key="d9">chunk-3b65cbb31e854658ff984a34247acde1</ns0:data>
  <ns0:data key="d10">_N6945025R0003.pdf</ns0:data>
  <ns0:data key="d11">1759838907</ns0:data>
</ns0:edge>
