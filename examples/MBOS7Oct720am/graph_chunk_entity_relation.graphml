  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor must rerepresent status for Long-term Contracts within 60 to 120 days prior to the end of the fifth year and before exercising options thereafter under 52.219-28.</ns0:data>
