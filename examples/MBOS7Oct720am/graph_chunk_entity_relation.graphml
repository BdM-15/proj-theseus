<ns0:edge source="TCR Rate" target="Offeror">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Offeror submits five years of TCR rate data, affirms absence if no rate exists, and explains negative trends above moderate risk.</ns0:data>
  <ns0:data key="d8">submission requirement,trend explanation</ns0:data>
  <ns0:data key="d9">chunk-6277b393cb9cf1d4f0f247c35b0fffa1</ns0:data>
