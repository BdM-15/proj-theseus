  <data key="d0">Disputes</data>
  <data key="d1">clause</data>
  <data key="d2">Disputes is a referenced clause that addresses disputes concerning questions of fact, such as those arising from equitable adjustments due to funding delays.</data>
  <data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795810</data>
</node>
<node id="Default">
  <data key="d0">Default</data>
  <data key="d1">clause</data>
  <data key="d2">Default is a referenced clause whose rights are not limited by the termination provisions in the Limitation of Government's Obligation clause.</data>
  <data key="d3">chunk-516b1e6efecfd543f141d1e1135ec455</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795810</data>
