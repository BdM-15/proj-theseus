<node id="Electrical">
  <data key="d0">Electrical</data>
  <data key="d1">requirement</data>
  <data key="d2">Electrical (1602000) covers transmission and distribution operations, maintenance, and repairs, similar to RFP requirements, required for relevant project demonstration.&lt;SEP&gt;Electrical under code 1602000 covers transmission and distribution operations, maintenance, and repairs similar to the RFP.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795803</data>
