  <data key="d1">clause</data>
  <data key="d2">52.204-30 is a clause titled Federal Acquisition Supply Chain Security Act Orders-Prohibition, providing definitions and prohibitions referenced in 52.204-29.</data>
  <data key="d3">chunk-4bcb91b404a9ca74c18944c1ba7f80a2</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795806</data>
</node>
