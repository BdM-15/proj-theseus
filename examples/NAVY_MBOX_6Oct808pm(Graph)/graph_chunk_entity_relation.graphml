  <data key="d0">Performance Work Statement (PWS)</data>
  <data key="d1">document</data>
  <data key="d2">Performance Work Statement (PWS) sets forth performance objectives and standards, requiring maintenance of Maximo data and adherence to systems approach.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Basis of Estimate (BOE)">
  <data key="d0">Basis of Estimate (BOE)</data>
  <data key="d1">concept</data>
  <data key="d2">Basis of Estimate (BOE) provides a reasonable foundation for staffing levels, labor quantities, and skills needed for each annex, sub-annex, and spec item under Factor 3.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="OEM Specifications">
  <data key="d0">OEM Specifications</data>
  <data key="d1">requirement</data>
  <data key="d2">OEM Specifications are the original equipment manufacturer guidelines ensuring systems are maintained fully functional in accordance with design parameters.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Small Disadvantaged Business (SDB)">
  <data key="d0">Small Disadvantaged Business (SDB)</data>
  <data key="d1">concept</data>
  <data key="d2">Small Disadvantaged Business (SDB) is a category of small business concerns eligible for maximum practicable participation opportunities in government acquisitions.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Woman-Owned Small Business (WOSB)">
  <data key="d0">Woman-Owned Small Business (WOSB)</data>
  <data key="d1">concept</data>
  <data key="d2">Woman-Owned Small Business (WOSB) is a category of small business concerns eligible for maximum practicable participation opportunities in government acquisitions.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Veteran-Owned Small Business (VOSB)">
  <data key="d0">Veteran-Owned Small Business (VOSB)</data>
  <data key="d1">concept</data>
  <data key="d2">Veteran-Owned Small Business (VOSB) is a category of small business concerns owned by veterans eligible for maximum practicable participation opportunities in government acquisitions.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Service-Disabled Veteran-Owned Small Business (SDVOSB)">
  <data key="d0">Service-Disabled Veteran-Owned Small Business (SDVOSB)</data>
  <data key="d1">concept</data>
  <data key="d2">Service-Disabled Veteran-Owned Small Business (SDVOSB) is a category of small business concerns owned by service-disabled veterans eligible for maximum practicable participation opportunities in government acquisitions.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Contractor Incident Reporting System (CIRS)">
  <data key="d0">Contractor Incident Reporting System (CIRS)</data>
  <data key="d1">technology</data>
  <data key="d2">Contractor Incident Reporting System (CIRS) is a NAVFAC system containing safety incident data that the Government may review.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Contractor Performance Assessment Reporting System (CPARS)">
  <data key="d0">Contractor Performance Assessment Reporting System (CPARS)</data>
  <data key="d1">technology</data>
