  <data key="d5">1759795803</data>
</node>
<node id="Base Operations Support">
  <data key="d0">Base Operations Support</data>
  <data key="d1">concept</data>
  <data key="d2">Base Operations Support encompasses services including port operations, facility management, facility investment, custodial, pest control, integrated solid waste management, grounds maintenance, utilities management, electrical, wastewater, steam, water, transportation, and environmental at specified locations.&lt;SEP&gt;Base Operations Support services encompass at least three specific annexes and one other technical annex to qualify as relevant projects.&lt;SEP&gt;Base Operations Support projects are evaluated for relevance if they encompass at least three specified annexes and one other technical area.</data>
  <data key="d3">chunk-9775b66c35e6cfe40c05dbf72803d6cd&lt;SEP&gt;chunk-ac133babc8ecde7c6f7014a40f53ce13&lt;SEP&gt;chunk-f8cbd3bc2ef4445a2ce77064100a7a3e</data>
