  <data key="d0">Naval Station Mayport</data>
  <data key="d1">location</data>
  <data key="d2">Naval Station Mayport is located in Jacksonville, Florida and requires base operations support services.&lt;SEP&gt;Naval station in Jacksonville, Florida, designated for base operations support services.</data>
