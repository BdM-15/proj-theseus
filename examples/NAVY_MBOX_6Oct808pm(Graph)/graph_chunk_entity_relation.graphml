  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-4bcb91b404a9ca74c18944c1ba7f80a2</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795806</data>
</node>
<node id="Hand Sanitizer">
  <data key="d0">Hand Sanitizer</data>
  <data key="d1">deliverable</data>
  <data key="d2">Hand sanitizer is a supply required to be obtained from nonprofit agencies for use by the Government.&lt;SEP&gt;Hand sanitizer is a mandatory supply required by law to be obtained from nonprofit agencies for Government use under the contract.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e&lt;SEP&gt;chunk-4bcb91b404a9ca74c18944c1ba7f80a2</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795806</data>
</node>
