  <data key="d0">Annex 1700000</data>
  <data key="d1">annex</data>
  <data key="d2">Annex 1700000 covers transportation requirements, including maintenance, repair, and limits of liability in Sections C and J.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
