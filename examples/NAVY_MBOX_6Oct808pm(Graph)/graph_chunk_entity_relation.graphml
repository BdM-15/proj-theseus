  <data key="d0">Factor 4 Small Business Utilization and Participation</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 4 assesses historical small business utilization and proposed participation commitment, requiring minimum 20% small business participation.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Small Business Participation">
  <data key="d0">Small Business Participation</data>
  <data key="d1">requirement</data>
  <data key="d2">Small Business Participation requires maximum practicable opportunities for small businesses including SDB, WOSB, HUBZone SB, VOSB, SDVOSB, with a minimum of 20% of total contract value.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Attachment JM-3">
  <data key="d0">Attachment JM-3</data>
  <data key="d1">document</data>
  <data key="d2">Attachment JM-3 is the Small Business Participation Commitment Document used to submit information on subcontractors and proposed small business participation.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
