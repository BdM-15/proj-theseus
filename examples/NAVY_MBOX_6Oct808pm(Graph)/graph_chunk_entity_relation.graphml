  <data key="d0">Factor 5 Safety</data>
  <data key="d1">evaluation_factor</data>
  <data key="d2">Factor 5 evaluates safety through DART Rate, TCR Rate, and technical approach to safety management.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
<node id="Safety Management System (SMS)">
  <data key="d0">Safety Management System (SMS)</data>
  <data key="d1">concept</data>
  <data key="d2">Safety Management System (SMS) includes management/leadership involvement, employee involvement, hazard prevention, hazard control, worksite analysis, and safety training, benchmarked against standards.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795812</data>
</node>
