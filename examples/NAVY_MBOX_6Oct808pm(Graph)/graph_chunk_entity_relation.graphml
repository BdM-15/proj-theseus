  <data key="d0">Base Operations Support Services</data>
  <data key="d1">requirement</data>
  <data key="d2">Services encompassing recurring and non-recurring operations support in accordance with the performance work statement and applicable attachments.</data>
  <data key="d3">chunk-3e097b0647fa14f34c4ff76380ed4beb</data>
