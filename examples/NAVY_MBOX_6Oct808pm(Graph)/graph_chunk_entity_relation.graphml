  <data key="d0">Electronic Submission Of Payment Requests And Receiving Reports</data>
  <data key="d1">clause</data>
  <data key="d2">Electronic Submission Of Payment Requests And Receiving Reports is DFARS clause 252.232-7003 effective Dec 2018, incorporated by reference for electronic processing in the contract.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795800</data>
</node>
<node id="Governmentwide Commercial Purchase Card Gcpc">
  <data key="d0">Governmentwide Commercial Purchase Card Gcpc</data>
  <data key="d1">other</data>
  <data key="d2">Governmentwide Commercial Purchase Card Gcpc is the payment method used by authorized government personnel to order indefinite quantity pre-priced line item services directly through FedMall without additional markup.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795800</data>
</node>
<node id="Indefinite Quantity Iq Services">
  <data key="d0">Indefinite Quantity Iq Services</data>
  <data key="d1">deliverable</data>
  <data key="d2">Indefinite Quantity Iq Services are pre-priced line items offered through FedMall for government ordering, to be provided at the contract price without handling fees.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795800</data>
</node>
<node id="Pgp Personal Software">
  <data key="d0">Pgp Personal Software</data>
  <data key="d1">technology</data>
  <data key="d2">Pgp Personal Software or comparable solution is required for the contractor to decrypt 128-bit encrypted email notifications of orders from FedMall.</data>
  <data key="d3">chunk-5874f638e9cb9ecd09e53d314b07e103</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795800</data>
</node>
