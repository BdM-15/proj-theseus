  <data key="d1">submission_instruction</data>
  <data key="d2">The Non-Price Proposal requires submission of non-price factors in a binder with three copies, electronic files, and adherence to page limits and formatting.</data>
  <data key="d3">chunk-6266f048b10bdb8222f03b8f5e597d7e</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759795811</data>
</node>
