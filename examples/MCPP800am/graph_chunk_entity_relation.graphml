  <ns0:data key="d11">1759841229</ns0:data>
</ns0:edge>
<ns0:edge source="Minimum Insurance Requirements" target="General Liability Insurance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Minimum Insurance Requirements specify General Liability Insurance with a $500,000 per occurrence limit for the MCMC.</ns0:data>
  <ns0:data key="d8">insurance type,minimum limits</ns0:data>
