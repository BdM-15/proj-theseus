  <ns0:data key="d11">1759841459</ns0:data>
</ns0:edge>
<ns0:edge source="3rd Network Battalion" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC reports software failures affecting distribution or server architecture to the 3rd Network Battalion within 30 minutes of identification.</ns0:data>
  <ns0:data key="d8">failure notification,reporting</ns0:data>
  <ns0:data key="d9">chunk-789ddbe0005097425aa3559f9388ad80</ns0:data>
