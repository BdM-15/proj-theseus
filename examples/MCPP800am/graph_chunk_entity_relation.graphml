  <ns0:data key="d11">1759841487</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Pest Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Pest Management requirements under the MCSF-BI Integrated Pest Management Plan.</ns0:data>
  <ns0:data key="d8">application,compliance</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841488</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Petroleum, Oil, Lubricant (POL) Storage and Fueling">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages POL storage and fueling in accordance with 40 CFR 112 to prevent environmental spills.</ns0:data>
  <ns0:data key="d8">spill prevention,storage</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
