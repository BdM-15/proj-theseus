  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Personnel Roster lists personnel and is required within 30 calendar days for X002 under section 6.A.1.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
