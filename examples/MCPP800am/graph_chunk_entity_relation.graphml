</ns0:edge>
<ns0:edge source="MCMC" target="TM 11240-15/3">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses TM 11240-15/3 for equipment operation and safety guidelines.</ns0:data>
  <ns0:data key="d8">compliance,operations</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
