  <ns0:data key="d11">1759841512</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 11262.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to MCO 11262.2 for NDT on Tactical Ground Load Lifting Equipment components and benefits from waivers on annual load testing during afloat phases.</ns0:data>
  <ns0:data key="d8">NDT compliance,exemptions</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CmdO 4450.1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs COSIS on ME and CESE assets in open storage in accordance with CmdO 4450.1 COSIS Order, including 90-day intervals for MCPP-PHIL PO assets.</ns0:data>
  <ns0:data key="d8">COSIS,inspection procedures</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
