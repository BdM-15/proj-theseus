<ns0:edge source="STRATIS" target="MMV200">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">STRATIS is utilized for warehouse operations of stocks in the MMV200 General Account.</ns0:data>
  <ns0:data key="d8">account management,warehouse system</ns0:data>
