  <ns0:data key="d0">Termination Clause</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Termination Clause is a contract clause referenced for excess costs of repurchase upon termination.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841116</ns0:data>
</ns0:node>
<ns0:node id="Far 15.408(k)">
  <ns0:data key="d0">Far 15.408(k)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Far 15.408(k) defines the applicability of the ownership change notification requirement to subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
