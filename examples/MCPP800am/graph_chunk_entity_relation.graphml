<ns0:edge source="Government" target="Fuel Delivery Service">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Government approves standard operating procedures submitted by the Contractor for Fuel Delivery Service operations.</ns0:data>
  <ns0:data key="d8">oversight,procedure approval</ns0:data>
