  <ns0:data key="d11">1759841307</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MREs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures MREs possess 33 months or more remaining shelf life at MMC embarkation aboard MPS.</ns0:data>
  <ns0:data key="d8">management,shelf life</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841307</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="FEDLOG">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC uses FEDLOG to determine CEC/CRIT codes for repair parts and shelf life codes when PMCS tables do not provide them.&lt;SEP&gt;MCMC uses FEDLOG for accurate shelf life data in the Quarterly Shelf Life/Service Life Expiration Report and database.</ns0:data>
  <ns0:data key="d8">accuracy,code lookup,criticality,data source</ns0:data>
