  <ns0:data key="d11">1759841136</ns0:data>
</ns0:edge>
<ns0:edge source="Clause 52.246-20 Warranty of Services" target="Acceptance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Acceptance triggers the warranty that services are free from defects and conform to contract requirements under Clause 52.246-20.</ns0:data>
  <ns0:data key="d8">defect correction,performance warranty</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Clause 52.252-2 Clauses Incorporated by Reference" target="Federal Acquisition Regulation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Clause 52.252-2 incorporates clauses from the Federal Acquisition Regulation by reference, with full text available upon request or electronically.</ns0:data>
  <ns0:data key="d8">accessibility,reference incorporation</ns0:data>
