  <ns0:data key="d11">1759841473</ns0:data>
</ns0:edge>
<ns0:edge source="Employee Compensation Plan" target="Area Wage Determination (AWD)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Employee Compensation Plan is compared against the Area Wage Determination (AWD) to ensure compliance with minimum wage and benefit requirements.</ns0:data>
  <ns0:data key="d8">benefit determination,rate verification</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="Employee Compensation Plan" target="Collective Bargaining Agreement (CBA)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Variances in the Employee Compensation Plan from the Collective Bargaining Agreement (CBA) may be considered unreasonable if not aligned with established law.</ns0:data>
  <ns0:data key="d8">compensation adjustment,union terms</ns0:data>
