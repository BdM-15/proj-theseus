</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contracting Officer'S Representative">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer appoints the Contracting Officer'S Representative to assist in inspecting and accepting performance.</ns0:data>
  <ns0:data key="d8">appointment,oversight role</ns0:data>
