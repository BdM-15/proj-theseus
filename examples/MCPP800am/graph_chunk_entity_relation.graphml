<ns0:node id="Termination for the Convenience of the Government">
  <ns0:data key="d0">Termination for the Convenience of the Government</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Termination for the Convenience of the Government is a standard clause referenced for handling incremental funding limits and contract termination procedures.</ns0:data>
  <ns0:data key="d3">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841053</ns0:data>
</ns0:node>
<ns0:node id="Disputes">
  <ns0:data key="d0">Disputes</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Disputes is a contract clause governing resolution of factual disputes related to equitable adjustments in incrementally funded contracts.</ns0:data>
  <ns0:data key="d3">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841053</ns0:data>
</ns0:node>
<ns0:node id="Default">
  <ns0:data key="d0">Default</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Default is a contract clause whose rights are not limited by the incremental funding termination provisions.</ns0:data>
  <ns0:data key="d3">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841053</ns0:data>
</ns0:node>
