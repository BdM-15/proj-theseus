  <ns0:data key="d11">1759841275</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 4140.5A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 4140.5A requires the MCMC to ensure security in storage operations.</ns0:data>
  <ns0:data key="d8">property storage,security requirement</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
