<ns0:edge source="52.216-7 Allowable Cost And Payment" target="Cas Disclosure Statement">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.216-7 Allowable Cost And Payment excludes contractors required to submit a Cas Disclosure Statement from certain accounting system description requirements in proposals.</ns0:data>
