  <ns0:data key="d11">1759841172</ns0:data>
</ns0:edge>
<ns0:edge source="Approved Purchasing System" target="Federal Acquisition Regulation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">An approved purchasing system is reviewed and approved in accordance with Part 44 of the Federal Acquisition Regulation.</ns0:data>
  <ns0:data key="d8">approval criteria,system review</ns0:data>
