</ns0:edge>
<ns0:edge source="MCMC" target="Navy Watercraft Oil Analysis Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Navy Watercraft Oil Analysis Report (CDRL 6044) within 5 business days of lab receipt.</ns0:data>
  <ns0:data key="d8">delivery,provision</ns0:data>
