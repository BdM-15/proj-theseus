  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer designates Contracting Officer Technical Representative in writing for assistance in specific technical areas of contract administration.</ns0:data>
  <ns0:data key="d8">designation,technical support</ns0:data>
