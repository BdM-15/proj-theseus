  <ns0:data key="d11">1759841354</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="OCONUS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages travel and per diem for OCONUS personnel under CPFF CLINs with Government approval.</ns0:data>
  <ns0:data key="d8">personnel support,travel restriction</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
