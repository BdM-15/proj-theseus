  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.237-1 governs the Site Visit by urging inspection and limiting claims for non-inspection.</ns0:data>
  <ns0:data key="d8">claim limitation,inspection requirement</ns0:data>
