  <ns0:data key="d11">1759841174</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Italy">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor complies with 252.229-7012 tax exemptions when performance is in Italy.</ns0:data>
  <ns0:data key="d8">performance,tax exemptions</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
