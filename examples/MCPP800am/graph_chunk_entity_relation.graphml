  <ns0:data key="d11">1759841191</ns0:data>
</ns0:edge>
<ns0:edge source="MCO 5530.14" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC notifies the government of missing, lost, stolen, or damaged assets in accordance with MCO 5530.14.&lt;SEP&gt;MCO 5530.14 directs the MCMC on markings and location verifications for materiel.</ns0:data>
  <ns0:data key="d8">asset reporting,identification,marking instruction,notification</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="MCO 5530.14" target="Armory Custodian Nomination Letters">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 5530.14 standards are followed in preparing Armory Custodian Nomination Letters.</ns0:data>
  <ns0:data key="d8">adherence,nomination standards</ns0:data>
  <ns0:data key="d9">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841367</ns0:data>
</ns0:edge>
<ns0:edge source="MOV" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts quarterly Materiel Obligation Validations as part of requisition management to align with demands and minimize delays.</ns0:data>
  <ns0:data key="d8">quarterly,validation</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="SECNAVINST 4855.3" target="Receipt Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Receipt management and processing by MCMC complies with SECNAVINST 4855.3 for physical and virtual receiving.</ns0:data>
  <ns0:data key="d8">compliance,processing</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841170</ns0:data>
</ns0:edge>
<ns0:edge source="ULO" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC reconciles Unliquidated Obligations during receipt validations against supply and maintenance records.</ns0:data>
  <ns0:data key="d8">reconciliation,validation</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="POD" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts Proof of Delivery file validations as part of receipt management to confirm deliveries.</ns0:data>
  <ns0:data key="d8">confirmation,validation</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Navy COR" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC submits DD Form 200 to the Navy COR for completion of specific blocks in the FLIPL process.&lt;SEP&gt;MCMC coordinates warranties and provides various reports to Navy COR for approval and oversight of maintenance and logistics.</ns0:data>
  <ns0:data key="d8">coordination,form completion,reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="252.223-7999" target="Executive Order 14042">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">252.223-7999 implements Executive Order 14042 by requiring compliance with COVID-19 safety guidance.</ns0:data>
  <ns0:data key="d8">implementation,safety protocols</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841172</ns0:data>
</ns0:edge>
<ns0:edge source="252.232-7007" target="Termination for the Convenience of the Government">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">252.232-7007 references Termination for the Convenience of the Government for handling excess costs beyond allotted funds in incremental funding.</ns0:data>
  <ns0:data key="d8">funding limit,termination</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841174</ns0:data>
</ns0:edge>
<ns0:edge source="252.232-7007" target="Disputes">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Failure to agree on equitable adjustments under 252.232-7007 is treated as a dispute under the Disputes clause.</ns0:data>
  <ns0:data key="d8">equitable adjustment,resolution</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841175</ns0:data>
</ns0:edge>
<ns0:edge source="252.232-7007" target="Default">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The termination provisions of 252.232-7007 do not limit the government's rights under the Default clause.</ns0:data>
  <ns0:data key="d8">rights limitation,termination</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841175</ns0:data>
</ns0:edge>
<ns0:edge source="252.237-7023" target="Mission-Essential Contractor Services Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">252.237-7023 governs the content of the Mission-Essential Contractor Services Plan.</ns0:data>
  <ns0:data key="d8">governance,plan requirement</ns0:data>
  <ns0:data key="d9">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841497</ns0:data>
</ns0:edge>
<ns0:edge source="Essential Contractor Service" target="Mission-Essential Functions">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Essential Contractor Services support Mission-Essential Functions to maintain DoD operations during interruptions.</ns0:data>
  <ns0:data key="d8">continuity,support</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841173</ns0:data>
</ns0:edge>
<ns0:edge source="Essential Contractor Service" target="Security Assistance Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Essential Contractor Services include those provided to foreign military sales customers under the Security Assistance Program.</ns0:data>
  <ns0:data key="d8">essential functions,support</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841175</ns0:data>
</ns0:edge>
<ns0:edge source="Mission-Essential Functions" target="Notice of Continuation of Essential Contractor Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The notice requires addressing mission-essential functions in the continuity plan, using definitions from 252.237-7023.</ns0:data>
  <ns0:data key="d8">definitions,planning</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841227</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN" target="Task Order">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLINs are included in Task Orders with descriptions, quantities, unit prices, and totals.</ns0:data>
  <ns0:data key="d8">line item integration,pricing detail</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841333</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN" target="SLIN">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">SLINs are associated with CLINs for specific pricing and descriptions in task orders.</ns0:data>
  <ns0:data key="d8">contract detail,subitem association</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841333</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN" target="Cost Breakout and Supporting Data">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Cost Breakout and Supporting Data correlates totals for each CLIN and SLIN to the proposal summary.</ns0:data>
  <ns0:data key="d8">cost correlation,pricing structure</ns0:data>
  <ns0:data key="d9">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841473</ns0:data>
</ns0:edge>
<ns0:edge source="Destructive Weather Plan" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC creates, maintains, executes, and annually reviews the Destructive Weather Plan for protecting Navy Watercraft from major weather events.&lt;SEP&gt;MCMC develops and maintains the Destructive Weather Plan addressing NAVFAC P-307 requirements for Navy cranes.</ns0:data>
  <ns0:data key="d8">creation,execution,planning,weather preparedness</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="WHE Program" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs internal self-assessments of the WHE Program and supports government assessments.</ns0:data>
  <ns0:data key="d8">assessment,program management</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="CDRL 6073" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the WHP Monitoring Observation Report as CDRL 6073 monthly, focusing on weight handling deficiencies.</ns0:data>
  <ns0:data key="d8">monitoring,observation reporting</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="NAVSEA Standard Items" target="CDRL 6075">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NAVSEA Standard Items guide the descriptive scopes of work in CDRL 6075 for Navy Watercraft repairs.</ns0:data>
  <ns0:data key="d8">guidance,scope of work</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841178</ns0:data>
</ns0:edge>
<ns0:edge source="NAVSEA Standard Items" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides surveys, statements of work, and estimates in accordance with NAVSEA Standard Items for Navy watercraft and ABLTS.</ns0:data>
  <ns0:data key="d8">compliance,maintenance standards</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Watercraft" target="MCMC">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">MCMC performs organizational level corrosion control, coating maintenance, high pressure washing, and monitoring on Navy Watercraft to prevent degradation and ensure readiness.&lt;SEP&gt;MCMC performs surveys and provides repair scopes and estimates for Navy Watercraft during MPF Maintenance Cycle.&lt;SEP&gt;MCMC replaces POL, performs load testing, maintenance, and fueling for Navy Watercraft per production schedule.</ns0:data>
  <ns0:data key="d8">corrosion control,maintenance,maintenance support,replacement,survey</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-48caa545ec007aaf46c9abe9ec8c0c78&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Watercraft" target="Section 6.F">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 6.F governs maintenance requirements for Navy Watercraft in Phases Bravo, Charlie, and Delta.</ns0:data>
  <ns0:data key="d8">governance,phasing</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841321</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Watercraft" target="OST">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">OST provides land and water movement, docking, and undocking services for Navy Watercraft per approved schedules.</ns0:data>
  <ns0:data key="d8">movement services,scheduling</ns0:data>
  <ns0:data key="d9">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841338</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Watercraft" target="Section 6.F.34">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 6.F.34 specifies spot maintenance criteria, such as less than 25% hull panel area, for Navy Watercraft coating systems to prevent depot level repairs.</ns0:data>
  <ns0:data key="d8">maintenance criteria</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841376</ns0:data>
</ns0:edge>
<ns0:edge source="ABLTS" target="MCMC">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">MCMC prioritizes ABLTS for containerized asset production and includes it in attainment and shortage reports.&lt;SEP&gt;MCMC includes ABLTS in weekly/bi-weekly reports on craft status and mitigation efforts.&lt;SEP&gt;MCMC performs load testing, rigging maintenance, and provides load test certifications for ABLTS.</ns0:data>
  <ns0:data key="d8">certification,mitigation,prioritization,reporting,testing</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841283</ns0:data>
</ns0:edge>
<ns0:edge source="ABLTS" target="WMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">WMC performs organizational level maintenance on ABLTS as part of Navy watercraft program.</ns0:data>
  <ns0:data key="d8">maintenance performance,organizational level</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841293</ns0:data>
</ns0:edge>
<ns0:edge source="ABLTS" target="LARCs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">LARCs and ABLTS undergo similar organizational level coating maintenance, cleaning, and preparation procedures as outlined for Navy Watercraft.</ns0:data>
  <ns0:data key="d8">shared maintenance</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841376</ns0:data>
</ns0:edge>
<ns0:edge source="CDRL 6074" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC includes the Corrosion Survey Report as CDRL 6074 in the Detailed Report of Findings within 60 days of MPS offload.</ns0:data>
  <ns0:data key="d8">corrosion survey,reporting</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841198</ns0:data>
</ns0:edge>
<ns0:edge source="Repair Log" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains and updates the Repair Log for all Navy Corrective Maintenance, submitting it weekly to NAV-P.</ns0:data>
  <ns0:data key="d8">corrective maintenance,tracking</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841198</ns0:data>
</ns0:edge>
<ns0:edge source="SECTION C.7" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs shipboard and exercise support activities as delineated in SECTION C.7 for the Afloat Phase of the MPF Program.</ns0:data>
  <ns0:data key="d8">afloat phase,logistics support</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841198</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Battery Maintenance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Battery Maintenance ensures MPE/S batteries maintain proper SOC during long-term storage aboard MPS.</ns0:data>
  <ns0:data key="d8">preservation,storage conditions</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841179</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Stock Checks">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Stock Checks are conducted every 30 days on MPE/S for defects, security, and fuel levels during afloat phase.</ns0:data>
  <ns0:data key="d8">inspection,security monitoring</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841179</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="CESE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CESE is included in MPE/S surveillance during MPS Afloat Phase, excluding certain items like refrigeration units.</ns0:data>
  <ns0:data key="d8">afloat phase,surveillance inclusion</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841183</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Refrigerated Containers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MPE/S in refrigerated containers for Supply Classes I, II, IV, and VIII are monitored weekly by MCMC for temperature compliance, with reports to ship’s master and government.</ns0:data>
  <ns0:data key="d8">monitoring,temperature control</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841184</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="MCMC">
  <ns0:data key="d6">5.0</ns0:data>
  <ns0:data key="d7">MCMC performs visual inspections, stock checks, and corrective maintenance on MPE/S every 30 days and during exercises.&lt;SEP&gt;MCMC performs surveillance, PMCS, battery maintenance, and stock checks on MPE/S during MPS afloat phase.&lt;SEP&gt;MCMC provides CESE maintenance services in support of the MPE/S Continuum.&lt;SEP&gt;MCMC validates, checks fuel levels, and issues MPE/S to MAGTF during withdrawal, exercises, and regeneration operations.&lt;SEP&gt;MCMC repairs, validates fuel levels, and stages MPE/S to meet configuration requirements during offloads, exercises, and backloads.</ns0:data>
  <ns0:data key="d8">inspection,issuance,maintenance,preventive maintenance,support,surveillance,validation</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-48caa545ec007aaf46c9abe9ec8c0c78&lt;SEP&gt;chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff&lt;SEP&gt;chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841199</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Section 7.E">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 7.E requires MCMC to inspect MPE/S for safety, fuel, and defects every 30 days.</ns0:data>
  <ns0:data key="d8">preventive maintenance</ns0:data>
  <ns0:data key="d9">chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841233</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Section 4.C.4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.C.4 requires management of physical inventory for MPE/S with accurate APSR accountability.</ns0:data>
  <ns0:data key="d8">APSR accountability,inventory management</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841246</ns0:data>
</ns0:edge>
<ns0:edge source="MPE/S" target="Navy Exercise and Surge Support">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy Exercise and Surge Support involves deployment and maintenance of MPE/S for USMC/USN forces.</ns0:data>
  <ns0:data key="d8">preparation,utilization</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841489</ns0:data>
</ns0:edge>
<ns0:edge source="PMCS" target="MCMC">
  <ns0:data key="d6">5.0</ns0:data>
  <ns0:data key="d7">MCMC conducts PMCS on equipment exposed to harsh environments and on Government Furnished Equipment per technical manuals.&lt;SEP&gt;MCMC conducts PMCS on ME, CESE, and GFE assets in accordance with TMs, rosters, and specific intervals for indoor and outdoor storage.&lt;SEP&gt;MCMC executes PMCS on Navy CESE according to equipment TMs, CmdO 4790.1, and approved schedules, including filter replacements and battery maintenance.&lt;SEP&gt;MCMC performs PMCS on Navy GSE and GFE according to OEM manuals and standards.&lt;SEP&gt;MCMC performs PMCS on Navy CESE, including operational tests and battery maintenance.</ns0:data>
  <ns0:data key="d8">checks,compliance,equipment care,execution,maintenance,maintenance procedures,performance,preventive checks,services</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841288</ns0:data>
</ns0:edge>
<ns0:edge source="PMCS" target="CESE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">PMCS on CESE includes replacing fuel filters, testing oil, servicing air filters, and engine coolant systems per technical procedures.</ns0:data>
  <ns0:data key="d8">filter replacement,service application</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841292</ns0:data>
</ns0:edge>
<ns0:edge source="PMCS" target="MTVR FOV">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">PMCS on MTVR FOV includes replacing dryer air filter and aftercooler filter every production cycle.</ns0:data>
  <ns0:data key="d8">component service,filter replacement</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841293</ns0:data>
</ns0:edge>
<ns0:edge source="Battery Maintenance" target="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Battery Maintenance tests and services batteries for square loaded MPE/S in conjunction with PMCS.</ns0:data>
  <ns0:data key="d8">battery servicing</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841411</ns0:data>
</ns0:edge>
<ns0:edge source="Battery Maintenance" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC tests, services, charges, and maintains batteries for ME and CESE, including specific installations and storage.</ns0:data>
  <ns0:data key="d8">servicing,testing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841480</ns0:data>
</ns0:edge>
<ns0:edge source="Battery Maintenance" target="MEP-831A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MEP-831A generators require installation of a specific 24-volt military standard battery.</ns0:data>
  <ns0:data key="d8">installation,specification</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="Battery Maintenance" target="THHR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">THHR hold-up batteries are charged, tested, and stored securely as part of battery maintenance.</ns0:data>
  <ns0:data key="d8">charging,storage</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="300 Ton Crawler Crane" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides at least two licensed operators qualified for 300 Ton Crawler Crane to support Navy operations IAW NAVFAC P-307.</ns0:data>
