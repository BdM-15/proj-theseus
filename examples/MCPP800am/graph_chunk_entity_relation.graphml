<ns0:edge source="NTVE/MHE" target="Dispatching Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Dispatching Services ensure NTVE/MHE are dispatched within 15 minutes plus or minus of scheduled time using Fleet Focus.</ns0:data>
