<ns0:edge source="MCMC" target="EMS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC participates in the EMS programs, supports audits, and takes corrective actions for nonconformances.</ns0:data>
  <ns0:data key="d8">environmental management,participation</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCSF-BI Integrated Contingency Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows the MCSF-BI Integrated Contingency Plan for spill notifications, responses, and cleanups.</ns0:data>
  <ns0:data key="d8">compliance,spill response</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CETEP">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses the CETEP database to report employee environmental training attendance via CDRL 10050.</ns0:data>
  <ns0:data key="d8">reporting,training tracking</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="40 CFR 265">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides position descriptions including training requirements defined in 40 CFR 265 for employees handling hazardous wastes.</ns0:data>
  <ns0:data key="d8">hazardous waste,training requirement</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841517</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MITSC East">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides touch labor and support to MITSC East for installing, configuring, and maintaining network devices and services.</ns0:data>
  <ns0:data key="d8">network operations,support</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841517</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Help Desk">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC operates the Help Desk for resolving video and data service issues and records activities using Remedy IT Service Management Suite.&lt;SEP&gt;MCMC operates the Help Desk to handle and record voice, video, and data service delivery issues during normal business hours.</ns0:data>
  <ns0:data key="d8">operation,problem resolution,service delivery</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841518</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DODI 8570">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC IT support positions at MCPP-PHIL meet minimum qualifications under DODI 8570 for privileged network access.</ns0:data>
  <ns0:data key="d8">certification,information assurance</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841518</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Manatee Watch">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts Manatee Watch as required by the INRMP and provides after-action logs via CDRL 10052.</ns0:data>
  <ns0:data key="d8">compliance,monitoring</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841519</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="IAWF">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC assigns IT support responsibilities as primary duties within the IAWF, meeting level II certification requirements.</ns0:data>
  <ns0:data key="d8">certification,workforce qualification</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841519</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="ISO 14001">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC participates in the installation's ISO 14001 site certification as part of the EMS programs.</ns0:data>
  <ns0:data key="d8">certification participation,environmental compliance</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841519</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Regulated Garbage">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC inspects and stores Regulated Garbage in labeled red containers, separate from other trash, and provides pickup records.</ns0:data>
  <ns0:data key="d8">inspection,storage</ns0:data>
  <ns0:data key="d9">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841520</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Organizational Chart">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides the Organizational Chart to differentiate support for MCPP II and Navy Operations.&lt;SEP&gt;MCMC includes Organizational Chart in the semi-annual PPSP for government review.</ns0:data>
  <ns0:data key="d8">deliverable,deliverable provision,personnel management,planning</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
