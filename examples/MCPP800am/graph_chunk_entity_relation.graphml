  <ns0:data key="d3">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d2">Squadron Plan provides a rollup of planned quantities for each TAMCN.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841228</ns0:data>
</ns0:node>
