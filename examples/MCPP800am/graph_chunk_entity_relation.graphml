<ns0:edge source="Government" target="Support Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Government requires the Contractor to provide Support Services including dispatching and GSA vehicle management during regular working hours.</ns0:data>
  <ns0:data key="d8">oversight,service provision</ns0:data>
  <ns0:data key="d9">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
