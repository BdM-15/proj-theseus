  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Prepositioning Objective establishes allowances for the MMV420 MCPP-N account, without a spread in MCPIC.</ns0:data>
  <ns0:data key="d8">account basis,allowance establishment</ns0:data>
