  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Consolidated Asset Listing compiles asset information and is required at E+5 for each ship for X002 and X003 under section 4.C.4.a.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
