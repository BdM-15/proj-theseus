<ns0:edge source="Segregation of Costs by ACRN/Funding Sources" target="ACRN">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Segregation of Costs by ACRN/Funding Sources explains processes for allocating costs by ACRN for different funding sources.</ns0:data>
