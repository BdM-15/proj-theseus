<ns0:edge source="TAMCN" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC handles military equipment identified by specific TAMCNs such as B0060, B0079, D1001, and B0038 for maintenance and modifications.</ns0:data>
  <ns0:data key="d8">equipment identification,nomenclature</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841512</ns0:data>
</ns0:edge>
<ns0:edge source="Squadron Level Plans" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to government-provided Squadron and Detailed Ship Level Plans in accordance with MMC Execution Milestones, with approved changes posted in MCPIC.</ns0:data>
  <ns0:data key="d8">compliance,execution</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841243</ns0:data>
</ns0:edge>
<ns0:edge source="Capability Set Letter" target="Sustainment Blocks">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Capability Set Letter directs the packaging and stowing of capabilities including Sustainment Blocks aboard MPS.</ns0:data>
  <ns0:data key="d8">capability achievement,packaging guidance</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="Capability Set Letter" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC assembles each Capability Set as directed by the government-provided Capability Set Letter per Command Order 4035.1, maintaining integrity through packaging and co-location, with deviations requiring government approval.</ns0:data>
  <ns0:data key="d8">assembly direction,integrity maintenance</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841244</ns0:data>
</ns0:edge>
<ns0:edge source="Sustainment Blocks" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC inventories, inspects, rotates stock, and adjusts records for sustainment blocks during MMC production in accordance with Detailed Ship Plans.&lt;SEP&gt;MCMC assembles and packages sustainment consumable materials into Sustainment Blocks, including Class I Rations, Class III Packaged POLs, Class IV materials, and Class IX items, as directed by government-provided plans, with deviations requiring approval.</ns0:data>
  <ns0:data key="d8">assembly,prepositioning,production preparation</ns0:data>
  <ns0:data key="d9">chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841245</ns0:data>
</ns0:edge>
<ns0:edge source="Sustainment Blocks" target="Section 4.C.3.c">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.C.3.c outlines loading of shipboard sustainment blocks to specific GCSS-MC sub-inventories.</ns0:data>
  <ns0:data key="d8">loading procedure,sub-inventory assignment</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841246</ns0:data>
</ns0:edge>
<ns0:edge source="Sustainment Blocks" target="MRE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Sustainment blocks include MREs that are rotated and inspected to ensure adequate shelf life for afloat phases.</ns0:data>
  <ns0:data key="d8">inventory management,shelf life</ns0:data>
  <ns0:data key="d9">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841311</ns0:data>
</ns0:edge>
<ns0:edge source="Container Estimate Worksheet" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to the government-provided Container Estimate Worksheet for loading containerized equipment and notifies the Government Plans Branch of any deviations.</ns0:data>
  <ns0:data key="d8">adherence,deviation notification</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841243</ns0:data>
</ns0:edge>
<ns0:edge source="Naval Support Element Container Plan" target="USN">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">USN provides Naval Support Element plans including container quantities and equipment sets.</ns0:data>
  <ns0:data key="d8">planning,support provision</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
