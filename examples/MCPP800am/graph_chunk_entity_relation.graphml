  <ns0:data key="d11">1759841274</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="E+5">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits signed listings within the E+5 timeline after each production cycle.</ns0:data>
  <ns0:data key="d8">submission deadline,timeline adherence</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841274</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 10330.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 10330.2 guides the MCMC in layout, spacing, and materiel handling for warehousing.</ns0:data>
  <ns0:data key="d8">materiel handling,procedural guidance</ns0:data>
