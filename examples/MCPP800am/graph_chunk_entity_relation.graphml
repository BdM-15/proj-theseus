  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841423</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="Squadron Level Plans">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Squadron Level Plans are posted onto MCPIC for review and situational awareness by MCMC.</ns0:data>
  <ns0:data key="d8">data storage,review</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="IMARK">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPIC integrates with IMARK for registering IUID and pRFID tags and managing label replacements on equipment per directives like MCTP 13-10D/NTTP 3.02.3M and NAVMC DIR 3000.18.</ns0:data>
  <ns0:data key="d8">compliance,labeling</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841231</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="CAL">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPIC provides data for generating initial CALs for prepositioned equipment.</ns0:data>
  <ns0:data key="d8">asset validation,data source</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841263</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="MCMC">
  <ns0:data key="d6">4.0</ns0:data>
  <ns0:data key="d7">MCMC posts reports, plans, and schedules to MCPIC through MMC production for Marine Corps prepositioning programs.&lt;SEP&gt;MCMC uses MCPIC to review, manage, and populate data for plans, embarkation, and transportation requirements.&lt;SEP&gt;MCMC updates MCPIC data, including UDL, and provides container production projects for approval.&lt;SEP&gt;MCMC uses MCPIC to log storage locations of portable fire extinguishers separated from parent equipment.</ns0:data>
  <ns0:data key="d8">data capture,data management,data posting,planning support,project submission,storage logging,system utilization</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841287</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="SL-3 Deficiency Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The SL-3 Deficiency Report includes data elements aligned with MCPIC for Government review.</ns0:data>
  <ns0:data key="d8">data integration,reporting</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841329</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="GCSS-MC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">GCSS-MC and MCPIC are compared to identify disparities in MPE/S assets, including unavoidable cases.&lt;SEP&gt;MCPIC and GCSS-MC are reconciled through the Discrepancy Report to identify disparities in MPE/S records.</ns0:data>
  <ns0:data key="d8">data reconciliation,discrepancy identification,system integration</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841330</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="PPS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">PPS is the application within MCPIC for managing Detailed Ship Plans and package IDs.</ns0:data>
  <ns0:data key="d8">planning integration,ship management</ns0:data>
  <ns0:data key="d9">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841365</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="NEIMS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPP-N data is transferred monthly from NEIMS to MCPIC.</ns0:data>
  <ns0:data key="d8">data transfer,information exchange</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841388</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="ICODES">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPIC data populated by MCMC supports ICODES for creating Dangerous Cargo Manifests and load plans.</ns0:data>
  <ns0:data key="d8">data integration,manifest generation</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841459</ns0:data>
</ns0:edge>
<ns0:edge source="MCPIC" target="MMV222">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPIC identifies spreads based on Prepositioning Objective as the basis for equipment requirements in the MMV222 Future Ashore account.</ns0:data>
  <ns0:data key="d8">planning source,requirement spreads</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="Navy WHE Program" target="NAVFAC P-307">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy WHE Program follows NAVFAC P-307 for personnel designation, training, maintenance, inspections, certifications, operations, critical lifts, accidents, and near misses.</ns0:data>
  <ns0:data key="d8">personnel designation,program requirements</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841138</ns0:data>
</ns0:edge>
<ns0:edge source="Navy WHE Program" target="NAVFAC P-300">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy WHE Program uses NAVFAC P-300 for inspections, testing, and certifications.</ns0:data>
  <ns0:data key="d8">certification standards,inspection support</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841138</ns0:data>
</ns0:edge>
<ns0:edge source="Navy WHE Program" target="CMR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy WHE Program manages CMR via DPAS for pre-positioning assets (PO).</ns0:data>
  <ns0:data key="d8">asset management,prepositioning</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841139</ns0:data>
</ns0:edge>
<ns0:edge source="Navy WHE Program" target="PO">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy WHE Program manages pre-positioning assets (PO) via CMR and DPAS.</ns0:data>
  <ns0:data key="d8">asset management,prepositioning focus</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841144</ns0:data>
</ns0:edge>
<ns0:edge source="Navy WHE Program" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and maintains the Navy WHE Program for WHE and rigging gear per NAVFAC P-307, NAVFAC P-300, and CMR via DPAS.</ns0:data>
  <ns0:data key="d8">equipment management,program establishment</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841156</ns0:data>
</ns0:edge>
<ns0:edge source="NAVFAC P-307" target="Critical Lift Plans">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NAVFAC P-307 section 10 defines critical lifts, requiring plans from MCMC prior to execution.</ns0:data>
  <ns0:data key="d8">definition,planning requirements</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841178</ns0:data>
</ns0:edge>
<ns0:edge source="NAVFAC P-307" target="MCMC">
  <ns0:data key="d6">4.0</ns0:data>
  <ns0:data key="d7">MCMC ensures compliance with NAVFAC P-307 for crane operations, rigging gear, critical lifts, and destructive weather plans.&lt;SEP&gt;MCMC procures load bearing parts per NAVFAC P-307 from OEM for GSE/GFE.&lt;SEP&gt;MCMC ensures WHE operators comply with NAVFAC P-307 standards.&lt;SEP&gt;MCMC complies with NAVFAC P-307 for conducting investigations and submitting reports on WHE accidents and near misses.</ns0:data>
  <ns0:data key="d8">compliance,investigation,operational standards,operator standards,procurement,safety</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e&lt;SEP&gt;chunk-48caa545ec007aaf46c9abe9ec8c0c78&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="NAVFAC P-307" target="Maintenance Records">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NAVFAC P-307 guides the creation of accurate maintenance history files for each Navy CESE PEI.</ns0:data>
  <ns0:data key="d8">filing,history file establishment</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841293</ns0:data>
</ns0:edge>
<ns0:edge source="NAVFAC P-307" target="10.A.3.d Maintenance, Facility-Mounted Weight Handling Equipment (WHE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 10.A.3.d requires WHE maintenance in accordance with NAVFAC P-307.</ns0:data>
  <ns0:data key="d8">equipment standards,maintenance procedures</ns0:data>
  <ns0:data key="d9">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841393</ns0:data>
</ns0:edge>
<ns0:edge source="NAVFAC P-300" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance and corrosion control per NAVFAC P-300 for Navy equipment.</ns0:data>
  <ns0:data key="d8">corrosion,maintenance</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841507</ns0:data>
</ns0:edge>
<ns0:edge source="CMR" target="DPAS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CMR is managed via DPAS in the Navy WHE Program.</ns0:data>
  <ns0:data key="d8">receipt management,system integration</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841139</ns0:data>
</ns0:edge>
<ns0:edge source="CMR" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts quarterly CMR inventories and submits signed CMRs for accountability validation.</ns0:data>
  <ns0:data key="d8">reconciliation,validation</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841267</ns0:data>
</ns0:edge>
<ns0:edge source="CMR" target="RO">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The RO signs CMRs to validate accountability using available data sources.</ns0:data>
  <ns0:data key="d8">accountability certification,signature validation</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841268</ns0:data>
</ns0:edge>
<ns0:edge source="DPAS" target="MCMC">
  <ns0:data key="d6">6.0</ns0:data>
  <ns0:data key="d7">The MCMC uses DPAS for accountability of specific equipment like non-tactical vehicles and CBRN items.&lt;SEP&gt;The MCMC accounts for Government-owned Garrison Fabricated Tools in DPAS per MCO 4790.2 and related orders.&lt;SEP&gt;MCMC uses DPAS for managing organic assets requiring sustainment services like PM and CM.&lt;SEP&gt;The MCMC accounts for Government-owned Garrison Fabricated Tools in DPAS according to specified chapters and orders.&lt;SEP&gt;The MCMC uses DPAS for accountability of assets like CBRN and certain equipment not in GCSS-MC.&lt;SEP&gt;MCMC manages CMR via DPAS for Navy GFE accountability.</ns0:data>
  <ns0:data key="d8">accountability,accountability system,alternative accountability,asset tracking,non-GCSS assets,property management,property tracking,receipt,tool management,tool tracking</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141&lt;SEP&gt;chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841207</ns0:data>
</ns0:edge>
<ns0:edge source="DPAS" target="Incumbent">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Incumbent provides historical DPAS records to the Successor no later than 30 days prior to the end of the transition period.</ns0:data>
  <ns0:data key="d8">phase-out delivery,record provision</ns0:data>
  <ns0:data key="d9">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841370</ns0:data>
</ns0:edge>
