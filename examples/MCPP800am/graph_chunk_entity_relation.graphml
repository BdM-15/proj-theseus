  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841509</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Offeror">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The apparently successful offeror agrees to submit Material Safety Data Sheets to the Contracting Officer prior to award, with failure potentially resulting in nonresponsibility.</ns0:data>
  <ns0:data key="d8">pre-award submission,responsibility determination</ns0:data>
