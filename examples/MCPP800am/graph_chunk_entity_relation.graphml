  <ns0:data key="d11">1759841184</ns0:data>
</ns0:edge>
<ns0:edge source="Consumable Supplies" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC maintains an inventory of consumable supplies and identifies reorder requirements when inventory drops below 30%.&lt;SEP&gt;MCMC maintains inventory of Consumable Supplies, reports quarterly, and identifies reorder needs when below 30%.</ns0:data>
  <ns0:data key="d8">inventory management,reordering</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-789ddbe0005097425aa3559f9388ad80</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841182</ns0:data>
</ns0:edge>
<ns0:edge source="Quarterly Inventory Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits a detailed quarterly inventory report of consumable supplies, including issued items, dates, and recipients.</ns0:data>
  <ns0:data key="d8">accountability,submission</ns0:data>
  <ns0:data key="d9">chunk-789ddbe0005097425aa3559f9388ad80</ns0:data>
