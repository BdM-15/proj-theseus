  <ns0:data key="d11">1759841181</ns0:data>
</ns0:edge>
<ns0:edge source="MCPP" target="Incumbent">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Incumbent maintains operational and maintenance responsibilities for MCPP until formal transfer to the Successor.</ns0:data>
  <ns0:data key="d8">maintenance responsibility,operational continuity</ns0:data>
