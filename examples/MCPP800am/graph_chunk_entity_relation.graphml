  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Atomic Energy Act of 1954" target="52.223-7 Notice of Radioactive Materials">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The notice requirement applies to radioactive materials requiring licensing under the Atomic Energy Act of 1954, as set forth in Title 10 of the Code of Federal Regulations.</ns0:data>
  <ns0:data key="d8">licensing authority,material criteria</ns0:data>
  <ns0:data key="d9">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841509</ns0:data>
</ns0:edge>
<ns0:edge source="Radioactive Material" target="Contracting Officer">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor provides notice to the Contracting Officer specifying parts containing radioactive materials, descriptions, isotopes, manufacturers, and hazards.</ns0:data>
  <ns0:data key="d8">notification requirement,safety precautions</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Radioactive Material" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor specifies details of radioactive materials in notices and ensures items are marked and labeled per regulatory requirements.</ns0:data>
  <ns0:data key="d8">marking,notification</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Radioactive Material" target="52.223-7 Notice of Radioactive Materials">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The clause requires notice for items containing radioactive materials meeting Atomic Energy Act licensing or activity thresholds.</ns0:data>
  <ns0:data key="d8">licensing criteria,notification</ns0:data>
  <ns0:data key="d9">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841509</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="MIL-STD 129">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer ensures items with radioactive materials are marked and labeled as required by the latest revision of MIL-STD 129.</ns0:data>
  <ns0:data key="d8">labeling compliance,marking standards</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="FAR 23.601(d)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer inserts the number of days required in advance based on FAR 23.601(d) to obtain licenses and notify personnel for safety.</ns0:data>
  <ns0:data key="d8">advance notice,licensing procedures</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Clause 52.243-2 Changes-Cost-Reimbursement">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer makes changes within the contract scope and adjusts estimated cost, schedule, fixed fee, and other terms accordingly.</ns0:data>
  <ns0:data key="d8">contract modifications,equitable adjustments</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Clause 52.244-2 Subcontracts">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer provides consent for subcontracts, approves purchases over thresholds, and reviews the Contractor's purchasing system.</ns0:data>
  <ns0:data key="d8">consent requirements,subcontract oversight</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Clause 52.246-20 Warranty of Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer provides written notice of defects and directs correction, reperformance, or equitable adjustments under Clause 52.246-20.</ns0:data>
  <ns0:data key="d8">adjustment authority,nonconformance notice</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841136</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="MCMC">
  <ns0:data key="d6">6.0</ns0:data>
  <ns0:data key="d7">MCMC responds only to directives from the Contracting Officer, who holds ultimate contract authority.&lt;SEP&gt;MCMC notifies Contracting Officer of accidents, provides mishap reports, and submits lists and approvals related to safety programs.&lt;SEP&gt;Contracting Officer has authority to approve work, make contract changes, and notify MCMC of personnel appointments and limitations.&lt;SEP&gt;Contracting Officer approves MCMC's Resource and Support Plan and provides exercise support letters outlining requirements.&lt;SEP&gt;The Contracting Officer provides written authorization to the MCMC prior to utilizing ancillary vendor support services.&lt;SEP&gt;Contracting Officer authorizes MCMC to use ancillary vendor support for troubleshooting and repairs.</ns0:data>
  <ns0:data key="d8">approval,authority,authority direction,authorization,contract administration,notification,oversight,planning,submission,vendor support</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-789ddbe0005097425aa3559f9388ad80&lt;SEP&gt;chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841185</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Continuation of Essential Contractor Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The contractor notifies the Contracting Officer if unable to perform essential services and the Contracting Officer directs continued performance and approves cost adjustments.</ns0:data>
  <ns0:data key="d8">direction,notification</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841219</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="E-1 Inspection/Monitoring Of Performance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer issues official notifications of discrepancies and unsatisfactory performance.</ns0:data>
  <ns0:data key="d8">discrepancy resolution,notification</ns0:data>
  <ns0:data key="d9">chunk-2829fe507a5073eafb2e5fb0cc5e85c9</ns0:data>
