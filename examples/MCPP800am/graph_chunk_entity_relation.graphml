<ns0:edge source="MCMC" target="Defense Information Systems Agency">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC configures hardware and software in accordance with Defense Information Systems Agency Security Technical Implementation Guidelines.</ns0:data>
  <ns0:data key="d8">compliance,guidelines</ns0:data>
