<ns0:edge source="Allowable Downtime Standards" target="Alpha Code">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Allowable Downtime Standards are applied per Alpha Code groups, limiting total downtime to 10% of available hours per month.</ns0:data>
