<ns0:edge source="MCSF-BI" target="40 CFR 260">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCSF-BI requires immediate notification and work stoppage upon discovery of military munitions as defined in 40 CFR 260.</ns0:data>
  <ns0:data key="d8">definition,munitions compliance</ns0:data>
