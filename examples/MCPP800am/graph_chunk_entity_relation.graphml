  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Configuration Control Board approves MCMC-proposed changes to network architecture, server architecture, or software configurations at Blount Island.</ns0:data>
  <ns0:data key="d8">approval,change control</ns0:data>
