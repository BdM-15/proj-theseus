  <ns0:data key="d11">1759841474</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Pre-Exercise Status Report (CDRL 6085)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs serviceability checks and delivers Pre-Exercise Status Report (CDRL 6085) as required by Exercise Support Letter.</ns0:data>
  <ns0:data key="d8">equipment check,report delivery</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841475</ns0:data>
