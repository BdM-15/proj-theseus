  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Intermediate Maintenance is a component of Corrective Maintenance (CM) in the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d8">inclusion,maintenance level</ns0:data>
  <ns0:data key="d9">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
