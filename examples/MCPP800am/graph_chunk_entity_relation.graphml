  <ns0:data key="d11">1759841487</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Hazardous Waste Control and Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages hazardous waste in accordance with plans and regulations, prohibited from bringing or disposing without approval.</ns0:data>
  <ns0:data key="d8">management,prohibition</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
