<ns0:edge source="Perpetual Inventory" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts cyclical physical inventories of perpetual inventory to ensure existence and completeness.&lt;SEP&gt;The MCMC ensures accurate accountability of perpetual inventory within MPF and ashore prepositioning programs.</ns0:data>
  <ns0:data key="d8">accountability,accuracy assurance,cyclical inventory,program management</ns0:data>
  <ns0:data key="d9">chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841213</ns0:data>
</ns0:edge>
<ns0:edge source="Perpetual Inventory" target="Section 4.C.3">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.C.3 mandates accurate accountability of perpetual inventory using GCSS-MC in MPF programs.</ns0:data>
  <ns0:data key="d8">GCSS-MC integration,accountability utilization</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841245</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="MIL-STD-130">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Data elements of the Unique Item Identifier are placed on items requiring marking based on criteria provided in MIL-STD-130.</ns0:data>
  <ns0:data key="d8">data placement,marking standard</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841191</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="ISO/IEC International Standard 16022">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Component data elements of the Unique Item Identifier are marked on items using two-dimensional data matrix symbology complying with ISO/IEC International Standard 16022.</ns0:data>
  <ns0:data key="d8">data matrix marking,symbology compliance</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Wide Area Workflow">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Information on items requiring Unique Item Identification is reported at delivery as part of the Material Inspection and Receiving Report using Wide Area Workflow for end items.</ns0:data>
  <ns0:data key="d8">delivery information,reporting mechanism</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="IUID Registry">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Embedded items requiring Unique Item Identification are reported by direct data submission to the IUID Registry.</ns0:data>
  <ns0:data key="d8">data submission,embedded items</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="FAR 2.101">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Unique Item Identifier applies to special tooling or special test equipment as defined in FAR 2.101.</ns0:data>
  <ns0:data key="d8">applicability,definition reference</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="ISO/IEC International Standard 15434">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Encoded data elements of the Unique Item Identifier conform to the transfer structure, syntax, and coding specified in ISO/IEC International Standard 15434 for Format Indicators 05, 06, and 12.</ns0:data>
  <ns0:data key="d8">encoding standard,format compliance</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Section D">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Unique Item Identifier marking is specified in Section D for UID-eligible items using data matrix 2D barcode, contract number, lot number, and serial number per MIL-STD-130.</ns0:data>
  <ns0:data key="d8">UID requirements,identification marking</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="ISO/IEC International Standard 15418">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Data elements of the Unique Item Identifier are encoded using Application Identifiers, Data Identifiers, or Text Element Identifiers in accordance with ISO/IEC International Standard 15418.</ns0:data>
  <ns0:data key="d8">data qualifier standard,identifier maintenance</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="ANSI MH 10.8.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">ANSI MH 10.8.2 supports the use of Data Identifiers and Application Identifiers for encoding unique item identifier data elements.</ns0:data>
  <ns0:data key="d8">application support,identifier standard</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="DD Form 1423">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Unique Item Identifier information for embedded items is reported via WAWF as a deliverable attachment using DD Form 1423.</ns0:data>
  <ns0:data key="d8">embedded items,reporting deliverable</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Enterprise Identifier">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Enterprise Identifier is encoded within the data matrix symbol of the Unique Item Identifier using data qualifiers.</ns0:data>
  <ns0:data key="d8">component element,encoding qualifier</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Issuing Agency Code">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Issuing Agency Code is derived from the data qualifier for the Enterprise Identifier in the Unique Item Identifier.</ns0:data>
  <ns0:data key="d8">component element,derivation method</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Serial Number">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Serial Number is part of the Unique Item Identifier to ensure no duplication in the DoD registry.</ns0:data>
  <ns0:data key="d8">duplication prevention,serialization component</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Application Identifiers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Application Identifiers are used to encode data elements of the Unique Item Identifier per ISO/IEC International Standard 15434 Format Indicator 05.</ns0:data>
  <ns0:data key="d8">data qualifier type,encoding method</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Data Identifiers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Data Identifiers are used to encode data elements of the Unique Item Identifier per ISO/IEC International Standard 15434 Format Indicator 06.</ns0:data>
  <ns0:data key="d8">data qualifier type,encoding method</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841196</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Text Element Identifiers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Text Element Identifiers are used to encode data elements of the Unique Item Identifier per ISO/IEC International Standard 15434 Format Indicator 12.</ns0:data>
  <ns0:data key="d8">data qualifier type,encoding method</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841197</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Subcontracts">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Unique Item Identifier clause must be included in subcontracts for items requiring unique item identification, including for commercial products or services.</ns0:data>
  <ns0:data key="d8">clause inclusion,flow-down requirement</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841197</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Material Inspection and Receiving Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Material Inspection and Receiving Report includes unique item identifier information at the time of delivery.</ns0:data>
  <ns0:data key="d8">delivery reporting,information inclusion</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841197</ns0:data>
</ns0:edge>
<ns0:edge source="Unique Item Identifier" target="Warranty">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Items with warranty requirements require unique item identification for embedded subassemblies, components, and parts.</ns0:data>
  <ns0:data key="d8">applicability trigger,embedded items</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841198</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-130" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MIL-STD-130 is used by the MCMC for identification marking of U.S. military property.&lt;SEP&gt;The MCMC follows MIL-STD-130 for identification in P3 processes.</ns0:data>
  <ns0:data key="d8">compliance,marking,property identification,standard compliance</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841223</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="252.232-7003">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">End items are reported using the receiving report capability in Wide Area Workflow in accordance with clause 252.232-7003.</ns0:data>
  <ns0:data key="d8">reporting clause,system integration</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="Section D">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Passive RFID tags are placed on shipping containers complying with Wide Area Workflow electronic tracking requirements in Section D.</ns0:data>
  <ns0:data key="d8">RFID tagging,tracking compliance</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="RFID Tagging">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">RFID Tagging complies with DoD Wide-Area Workflow electronic tracking requirements.</ns0:data>
  <ns0:data key="d8">DoD compliance,tracking integration</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="Wide Area Workflow Payment Instructions">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Wide Area Workflow Payment Instructions clause mandates use of Wide Area Workflow for submitting payment requests and receiving reports.</ns0:data>
  <ns0:data key="d8">electronic processing,system usage</ns0:data>
  <ns0:data key="d9">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841290</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="System For Award Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Access to Wide Area Workflow requires a designated electronic business point of contact in the System For Award Management.</ns0:data>
  <ns0:data key="d8">access requirement,registration</ns0:data>
  <ns0:data key="d9">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841290</ns0:data>
</ns0:edge>
<ns0:edge source="Wide Area Workflow" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes Wide Area Workflow for monthly invoice submissions with detailed backups.</ns0:data>
  <ns0:data key="d8">invoicing,submission</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841334</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-129" target="Section D">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MIL-STD-129 is required for marking shipments to DoD facilities as part of Section D's general packaging requirements.</ns0:data>
  <ns0:data key="d8">packaging marking,shipment standards</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-129" target="Military Shipping Label">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Military Shipping Label includes linear and 2D barcodes as required by MIL-STD-129 for shipments to DoD facilities.</ns0:data>
  <ns0:data key="d8">barcode inclusion,labeling standard</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841194</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-129" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC applies MIL-STD-129 for military marking of shipments in warehousing operations.</ns0:data>
  <ns0:data key="d8">shipment marking,standard application</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841275</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-129" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC applies markings to shipping containers per MIL-STD-129 standards.</ns0:data>
  <ns0:data key="d8">marking,shipment</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841405</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-2073-1" target="Section D">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MIL-STD-2073-1 is applied for items requiring military-grade protection under Section D's general packaging requirements.</ns0:data>
  <ns0:data key="d8">military packaging,protection standards</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
<ns0:edge source="Command Order 4035.1" target="Section D">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Command Order 4035.1 governs the preservation, packaging, packing, and marking of supplies and materials under Section D.</ns0:data>
  <ns0:data key="d8">contract compliance,preservation requirement</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841193</ns0:data>
</ns0:edge>
<ns0:edge source="Section D" target="Packing List">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Packing List is required inside the primary shipping container as part of Section D's delivery and inspection provisions.</ns0:data>
  <ns0:data key="d8">content requirement,shipment documentation</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841195</ns0:data>
</ns0:edge>
<ns0:edge source="Section E" target="Contract Line Item Number">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Supplies and services for each Contract Line Item Number are inspected and accepted at destination by the government as specified in Section E.</ns0:data>
  <ns0:data key="d8">destination terms,inspection acceptance</ns0:data>
  <ns0:data key="d9">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841192</ns0:data>
</ns0:edge>
