  <ns0:data key="d11">1759841511</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Modification Instructions (MIs)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC identifies and performs required MIs on ME and CESE during production periods, notifying Government for Navy CESE applicability.</ns0:data>
  <ns0:data key="d8">identification,performance</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841511</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Non-Destructive Testing (NDT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates NDT on load-sustaining components with MDMC Albany and enters results into GCSS-MC.</ns0:data>
  <ns0:data key="d8">coordination,testing</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
