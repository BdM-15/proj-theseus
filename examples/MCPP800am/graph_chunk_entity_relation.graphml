<ns0:edge source="MCMC" target="Navy Containerized Equipment Maintenance Transfer Log">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides, maintains, and delivers the Navy Containerized Equipment Maintenance Transfer Log bi-weekly to NAV-P.</ns0:data>
  <ns0:data key="d8">maintenance logging,reporting</ns0:data>
