</ns0:edge>
<ns0:edge source="Shelf Life/Service Life Management" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC develops and executes Shelf Life/Service Life Management for stored Navy materiel to ensure proper condition and compliance.</ns0:data>
  <ns0:data key="d8">development,execution</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
