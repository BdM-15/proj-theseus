  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Clause 252.203-7004 Display of Hotline Posters" target="Department of Defense">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Clause 252.203-7004 requires display of the Department of Defense fraud hotline poster in work areas for DoD contracts.</ns0:data>
  <ns0:data key="d8">fraud prevention,hotline display</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
