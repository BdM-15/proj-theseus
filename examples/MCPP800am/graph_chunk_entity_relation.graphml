</ns0:node>
<ns0:node id="United Steel Workers">
  <ns0:data key="d0">United Steel Workers</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">United Steel Workers is the organization associated with the Collective Bargaining Agreement in Attachment #10.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
