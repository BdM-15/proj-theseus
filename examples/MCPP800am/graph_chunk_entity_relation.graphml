<ns0:edge source="MCMC" target="St Johns River Water Management District (SJRWMD)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with the SJRWMD Master Stormwater Permit for stormwater management.</ns0:data>
  <ns0:data key="d8">permit compliance</ns0:data>
