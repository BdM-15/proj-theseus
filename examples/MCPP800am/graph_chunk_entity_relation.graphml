<ns0:edge source="Corrective Maintenance Memo" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC includes recommended corrective actions in the Corrective Maintenance Memo as part of the Detailed Report of Findings to NAV-P.</ns0:data>
  <ns0:data key="d8">maintenance planning,recommendation</ns0:data>
