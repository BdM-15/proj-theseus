  <ns0:data key="d0">52.246-4 Inspection Of Services Fixed Price</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-4 Inspection Of Services Fixed Price is a clause incorporated by reference dated AUG 1996.</ns0:data>
