</ns0:edge>
<ns0:edge source="MCMC" target="NAV-P Maintenance Requirements Package">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains NAV-P Maintenance Requirements Package IAW latest Force Revision, updating NLT 20 business days or ten for CAT II/III.</ns0:data>
  <ns0:data key="d8">maintenance,updates</ns0:data>
