  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Squadron Plan provides a rollup of planned quantities for each TAMCN.</ns0:data>
  <ns0:data key="d8">distribution,quantity tracking</ns0:data>
