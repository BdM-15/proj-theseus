  <ns0:data key="d11">1759841418</ns0:data>
</ns0:edge>
<ns0:edge source="4.J Fiscal Requirements" target="FAMRS Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.J includes daily FAMRS Report for status of funds monitoring.</ns0:data>
  <ns0:data key="d8">reporting requirement</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
