<ns0:edge source="MCMC" target="Stormwater">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Stormwater requirements and submits inspection reports per CDRL 10045.</ns0:data>
  <ns0:data key="d8">compliance,reporting</ns0:data>
