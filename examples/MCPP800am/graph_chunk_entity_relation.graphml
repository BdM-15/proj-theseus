</ns0:edge>
<ns0:edge source="Elastomeric Service Life Program" target="TM 3835-OI/1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Elastomeric Service Life Program for TFS follows guidelines in TM 3835-OI/1 for service life management.</ns0:data>
  <ns0:data key="d8">compliance,guidance</ns0:data>
