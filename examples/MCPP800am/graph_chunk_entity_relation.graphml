<ns0:edge source="4.J Fiscal Requirements" target="Unmatched Transaction Report (UMT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.J requires daily UMT for fiscal precision and accounting.</ns0:data>
