  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841343</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Bill of Material (BOM)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC produces and orders Bill of Material (BOM) IAW MRP and WDC-II for Navy Watercraft production NLT E-236.</ns0:data>
  <ns0:data key="d8">ordering,production</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
