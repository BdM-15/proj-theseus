<ns0:edge source="MCO 4400.201" target="UM 4000-125">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 4400.201 and UM 4000-125 together guide the MCMC's supply validations and accountability procedures.</ns0:data>
  <ns0:data key="d8">procedural alignment,supply management</ns0:data>
  <ns0:data key="d9">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
