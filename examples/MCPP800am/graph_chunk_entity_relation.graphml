  <ns0:data key="d0">Military Equipment (ME)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Military Equipment (ME) includes Class II and Class VII assets supporting MPS, MCPP-N, MCPP-PHIL, and future sites, subject to various maintenance requirements.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="LAV">
  <ns0:data key="d0">LAV</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">LAV is a vehicle requiring hydraulic filter replacements, air system services, and PMCS during production periods.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="JLTV">
  <ns0:data key="d0">JLTV</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">JLTV is a vehicle requiring air dryer filter services as part of PMCS functions.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="P19R">
  <ns0:data key="d0">P19R</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">P19R is a vehicle requiring air dryer desiccant services as part of PMCS functions.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="MEP-831A">
  <ns0:data key="d0">MEP-831A</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MEP-831A is a generator model requiring installation of a specific 24-volt battery.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="THHR">
  <ns0:data key="d0">THHR</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">THHR refers to Tactical Hand Held Radios requiring battery charging, testing, and secure storage.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="CmdO 4790.1 (MMSOP)">
  <ns0:data key="d0">CmdO 4790.1 (MMSOP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 4790.1 (MMSOP) is a command order detailing maintenance procedures, including PMCS levels, oil testing, and recording requirements.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841117</ns0:data>
</ns0:node>
<ns0:node id="Operational Function Tests">
  <ns0:data key="d0">Operational Function Tests</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Operational Function Tests are tests performed on pumping mechanisms and specific equipment like tanker pumps and fuel trucks during production periods.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Fuel Container Purging and Cleaning">
  <ns0:data key="d0">Fuel Container Purging and Cleaning</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Fuel Container Purging and Cleaning involves purging, cleaning, and drying fuel containers and cans to ensure safety before maintenance and storage.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Lower Explosive Level Testing">
  <ns0:data key="d0">Lower Explosive Level Testing</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Lower Explosive Level Testing is conducted on bulk fuel carriers to determine explosive levels, with documentation in GCSS-MC or local records.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Elastomeric Service Life Program">
  <ns0:data key="d0">Elastomeric Service Life Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Elastomeric Service Life Program manages service life of TFS components, with standards for unused and used conditions, and data entry in GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Fuel Filtration Services">
  <ns0:data key="d0">Fuel Filtration Services</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Fuel Filtration Services involve processing and cleaning fuel in equipment cells through filtration units during production and receipt phases.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Lubrication Service">
  <ns0:data key="d0">Lubrication Service</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Lubrication Service requires applying fresh lubricant to service points after washing and before staging or packing.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Full Mission Capable (FMC)">
  <ns0:data key="d0">Full Mission Capable (FMC)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Full Mission Capable (FMC) is the equipment status achieved after maintenance, QA inspections, and operational tests.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Quality Assurance (QA)">
  <ns0:data key="d0">Quality Assurance (QA)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Quality Assurance (QA) encompasses government inspections, supervision, and notifications related to maintenance activities on ME and CESE assets.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="In-Process Inspections">
  <ns0:data key="d0">In-Process Inspections</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">In-Process Inspections are QA activities performed before equipment reaches FMC status to avoid disassembly, defined in Joint ISO procedures.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="DTR 4500-R">
  <ns0:data key="d0">DTR 4500-R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DTR 4500-R is the Defense Transportation Regulation governing purging, cleaning, and testing of fuel containers on ME and CESE assets.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Operator Functional Testing">
  <ns0:data key="d0">Operator Functional Testing</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Operator Functional Testing is conducted on tactical communication systems in Navy lighterage according to approved production schedules and applicable TMs.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Load Lifting Certification">
  <ns0:data key="d0">Load Lifting Certification</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Load Lifting Certification involves inspections, testing, and formal certification of load-lifting ME and CESE assets per specified manuals and policies.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Transportable Fuel and Water Systems">
  <ns0:data key="d0">Transportable Fuel and Water Systems</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Transportable Fuel and Water Systems include components with ISO fittings requiring inspection, certification, and maintenance during production periods.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Elastomeric Components">
  <ns0:data key="d0">Elastomeric Components</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Elastomeric Components in TFS are subject to service life standards, with minimum unused life of 36 months for MPS and 25 months for MCPP-PHIL.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Service Life Certification Inspections">
  <ns0:data key="d0">Service Life Certification Inspections</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Service Life Certification Inspections are performed upon receipt of elastomeric components for TFS during designated production periods.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Lead-Acid Batteries">
  <ns0:data key="d0">Lead-Acid Batteries</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Lead-Acid Batteries for ME and CESE are tested, serviced, and maintained according to TM 9-6140-200-13 during production periods.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="4HN Series Battery">
  <ns0:data key="d0">4HN Series Battery</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">4HN Series is a dry inactive 24-volt military standard battery installed in MEP-831A generators in place of the Concorde RG-24 model.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Uninterruptible Power Supplies (UPS)">
  <ns0:data key="d0">Uninterruptible Power Supplies (UPS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Uninterruptible Power Supplies (UPS) for ME must be properly stored and charged by MCMC in accordance with TI 2000-OR/ and applicable equipment TM, potentially stored separately from parent end items.&lt;SEP&gt;Uninterruptible Power Supplies (UPS) associated with ME are charged, tested, and stored per TI 2000-OR, potentially separate from parent equipment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Wash and Clean">
  <ns0:data key="d0">Wash and Clean</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Wash and Clean removes mud, dirt, sand, oil, and contaminants from ME and CESE assets, including operator stations and stowage compartments, after production maintenance.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="High-Pressure Wash">
  <ns0:data key="d0">High-Pressure Wash</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">High-Pressure Wash is applied to ME and CESE after initial PMCS, requiring subsequent lubrication reapplication to affected service points.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Engine Coolant Systems">
  <ns0:data key="d0">Engine Coolant Systems</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Engine Coolant Systems in ME and CESE are tested and serviced with 50/50 ethylene glycol antifreeze, ensuring freeze protection between -34°F and -40°F and nitrite levels of 1200-1400 ppm.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Ether Cylinders">
  <ns0:data key="d0">Ether Cylinders</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Ether Cylinders on ME and CESE are disconnected, disabled, capped, or replaced with unactivated units during PMCS to prevent accidental gas release.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Tactical Communication Systems">
  <ns0:data key="d0">Tactical Communication Systems</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Tactical Communication Systems in Navy lighterage undergo operator functional testing per government schedules and TMs.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="SINCGARS">
  <ns0:data key="d0">SINCGARS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">SINCGARS radio systems, including Interface Module (SIM), require DC power cable disconnection from J27 when not operational to mitigate failures in TAMCN A0097 and A0135.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="COMM/ELEC">
  <ns0:data key="d0">COMM/ELEC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">COMM/ELEC denotes Communications/Electronic assets, including CCI/KMI, limited to PMCS and CM at MCPP-N.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="TM 3835-OI/1">
  <ns0:data key="d0">TM 3835-OI/1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 3835-OI/1 details the elastomeric service life program and standards for Tactical Fuel Systems components.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="TI 10340-12/1">
  <ns0:data key="d0">TI 10340-12/1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TI 10340-12/1 provides instructions for elastomeric shelf life tracking, including figures for GCSS-MC module entry and fuel drum data.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="TB 750-651">
  <ns0:data key="d0">TB 750-651</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TB 750-651 outlines procedures for testing and servicing engine coolant systems in conjunction with PMCS.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="TI 2000-OR">
  <ns0:data key="d0">TI 2000-OR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TI 2000-OR instructs on proper storage and charging of Uninterruptible Power Supplies for ME.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="MCO 11262.2">
  <ns0:data key="d0">MCO 11262.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 11262.2 provides guidance on annual load testing, Non-Destructive Testing (NDT) for load-sustaining components, and exemptions for prepositioned equipment during afloat phases.&lt;SEP&gt;MCO 11262.2 governs certification and testing of Marine Corps tactical load-lifting equipment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Section 1 Basic Past Performance Information">
  <ns0:data key="d0">Section 1 Basic Past Performance Information</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1 Basic Past Performance Information includes details such as name of effort, contracting agency contacts, contract number, type, values, period of performance, and key subcontractors.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841118</ns0:data>
</ns0:node>
<ns0:node id="Section 2 Relevance to Current Requirement">
  <ns0:data key="d0">Section 2 Relevance to Current Requirement</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 2 Relevance to Current Requirement describes work products, services delivered, and correlation to the solicitation's requirements in scope, magnitude, period, and complexity.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Standard Proposal Information">
  <ns0:data key="d0">Standard Proposal Information</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Standard Proposal Information requires a table of contents and list of tables and figures for Volume VI.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Cost/Price">
  <ns0:data key="d0">Cost/Price</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Cost/Price requires information other than certified cost or pricing data to support reasonableness, completeness, and realism, including a cost model workbook and narratives on assumptions.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Summary Descriptions and Narrative">
  <ns0:data key="d0">Summary Descriptions and Narrative</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Summary Descriptions and Narrative provides descriptions of estimating systems or methods for major cost elements and any cost reductions.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Summary and Supporting Schedules">
  <ns0:data key="d0">Summary and Supporting Schedules</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Summary and Supporting Schedules mandates completion of Schedule B, pricing each optional ordering period, rounded to the nearest whole dollar.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Proposal Summary">
  <ns0:data key="d0">Proposal Summary</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Proposal Summary provides summaries for each contract CLIN and SLIN by year within ordering periods, utilizing the cost model workbook, including the phase-in period.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Employee Compensation Plan">
  <ns0:data key="d0">Employee Compensation Plan</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Employee Compensation Plan sets forth proposed salaries and fringe benefits for professional employees under cost-type CLINs, assessed for realism and reasonableness per FAR 52.222-46.&lt;SEP&gt;Employee Compensation Plan details proposed compensation, labor incentives, basis for salaries and benefits, alignment with wage determinations or collective bargaining agreements, and variances.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Cost Breakout and Supporting Data">
  <ns0:data key="d0">Cost Breakout and Supporting Data</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Cost Breakout and Supporting Data by COST TYPE CLIN and SLIN correlates totals to the proposal summary using the cost model workbook, covering labor, materials, travel, overtime, other direct costs, indirect rates, and subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Cost Reimbursable Material, Travel and Overtime">
  <ns0:data key="d0">Cost Reimbursable Material, Travel and Overtime</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Cost Reimbursable Material, Travel and Overtime details reimbursement for actual costs, material handling, indirect costs, and exclusions for fee, with compliance to DFARS clauses.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Segregation of Costs by ACRN/Funding Sources">
  <ns0:data key="d0">Segregation of Costs by ACRN/Funding Sources</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Segregation of Costs by ACRN/Funding Sources demonstrates capability to segregate costs by accounting classification reference number, with narratives and sample reports.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Fee Structure">
  <ns0:data key="d0">Fee Structure</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Fee Structure applies limitations from FAR and DFARS, with maximum total fee of 10 percent of estimated cost excluding fee.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Other Information">
  <ns0:data key="d0">Other Information</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Other Information includes company organization details, DCAA and DCMA contacts, disclosure statement, estimating and accounting systems, forward pricing rate agreement, purchasing system, and subcontractor information.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Small Business Participation">
  <ns0:data key="d0">Small Business Participation</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Small Business Participation discusses extent of participation of small business concerns and small disadvantaged business concerns, addressing identification and commitment levels.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Schedule B">
  <ns0:data key="d0">Schedule B</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Schedule B to the solicitation requires mandatory completion for pricing contract CLINs and SLINs.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DCAA">
  <ns0:data key="d0">DCAA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DCAA is the Defense Contract Audit Agency responsible for oversight, indirect rate ceilings, and approval of estimating and accounting systems.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DCMA">
  <ns0:data key="d0">DCMA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DCMA is the Defense Contract Management Agency responsible for oversight, administrative contracting officers, and approval of purchasing systems.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Small Business Participation Proposal">
  <ns0:data key="d0">Small Business Participation Proposal</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Small Business Participation Proposal requires offerors to discuss participation of small businesses and small disadvantaged businesses in contract performance.&lt;SEP&gt;Small Business Participation Proposal discusses participation of small and disadvantaged businesses in contract performance, in accordance with DFARS criteria.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="FAR 15.403-3">
  <ns0:data key="d0">FAR 15.403-3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 15.403-3 requires submission of information other than certified cost or pricing data to support reasonableness, completeness, and realism of proposed costs.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="FAR 15.404-3">
  <ns0:data key="d0">FAR 15.404-3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 15.404-3 governs subcontract pricing considerations, requiring analysis to establish reasonableness of proposed subcontract prices.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.237-10">
  <ns0:data key="d0">FAR 52.237-10</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.237-10 mandates identification of uncompensated overtime in proposals, with compliance required for workload analysis.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.222-46">
  <ns0:data key="d0">FAR 52.222-46</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.222-46 provides the standard for evaluating the offeror's compensation plan, including salaries and fringe benefits for professional employees.&lt;SEP&gt;FAR 52.222-46 addresses evaluation of compensation for professional employees, requiring description in the employee compensation plan.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.222-43">
  <ns0:data key="d0">FAR 52.222-43</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.222-43 provides for fair labor standards and service contract labor standards price adjustment for multiple year contracts.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7003">
  <ns0:data key="d0">DFARS 252.215-7003</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7003 requires submission of contractor certified cost or pricing data and compliance for indirect rates on subcontracted services.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.215-7004">
  <ns0:data key="d0">DFARS 252.215-7004</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.215-7004 addresses contract clauses for submission of certified cost or pricing data modifications.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.242-7005">
  <ns0:data key="d0">DFARS 252.242-7005</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.242-7005 addresses the requirements for contractor business systems to be approved or determined acceptable by the Government.&lt;SEP&gt;DFARS 252.242-7005 requires evidence of government approval for estimating and accounting systems in compliance with contractor business systems.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.244-7001">
  <ns0:data key="d0">DFARS 252.244-7001</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.244-7001 governs contractor purchasing system administration, requiring documentation of DCMA approval.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="DFARS 215.304">
  <ns0:data key="d0">DFARS 215.304</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 215.304 provides criteria for small business participation evaluation.&lt;SEP&gt;DFARS 215.304 provides criteria for evaluating small business participation in proposals.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Service Contract Labor Standards">
  <ns0:data key="d0">Service Contract Labor Standards</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The statute and regulations under 29 CFR part 4 that the statement of equivalent rates complies with, specifying wages and benefits for service employees.&lt;SEP&gt;Service Contract Labor Standards establish legal requirements for minimum wages and benefits in service contracts, including alignment with Area Wage Determinations or Collective Bargaining Agreements.&lt;SEP&gt;Service Contract Labor Standards require alignment of positions with area wage determinations or collective bargaining agreements, including overtime and benefits.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467&lt;SEP&gt;chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Area Wage Determination">
  <ns0:data key="d0">Area Wage Determination</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Area Wage Determination specifies minimum wages and benefits for service contract labor, with explanations required for any variances.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Forward Pricing Rate Agreement">
  <ns0:data key="d0">Forward Pricing Rate Agreement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Forward Pricing Rate Agreement provides approved rates for the cost proposal, with limitations to DCMA/DCAA ceilings if not applicable.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Contractor Business Systems">
  <ns0:data key="d0">Contractor Business Systems</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Contractor Business Systems include estimating, accounting, and purchasing systems evaluated for adequacy in handling MCPP costs under cost-type CLINs, per DFARS 252.242-7005.&lt;SEP&gt;Contractor Business Systems include estimating, accounting, purchasing, material management, and property management, used for value and cost reporting.&lt;SEP&gt;Contractor Business Systems encompass Estimating, Accounting, Purchasing, Material Management, and Property Management, used for developing Planned Value, Earned Value, Actual Cost reporting, and EAC Projections.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Uncompensated Overtime">
  <ns0:data key="d0">Uncompensated Overtime</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Uncompensated Overtime requires identification and compliance with FAR 52.237-10, including workload analysis for RFP labor requirements.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="ACRN">
  <ns0:data key="d0">ACRN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">ACRN is Accounting Classification Reference Number, requiring segregation of costs by funding sources like USMC and Navy.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="PPIS Questionnaire Letter">
  <ns0:data key="d0">PPIS Questionnaire Letter</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">PPIS Questionnaire Letter is emailed by the offeror to points of contact listed in past performance information sheets.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Small Business">
  <ns0:data key="d0">Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Business is a category with a 20% subcontracting goal for the acquisition.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Small Disadvantaged Business">
  <ns0:data key="d0">Small Disadvantaged Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Disadvantaged Business has a 5% goal for the acquisition.&lt;SEP&gt;Small Disadvantaged Business is a category with a 5% subcontracting goal.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841119</ns0:data>
</ns0:node>
<ns0:node id="Woman-Owned Small Business">
  <ns0:data key="d0">Woman-Owned Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Woman-Owned Small Business has a 4% goal for the acquisition.&lt;SEP&gt;Woman-Owned Small Business is a category with a 4% subcontracting goal.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="HUBZone Small Business">
  <ns0:data key="d0">HUBZone Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HUBZone Small Business has a 1% goal for the acquisition.&lt;SEP&gt;HUBZone Small Business is a category with a 1% subcontracting goal.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Hearing Conservation Program (HCP)">
  <ns0:data key="d0">Hearing Conservation Program (HCP)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Hearing Conservation Program (HCP) is a continuing effective program administered by the MCMC in accordance with 29 CFR 1910.95 and MCO 5100.29 for personnel exposed to workplace noise at or exceeding 85 decibels TWA.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Hazard Communication (HAZCOM) Program">
  <ns0:data key="d0">Hazard Communication (HAZCOM) Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Hazard Communication (HAZCOM) Program is a written program developed, implemented, and maintained by the MCMC in accordance with 29 CFR 1910.1200 and MCO 5100.29, including label requirements, Safety Data Sheet requirements, and employee training.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10040">
  <ns0:data key="d0">CDRL 10040</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10040 is the deliverable for providing an Environmental Manager and designated alternate.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Department of Navy (DoN)">
  <ns0:data key="d0">Department of Navy (DoN)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Department of Navy (DoN) issues policies, instructions, and directives that the MCMC must comply with for environmental requirements.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps (USMC)">
  <ns0:data key="d0">Marine Corps (USMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Marine Corps (USMC) issues policies, instructions, and directives, including MCO 5100.29 and MCO 5090.2, that the MCMC must follow for safety and environmental programs.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="St Johns River Water Management District (SJRWMD)">
  <ns0:data key="d0">St Johns River Water Management District (SJRWMD)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The St John’s River Water Management District (SJRWMD) issues the Master Stormwater Permit that the MCMC must comply with.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Air Resources">
  <ns0:data key="d0">Air Resources</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Air Resources section outlines requirements for equipment operation in accordance with 40 CFR 64, state air emission standards, and air permits, including data input for painting and blast operations.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Stormwater">
  <ns0:data key="d0">Stormwater</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Stormwater section requires compliance with the installation’s Stormwater Pollution Prevention Plan, 40 CFR 122.26, NPDES, and SJRWMD Master Stormwater Permit, including submission of inspection reports.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Material Management">
  <ns0:data key="d0">Hazardous Material Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Hazardous Material Management section requires compliance with federal, state, local, and DoD regulations, including SDS submission, exposure control plans, and training for handling hazardous materials.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Waste Control and Management">
  <ns0:data key="d0">Hazardous Waste Control and Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Hazardous Waste Control and Management section prohibits disposal or bringing hazardous waste onto government property without approval, requires management in accordance with plans and regulations, and designates MCSF-BI as a Large Quantity Generator.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Pest Management">
  <ns0:data key="d0">Pest Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Pest Management section requires compliance with the MCSF-BI Integrated Pest Management Plan and application of pesticides only as needed based on inspections.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Petroleum, Oil, Lubricant (POL) Storage and Fueling">
  <ns0:data key="d0">Petroleum, Oil, Lubricant (POL) Storage and Fueling</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Petroleum, Oil, Lubricant (POL) Storage and Fueling section requires management and storage in accordance with 40 CFR 112 and other regulations to prevent spills, including secondary containment and SPCC plans.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Employee Training">
  <ns0:data key="d0">Employee Training</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Employee Training section requires development of a training program for environmental awareness, spill response, and specific certifications, with records maintained and reported via CETEP database.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Solid Waste Management">
  <ns0:data key="d0">Solid Waste Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Solid Waste Management section requires pickup and disposal in covered containers, segregation of wastes, and compliance with the MCSF-BI Integrated Solid Waste Management Plan including recycling.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Green Procurement">
  <ns0:data key="d0">Green Procurement</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Green Procurement section requires compliance with federal laws, EOs, DoD, and DoN policies via the MCSF-BI Green Procurement Plan, with monthly reports submitted.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Pollution Prevention">
  <ns0:data key="d0">Pollution Prevention</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Pollution Prevention section requires compliance with federal laws, EOs, DoD, and DoN policies via the MCSF-BI Pollution Prevention Management Plan, including participation in the Navy’s program.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 112">
  <ns0:data key="d0">40 CFR 112</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">40 CFR 112 is the EPA regulation for oil pollution prevention that applies to POL storage and SPCC plans.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10041">
  <ns0:data key="d0">CDRL 10041</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10041 requires the MCMC to input and maintain operating data for painting and abrasive blast operations in the Government-provided Microsoft Access Air database, updated monthly.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10042">
  <ns0:data key="d0">CDRL 10042</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10042 is the request form for approval of new or existing paint or paint-related products, including product name, information, and SDS, submitted at least 5 business days prior to use.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10043">
  <ns0:data key="d0">CDRL 10043</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10043 requires the MCMC to provide an accurate inventory of all assigned Green House Gas sources within 30 calendar days of the Government's annual reporting request.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10044">
  <ns0:data key="d0">CDRL 10044</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10044 requires the MCMC to input and update Ozone Depleting Substance inventory data in the Government database quarterly by the 5th business day.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10045">
  <ns0:data key="d0">CDRL 10045</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10045 is the submission of Stormwater Inspection Reports to the Contracting Officer in accordance with the Stormwater Pollution Prevention requirements.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10046">
  <ns0:data key="d0">CDRL 10046</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10046 requires submission of SDS and estimated quantities for each hazardous material to the Installation Division Environmental Manager prior to bringing it on site.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10047">
  <ns0:data key="d0">CDRL 10047</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10047 is the written Exposure Control Plan for hazardous work environments, provided to work centers within 30 days of contract award or plan changes.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10048">
  <ns0:data key="d0">CDRL 10048</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10048 requires submission of HAZMAT Inspection Forms to the Government by the 5th business day following inspections conducted per the HMMP.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10049">
  <ns0:data key="d0">CDRL 10049</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10049 requires monthly submission of Tank Maintenance Records by the 30th day following maintenance for storage tanks under MCMC control.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10050">
  <ns0:data key="d0">CDRL 10050</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10050 is the report on attendance of all employees' Environmental Training and Education entered into the CETEP database.&lt;SEP&gt;CDRL 10050 requires reporting of employee attendance for Environmental Training and Education using the CETEP Microsoft Access Database, entered by the 5th business day of the following month.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10051">
  <ns0:data key="d0">CDRL 10051</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10051 is the monthly report of Green Procurement actions provided to the Government.&lt;SEP&gt;CDRL 10051 is the monthly report of Green Procurement actions, submitted by the 5th of each month in accordance with the MCSF-BI Green Procurement Plan.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Clean Air Act (CAA)">
  <ns0:data key="d0">Clean Air Act (CAA)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Clean Air Act (CAA) requires tracking and inventory of Green House Gases in accordance with MCSF-BI Air Emission Integrity and Green House Gas Inventory procedures.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Stormwater Pollution Prevention Plan (SWPP)">
  <ns0:data key="d0">Stormwater Pollution Prevention Plan (SWPP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Stormwater Pollution Prevention Plan (SWPP) is the installation plan that the MCMC must comply with, along with 40 CFR 122.26, NPDES, and SJRWMD permits.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="NPDES">
  <ns0:data key="d0">NPDES</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NPDES refers to the National Pollutant Discharge Elimination System, requiring compliance for stormwater management and water discharges.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841120</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Waste Management Plan">
  <ns0:data key="d0">Hazardous Waste Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Hazardous Waste Management Plan is the approved installation plan for identifying, labeling, handling, transporting, and storing hazardous waste.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Hazardous Material Management Plan (HMMP)">
  <ns0:data key="d0">MCSF-BI Hazardous Material Management Plan (HMMP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The MCSF-BI Hazardous Material Management Plan (HMMP) governs the maintenance of hazardous materials in the HMMS and required inspections.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Material Management System (HMMS)">
  <ns0:data key="d0">Hazardous Material Management System (HMMS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">The Hazardous Material Management System (HMMS) is the Marine Corps approved system for maintaining hazardous materials in accordance with the HMMP.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Integrated Contingency Plan">
  <ns0:data key="d0">Integrated Contingency Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Integrated Contingency Plan is the MCSF-BI plan for emergency planning, EPCRA compliance, and operational control of storage tanks.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="MCSf-BI Integrated Pest Management Plan">
  <ns0:data key="d0">MCSf-BI Integrated Pest Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The MCSF-BI Integrated Pest Management Plan outlines compliance requirements for pest management, including pesticide application based on need.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 279">
  <ns0:data key="d0">40 CFR 279</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">40 CFR 279 governs the management of used oil generated on site in accordance with state, local, and MCSF-BI environmental plans.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="AST-UST Plan">
  <ns0:data key="d0">AST-UST Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The AST-UST Plan is the MCSF-BI plan for aboveground and underground storage tanks, under which the MCMC takes operational control.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Comprehensive Environmental Training and Education Plan (CETEP)">
  <ns0:data key="d0">Comprehensive Environmental Training and Education Plan (CETEP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Comprehensive Environmental Training and Education Plan (CETEP) is the Government-provided plan and Microsoft Access Database for tracking employee environmental training.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="MCSf-BI Integrated Solid Waste Management Plan">
  <ns0:data key="d0">MCSf-BI Integrated Solid Waste Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The MCSF-BI Integrated Solid Waste Management Plan requires compliance including recycling of all outlined waste streams.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="MCSf-BI Green Procurement Plan">
  <ns0:data key="d0">MCSf-BI Green Procurement Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The MCSF-BI Green Procurement Plan governs the green procurement process for consumables, materials, and equipment.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="MCSf-BI Pollution Prevention Management Plan">
  <ns0:data key="d0">MCSf-BI Pollution Prevention Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The MCSF-BI Pollution Prevention Management Plan implements compliance with federal laws, EOs, DoD, and DoN policies for pollution prevention.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Executive Order 13423">
  <ns0:data key="d0">Executive Order 13423</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Executive Order 13423 mandates participation in the Navy’s Pollution Prevention Program.&lt;SEP&gt;Executive Order 13423 requires participation in the Navy’s Pollution Prevention Program as part of MCMC compliance.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="OPNAV 5090.1">
  <ns0:data key="d0">OPNAV 5090.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">OPNAV 5090.1 provides guidance for the Navy’s Pollution Prevention Program.&lt;SEP&gt;OPNAV 5090.1 supports the Navy’s Pollution Prevention Program in which the MCMC must participate.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Large Quantity Generator">
  <ns0:data key="d0">Large Quantity Generator</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Large Quantity Generator is the designation for MCSF-BI, requiring the MCMC to meet specific regulatory requirements for training, storage, handling, and disposal of hazardous wastes.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="SPCC">
  <ns0:data key="d0">SPCC</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">SPCC is the Spill Prevention, Control, and Countermeasure plan required for facilities with aggregate aboveground storage capacity over 1,320 gallons, to be submitted for approval.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="EPCRA">
  <ns0:data key="d0">EPCRA</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">EPCRA is the Emergency Planning and Community Right-to-Know Act, requiring compliance and reporting in accordance with MCSF-BI Integrated Contingency Plan and MCO 5090.2.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="HAZWOPER">
  <ns0:data key="d0">HAZWOPER</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">HAZWOPER is the 40-hour initial training with annual 8-hour refresher required for the Environmental Manager and personnel handling hazardous wastes.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Access Air Database">
  <ns0:data key="d0">Microsoft Access Air Database</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">The Microsoft Access Air Database is the Government-provided database for inputting and maintaining data on painting and abrasive blast operations, updated monthly.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Access Ozone Depleting Substance Database">
  <ns0:data key="d0">Microsoft Access Ozone Depleting Substance Database</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">The Microsoft Access Ozone Depleting Substance Database is the Government database located on the shared site for inventory data updates quarterly.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Installation Division Environmental Section">
  <ns0:data key="d0">Installation Division Environmental Section</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Installation Division Environmental Section provides database training, approves paint products, and handles hazardous material SDS submissions and rainwater removal coordination.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Biomedical Waste Management Plan">
  <ns0:data key="d0">Biomedical Waste Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Biomedical Waste Management Plan is the MCSF-BI plan for managing biomedical waste generation, handling, storage, and permit maintenance.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Universal Waste Management">
  <ns0:data key="d0">Universal Waste Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Universal Waste Management requires handling of batteries, lamps, mercury-containing equipment, and pesticides in accordance with 40 CFR 273 and installation instructions.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Electronics End-of-Life Management">
  <ns0:data key="d0">Electronics End-of-Life Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Electronics End-of-Life Management requires recycling or disposal of electronic waste such as computers and monitors in accordance with 40 CFR 260-262 and installation instructions.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Water Discharge Form">
  <ns0:data key="d0">Water Discharge Form</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">The Water Discharge Form is the workflow tool used by the MCMC to obtain Government approval prior to any water discharges including stormwater and wastewater.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Total Attainment Rate (TAR)">
  <ns0:data key="d0">Total Attainment Rate (TAR)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Total Attainment Rate (TAR) reflects the percentage of materiel that is eligible and successfully prepositioned, calculated using quantities of materiel actually available minus deferred and short items divided by total materiel actually available.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Prepositioned Attainment Rate (PAR)">
  <ns0:data key="d0">Prepositioned Attainment Rate (PAR)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Prepositioned Attainment Rate (PAR) reflects the percentage of materiel that is eligible and successfully prepositioned, considering items that can be prepositioned in accordance with NAVMC 4000.2A, calculated similarly to TAR but focused on prepositioned items.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Deferred Items">
  <ns0:data key="d0">Deferred Items</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Deferred items are those that cannot be prepositioned due to policy restrictions.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Short Items">
  <ns0:data key="d0">Short Items</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Short items are those that were not procured due to procurement issues.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Maintenance Contractor (MCMC)">
  <ns0:data key="d0">Marine Corps Maintenance Contractor (MCMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Maintenance Contractor (MCMC) is responsible for maintenance, repair, logistical services, inventory accountability, and production of medical and Navy assets in support of the Marine Corps Prepositioning Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Inventory Findings Report">
  <ns0:data key="d0">Inventory Findings Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Inventory Findings Report is a document delivered by MCMC detailing results from annual 100 percent wall-to-wall inventories of MPF assets.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Memorandum">
  <ns0:data key="d0">Memorandum</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Memorandum is a document delivered by MCMC accompanying the Inventory Findings Report for MPF assets.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Inventory Adjustment Report">
  <ns0:data key="d0">Inventory Adjustment Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Inventory Adjustment Report is provided by MCMC to the Government within 7 calendar days of inventory, addressing any discrepancies.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Inventory Voucher Report">
  <ns0:data key="d0">Inventory Voucher Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Inventory Voucher Report is provided by MCMC for any discrepancies in the Inventory Adjustment Report within 7 calendar days of inventory, as exemplified in Attachment C.5.D.1.a.i.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Authorized Medical Allowance List (AMAL)">
  <ns0:data key="d0">Authorized Medical Allowance List (AMAL)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Authorized Medical Allowance List (AMAL) is a list of medical equipment and materiel for which maintenance and assembly into blocks are performed.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="Authorized Dental Allowance List (ADAL)">
  <ns0:data key="d0">Authorized Dental Allowance List (ADAL)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Authorized Dental Allowance List (ADAL) is a list of dental equipment and materiel for which maintenance and assembly into blocks are performed.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841121</ns0:data>
</ns0:node>
<ns0:node id="United States Army Medical Material Agency (USAMMA)">
  <ns0:data key="d0">United States Army Medical Material Agency (USAMMA)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">United States Army Medical Material Agency (USAMMA) provides information on suspensions and recalls via notifications.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Medical Material Quality Control (MMQC)">
  <ns0:data key="d0">Medical Material Quality Control (MMQC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Medical Material Quality Control (MMQC) provides information on suspensions and recalls via notifications.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Suspensions and Recall Items Notification">
  <ns0:data key="d0">Suspensions and Recall Items Notification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Suspensions and Recall Items Notification is provided by MCMC in response to recalls, with a written response required no later than 7 calendar days of notification.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="SF-368">
  <ns0:data key="d0">SF-368</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SF-368 is a form completed by MCMC for equipment that fails acceptance inspection, in accordance with NAVMED P-5132.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Surplus Equipment Report">
  <ns0:data key="d0">Surplus Equipment Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Surplus Equipment Report is provided by MCMC to the Government detailing equipment quantities greater than the production order, within the first 7 calendar days of the month.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="MMS NO. 1A">
  <ns0:data key="d0">MMS NO. 1A</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MMS NO. 1A is a manual referenced for marking AMAL/ADAL Environmental Container Systems.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Navy Prepositioning Department (NAV-P)">
  <ns0:data key="d0">Navy Prepositioning Department (NAV-P)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy Prepositioning Department (NAV-P) manages assets supporting the Marine Corps Prepositioning Program, for which MCMC provides maintenance and logistical services.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Prepositioning Program (MCPP)">
  <ns0:data key="d0">Marine Corps Prepositioning Program (MCPP)</ns0:data>
  <ns0:data key="d1">strategic_theme</ns0:data>
  <ns0:data key="d2">Marine Corps Prepositioning Program (MCPP) involves prepositioned military equipment requiring maintenance, supply chain management, and accountability for combat-ready assets.&lt;SEP&gt;Marine Corps Prepositioning Program (MCPP) is the program supported by MCMC through maintenance, inventory, and production of medical and Navy assets at various sites.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Table of Allowances (TOAs)">
  <ns0:data key="d0">Table of Allowances (TOAs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Table of Allowances (TOAs) outlines equipment for NSE and NCE assigned to support the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Naval Tactical Command Support System (NTCSS)">
  <ns0:data key="d0">Naval Tactical Command Support System (NTCSS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">NTCSS is a system used for documenting Navy supply and maintenance administration.&lt;SEP&gt;Naval Tactical Command Support System (NTCSS) is a system used for documenting Navy supply and maintenance administration.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Organizational Maintenance Management System-Next Generation (OMMS-NG)">
  <ns0:data key="d0">Organizational Maintenance Management System-Next Generation (OMMS-NG)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Organizational Maintenance Management System-Next Generation (OMMS-NG) is a module used for Navy maintenance administration.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Relational Supply (RSupply)">
  <ns0:data key="d0">Relational Supply (RSupply)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">RSupply is a module used for documenting Navy supply and maintenance administration.&lt;SEP&gt;Relational Supply (RSupply) is a module used for Navy supply administration.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Lighterage Maintenance Model">
  <ns0:data key="d0">Lighterage Maintenance Model</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The Lighterage Maintenance Model represents watercraft maintenance steps over an approximately 18-month process, including Preventive Maintenance (PM) and Corrective Maintenance (CM) across four phases.&lt;SEP&gt;Lighterage Maintenance Model is a process for watercraft maintenance over an approximately 18-month cycle, including preventive and corrective maintenance phases, supporting Navy assets in parallel to Marine Corps operations.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Preventive Maintenance (PM)">
  <ns0:data key="d0">Preventive Maintenance (PM)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Preventive Maintenance (PM) is a component of the Lighterage Maintenance Model performed on Navy watercraft.&lt;SEP&gt;PM is a component of the Lighterage Maintenance Model, included in phases such as Alpha, Bravo, and Delta.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="DMLSS User Manual">
  <ns0:data key="d0">DMLSS User Manual</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DMLSS User Manual is referenced alongside NAVMED P-5132 for inputting data into DMLSS, including minimum data entry elements.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Lot Number">
  <ns0:data key="d0">Lot Number</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Lot Number is a minimum data entry element for materiel in DMLSS.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Expiration Date">
  <ns0:data key="d0">Expiration Date</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Expiration Date of all materiel, regardless of shelf-life code, is a minimum data entry element in DMLSS.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="On Hand Quantity">
  <ns0:data key="d0">On Hand Quantity</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">On Hand Quantity is a minimum data entry element for materiel in DMLSS.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Short Shelf-Life Material">
  <ns0:data key="d0">Short Shelf-Life Material</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Short shelf-life material is managed by MCMC in accordance with DoD 4140.27-M (Vol. 1).</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Quality Deficiency Report (QDR)">
  <ns0:data key="d0">Quality Deficiency Report (QDR)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quality Deficiency Report (QDR) is submitted by MCMC to the Defense Logistics Agency if equipment fails operational tests, as per NAVMED P-5132.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Class VIII Items">
  <ns0:data key="d0">Class VIII Items</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class VIII items are medical materiel for which maintenance is tracked using DMLSS as the sole APSR.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="DMLSS Work Order">
  <ns0:data key="d0">DMLSS Work Order</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">DMLSS Work Order is created by MCMC for non-operational equipment following failed tests.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="DMLSS Active Report">
  <ns0:data key="d0">DMLSS Active Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">DMLSS Active Report is placed with the equipment by MCMC in accordance with NAVMED P-5132.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Blount Island Command (BICmd)">
  <ns0:data key="d0">Blount Island Command (BICmd)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Blount Island Command (BICmd) is the site where a technical library for equipment manuals is maintained.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Production Order (PO)">
  <ns0:data key="d0">Production Order (PO)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Production Order (PO) is referenced for detailing equipment quantities in the Surplus Equipment Report.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Post-Production Documents">
  <ns0:data key="d0">Post-Production Documents</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Post-Production Documents include the Hazardous Material List following production.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Environmental Container System (ECS)">
  <ns0:data key="d0">Environmental Container System (ECS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Environmental Container System (ECS) for AMAL/ADAL blocks is properly marked by MCMC in accordance with MIL-STD-2073-1E and MMS NO. 1A.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Consumables">
  <ns0:data key="d0">Consumables</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Consumables are subject to disposition services by MCMC in accordance with DoD 4160.21-M and NAVMC 4000.2A.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Contract Line Item Numbers (CLINs)">
  <ns0:data key="d0">Contract Line Item Numbers (CLINs)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Contract Line Item Numbers (CLINs) are met by MCMC for cost control in providing Navy equipment readiness.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Sub Line Item Numbers (SLINs)">
  <ns0:data key="d0">Sub Line Item Numbers (SLINs)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Sub Line Item Numbers (SLINs) are met by MCMC for cost control in providing Navy equipment readiness.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Marine Prepositioning Force (MPF)">
  <ns0:data key="d0">Marine Prepositioning Force (MPF)</ns0:data>
  <ns0:data key="d1">strategic_theme</ns0:data>
  <ns0:data key="d2">Marine Prepositioning Force (MPF) Program is supported by inventories of assets and equipment outlined in TOAs for NSE and NCE.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Rotational Spares">
  <ns0:data key="d0">Rotational Spares</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Rotational spares are included in the equipment for NSE and NCE assigned to support the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Designated Management Stock">
  <ns0:data key="d0">Designated Management Stock</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Designated management stock is included in the equipment for NSE and NCE assigned to support the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="MCPP II Contract">
  <ns0:data key="d0">MCPP II Contract</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCPP II Contract governs the locations and performance of Navy products and services in support of the program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Watercraft">
  <ns0:data key="d0">Watercraft</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Watercraft undergo maintenance through the Lighterage Maintenance Model, including backload onto ships with Marine Corps equipment.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Organizational Maintenance">
  <ns0:data key="d0">Organizational Maintenance</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Organizational Maintenance is included in Corrective Maintenance for Navy watercraft in the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Intermediate Maintenance">
  <ns0:data key="d0">Intermediate Maintenance</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Intermediate Maintenance is included in Corrective Maintenance for Navy watercraft in the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841122</ns0:data>
</ns0:node>
<ns0:node id="Depot Level Maintenance">
  <ns0:data key="d0">Depot Level Maintenance</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Depot Level Maintenance is included in Corrective Maintenance for Navy watercraft in the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Allowable Cost And Payment">
  <ns0:data key="d0">Allowable Cost And Payment</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Allowable Cost and Payment is a clause that specifies requirements for submitting direct and indirect costs, final indirect cost rates, billing rates, audits, and final payments under the contract.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Order Limitations">
  <ns0:data key="d0">Order Limitations</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Order Limitations is a clause that establishes minimum and maximum order amounts for supplies or services, including limits on single items, combinations, and series of orders.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Indefinite Quantity">
  <ns0:data key="d0">Indefinite Quantity</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Indefinite Quantity is a clause for an indefinite-quantity contract where specified quantities are estimates, with minimum and maximum orders, and delivery authorized by orders.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Option To Extend Services">
  <ns0:data key="d0">Option To Extend Services</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Option to Extend Services is a clause allowing the Government to require continued performance of services for up to 6 months, exercisable by written notice.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Option To Extend The Term Of The Contract">
  <ns0:data key="d0">Option To Extend The Term Of The Contract</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Option to Extend the Term of the Contract is a clause permitting the Government to extend the contract term up to ten years and six months with preliminary and final notices.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Payment For Overtime Premiums">
  <ns0:data key="d0">Payment For Overtime Premiums</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Payment for Overtime Premiums is a clause authorizing overtime premiums under specific conditions like emergencies or cost savings, with justification required for excesses.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Equal Opportunity For Veterans">
  <ns0:data key="d0">Equal Opportunity For Veterans</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Equal Opportunity for Veterans is a clause requiring the Contractor to prohibit discrimination against protected veterans, provide affirmative action, and include the clause in subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Equal Opportunity For Workers With Disabilities">
  <ns0:data key="d0">Equal Opportunity For Workers With Disabilities</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Equal Opportunity for Workers with Disabilities is a clause mandating the Contractor to prohibit discrimination based on disability, provide affirmative action, and include the clause in subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Statement Of Equivalent Rates For Federal Hires">
  <ns0:data key="d0">Statement Of Equivalent Rates For Federal Hires</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Statement of Equivalent Rates for Federal Hires is a clause addressing compliance with equivalent rates for federal hires.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Final Indirect Cost Rates">
  <ns0:data key="d0">Final Indirect Cost Rates</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Final indirect cost rates are agreed-upon rates between the Contractor and Government for reimbursing indirect costs, including bases, periods, and specific treatments.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Billing Rates">
  <ns0:data key="d0">Billing Rates</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Billing rates are anticipated final rates established for reimbursing the Contractor until final indirect cost rates are settled, subject to adjustment.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Quick-Closeout Procedures">
  <ns0:data key="d0">Quick-Closeout Procedures</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Quick-closeout procedures apply to contracts when conditions in FAR 42.708(a) are met, facilitating faster settlement.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Completion Invoice Or Voucher">
  <ns0:data key="d0">Completion Invoice Or Voucher</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Completion invoice or voucher is submitted by the Contractor within 120 days after final indirect cost rates settlement to reflect settled amounts and rates.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="U.S. Department Of Labor">
  <ns0:data key="d0">U.S. Department Of Labor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Department of Labor provides prevailing labor rates for adjustments and oversees equal opportunity enforcement through its programs.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Office Of Federal Contract Compliance Programs">
  <ns0:data key="d0">Office Of Federal Contract Compliance Programs</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Office of Federal Contract Compliance Programs directs enforcement of equal opportunity clauses in subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Requirements Clause">
  <ns0:data key="d0">Requirements Clause</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Requirements clause applies to requirements contracts, affecting order limitations when requirements exceed maximums.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Certificate Of Final Indirect Costs">
  <ns0:data key="d0">Certificate Of Final Indirect Costs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Certificate of Final Indirect Costs is a required submission per 52.242-4 for certifying final indirect costs.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Cognizant Auditor">
  <ns0:data key="d0">Cognizant Auditor</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Cognizant auditor is an authorized representative responsible for establishing billing rates for indirect costs until final rates are determined.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Subcontractor">
  <ns0:data key="d0">Subcontractor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Subcontractor is a lower-tier entity to which work is awarded by the prime contractor, requiring settlement of amounts and rates in completion invoices.&lt;SEP&gt;An entity receiving subcontracts from the Contractor where equal opportunity terms must be inserted if valued at or above specified thresholds, unless exempted.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839&lt;SEP&gt;chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Secretary Of Labor">
  <ns0:data key="d0">Secretary Of Labor</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Secretary of Labor provides prevailing labor rates used for adjusting service extension rates under the contract option.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Securities And Exchange Commission">
  <ns0:data key="d0">Securities And Exchange Commission</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Securities and Exchange Commission is the regulatory body for which 10-K annual reports are submitted as supplemental financial information.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Ordering Clause">
  <ns0:data key="d0">Ordering Clause</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Ordering clause governs the issuance of orders for delivery or performance under the indefinite quantity contract.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Contractor Compensation Cap">
  <ns0:data key="d0">Contractor Compensation Cap</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contractor Compensation Cap limits allowability of compensation for certain personnel, with references to specific White House documents for pre- and post-June 24 awards.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Management Letter">
  <ns0:data key="d0">Management Letter</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Management letter is issued by outside CPAs identifying internal control weaknesses, requiring corrective actions.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Internal Audit Report">
  <ns0:data key="d0">Internal Audit Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Internal audit report is a record of audits issued since the last disclosure to the Government, included in supplemental information.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Income Tax Returns">
  <ns0:data key="d0">Income Tax Returns</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Federal and State income tax returns are financial documents provided as supplemental information during the audit process.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="10-K Annual Report">
  <ns0:data key="d0">10-K Annual Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">10-K annual report is the Securities and Exchange Commission filing submitted as part of certified financial statements.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Board Of Directors Minutes">
  <ns0:data key="d0">Board Of Directors Minutes</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Minutes from board of directors meetings are internal records provided as supplemental information.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Delay Claims">
  <ns0:data key="d0">Delay Claims</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Delay claims are submissions containing costs related to the fiscal year, listed for audit review.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Termination Claims">
  <ns0:data key="d0">Termination Claims</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Termination claims are submissions including fiscal year costs, required to be listed in supplemental information.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Contract Briefings">
  <ns0:data key="d0">Contract Briefings</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Contract briefings provide synopses of contract provisions such as type, amount, performance period, and limitations.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="ISO RFID Tags">
  <ns0:data key="d0">ISO RFID Tags</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">ISO RFID Tags are used by MCMC for item identification, including ISO 18000-7 aRFID tags for specific applications.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="OPP">
  <ns0:data key="d0">OPP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">OPP is Offload Preparation Party involved in handling prepositioned MPE/S.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841123</ns0:data>
</ns0:node>
<ns0:node id="Navy Organic Ground Support Equipment Maintenance">
  <ns0:data key="d0">Navy Organic Ground Support Equipment Maintenance</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Organic Ground Support Equipment Maintenance is a section specifying PMCS and corrective maintenance for Navy GSE.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="Link-Belt Crawler Crane">
  <ns0:data key="d0">Link-Belt Crawler Crane</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Link-Belt Crawler Crane is a 348 model critical Navy GSE assigned Priority 1 maintenance.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="Marine Travel Lift Mobile Boat Hoist">
  <ns0:data key="d0">Marine Travel Lift Mobile Boat Hoist</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Marine Travel Lift Mobile Boat Hoist is a 150C model critical Navy GSE assigned Priority 1 maintenance.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="Heavy-Lift Transporters">
  <ns0:data key="d0">Heavy-Lift Transporters</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Heavy-Lift Transporters are two units of critical Navy GSE assigned Priority 1 maintenance.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6066">
  <ns0:data key="d0">CDRL 6066</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6066 is a Contract Data Requirements List for reporting accidents on Navy leased equipment.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
