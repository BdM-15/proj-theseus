  <ns0:data key="d11">1759841532</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Supply Demand Planning">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs supply demand planning by monitoring and tracking Military Equipment excesses and deficiencies.</ns0:data>
  <ns0:data key="d8">materiel tracking,monitoring requirements</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841533</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Marine Corps Support Facility">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs supply, container, and distribution management operations at Marine Corps Support Facility (MCSF-BI).</ns0:data>
  <ns0:data key="d8">operations location,supply management</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841533</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Equipment Operational Time Codes">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC pays attention to Equipment Operational Time Codes during annual PMCS for equipment regeneration.</ns0:data>
  <ns0:data key="d8">PMCS attention,maintenance tracking</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841533</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Technical Manuals">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts PMCS on Organic Support Assets in accordance with timeframes and methods in Technical Manuals.</ns0:data>
  <ns0:data key="d8">PMCS methods,compliance</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
