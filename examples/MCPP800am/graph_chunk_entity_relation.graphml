<ns0:edge source="Contractor" target="252.225-7043">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Under 252.225-7043, the Contractor must comply with antiterrorism/force protection requirements when performing outside the United States.</ns0:data>
  <ns0:data key="d8">antiterrorism,compliance</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
