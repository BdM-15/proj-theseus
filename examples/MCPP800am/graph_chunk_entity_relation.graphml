  <ns0:data key="d11">1759841473</ns0:data>
</ns0:edge>
<ns0:edge source="Employee Compensation Plan" target="Area Wage Determination">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Employee Compensation Plan identifies positions per Area Wage Determination and explains any minimum wage variances.</ns0:data>
  <ns0:data key="d8">position designation,wage specification</ns0:data>
  <ns0:data key="d9">chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
