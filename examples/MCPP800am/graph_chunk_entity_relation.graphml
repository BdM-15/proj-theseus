<ns0:edge source="Employee Compensation Plan" target="FAR 52.222-46">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Employee Compensation Plan addresses concerns under FAR 52.222-46 for professional employee compensation.</ns0:data>
  <ns0:data key="d8">compensation evaluation,professional employees</ns0:data>
