<ns0:node id="Operations Support Team">
  <ns0:data key="d0">Operations Support Team</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Operations Support Team (OST) handles watercraft berthing, drydocking, and monitoring in Navy methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft Maintenance Center">
  <ns0:data key="d0">Navy Watercraft Maintenance Center</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy Watercraft Maintenance Center (WMC) performs preventive and corrective maintenance for Navy watercraft.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Control Systems Support">
  <ns0:data key="d0">Control Systems Support</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Control Systems Support (CSS) is part of Navy maintenance for watercraft and assets.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Collection Bargaining Agreement">
  <ns0:data key="d0">Collection Bargaining Agreement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Collective Bargaining Agreement aligns with labor categories in manning requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Service Contract Act">
  <ns0:data key="d0">Service Contract Act</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Service Contract Act governs wage and labor standards for contract performance.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Area Wage Determinations">
  <ns0:data key="d0">Area Wage Determinations</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Area Wage Determinations set prevailing wages for labor categories.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officer Representative">
  <ns0:data key="d0">Contracting Officer Representative</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Contracting Officer Representative is a qualified individual appointed in writing by the Contracting Officer to assist in technical monitoring or administration of the contract.&lt;SEP&gt;Contracting Officer Representative (COR) contacts are provided in past performance information.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Automated External Defibrillators">
  <ns0:data key="d0">Automated External Defibrillators</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Automated External Defibrillators are devices that require monthly inspection for operability and immediate return to the IDIV Safety Office if inoperable.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Fire Protection and Prevention">
  <ns0:data key="d0">Fire Protection and Prevention</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Fire Protection and Prevention outlines requirements for handling combustible materials, training on fire response, maintaining fire extinguisher inventories, inspections, notifications, designating fire wardens, providing evacuation routes, and conducting fire drills.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="NFPA Codes Standards">
  <ns0:data key="d0">NFPA Codes Standards</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NFPA Codes Standards are referenced for fire extinguisher inspections, evacuation routes, and fire drills.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Fire Wardens">
  <ns0:data key="d0">Fire Wardens</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Fire Wardens are competent persons designated as primary and alternate for MCMC work and administrative areas, with roster provided annually.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Fire Drills">
  <ns0:data key="d0">Fire Drills</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Fire Drills are conducted semi-annually in coordination with IDIV, with after-action reports submitted within 30 days including details on date, type, participants, and corrective actions.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Smoking Policy">
  <ns0:data key="d0">Smoking Policy</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Smoking Policy prohibits smoking except in designated areas, requires enforcement by MCMC, and considers improper disposal as littering.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Accident and Damage Reporting">
  <ns0:data key="d0">Accident and Damage Reporting</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Accident and Damage Reporting requires notification to the Contracting Officer within four hours for recordable injuries, high visibility accidents, property damage, or WHE accidents, with investigations and preservation of site.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Recordable Injuries or Illnesses">
  <ns0:data key="d0">Recordable Injuries or Illnesses</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Recordable Injuries or Illnesses include work-related incidents resulting in death, days away from work, restricted work, medical treatment beyond first aid, loss of consciousness, or significant diagnosed injuries.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="High Visibility Accident">
  <ns0:data key="d0">High Visibility Accident</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">High Visibility Accident refers to any mishap that may generate publicity or high visibility, requiring prompt notification.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="WHE Accident">
  <ns0:data key="d0">WHE Accident</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">WHE Accident involves failure in operating envelope elements during weight handling equipment operations, including dropped loads or collisions, even without damage.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Radiation Safety Requirements">
  <ns0:data key="d0">Radiation Safety Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Radiation Safety Requirements mandate compliance with standards, notifications of incidents, training, management of radioactive materials, semi-annual inventories, and notifications of radiation components.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Vehicle Safety">
  <ns0:data key="d0">Vehicle Safety</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Vehicle Safety requires following regulations for licensing, certified operators, commercial driver's licenses, hazardous materials handling, and incident reporting within one hour.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Safety Inspections">
  <ns0:data key="d0">Safety Inspections</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Safety Inspections involve daily checks of work areas for hazards, PPE usage, safe practices, and equipment condition, with government monitoring and reporting upon request.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Hazard Reporting and Abatement Program">
  <ns0:data key="d0">Hazard Reporting and Abatement Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Hazard Reporting and Abatement Program is developed by MCMC for reporting hazardous situations confidentially, with verbal notification within 30 minutes and written within 48 hours for high-risk hazards.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Medical Screening and Surveillance Requirements">
  <ns0:data key="d0">Medical Screening and Surveillance Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Medical Screening and Surveillance Requirements comply with OSHA standards, with notifications of personnel changes and maintenance of records.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Respiratory Protection Program">
  <ns0:data key="d0">Respiratory Protection Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Respiratory Protection Program is established with lists of assigned personnel provided to Contracting Officer and Installation Safety, updated within 10 business days of changes.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Hazard Communication Program">
  <ns0:data key="d0">Hazard Communication Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Hazard Communication Program is written and maintained, covering labels, safety data sheets, and employee training.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Environmental Manager">
  <ns0:data key="d0">Environmental Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Environmental Manager ensures compliance with environmental policies, develops strategies, and has experience in hazardous waste management and spill response, with specific training requirements.&lt;SEP&gt;The Environmental Manager is a position provided by the contractor with primary responsibility for ensuring adherence to environmental policies, developing strategies, and possessing specific training and experience in environmental procedures, hazardous waste management, and spill response.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="CmdO P5104.3">
  <ns0:data key="d0">CmdO P5104.3</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO P5104.3 establishes radiation safety standards, including notification procedures, training, and inventory requirements for radioactive materials.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="EPA 40 CFR">
  <ns0:data key="d0">EPA 40 CFR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">EPA 40 CFR regulates the management and storage of radioactive material and waste.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="NRC 10 CFR Part 20">
  <ns0:data key="d0">NRC 10 CFR Part 20</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NRC 10 CFR Part 20 provides standards for radiation protection and compliance in handling radioactive materials.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="CmdO 11240.1C">
  <ns0:data key="d0">CmdO 11240.1C</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 11240.1C specifies safety requirements for vehicle operations.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="MCO 11240.118">
  <ns0:data key="d0">MCO 11240.118</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 11240.118 provides guidelines for equipment licensing and operator certification.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="MCO 8400.6">
  <ns0:data key="d0">MCO 8400.6</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 8400.6 addresses vehicle and equipment safety standards.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="TM 11275-15/4">
  <ns0:data key="d0">TM 11275-15/4</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 11275-15/4 is a technical manual referenced for vehicle safety and licensing.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="5 CFR">
  <ns0:data key="d0">5 CFR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">5 CFR provides federal regulations applicable to government contractor operations.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="OSHA 3162-01R">
  <ns0:data key="d0">OSHA 3162-01R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">OSHA 3162-01R is a guide for medical screening and surveillance requirements.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="29 CFR 1910.95">
  <ns0:data key="d0">29 CFR 1910.95</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">29 CFR 1910.95 is the OSHA standard for occupational noise exposure that the MCMC must follow for the Hearing Conservation Program.&lt;SEP&gt;29 CFR 1910.95 establishes standards for hearing conservation programs.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="29 CFR 1910.1200">
  <ns0:data key="d0">29 CFR 1910.1200</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">29 CFR 1910.1200 is the OSHA standard for hazard communication that the MCMC must implement in the HAZCOM program.&lt;SEP&gt;29 CFR 1910.1200 outlines requirements for hazard communication programs.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="OSHA">
  <ns0:data key="d0">OSHA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">OSHA establishes the occupational noise Action Level of 85 decibels TWA and issues standards such as 29 CFR 1910 for hearing conservation, hazard communication, and spill cleanup training.&lt;SEP&gt;OSHA is the Occupational Safety and Health Administration, enforcing safety standards, issuing citations, and guiding medical, respiratory, and hearing programs.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="EPA">
  <ns0:data key="d0">EPA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">EPA administers regulations including 40 CFR for air permits, stormwater, hazardous waste management, universal waste, and oil pollution prevention applicable to MCMC operations.&lt;SEP&gt;EPA is the Environmental Protection Agency, regulating environmental compliance including radioactive waste under 40 CFR.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="U.S. Nuclear Regulatory Commission">
  <ns0:data key="d0">U.S. Nuclear Regulatory Commission</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Nuclear Regulatory Commission oversees nuclear regulation and radiation safety under 10 CFR Part 20.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Department of Navy">
  <ns0:data key="d0">Department of Navy</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Department of Navy provides policies and directives for environmental and safety requirements.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Radiation Safety Manager">
  <ns0:data key="d0">Radiation Safety Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Radiation Safety Manager receives notifications of radiation incidents, inventories of radioactive materials, and details of radiation-producing components.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Government Licensing Official">
  <ns0:data key="d0">Government Licensing Official</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Government Licensing Official approves licenses for vehicle and equipment operators provided by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Environmental">
  <ns0:data key="d0">Environmental</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Environmental section mandates compliance with local, state, federal statutes, regulations, Executive Orders, and DoD, DoN, USMC policies for sustainable operations.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="After-Action Fire-Drill Report">
  <ns0:data key="d0">After-Action Fire-Drill Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">After-Action Fire-Drill Report (CDRL 10029) details drill date, type, participants, issues, and corrective actions, submitted within 30 calendar days after each fire drill.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Accident Notification">
  <ns0:data key="d0">Accident Notification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Accident Notification (CDRL 10030) informs the Contracting Officer of recordable injuries, high visibility accidents, property damage, or WHE incidents within four hours.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="WHE Accident Report">
  <ns0:data key="d0">WHE Accident Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">WHE Accident Report is submitted following weight handling equipment accidents to establish root causes and recommend controls.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Crane and Rigging Gear Near Miss Report">
  <ns0:data key="d0">Crane and Rigging Gear Near Miss Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Crane and Rigging Gear Near Miss Report is submitted for near misses in crane or rigging operations, with verbal notification within four hours.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Annual Mishap Statistics Report">
  <ns0:data key="d0">Annual Mishap Statistics Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Annual Mishap Statistics Report categorizes mishaps from the previous year by type, property losses, and man-days lost, submitted by January 15.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Mishap Statistics Report">
  <ns0:data key="d0">Quarterly Mishap Statistics Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quarterly Mishap Statistics Report categorizes incidents by type such as first aid, OSHA reportable, and lost time.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Radiation Incident Notification">
  <ns0:data key="d0">Radiation Incident Notification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Radiation Incident Notification (CDRL 10031) is provided verbally within 30 minutes and in writing within three business days of any radiation accident.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Radioactive Material Inventory">
  <ns0:data key="d0">Radioactive Material Inventory</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Radioactive Material Inventory (CDRL 10032) is submitted semi-annually by June 30 and January 30, listing radioactive materials.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Radiation Component Notification">
  <ns0:data key="d0">Radiation Component Notification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Radiation Component Notification (CDRL 10033) lists radiation sources, locations, and documentation, submitted within three business days of receipt or departure.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Vehicle License">
  <ns0:data key="d0">Vehicle License</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Vehicle License (CDRL 10034) documents approved certifications for operators of tactical, organic vehicles, and equipment.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Vehicle Mishap Report">
  <ns0:data key="d0">Vehicle Mishap Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Vehicle Mishap Report (CDRL 10035) details incidents involving vehicles, submitted within 10 business days after notification.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Contractor Safety Inspection and Monitoring Report">
  <ns0:data key="d0">Contractor Safety Inspection and Monitoring Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Contractor Safety Inspection and Monitoring Report (CDRL 10036) includes narratives, summaries, corrective actions, and management adjustments, submitted upon request.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="OSHA Citations and Violations Corrective Action Report">
  <ns0:data key="d0">OSHA Citations and Violations Corrective Action Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">OSHA Citations and Violations Corrective Action Report is submitted within 48 hours after receiving an OSHA citation, detailing corrections.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Third-Party Inspection Notification">
  <ns0:data key="d0">Third-Party Inspection Notification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Third-Party Inspection Notification (CDRL 10037) alerts the government verbally within 30 minutes of discovering regulatory agency inspections.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Hazard Situation Report">
  <ns0:data key="d0">Hazard Situation Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Hazard Situation Report (CDRL 10038) documents high-risk hazards with probable loss of life or damage, verbally within 30 minutes and written within 48 hours.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Respirator Personnel List">
  <ns0:data key="d0">Respirator Personnel List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Respirator Personnel List (CDRL 10039) identifies personnel assigned to the respiratory protection program, submitted to Contracting Officer and Installation Safety.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Environmental Manager Provision">
  <ns0:data key="d0">Environmental Manager Provision</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Environmental Manager Provision (CDRL 10040) provides details of the Environmental Manager and alternate for ensuring compliance with environmental policies.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Fire Extinguisher Inventory">
  <ns0:data key="d0">Fire Extinguisher Inventory</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Fire Extinguisher Inventory (CDRL 10026) lists portable fire extinguishers with manufacturer name, date, serial number, type, and weight, submitted annually and within 30 days of changes.</ns0:data>
  <ns0:data key="d3">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="BICmd Resource Management Office (RMO)">
  <ns0:data key="d0">BICmd Resource Management Office (RMO)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">BICmd Resource Management Office (RMO) is the primary government entity referenced in Section 4.H for supply and fiscal matters.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Contract Cost Plus Fixed Fee (CPFF) and Status Report (CCSR)">
  <ns0:data key="d0">Contract Cost Plus Fixed Fee (CPFF) and Status Report (CCSR)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Contract Cost Plus Fixed Fee (CPFF) and Status Report (CCSR) is a monthly electronic report (CDRL 5057) delivered by MCMC for each Task Order, submitted with invoices starting 30 days after contract award.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Prepositioning Program-Norway (MCPP-N)">
  <ns0:data key="d0">Marine Corps Prepositioning Program-Norway (MCPP-N)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Prepositioning Program-Norway (MCPP-N) is a prepositioning program supported by MCMC, including specific small arms reporting and accountability actions.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Class VIII Medical Material">
  <ns0:data key="d0">Class VIII Medical Material</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class VIII Medical Material includes medical consumables and equipment managed by MCMC in accordance with Marine Corps orders and production schedules.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="AMAL">
  <ns0:data key="d0">AMAL</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">AMAL is the Authorized Medical Allowance List used by MCMC for identifying requirements, attainment rates, and reporting in medical management.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="ADAL">
  <ns0:data key="d0">ADAL</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">ADAL is the Authorized Dental Allowance List used by MCMC for identifying requirements, attainment rates, and reporting in medical management.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Section 4.J">
  <ns0:data key="d0">Section 4.J</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.J outlines MCMC responsibilities for fiscal management, accounting, supply reconciliations, reports, and manpower requirements.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Section 4.K">
  <ns0:data key="d0">Section 4.K</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.K details exemptions and waivers for MCMC, including property record adjustments, small arms accountability, and shelf-life policies.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841111</ns0:data>
</ns0:node>
<ns0:node id="Section C.5">
  <ns0:data key="d0">Section C.5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.5 specifies requirements for MCMC in managing Class VIII medical material for prepositioning programs, including receiving, accountability, and reporting.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Budget Execution Report">
  <ns0:data key="d0">Budget Execution Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Budget Execution Report (SAIF Load Balances) is a weekly report included in MCMC's supply fiscal reports.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Naval Surface Warfare Center Crane Division (NSWC Crane)">
  <ns0:data key="d0">Naval Surface Warfare Center Crane Division (NSWC Crane)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Naval Surface Warfare Center Crane Division (NSWC Crane) is the entity to which the Government conducts small arms reporting and annual Crane verification.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="DNR Unmatched Report">
  <ns0:data key="d0">DNR Unmatched Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DNR Unmatched Report is reconciled daily by MCMC to update and correct error records.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="MCPIC Prepositioning Planning System (PPS)">
  <ns0:data key="d0">MCPIC Prepositioning Planning System (PPS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MCPIC Prepositioning Planning System (PPS) is an application containing AMAL/ADAL ship spread loads used by MCMC for medical management planning.&lt;SEP&gt;MCPIC Prepositioning Planning System (PPS) application is used to find ship spread loads for packing hazardous material.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 4000.2A">
  <ns0:data key="d0">NAVMC 4000.2A</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 4000.2A is a manual referenced for prepositioning eligibility, recall procedures, and packing instructions for materiel.&lt;SEP&gt;NAVMC 4000.2A is a Marine Corps order outlining procedures for supply management, accountability, and prepositioning that MCMC must follow.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="NAVMED P-5132">
  <ns0:data key="d0">NAVMED P-5132</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMED P-5132 is a Navy medical publication referenced for data entry, maintenance procedures, inspections, and equipment management in DMLSS.&lt;SEP&gt;NAVMED P-5132 is a Navy medical publication governing receiving discrepancies, shelf-life items, and chain of custody that MCMC adheres to.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="SF-361 Transportation Discrepancy Report">
  <ns0:data key="d0">SF-361 Transportation Discrepancy Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SF-361 Transportation Discrepancy Report is completed by MCMC for any receiving discrepancies in medical materials.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="True Attainment Rate (TAR)">
  <ns0:data key="d0">True Attainment Rate (TAR)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">True Attainment Rate (TAR) is a calculated percentage measuring the readiness of AMAL/ADAL materiel against fleet standards, excluding deferred and hazardous items.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Prepositioned Attainment Rate">
  <ns0:data key="d0">Prepositioned Attainment Rate</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Prepositioned Attainment Rate is a calculated percentage for materiel prepositioned in capability sets for AMAL/ADAL.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="MCO 4140.5">
  <ns0:data key="d0">MCO 4140.5</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4140.5 is a Marine Corps order on shelf life requirements superseded by MCO 4000.58 in specific areas for MCMC.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="AMAL/ADAL Spread Load">
  <ns0:data key="d0">AMAL/ADAL Spread Load</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">AMAL/ADAL Spread Load (CDRL 5058) is a post-production document provided by MCMC to the Government within 30 days.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="AMAL/ADAL Attainment Status Report">
  <ns0:data key="d0">AMAL/ADAL Attainment Status Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">AMAL/ADAL Attainment Status Report (CDRL 5059) includes true and prepositioned attainment rates, provided post-production by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="AMAL/ADAL Fly-in-Echelon (FIE) Report">
  <ns0:data key="d0">AMAL/ADAL Fly-in-Echelon (FIE) Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">AMAL/ADAL Fly-in-Echelon (FIE) Report (CDRL 5061) details deferred items, shorts, and short shelf life items, provided post-production by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Program Management">
  <ns0:data key="d0">Program Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Program Management requires MCMC to provide program and risk management support in accordance with sections C.1, C.2.A, C.2.B, C.2.C, and C.2.D of the Statement of Work, including phase-out requirements under H-21, priced as FFP for 12 months.&lt;SEP&gt;Firm Fixed Price service for 12 months providing program and risk management support per specified Statement of Work sections, including phase-out requirements.</ns0:data>
  <ns0:data key="d3">chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Production CONUS">
  <ns0:data key="d0">Maintenance Production CONUS</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Maintenance Production (CONUS) requires MCMC to provide resources to execute maintenance activities to established standards in accordance with the Statement of Work, priced as CPFF on an hours basis.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Production OCONUS">
  <ns0:data key="d0">Maintenance Production OCONUS</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Maintenance Production (OCONUS) requires MCMC to provide resources to execute maintenance activities to established standards in accordance with the Statement of Work, priced as CPFF on an hours basis.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Other Direct Costs">
  <ns0:data key="d0">Other Direct Costs</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Other Direct Costs are provided as a unit under COST pricing with no fee applied, for the base ordering period year two.&lt;SEP&gt;Cost reimbursable unit with no fee applied.&lt;SEP&gt;Other Direct Costs proposes costs in accordance with the disclosure statement, including safety equipment and uniforms within specified CLINs, with justification for additional costs.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Data Requirements CDRLs">
  <ns0:data key="d0">Data Requirements CDRLs</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Data Requirements / CDRLs require MCMC to provide all data requirements, reports, and submittals using DD Form 1423-1 as established in the Statement of Work, not separately priced under NSP for the base ordering period year two.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="COST">
  <ns0:data key="d0">COST</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">COST is applied to travel and other direct costs without fee or markups during the base ordering period two.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="NSP">
  <ns0:data key="d0">NSP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NSP is Not Separately Priced applied to data requirements / CDRLs during the base ordering period year two.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Section H-8.3">
  <ns0:data key="d0">Section H-8.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-8.3 specifies that the same ratio of fee awarded in the initial contract award will be used in any task orders issued for contingency/exercise/emerging requirements fixed fee.&lt;SEP&gt;Contract section specifying the fee ratio method for task orders in contingency, exercise, and emerging requirements.</ns0:data>
  <ns0:data key="d3">chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="FAR 16.306(d)(2)">
  <ns0:data key="d0">FAR 16.306(d)(2)</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 16.306(d)(2) governs the CPFF level of effort for applicable contract line items.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Two">
  <ns0:data key="d0">Base Ordering Period Two</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Base Ordering Period Two is the contractual period for option CLINs 5004 through 5007 and subsequent similar items, covering services provided by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="PSC R706">
  <ns0:data key="d0">PSC R706</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">PSC CD: R706 is the product service code assigned to all listed supplies and services.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Overtime Premium">
  <ns0:data key="d0">Overtime Premium</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Premium compensation for overtime labor, excluded from fee calculation in Other Logistics Support.&lt;SEP&gt;Overtime Premium is not subject to fee in the CPFF structure for Other Logistics Support.</ns0:data>
  <ns0:data key="d3">chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Task Orders">
  <ns0:data key="d0">Task Orders</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Task orders are issued under the contract with fixed fee determined using the same ratio as the initial contract award per Section H-8.3.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="Initial Contract Award">
  <ns0:data key="d0">Initial Contract Award</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Initial contract award establishes the fee ratio applied to contingency/exercise/emerging requirements fixed fee in task orders.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="CLIN 5004">
  <ns0:data key="d0">CLIN 5004</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">CLIN 5004 covers hours of Other Logistics Support under CPFF for Base Ordering Period Two.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
<ns0:node id="CLIN 5005">
  <ns0:data key="d0">CLIN 5005</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">CLIN 5005 covers task of Travel under COST for Base Ordering Period Two.</ns0:data>
  <ns0:data key="d3">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841112</ns0:data>
</ns0:node>
