  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 10.B mandates compliance with 29 CFR 1910 for occupational safety.</ns0:data>
  <ns0:data key="d8">general industry standards,regulatory adherence</ns0:data>
  <ns0:data key="d9">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
