  <ns0:data key="d11">1759841357</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="DLA">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Government coordinates Class I/MRE replenishment with DLA after T-AKE exercises.</ns0:data>
  <ns0:data key="d8">Class I support,replenishment coordination</ns0:data>
