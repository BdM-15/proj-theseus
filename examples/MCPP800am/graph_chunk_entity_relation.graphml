  <ns0:data key="d0">Alpha</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Alpha is a site where parent TAMCN military equipment with Li-Ion hold-up batteries is installed.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
