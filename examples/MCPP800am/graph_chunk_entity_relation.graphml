<ns0:edge source="Section H-8.3" target="Task Orders">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H-8.3 requires the same fee ratio from the initial contract award to be used in any task orders issued for fixed fee determination.</ns0:data>
  <ns0:data key="d8">consistency,fee calculation</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
