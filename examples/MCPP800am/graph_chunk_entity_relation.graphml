<ns0:edge source="Marine Corps Logistics Command (LOGCOM)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC assists LOGCOM with internal testing samples for APSR validation, including possession confirmation within five days.</ns0:data>
  <ns0:data key="d8">internal testing,support</ns0:data>
