  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841241</ns0:data>
</ns0:edge>
<ns0:edge source="6.D" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy Containerized Capset Production is managed by the MCMC as outlined in section 6.D.</ns0:data>
  <ns0:data key="d8">containerized production,management</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841241</ns0:data>
</ns0:edge>
<ns0:edge source="Maritime Prepositioning Force (MPF)" target="SECTION C.3 – MAINTENANCE ACTIVITIES">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">SECTION C.3 delineates maintenance requirements during the MPF Maintenance Cycle for equipment support.</ns0:data>
  <ns0:data key="d8">maintenance,support</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841420</ns0:data>
</ns0:edge>
<ns0:edge source="Maritime Prepositioning Force (MPF)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides supply, fiscal, and medical management support to Maritime Prepositioning Force (MPF), including shelf-life and production documents.</ns0:data>
  <ns0:data key="d8">management,support</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841458</ns0:data>
</ns0:edge>
<ns0:edge source="Continuation of Essential Contractor Services" target="Essential Contractor Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The clause assigns the contractor responsibility to perform essential contractor services during crisis situations as directed by the Contracting Officer.</ns0:data>
  <ns0:data key="d8">crisis performance,responsibility</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841218</ns0:data>
</ns0:edge>
<ns0:edge source="Continuation of Essential Contractor Services" target="Notice of Continuation of Essential Contractor Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Notice provision references definitions from the Continuation clause for essential contractor services and mission-essential functions.</ns0:data>
  <ns0:data key="d8">definitions,reference</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841220</ns0:data>
</ns0:edge>
<ns0:edge source="Continuation of Essential Contractor Services" target="Crisis Situations">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The clause mandates performance of essential services during crisis situations, with provisions for notification and adjustments.</ns0:data>
  <ns0:data key="d8">continuity,performance obligation</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841227</ns0:data>
</ns0:edge>
<ns0:edge source="Notice of Continuation of Essential Contractor Services" target="Essential Contractor Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The provision requires the offeror to submit a plan for continuing essential contractor services during crises, covering personnel, resources, and challenges.</ns0:data>
  <ns0:data key="d8">continuity,planning</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841219</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="General Services Administration">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The clause mandates following terms of GSA schedules and agreements when placing orders for supplies and services.</ns0:data>
  <ns0:data key="d8">compliance,procurement procedures</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841219</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="Federal Supply Schedules">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Ordering from Government Supply Sources requires following terms of Federal Supply Schedules, including authorizations and statements.</ns0:data>
  <ns0:data key="d8">compliance,ordering procedure</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841227</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="Personal Property Rehabilitation Price Schedules">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Ordering from Government Supply Sources applies to Personal Property Rehabilitation Price Schedules with specific order inclusions.</ns0:data>
  <ns0:data key="d8">compliance,ordering procedure</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841227</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="Enterprise Software Agreements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Ordering from Government Supply Sources specifies that Enterprise Software Agreements control price reductions and are governed by Federal Supply Schedule contracts.</ns0:data>
  <ns0:data key="d8">governance,ordering procedure</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="GSA Form 1948-A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Ordering from Government Supply Sources mandates use of GSA Form 1948-A for orders from GSA Self-Service Stores.</ns0:data>
  <ns0:data key="d8">compliance,ordering tool</ns0:data>
  <ns0:data key="d9">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="Ordering from Government Supply Sources" target="Defense Logistics Management System">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Ordering from Government Supply Sources requires use of DLMS supplements for non-reimbursable requisitions and receipts.</ns0:data>
  <ns0:data key="d8">compliance,electronic transaction</ns0:data>
