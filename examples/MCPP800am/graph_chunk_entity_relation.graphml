<ns0:edge source="MCMC" target="Navy Consolidated Memorandum Receipt">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Navy Consolidated Memorandum Receipt for on-island PEIs by the fifth business day of each quarter.</ns0:data>
  <ns0:data key="d8">receipt management,reporting</ns0:data>
