  <ns0:data key="d11">1759841488</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Solid Waste Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">#&gt;|The MCMC complies with Solid Waste Management requirements, including recycling per the MCSF-BI plan.</ns0:data>
  <ns0:data key="d8">disposal,recycling</ns0:data>
