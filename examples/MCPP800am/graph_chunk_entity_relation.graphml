  <ns0:data key="d11">1759841218</ns0:data>
</ns0:edge>
<ns0:edge source="WEBVLIPS" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses WEBVLIPS for research in receipt validations and tracer actions.</ns0:data>
  <ns0:data key="d8">research,validation</ns0:data>
