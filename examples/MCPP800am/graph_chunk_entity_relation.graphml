  <ns0:data key="d11">1759841220</ns0:data>
</ns0:edge>
<ns0:edge source="DoD 4500.32-R" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC performs receiving functions in line with DoD 4500.32-R.</ns0:data>
  <ns0:data key="d8">compliance,receiving</ns0:data>
