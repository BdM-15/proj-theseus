<ns0:edge source="MCMC" target="Hazard Communication (HAZCOM) Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC develops, implements, and maintains the Hazard Communication Program in accordance with 29 CFR 1910.1200 and MCO 5100.29.</ns0:data>
  <ns0:data key="d8">development,implementation</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
