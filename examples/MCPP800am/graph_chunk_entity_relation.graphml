</ns0:node>
<ns0:node id="Principal">
  <ns0:data key="d0">Principal</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Principal refers to an officer, director, owner, partner, or person with primary management or supervisory responsibilities within a business entity.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
