<ns0:edge source="UM 4000-125" target="Section 7.F">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 7.F directs corrective maintenance on MPE/S in accordance with UM 4000-125.</ns0:data>
  <ns0:data key="d8">maintenance guidance</ns0:data>
