<ns0:edge source="MCMC" target="NSTM 613">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance and inspections on wire and fiber rope and rigging for Navy Watercraft IAW NSTM 613.&lt;SEP&gt;MCMC performs maintenance and inspections on wire and fiber rope using NSTM 613 for Navy Watercraft.</ns0:data>
  <ns0:data key="d8">compliance,inspection guidance,inspections,rigging maintenance</ns0:data>
