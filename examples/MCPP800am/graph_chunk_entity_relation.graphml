  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Subsection 10.B.5 aligns VPP participation with OSHA standards and evaluation checklists.</ns0:data>
  <ns0:data key="d8">OSHA integration,safety evaluation</ns0:data>
