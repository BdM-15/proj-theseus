  <ns0:data key="d11">1759841502</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Water Discharge Form">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses the Water Discharge Form to obtain approval for all water discharges.</ns0:data>
