<ns0:edge source="MCMC" target="Test, Measurement, and Diagnostic Equipment (TMDE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures calibration of TMDE used for ME and CESE assets during production maintenance phase per UM 4000-125 and FEDLOG OTC.</ns0:data>
  <ns0:data key="d8">calibration services,inventory control</ns0:data>
