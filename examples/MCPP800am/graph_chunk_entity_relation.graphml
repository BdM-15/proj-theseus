  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Navy INLS, MPFUB, LARC, ABLTS and LCM-8 Class IX Attainment and Shortage Report five business days after production completion.</ns0:data>
  <ns0:data key="d8">attainment tracking,reporting</ns0:data>
