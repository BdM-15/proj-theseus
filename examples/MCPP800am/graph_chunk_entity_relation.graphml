</ns0:edge>
<ns0:edge source="MCMC" target="Program Manager">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides an on-site Program Manager with required experience to oversee overall management and coordination of logistics services.</ns0:data>
  <ns0:data key="d8">management,provision</ns0:data>
