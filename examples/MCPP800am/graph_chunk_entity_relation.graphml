</ns0:edge>
<ns0:edge source="IPACK" target="CmdBul 3162 Data Standards">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CmdBul 3162 Data Standards govern data accuracy requirements for IPACK orders and metadata updates.</ns0:data>
  <ns0:data key="d8">accuracy,compliance</ns0:data>
