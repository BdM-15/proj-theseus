  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841475</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Unit Deployment Listing (UDL)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC produces Unit Deployment Listing (UDL) via MCPIC for embarked equipment and supplies at NSN level.</ns0:data>
  <ns0:data key="d8">data production,management</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841475</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Exercise and Surge Support">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides Navy Exercise and Surge Support including personnel and maintenance for prepositioning assets as per Exercise Support Letter.&lt;SEP&gt;MCMC provides personnel and resources for Navy Exercise and Surge Support using MPE/S.</ns0:data>
  <ns0:data key="d8">deployment,resource deployment,support provision</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841476</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NAVFOR RO">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC documents the issue and receipt of MPE/S to NAVFOR RO using the Government-issued Consolidated Asset Listing.</ns0:data>
  <ns0:data key="d8">asset issuance,documentation</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841476</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="JLTI">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC accounts for Temporary Equipment Folders and keys prior to and after the JLTI process during MPS operations.</ns0:data>
  <ns0:data key="d8">accounting,process compliance</ns0:data>
