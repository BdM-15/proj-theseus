  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CAS Disclosure Statement is a required submission for contractors subject to Cost Accounting Standards, describing the accounting system.&lt;SEP&gt;Cas Disclosure Statement is a required submission for certain contractors, affecting accounting system description in proposals.</ns0:data>
  <ns0:data key="d3">chunk-55bcb4486837a866d3ae601a0bfee839&lt;SEP&gt;chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
