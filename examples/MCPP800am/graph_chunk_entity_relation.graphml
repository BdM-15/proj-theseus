  <ns0:data key="d11">1759841527</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DoD Directive 5220.22-M">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC and subcontractors adhere to DoD Directive 5220.22-M for industrial security.</ns0:data>
  <ns0:data key="d8">security compliance</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
