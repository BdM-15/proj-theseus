  <ns0:data key="d11">1759841354</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="LARCs">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC reports on status and provides familiarization training for LARCs.&lt;SEP&gt;MCMC conducts POL replacement, rigging inspections, and corrosion control on LARCs in various phases.</ns0:data>
  <ns0:data key="d8">inspection,maintenance,reporting,training</ns0:data>
  <ns0:data key="d9">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841354</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Phase Delta">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC submits reports, stages ship sets, and performs operational checks during Phase Delta for Navy Watercraft backload and readiness.&lt;SEP&gt;MCMC executes POL replacement, load testing, maintenance, and delivery tasks during Phase Delta.</ns0:data>
  <ns0:data key="d8">reporting,scheduling,staging,task execution</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841355</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Phase Bravo">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance tasks like corrosion control and high pressure washing during Phase Bravo on Navy Watercraft and ABLTS.&lt;SEP&gt;MCMC performs oil sampling, equipage inspection, and operational testing during Phase Bravo.</ns0:data>
  <ns0:data key="d8">inventory,task performance,testing</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841355</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Phase Charlie">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts approved corrective maintenance and coating repairs during Phase Charlie.</ns0:data>
  <ns0:data key="d8">corrective maintenance,corrosion control</ns0:data>
  <ns0:data key="d9">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841355</ns0:data>
</ns0:edge>
