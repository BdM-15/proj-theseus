</ns0:edge>
<ns0:edge source="Corrective Maintenance (CM)" target="Organizational Maintenance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Organizational Maintenance is a component of Corrective Maintenance (CM) in the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d8">inclusion,maintenance level</ns0:data>
