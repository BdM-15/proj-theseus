<ns0:edge source="MCMC" target="Section 11.E">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 11.E assigns MCMC tasks for network administration, COOP updates, and data backup and restoration for Blount Island LAN/BAN/WAN.</ns0:data>
  <ns0:data key="d8">backup,network administration</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841538</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 11.F">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 11.F requires MCMC to provide recommendations for IT systems and prepare procurement forms in accordance with FAR and USMC procedures.</ns0:data>
  <ns0:data key="d8">life cycle management,procurement</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
