<ns0:node id="52.204-23 Prohibition on Contracting for Hardware, Software, and Services Developed or Provided by Kaspersky Lab Covered Entities">
  <ns0:data key="d0">52.204-23 Prohibition on Contracting for Hardware, Software, and Services Developed or Provided by Kaspersky Lab Covered Entities</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-23 Prohibition on Contracting for Hardware, Software, and Services Developed or Provided by Kaspersky Lab Covered Entities is a FAR clause incorporated by reference, dated DEC 2023.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.237-3">
  <ns0:data key="d0">FAR 52.237-3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.237-3 Continuity of Services is incorporated by reference to support transition requirements for maintaining service continuity.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Kaspersky Lab Covered Entities">
  <ns0:data key="d0">Kaspersky Lab Covered Entities</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Kaspersky Lab Covered Entities are entities prohibited from developing or providing hardware, software, or services under the contract as per incorporated clauses.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Incumbent">
  <ns0:data key="d0">Incumbent</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Incumbent is the current contractor responsible for phase-out tasks, maintaining operations until transfer, providing records and training, and cooperating in joint inventories during transition.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Successor">
  <ns0:data key="d0">Successor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Successor is the new contractor responsible for phase-in tasks, assuming accountability for government property, conducting inventories, and providing qualified personnel to ensure continuity during transition.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Prepositioning Objective (PO)">
  <ns0:data key="d0">Prepositioning Objective (PO)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Prepositioning Objective equipment and supplies cannot be used by MCMC for organic support without prior government approval.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Contract Attachment 6.a">
  <ns0:data key="d0">Contract Attachment 6.a</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Contract Attachment 6.a contains the list of Government Furnished Equipment.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Government Furnished Facilities (GFF)">
  <ns0:data key="d0">Government Furnished Facilities (GFF)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Government Furnished Facilities are provided by the Marine Corps for MCMC operations, with a list in Contract Attachment 6.b.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Contract Attachment 6.b">
  <ns0:data key="d0">Contract Attachment 6.b</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Contract Attachment 6.b contains the list of Government Furnished Facilities.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Facility Planning Committee">
  <ns0:data key="d0">Facility Planning Committee</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Facility Planning Committee coordinates new requirements for space, modifications, and changes to facilities and equipment with BICmd/MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="United States Marine Corps (USMC)">
  <ns0:data key="d0">United States Marine Corps (USMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">United States Marine Corps provides facilities, equipment, and oversight for prepositioning programs and expects professional workplace standards from MCMC.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Trondelog Region">
  <ns0:data key="d0">Trondelog Region</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Trondelog Region of Norway is the primary area where MCPP-N services are provided using government facilities and equipment.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Republic of the Philippines">
  <ns0:data key="d0">Republic of the Philippines</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Republic of the Philippines hosts MCPP-PHIL operations, requiring compliance with local laws and regulations.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Philippine Security and Exchange Commission">
  <ns0:data key="d0">Philippine Security and Exchange Commission</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Philippine Security and Exchange Commission is the entity with which MCMC must register for licensure and credentials in the Philippines.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="SBMA">
  <ns0:data key="d0">SBMA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">SBMA is the Subic Bay Metropolitan Authority, regulating operations and requiring MCMC compliance for MCPP-PHIL.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Philippine Certificate of Registration and Tax Exemption (CRTE)">
  <ns0:data key="d0">Philippine Certificate of Registration and Tax Exemption (CRTE)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Philippine Certificate of Registration and Tax Exemption is required for MCMC to attain status as a licensed importer/exporter in the Philippines.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="International Traffic in Arms Regulations">
  <ns0:data key="d0">International Traffic in Arms Regulations</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">International Traffic in Arms Regulations require MCMC compliance for export of defense articles, including obtaining a DSP-5 License.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="U.S. Directorate of Defense Trade Controls">
  <ns0:data key="d0">U.S. Directorate of Defense Trade Controls</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Directorate of Defense Trade Controls issues the DSP-5 License for permanent export of unclassified defense articles.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="DSP-5 License">
  <ns0:data key="d0">DSP-5 License</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">DSP-5 License is required for MCMC to export unclassified defense articles, with application submission to the government within 30 days of contract award.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Prepositioning Programs (MCPP)">
  <ns0:data key="d0">Marine Corps Prepositioning Programs (MCPP)</ns0:data>
  <ns0:data key="d1">strategic_theme</ns0:data>
  <ns0:data key="d2">Marine Corps Prepositioning Programs encompass MPS, MCPP-N, and MCPP-PHIL, with MCMC providing full logistics support for equipment maintenance and materiel management.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="Statement of Work (SOW)">
  <ns0:data key="d0">Statement of Work (SOW)</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">The Statement of Work outlines requirements for Navy services, maintenance, and support under the MCPP II contract.&lt;SEP&gt;Statement of Work (SOW) is the document containing outlined requirements that the MCMC must meet to ensure equipment readiness.&lt;SEP&gt;Statement of Work delineates tasks for MCMC including maintenance, logistics, and support for prepositioning programs, with attachments defining plans and schedules.&lt;SEP&gt;Statement of Work (SOW) describes the scope, magnitude, and complexities of the logistics services required in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b&lt;SEP&gt;chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="MMC Notional Plan of Action &amp; Milestones (POA&amp;M)">
  <ns0:data key="d0">MMC Notional Plan of Action &amp; Milestones (POA&amp;M)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MMC Notional Plan of Action &amp; Milestones outlines the phasing of MCMC operations conducted with the government.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="American Bureau of Shipping (ABS)">
  <ns0:data key="d0">American Bureau of Shipping (ABS)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">American Bureau of Shipping requirements drive MPS rotation schedules for hull inspections and certifications.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachments C.1-8">
  <ns0:data key="d0">SOW Attachments C.1-8</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachments C.1-8 contains the MMC-14 schedule and proposed MMC-15 schedule.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841098</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.1-9">
  <ns0:data key="d0">SOW Attachment C.1-9</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.1-9 details projected notional quantities of watercraft for each maintenance phase.&lt;SEP&gt;SOW Attachment C.1-9 is the Navy Watercraft Plan.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Department of Defense (DoD)">
  <ns0:data key="d0">Department of Defense (DoD)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Department of Defense operating forces receive operational logistics services from MCMC to support missions in expeditionary warfare.&lt;SEP&gt;The Department of Defense (DoD) issues policies, instructions, and directives that the MCMC must comply with for environmental requirements.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Navy Support Element (NSE)">
  <ns0:data key="d0">Navy Support Element (NSE)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy Support Element equipment is supported by MCMC for maintenance and logistics in the MPF Program.&lt;SEP&gt;Navy Support Element (NSE) is an element whose equipment, including rotational spares and management stock, is supported by MCMC under the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Naval Construction Element (NCE)">
  <ns0:data key="d0">Naval Construction Element (NCE)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Naval Construction Element equipment is outlined in Tables of Allowance and supported by MCMC.&lt;SEP&gt;Naval Construction Element (NCE) is an element whose equipment, including rotational spares and management stock, is supported by MCMC under the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Tables of Allowance (TOA)">
  <ns0:data key="d0">Tables of Allowance (TOA)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Tables of Allowance assign equipment for Navy Support Element and Naval Construction Element in the MPF Program.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Communications Security Materiel/Controlled Cryptographic Items (COMSEC/CCI)">
  <ns0:data key="d0">Communications Security Materiel/Controlled Cryptographic Items (COMSEC/CCI)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Communications Security Materiel/Controlled Cryptographic Items require U.S. personnel accountability and maintenance in MCPP-N.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="MCPP-N KMI Local Element (LE)">
  <ns0:data key="d0">MCPP-N KMI Local Element (LE)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">MCPP-N KMI Local Element subaccount is maintained by MCMC with two-person integrity for COMSEC/CCI.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Naval Communications Security Materiel System (NCMS)">
  <ns0:data key="d0">Naval Communications Security Materiel System (NCMS)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Naval Communications Security Materiel System supplies hardware and software for records and files in Norway.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Emergency Action Plan (EAP)">
  <ns0:data key="d0">Emergency Action Plan (EAP)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Emergency Action Plan for COMSEC materiel must be established, tested, and maintained by MCMC in Norway.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Continental United States (CONUS)">
  <ns0:data key="d0">Continental United States (CONUS)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Continental United States facilities are primarily used by MCMC for maintenance and logistics operations.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Outside Continental United States (OCONUS)">
  <ns0:data key="d0">Outside Continental United States (OCONUS)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Outside Continental United States operations include MCPP-N and MCPP-PHIL, with specific support requirements.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Camp Lejeune">
  <ns0:data key="d0">Camp Lejeune</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Camp Lejeune in North Carolina is a CONUS installation for potential maintenance support on Remain Behind Equipment.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Camp Pendleton">
  <ns0:data key="d0">Camp Pendleton</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Camp Pendleton in California is a CONUS installation for potential maintenance support.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="USINDOPACOM AOR">
  <ns0:data key="d0">USINDOPACOM AOR</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">USINDOPACOM Area of Responsibility includes locations for MCPP-PHIL crisis support.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="U.S. Department of the Navy">
  <ns0:data key="d0">U.S. Department of the Navy</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Department of the Navy communications are protected by COMSEC/CCI prepositioned in Norway under MCPP-N, requiring U.S. personnel accountability.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Key Management Infrastructure (KMI)">
  <ns0:data key="d0">Key Management Infrastructure (KMI)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Key Management Infrastructure supports the Local Element subaccount for COMSEC/CCI management in MCPP-N.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="EKMS-1">
  <ns0:data key="d0">EKMS-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">EKMS-1 governs the maintenance of records and files for COMSEC operations in Norway using NCMS-supplied hardware and software.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Appendix K MPF SOW">
  <ns0:data key="d0">Appendix K MPF SOW</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Appendix K MPF SOW details container management and reporting requirements for MCPP-PHIL operations.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Preventive Maintenance Checks and Services (PMCS)">
  <ns0:data key="d0">Preventive Maintenance Checks and Services (PMCS)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Preventive Maintenance Checks and Services (PMCS) involve scheduled maintenance actions on ME and CESE assets, including filter replacements and testing, during designated production periods.&lt;SEP&gt;Preventive Maintenance Checks and Services are performed by MCMC on MCPP-PHIL equipment at the field-level echelon.</ns0:data>
  <ns0:data key="d3">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Corrective Maintenance (CM)">
  <ns0:data key="d0">Corrective Maintenance (CM)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Corrective Maintenance (CM) involves actions to return ME and CESE to Mission Capable (MC) status at Field Level of Maintenance (LOM).&lt;SEP&gt;Corrective Maintenance (CM) includes organizational, intermediate, and depot level maintenance as part of the Lighterage Maintenance Model for Navy watercraft.&lt;SEP&gt;CM includes organizational, intermediate, and depot level maintenance within the Lighterage Maintenance Model across various phases.&lt;SEP&gt;Corrective Maintenance is provided by MCMC within the field-level echelon for MCPP-PHIL assets.&lt;SEP&gt;Corrective Maintenance (CM) is limited to COMM/ELEC assets, including CCI/KMI, at MCPP-N sites.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="DoDI 3020.37">
  <ns0:data key="d0">DoDI 3020.37</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoDI 3020.37 Section 6 classifies all services provided in support of MCPP-PHIL as mission essential.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Remain Behind Equipment (RBE)">
  <ns0:data key="d0">Remain Behind Equipment (RBE)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Remain Behind Equipment at CONUS installations requires maintenance support from BICmd during Marine Corps contingencies.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Program Management Team">
  <ns0:data key="d0">Marine Corps Program Management Team</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Program Management Team tasks BICmd for overflow maintenance and workforce sustainment during contingencies or schedule changes.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Exercise Support Letters">
  <ns0:data key="d0">Exercise Support Letters</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Exercise Support Letters outline personnel and resource requirements for MCMC support in Marine Corps and Navy exercises utilizing MCPP assets.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="MMC-14 Schedule">
  <ns0:data key="d0">MMC-14 Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MMC-14 Schedule details timelines for MPS rotations tied to dry dock periods and is included in SOW Attachments C.1-8.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="MMC-15 Schedule">
  <ns0:data key="d0">MMC-15 Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MMC-15 Schedule is a proposed plan for future MPS rotations and is included in SOW Attachments C.1-8.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Production Planning and Execution Team (P-PET)">
  <ns0:data key="d0">Production Planning and Execution Team (P-PET)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Production Planning and Execution Team conducts government-led meetings to monitor MCMC materiel management and production activities.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Joint Quality Management Support System (QMSS)">
  <ns0:data key="d0">Joint Quality Management Support System (QMSS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Joint Quality Management Support System documents the quality of services and products delivered by MCMC and used jointly with BICmd.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Business Operating Systems/Accountable Property Systems of Record">
  <ns0:data key="d0">Business Operating Systems/Accountable Property Systems of Record</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Business Operating Systems/Accountable Property Systems of Record are used for accurate identification and accountability of MCPP assets as specified in paragraph 2.C.1.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.A.8.A">
  <ns0:data key="d0">Section 1.A.8.A</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.A.8.A specifies that most MCPP-N services are provided in the Trondelog region using government facilities, GFE/M, and common hand tools.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.A.8.B">
  <ns0:data key="d0">Section 1.A.8.B</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.A.8.B details MCPP-PHIL services in Subic Bay, including responsibilities for clearances, labor, compliance, and licensure.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B">
  <ns0:data key="d0">Section 1.B</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B outlines the overall MCPP scope, including logistics services for MPS, MCPP-N, and MCPP-PHIL, with provisions for equipment and supplies.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.1">
  <ns0:data key="d0">Section 1.B.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.1 describes MMC operations, including time-sensitive maintenance during MPS dry dock periods in CONUS-based facilities up to intermediate level.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.2">
  <ns0:data key="d0">Section 1.B.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.2 covers program sustainment through materiel management operations like quality control, supply, and COSIS in CONUS facilities.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.3">
  <ns0:data key="d0">Section 1.B.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.3 specifies shipboard operations aboard MPS and ROS ships, including COSIS and maintenance at off-load sites.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841099</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.4">
  <ns0:data key="d0">Section 1.B.4</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.4 details Navy support requirements for NSE and NCE equipment under the MPF Program, including maintenance and readiness standards in Section C.6.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.5">
  <ns0:data key="d0">Section 1.B.5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.5 addresses OCONUS operations for MCPP-N and MCPP-PHIL, including COMSEC management and asset issuance.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.5.a">
  <ns0:data key="d0">Section 1.B.5.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.5.a outlines MCPP-N responsibilities for COMSEC/CCI accountability, storage, transportation, and EAP maintenance in Norway.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.5.b">
  <ns0:data key="d0">Section 1.B.5.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.5.b describes MCPP-PHIL functions like inventory management, PMCS, COSIS, CM, shipping, and mission essential support per DoDI 3020.37.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.7">
  <ns0:data key="d0">Section 1.B.7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.7 covers military contingency support worldwide, including deployed in-theater logistics and CONUS-based support for RBE.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.7.a">
  <ns0:data key="d0">Section 1.B.7.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.7.a details deployed contingency support, such as equipment rotation, retrograde, and deployment to off-load sites or theaters.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.7.b">
  <ns0:data key="d0">Section 1.B.7.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.7.b specifies CONUS-based support for RBE maintenance at installations like Camp Lejeune and Camp Pendleton, including overflow from depots.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.B.8">
  <ns0:data key="d0">Section 1.B.8</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.B.8 requires MCMC to provide exercise support per Exercise Support Letters, including personnel sourcing and costs to specific CLINs.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.C">
  <ns0:data key="d0">Section 1.C</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.C categorizes work requirements into Sustainment Operations and MMC Operations, with reporting to a common access location and quality via QMSS.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.C.1">
  <ns0:data key="d0">Section 1.C.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.C.1 addresses sustainment operations supporting core MMC requirements, including issue identification and reporting.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 1.C.2">
  <ns0:data key="d0">Section 1.C.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 1.C.2 covers MMC operations for materiel management and refurbishment, monitored via P-PET and Quality Meetings.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section C.6">
  <ns0:data key="d0">Section C.6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.6 supersedes other sections concerning Navy requirements and outlines Navy services.&lt;SEP&gt;Section C.6 identifies standards for Navy products and services delivered by MCMC.&lt;SEP&gt;Section C.6 sets forth requirements related to Navy Prepositioning Department assets supporting the Marine Corps Prepositioning Program.&lt;SEP&gt;Section C.6 outlines specific maintenance requirements for Navy CESE assets.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section C.7">
  <ns0:data key="d0">Section C.7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.7 specifies shipboard logistics requirements for MCMC performance.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="CLIN X005">
  <ns0:data key="d0">CLIN X005</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">CLIN X005 is a contract line item for allocating travel costs in exercise support.&lt;SEP&gt;CLIN X005 allocates costs for travel in exercise support provided by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="CLIN X006">
  <ns0:data key="d0">CLIN X006</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">CLIN X006 is a contract line item for allocating materials and other direct costs in exercise support.&lt;SEP&gt;CLIN X006 allocates costs for materials, other direct costs, and subcontractor support in exercise support.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Two-Person Integrity Rule">
  <ns0:data key="d0">Two-Person Integrity Rule</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Two-Person Integrity Rule must be maintained by U.S. MCMC personnel for the MCPP-N KMI Local Element during working hours.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Dry Dock Periods">
  <ns0:data key="d0">Dry Dock Periods</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Dry Dock Periods schedule MPS rotations for hull inspections and certifications per ABS requirements, during which MCMC performs time-sensitive maintenance.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Area of Responsibility (AOR)">
  <ns0:data key="d0">Area of Responsibility (AOR)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Area of Responsibility refers to the operational region where squadron capability is degraded when ships are out for maintenance.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Geographic Combatant Commander (GCC)">
  <ns0:data key="d0">Geographic Combatant Commander (GCC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Geographic Combatant Commander relies on full squadron capability, affected by MPS maintenance schedules.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Intermediate Maintenance Activities">
  <ns0:data key="d0">Intermediate Maintenance Activities</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Intermediate Maintenance Activities may receive overflow maintenance support from BICmd to sustain workforce skills.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Depots">
  <ns0:data key="d0">Depots</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Depots may receive overflow maintenance from the Marine Corps Program Management Team during reduced logistics periods.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.34">
  <ns0:data key="d0">Section 6.F.34</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.34 outlines requirements for organizational level corrosion control and coating systems maintenance on Navy Watercraft, LARCs, and ABLTS during Phases Bravo through Delta, including spot maintenance criteria and prioritization.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Tool Control Program">
  <ns0:data key="d0">Tool Control Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Tool Control Program is established and maintained by MCMC for Navy Watercraft Maintenance Center, including LMF, NSC, CSS, and RST, ensuring tools and test equipment are accounted for and replaced with NAV-P approval.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Readiness Report">
  <ns0:data key="d0">Readiness Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Readiness Report (CDRL 6059) is staged and delivered by MCMC with Navy Watercraft ship sets for backload NLT E+3, reporting on staging, preparations, fuel status, weight, and craft remarks.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="INLS Paint Schedule">
  <ns0:data key="d0">INLS Paint Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">INLS Paint Schedule (NAVFAC 1600471) details painting and deck covering requirements for Navy Watercraft maintenance.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Lighterage Milestones and Maintenance Model">
  <ns0:data key="d0">Lighterage Milestones and Maintenance Model</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Lighterage Milestones and Maintenance Model guides high pressure washing and maintenance scheduling for Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Watercraft Monitoring Requirements">
  <ns0:data key="d0">Watercraft Monitoring Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Watercraft Monitoring Requirements (CDRL 6056, SOW Attachment C.6-041) involve systematic inspections and corrections for Navy Watercraft not scheduled for maintenance within 30 days, submitted to NAV-P for approval.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.35">
  <ns0:data key="d0">Section 6.F.35</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.35 requires MCMC to maintain Navy Watercraft, LARCs, and ABLTS in a clean and usable condition in compliance with Section C.9 Port Operations, NSTM 583, INLS SOM, and USDA Regulations.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.36">
  <ns0:data key="d0">Section 6.F.36</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.36 mandates high pressure washing of Navy Watercraft during Phases Bravo or Delta in accordance with the Lighterage Milestones and Maintenance Model to prevent corrosion and remove contaminants.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.37">
  <ns0:data key="d0">Section 6.F.37</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.37 requires MCMC to create, maintain, and execute a Destructive Weather Plan for Navy Watercraft and LARCs to minimize damage from hurricanes or major weather events.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.38">
  <ns0:data key="d0">Section 6.F.38</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.38 establishes requirements for MCMC to maintain a tool control program for the Navy Watercraft Maintenance Center, including checking in and out of tools with NAV-P approval.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.41">
  <ns0:data key="d0">Section 6.F.41</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.41 requires MCMC to comply with Hazardous Material/Hazardous Waste management in accordance with Section 6.T.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.42">
  <ns0:data key="d0">Section 6.F.42</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.42 allows NAV-P personnel and authorized contractors to perform work at MCMC facilities concurrently, with access provided within 24 hours of notification.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.43">
  <ns0:data key="d0">Section 6.F.43</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.43 requires MCMC to provide advance email notification to NAV-P for scheduled QA checks on Watercraft and ABLTS, with varying notice periods based on location from MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.44">
  <ns0:data key="d0">Section 6.F.44</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.44 requires MCMC to monitor and maintain Navy Watercraft in accordance with Watercraft Monitoring Requirements regardless of CONUS location.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.45">
  <ns0:data key="d0">Section 6.F.45</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.45 requires MCMC to participate in Joint Limited Technical Inspections for custody transfer of Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.46">
  <ns0:data key="d0">Section 6.F.46</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.46 outlines procedures for MCMC to prepare Navy Watercraft, INLS, MPFUB, LCM8, and ABLTS for MPS embarkation and backload at MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.47">
  <ns0:data key="d0">Section 6.F.47</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.47 requires MCMC to submit a Watercraft End of Ship Report to NAV-P NLT E-3 during Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.49">
  <ns0:data key="d0">Section 6.F.49</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.49 requires MCMC to safeguard assigned lighterage and watercraft from various damages and maintain a written security plan compliant with NSI 009-72.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.51">
  <ns0:data key="d0">Section 6.F.51</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">#Section 6.F.51 requires MCMC to stage and deliver Navy Watercraft ship sets with Readiness Reports for backload NLT E+3 during Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.52">
  <ns0:data key="d0">Section 6.F.52</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.52 requires MCMC to manage hazardous material inventory at WMC and conduct monthly inspections with reports per 40 CFR.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.53">
  <ns0:data key="d0">Section 6.F.53</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.53 requires MCMC to schedule a shipset production hotwash meeting with NAV-P upon final craft close-out to discuss improvements.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841100</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.54">
  <ns0:data key="d0">Section 6.F.54</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.54 requires MCMC to utilize the Functional Area Breakdown format to report on watercraft mission capability.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Section 6.G">
  <ns0:data key="d0">Section 6.G</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.G outlines MCMC support for external contracts, including data entry, procurement, storage, and shipping services for NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Watercraft End of Ship Report">
  <ns0:data key="d0">Watercraft End of Ship Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Watercraft End of Ship Report (CDRL 6047, SOW Attachment C.6-026) is submitted by MCMC to NAV-P NLT E-3, including incomplete work lists and inventory of unused parts.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Incomplete Work List">
  <ns0:data key="d0">Incomplete Work List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Incomplete Work List is part of CDRL 6047 and includes unaccomplished maintenance items, SYSALTs, FSBs, and CFRs prior to MPS backload.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="USDA Regulations">
  <ns0:data key="d0">USDA Regulations</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">USDA Regulations govern the cleanliness and agricultural inspection compliance for Navy Watercraft, LARCs, and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="NSTM 583">
  <ns0:data key="d0">NSTM 583</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NSTM 583 is a naval ships' technical manual referenced for maintaining Navy Watercraft in a clean and usable condition.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="INLS SOM">
  <ns0:data key="d0">INLS SOM</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">INLS SOM provides operational and maintenance guidelines for Inland Navigation Logistics Support related to Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="40 CFR">
  <ns0:data key="d0">40 CFR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">40 CFR is a federal regulation referenced for hazardous material inventory management, waste handling, and monthly reporting submissions.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Section 6.T">
  <ns0:data key="d0">Section 6.T</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.T addresses Hazardous Material/Hazardous Waste management compliance requirements for MCMC operations.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-041">
  <ns0:data key="d0">SOW Attachment C.6-041</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-041 details Watercraft Monitoring Requirements for inspections and documentation of discrepancies.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="JLTI Custody Transfer Package">
  <ns0:data key="d0">JLTI Custody Transfer Package</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">JLTI Custody Transfer Package (SOW Attachment C.6-044) supports joint inspections for turnover of Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Vessel Offload/Backload Letter of Instruction">
  <ns0:data key="d0">Vessel Offload/Backload Letter of Instruction</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Vessel Offload/Backload Letter of Instruction is provided by BICmd Operations Department for procedures at MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6058">
  <ns0:data key="d0">CDRL 6058</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6058 is the OPTEST form completed and delivered by MCMC within five calendar days after Operational Tests.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Partial Mission Capable">
  <ns0:data key="d0">Partial Mission Capable</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Partial Mission Capable (PMC) is a status for watercraft with some functional areas limited but still partially operational.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Non-Mission Capable">
  <ns0:data key="d0">Non-Mission Capable</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Non-Mission Capable (NMC) is a status for watercraft unable to perform any assigned missions due to functional area deficiencies.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="SYSALT">
  <ns0:data key="d0">SYSALT</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SYSALT refers to System Alterations that are part of maintenance items tracked in reports and incomplete work lists.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="FSB">
  <ns0:data key="d0">FSB</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">FSB refers to Fleet Support Bills included in maintenance tracking and reporting for Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="CFR">
  <ns0:data key="d0">CFR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CFR refers to Condition Found Reports submitted for significant corrosion issues requiring depot level consideration.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="OPTEST">
  <ns0:data key="d0">OPTEST</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">OPTEST encompasses operational tests for Navy Watercraft systems, including technical refresh and upgrades, documented per CDRL 6058.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Request for Proposal M67004-25-R-0007">
  <ns0:data key="d0">Request for Proposal M67004-25-R-0007</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Request for Proposal M67004-25-R-0007 is the solicitation document referenced in questions and comments, covering a base ordering period of 60 months with options.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Industry Day Event">
  <ns0:data key="d0">Industry Day Event</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">The Industry Day Event follows the Site Visit, where verbal answers to questions will be provided in writing.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="L-2 Notice of Organizational Conflict of Interest Avoidance FAR 9.5">
  <ns0:data key="d0">L-2 Notice of Organizational Conflict of Interest Avoidance FAR 9.5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">L-2 Notice of Organizational Conflict of Interest Avoidance FAR 9.5 directs offerors' attention to Section H, Paragraph H-16 relating to Organizational Conflict of Interest.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Section H, Paragraph H-16">
  <ns0:data key="d0">Section H, Paragraph H-16</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H, Paragraph H-16 relates to Organizational Conflict of Interest as referenced in L-2.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="L-4 Proposal Preparation Instructions to Offerors">
  <ns0:data key="d0">L-4 Proposal Preparation Instructions to Offerors</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">L-4 Proposal Preparation Instructions to Offerors prescribes the format, content, and organization of proposals, including nine separate volumes with specific page limits and requirements.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume I Executive Summary">
  <ns0:data key="d0">Volume I Executive Summary</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume I Executive Summary includes an overview, master table of contents, and standard proposal information, with a 10-page limit for the overview.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume II Management Proposal">
  <ns0:data key="d0">Volume II Management Proposal</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume II Management Proposal covers management aspects with a 40-page limit, including standard proposal information.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume III Technical Proposal - USMC">
  <ns0:data key="d0">Volume III Technical Proposal - USMC</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume III Technical Proposal - USMC focuses on USMC technical methodology with a 50-page limit, including standard proposal information.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume IV Technical Proposal - Navy">
  <ns0:data key="d0">Volume IV Technical Proposal - Navy</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume IV Technical Proposal - Navy addresses Navy technical methodology with a 50-page limit, including standard proposal information.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume V Past Performance">
  <ns0:data key="d0">Volume V Past Performance</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume V Past Performance includes past performance information and questionnaires, each with a 10-page limit, plus standard proposal information.&lt;SEP&gt;Volume V Past Performance requires offerors to provide current and accurate past performance information, including validation of contact details and compliance with specified FAR clauses.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume VI Cost/Price Proposal">
  <ns0:data key="d0">Volume VI Cost/Price Proposal</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume VI Cost/Price Proposal contains cost breakdowns, summaries, and supporting data by CLIN and SLIN, with unlimited pages for certain elements.&lt;SEP&gt;Volume VI Cost/Price Proposal includes standard proposal information, cost/price details, summary descriptions, narratives, and supporting data for costs, labor, materials, and subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume VII Small Business Participation and Subcontracting Plan">
  <ns0:data key="d0">Volume VII Small Business Participation and Subcontracting Plan</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume VII Small Business Participation and Subcontracting Plan covers small business participation and plans, with unlimited pages.&lt;SEP&gt;Volume VII Small Business Participation and Subcontracting Plan requires compliance with socio-economic regulations and submission of a participation proposal consistent with subcontracting plan goals.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume VIII Proposal Documentation">
  <ns0:data key="d0">Volume VIII Proposal Documentation</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume VIII Proposal Documentation includes solicitation submissions, required documents, and exceptions, with unlimited pages.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Volume IX Oral Presentation">
  <ns0:data key="d0">Volume IX Oral Presentation</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume IX Oral Presentation involves identification of presenters and briefing materials, limited to 30 slides.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Shipboard MCMC USMC Personnel Staffing">
  <ns0:data key="d0">Shipboard MCMC USMC Personnel Staffing</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Shipboard MCMC USMC Personnel Staffing is a proposal focus area challenging remote locations and operational tempo, requiring innovative solutions for MCPP shipboard requirements.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Watercraft Maintenance Center">
  <ns0:data key="d0">Watercraft Maintenance Center</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Watercraft Maintenance Center is a Navy technical area requiring subcontracted services for intermediate and depot level repairs, impacting maintenance milestones and Navy Capability Sets delivery.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Production Planning and Control">
  <ns0:data key="d0">Production Planning and Control</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Production Planning and Control is an enterprise tool administered by MCMC for creating and maintaining production plans, schedules, and quality controls.&lt;SEP&gt;Production Planning and Control is central to planning and executing maintenance schedules for MCPP mission accomplishment, seeking strategies for scheduling, forecasting, capacity planning, workflow adaptation, and employee performance analysis.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Government Accountable Property System of Record">
  <ns0:data key="d0">Government Accountable Property System of Record</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Government Accountable Property System of Record (APSR) provides data incorporated into accurate scheduling within production planning and control strategies.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period">
  <ns0:data key="d0">Base Ordering Period</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period spans 60 months after the award date, forming the core of the solicitation's performance timeline.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Option 1">
  <ns0:data key="d0">Option 1</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Option 1 is a five-year ordering period exercisable in accordance with FAR 52.217-9.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="Extension of Services">
  <ns0:data key="d0">Extension of Services</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Extension of Services allows for a six-month extension in accordance with FAR 52.217-8.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.217-8">
  <ns0:data key="d0">FAR 52.217-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.217-8 is the clause incorporated for the Ordering Period in the hybrid IDIQ Contract.&lt;SEP&gt;FAR 52.217-8 is the clause governing the six-month extension of contract services.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841101</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.217-9">
  <ns0:data key="d0">FAR 52.217-9</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.217-9 is the clause for exercising the five-year optional ordering period.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.227-7013">
  <ns0:data key="d0">DFARS 252.227-7013</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.227-7013 addresses rights in technical data related to proprietary or patent information in proposals.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.227-7016">
  <ns0:data key="d0">DFARS 252.227-7016</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.227-7016 pertains to rights in technical data and computer software for proprietary information usage.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Small Business Subcontracting Plan">
  <ns0:data key="d0">Small Business Subcontracting Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Small Business Subcontracting Plan requires businesses identified as Other than Small to outline plans to meet small business subcontracting goals, including identification of specific small business types and their roles.&lt;SEP&gt;Small Business Subcontracting Plan sets goals for small business concerns at 20%, small disadvantaged at 5%, woman-owned at 4%, HUBZone at 1%, and service-disabled veteran-owned at 1%.&lt;SEP&gt;Small Business Subcontracting Plan is required in Volume VII for detailing subcontracting commitments.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Cost Model Workbook">
  <ns0:data key="d0">Cost Model Workbook</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Cost Model Workbook is provided at Contract Attachment #7 and used for cost proposal summaries, breakouts, and supporting data.&lt;SEP&gt;Cost Model Workbook is provided at Contract Attachment #7 and required for cost breakdown elements in Volume VI.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Contract Attachment #7">
  <ns0:data key="d0">Contract Attachment #7</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Contract Attachment #7 contains the Cost Model Workbook for proposal cost submissions.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Master Table of Contents">
  <ns0:data key="d0">Master Table of Contents</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Master Table of Contents covers all volumes and is included in Volume I Executive Summary.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Glossary of Abbreviations and Acronyms">
  <ns0:data key="d0">Glossary of Abbreviations and Acronyms</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Glossary of Abbreviations and Acronyms is developed for the entire proposal and provided in each volume.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Solicitation Submission">
  <ns0:data key="d0">Solicitation Submission</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Solicitation Submission in Volume VIII requires inclusion of required documents and exceptions to terms and conditions.&lt;SEP&gt;Solicitation Submission details required documents and procedures for proposal preparation and contract binding.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Consent to Record">
  <ns0:data key="d0">Consent to Record</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Consent to Record is part of Volume IX Oral Presentation requirements.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Adobe Acrobat">
  <ns0:data key="d0">Adobe Acrobat</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Adobe Acrobat is specified for electronic copies of proposals in PDF searchable text format.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Excel">
  <ns0:data key="d0">Microsoft Excel</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Excel is required for cost breakdowns, manning documents, and certain electronic submissions.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Accountable Property Systems of Record">
  <ns0:data key="d0">Accountable Property Systems of Record</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Accountable Property Systems of Record are systems like GCSS-MC and DPAS used for tracking assets requiring maintenance and sustainment.&lt;SEP&gt;Accountable Property Systems of Record (APSR) manage on-hand quantities, physical inventories, and data elements like O/H for reporting.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Dynamics 365">
  <ns0:data key="d0">Microsoft Dynamics 365</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Dynamics 365 serves as the PPC tool for enterprise production planning, including administration, user permissions, and schedule management.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="QMSS">
  <ns0:data key="d0">QMSS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">QMSS is the Quality Management Support System used jointly by MCMC and BICmd to document service quality and performance.&lt;SEP&gt;QMSS is a quality management support system for recording and responding to nonconformities, used for KPI monitoring in cost, schedule, and conformance areas.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="DAI">
  <ns0:data key="d0">DAI</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DAI is an accounting system where MCMC posts requisitions, reconciles records, and manages fiscal transactions.&lt;SEP&gt;DAI is a system for program-wide performance monitoring and measuring, governed by Command ISOs.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="DMLSS">
  <ns0:data key="d0">DMLSS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DMLSS is an IT system within the Defense Medical Logistics Enterprise Solution for medical logistics functions, including inventory and equipment maintenance.&lt;SEP&gt;DMLSS is the Defense Medical Logistics Standard Support system used for data entry, maintenance tracking, and reporting on medical materiel and equipment.&lt;SEP&gt;DMLSS is a software system utilized by MCMC for line-item accountability of medical materials.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="FMIS">
  <ns0:data key="d0">FMIS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FMIS is an IT system mandated by HQMC for non-tactical vehicle equipment management, used for preventive maintenance checks and services.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Section 2.C.1">
  <ns0:data key="d0">Section 2.C.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 2.C.1 describes Business Operating Systems and Accountable Property Systems of Record, including specific tools and their usage requirements.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="KPI">
  <ns0:data key="d0">KPI</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">KPI refers to key performance indicators measuring cost, schedule, and conformance in program management, used in dashboards and reviews.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="CEI">
  <ns0:data key="d0">CEI</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CEI is the Cost Effectiveness Index used in quality meetings to review production planning and execution results.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="SEI">
  <ns0:data key="d0">SEI</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SEI is the Schedule Effectiveness Index used in quality meetings to review production planning and execution results.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Production Planning and Execution Team">
  <ns0:data key="d0">Production Planning and Execution Team</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Production Planning and Execution Team produces the Ship’s/Period of Production Planning Considerations Letter in accordance with CmdO 4850.1.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Care of Supplies in Storage">
  <ns0:data key="d0">Care of Supplies in Storage</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Care of Supplies in Storage is a maintenance activity included in production plans and schedules for MCPP.&lt;SEP&gt;Care of Supplies in Storage (COSIS) is a supply requirement with noted government concerns on staffing adequacy for USMC and Navy elements.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft Master Schedule">
  <ns0:data key="d0">Navy Watercraft Master Schedule</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Navy Watercraft Master Schedule is a continuous rolling three-year plan created and maintained by MCMC as described in Section C.6.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Oracle E-Business Suite">
  <ns0:data key="d0">Oracle E-Business Suite</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Oracle E-Business Suite is a widely used ERP system in commercial industries for supply chain management, maintenance management, and human resource functions, similar to GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Users Manual 4000-125">
  <ns0:data key="d0">Marine Corps Users Manual 4000-125</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Marine Corps Users Manual 4000-125 contains technical requirements and user documentation for functional procedures in executing supply and maintenance using GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="End-of Ship MCMC Performance Review">
  <ns0:data key="d0">End-of Ship MCMC Performance Review</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">The End-of Ship MCMC Performance Review is participated in and responded to by MCMC as described in Section C.2.D and CmdO P5000.11.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Sustainment MCMC Performance Review">
  <ns0:data key="d0">Quarterly Sustainment MCMC Performance Review</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">The Quarterly Sustainment MCMC Performance Review is participated in and responded to by MCMC, focusing on risk and performance, as described in Section C.2.D and CmdO P5000.11.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Headquarters Marine Corps">
  <ns0:data key="d0">Headquarters Marine Corps</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Headquarters Marine Corps (HQMC) approves TOECRs and provides funding plans for GCSS-MC expenditures.&lt;SEP&gt;Headquarters Marine Corps mandates the use of FMIS for non-tactical vehicle equipment management.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Defense Health Agency">
  <ns0:data key="d0">Defense Health Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Defense Health Agency is supported by the DML-ES portfolio, which includes DMLSS for medical logistics functions.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Quality Meeting">
  <ns0:data key="d0">Quality Meeting</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Quality Meeting requires MCMC participation to address six KPIs of Program Management and planned actions for correcting negative trends.&lt;SEP&gt;The Quality Meeting reviews results of production planning and execution in light of Cost Effectiveness Index and Schedule Effectiveness Index.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Site Safety and Health Officer (SSHO)">
  <ns0:data key="d0">Site Safety and Health Officer (SSHO)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">SSHO is a required position with primary duty to prepare and enforce the safety program, possessing specific qualifications including a four-year degree, 5-7 years experience, OSHA 30-hour training, and First Aid/CPR/AED certification.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Accident Prevention Plan (APP)">
  <ns0:data key="d0">Accident Prevention Plan (APP)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">APP is a written site-specific plan prepared in accordance with 29 CFR 1910 and MCO 5100.29, submitted as CDRL 10014, requiring signatures and enforcement as part of the contract.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="MCO 11240.106_">
  <ns0:data key="d0">MCO 11240.106_</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 11240.106_ is a Marine Corps Order outlining standards for vehicle maintenance, inspections, and markings.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841102</ns0:data>
</ns0:node>
<ns0:node id="Weight Handling Equipment (WHE)">
  <ns0:data key="d0">Weight Handling Equipment (WHE)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">WHE includes facility-mounted jib and rail systems requiring a preventive maintenance program to ensure operation, minimize breakdowns, and maximize useful life.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Government-Owned Equipment">
  <ns0:data key="d0">Government-Owned Equipment</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Government-Owned Equipment encompasses vehicles and other items, excluding IT equipment, that must be maintained, repaired, and altered to operational condition.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officer (KO)">
  <ns0:data key="d0">Contracting Officer (KO)</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">KO is the government representative authorizing selective exchange of parts and reviewing submissions like the Accident Prevention Plan.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Fleet Inventory">
  <ns0:data key="d0">Fleet Inventory</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Fleet Inventory is provided in C-10-## and -05, listing equipment to be maintained with associated alpha codes and priorities.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="MCO 5100.29">
  <ns0:data key="d0">MCO 5100.29</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 5100.29 is a Marine Corps order referenced for fire safety, accident reporting, radiation safety, vehicle safety, and other compliance requirements.&lt;SEP&gt;MCO 5100.29 is a Marine Corps Order referenced for hearing conservation, hazard communication, and other safety programs that the MCMC must adhere to.&lt;SEP&gt;MCO 5100.29 is a Marine Corps Order detailing safety and occupational health requirements.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Confined Space Entry Plan">
  <ns0:data key="d0">Confined Space Entry Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Confined Space Entry Plan is developed in accordance with OSHA standards as CDRL 10017, identifying qualified personnel and procedures for hazardous conditions.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Fall Protection and Prevention Plan">
  <ns0:data key="d0">Fall Protection and Prevention Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Fall Protection and Prevention Plan complies with ASSE/SAFE Z359.2 as CDRL 10019, addressing fall hazards and requiring annual inspections.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Activity Hazard Analysis (AHA)">
  <ns0:data key="d0">Activity Hazard Analysis (AHA)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">AHA is prepared for recurring and non-recurring work activities as CDRL 10022, submitted with the APP or prior to work start.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Hot Work Permit">
  <ns0:data key="d0">Hot Work Permit</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Hot Work Permit is obtained from IDIV Safety Office as CDRL 10023 for welding or cutting activities, requiring fire extinguishers and fire watch.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Personal Protective Equipment (PPE)">
  <ns0:data key="d0">Personal Protective Equipment (PPE)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">PPE must be provided in serviceable condition based on hazard assessments, in compliance with 29 CFR 1910 and MCO 5100.29.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Automated External Defibrillators (AEDs)">
  <ns0:data key="d0">Automated External Defibrillators (AEDs)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">AEDs are government-provided devices requiring annual inspections, monthly visual checks, and maintenance per manufacturer instructions.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.A.3.d Maintenance, Facility-Mounted Weight Handling Equipment (WHE)">
  <ns0:data key="d0">10.A.3.d Maintenance, Facility-Mounted Weight Handling Equipment (WHE)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 10.A.3.d outlines requirements for developing and implementing a preventive maintenance program for facility-mounted WHE.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.A.3.e Maintenance (Government-Owned) Equipment">
  <ns0:data key="d0">10.A.3.e Maintenance (Government-Owned) Equipment</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 10.A.3.e specifies maintenance, repair, and alteration of government-owned equipment, including history files and tools provision.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B Safety Requirements">
  <ns0:data key="d0">10.B Safety Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 10.B details compliance with safety and occupational health standards, including provision of SSHO and various plans.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.1 Accident Prevention Plan (APP)">
  <ns0:data key="d0">10.B.1 Accident Prevention Plan (APP)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.1 requires preparation and submission of the APP, including subcontractor safety measures and continuous review.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.1.a Confined Space Entry Plan">
  <ns0:data key="d0">10.B.1.a Confined Space Entry Plan</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.1.a mandates development of a confined space entry plan addressing OSHA standards and rescue procedures.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.1.c Fall Protection and Prevention (FP&amp;P) Plan">
  <ns0:data key="d0">10.B.1.c Fall Protection and Prevention (FP&amp;P) Plan</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.1.c requires a site-specific FP&amp;P plan covering fall hazards, systems, and annual inspections.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.2 Activity Hazard Analysis (AHA)">
  <ns0:data key="d0">10.B.2 Activity Hazard Analysis (AHA)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.2 requires AHAs for work activities, submitted with APP or prior to non-recurring work.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.3 Hot Work">
  <ns0:data key="d0">10.B.3 Hot Work</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.3 outlines permit requirements, personnel training, and designated areas for hot work activities.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.4 Explosive Safety">
  <ns0:data key="d0">10.B.4 Explosive Safety</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.4 specifies compliance with explosive safety regulations, including quarterly personnel reports and work requests.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.6 Personal Protective Equipment (PPE)">
  <ns0:data key="d0">10.B.6 Personal Protective Equipment (PPE)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.6 requires hazard assessments and provision of appropriate PPE to employees.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.7 Automated External Defibrillators (AEDs)">
  <ns0:data key="d0">10.B.7 Automated External Defibrillators (AEDs)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.7 mandates inspections and maintenance of AEDs installation-wide.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="10.B.8 Fire Protection and Prevention">
  <ns0:data key="d0">10.B.8 Fire Protection and Prevention</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.8 requires knowledge of fire alarms, proper storage of combustibles, and maintenance of fire extinguishers.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="IDIV Safety Office">
  <ns0:data key="d0">IDIV Safety Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">IDIV Safety Office receives reports, inventories, and notifications related to safety equipment and incidents from the MCMC.&lt;SEP&gt;IDIV Safety Office issues permits, receives notifications, and oversees safety compliance including hot work and equipment issues.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Voluntary Protection Program (VPP)">
  <ns0:data key="d0">Voluntary Protection Program (VPP)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Voluntary Protection Program (VPP) is an OSHA program in which the MCMC provides representation, employee participation, data, and recommendations for process improvements and compliance.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Multi-Purpose Machines and Material Handling Equipment Plan">
  <ns0:data key="d0">Multi-Purpose Machines and Material Handling Equipment Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Multi-Purpose Machines and Material Handling Equipment Plan is prepared as CDRL 10018, requiring proof of authorization from OEM or engineer for lifts with rigging gear, operator training, and equipment configuration.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Control of Hazardous Energy Program">
  <ns0:data key="d0">Control of Hazardous Energy Program</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Control of Hazardous Energy Program, also known as lockout/tagout, is established as CDRL 10021 to prevent unexpected energization or release of stored energy, complying with 29 CFR 1910.147 and related standards.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="NFPA 51B">
  <ns0:data key="d0">NFPA 51B</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NFPA 51B is a standard for fire prevention during welding, cutting, and other hot work, used for training fire watches and maintaining designated areas.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="CmdO 8020.13">
  <ns0:data key="d0">CmdO 8020.13</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 8020.13 provides command operations guidance for handling ammunition shipments.&lt;SEP&gt;CmdO 8020.13 is a command order outlining explosive safety requirements and regulations applicable to MCMC operations.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="CmdO 8020.10">
  <ns0:data key="d0">CmdO 8020.10</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 8020.10 is a command order providing guidelines for explosive safety compliance in conjunction with other regulations.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Explosive Safety Personnel Report">
  <ns0:data key="d0">Quarterly Explosive Safety Personnel Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quarterly Explosive Safety Personnel Report is submitted as CDRL 10024, listing all personnel for explosive safety purposes by the last business day of each quarter, including changes in schedule or location.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Portable Fire Extinguishers Inventory">
  <ns0:data key="d0">Portable Fire Extinguishers Inventory</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Portable Fire Extinguishers Inventory is maintained and submitted as CDRL 10026 annually and within 30 days of changes, including manufacturer details, serial numbers, types, and weights.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Fire Wardens Roster">
  <ns0:data key="d0">Fire Wardens Roster</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Fire Wardens Roster designates competent primary and alternate Fire Wardens for work areas, submitted as CDRL 10027 annually and within 30 days of personnel changes.&lt;SEP&gt;Fire Wardens Roster (CDRL 10027) identifies primary and alternate competent persons designated as Fire Wardens, submitted annually and within 30 days of changes.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Evacuation Routes">
  <ns0:data key="d0">Evacuation Routes</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Evacuation Routes are provided as maps or floor plans showing entrances, exits, alarms, extinguishers, and muster locations, submitted initially and after changes.&lt;SEP&gt;Evacuation Routes are provided as maps or floor plans showing entrance/exit locations for work/administrative areas, submitted as CDRL 28 within 30 days of award and 10 days after changes.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841103</ns0:data>
</ns0:node>
<ns0:node id="Explosives Safety Office">
  <ns0:data key="d0">Explosives Safety Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Explosives Safety Office issues permits for hot work in areas where explosives are processed, stored, or handled.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="10.B.1.b Multi-Purpose Machines and Material Handling Equipment Plan">
  <ns0:data key="d0">10.B.1.b Multi-Purpose Machines and Material Handling Equipment Plan</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.1.b requires development of a plan for multi-purpose machines and material handling equipment used for suspended lifts, including OEM authorization and safety analysis.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="10.B.1.d Control of Hazardous Energy (lockout/tagout)">
  <ns0:data key="d0">10.B.1.d Control of Hazardous Energy (lockout/tagout)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.1.d mandates establishment of a lockout/tagout program to control hazardous energy sources and prevent injuries from unexpected equipment startup.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="10.B.5 Voluntary Protection Program (VPP)">
  <ns0:data key="d0">10.B.5 Voluntary Protection Program (VPP)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Subsection 10.B.5 requires MCMC participation in the Installation's OSHA VPP, including attendance, data provision, and recommendations per VPP standards.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="ASSE/SAFE Z359.2">
  <ns0:data key="d0">ASSE/SAFE Z359.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ASSE/SAFE Z359.2 is a standard for fall protection requirements, used in preparing the Fall Protection and Prevention Plan.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Cmd SOP 5100.17">
  <ns0:data key="d0">Cmd SOP 5100.17</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Cmd SOP 5100.17 provides procedures for monthly inspection of AEDs in work and administrative areas.&lt;SEP&gt;Cmd SOP 5100.17 is a command standard operating procedure for monthly inspections of AEDs in work/admin areas.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d0">Marine Corps Maintenance Coordinator (MCMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Marine Corps Maintenance Coordinator is responsible for managing ISO containers, conducting inspections, recertifications, maintenance, transportation, distribution, and fiscal accounting within USMC Prepositioning Programs.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="USMC Prepositioning Programs">
  <ns0:data key="d0">USMC Prepositioning Programs</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">USMC Prepositioning Programs encompass programs like MCPP-N and MCPP-PHIL, involving container management and transportation operations overseen by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Container Projection Report (CDRL 5047)">
  <ns0:data key="d0">Quarterly Container Projection Report (CDRL 5047)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Quarterly Container Projection Report details on-hand quantity by type, condition code, and location, washout rates, maintenance requirements, container availability versus requirements, and projected procurement needs, submitted by the last business day of each quarter.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Container Seal Verification Report (CDRL 5048)">
  <ns0:data key="d0">Container Seal Verification Report (CDRL 5048)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Container Seal Verification Report includes container serial number and associated seal number for ammunition containers, endorsed by the MCMC and supervisor, provided within one business day of completion.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="MCPP-N Weekly Equipment Clearance Report (CDRL 5049)">
  <ns0:data key="d0">MCPP-N Weekly Equipment Clearance Report (CDRL 5049)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The MCPP-N Weekly Equipment Clearance Report covers foreign military equipment or materiel transported across the Norwegian border, submitted no later than close of business Wednesday via email.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Outbound Ammunition Container Seal Verification Report (CDRL 5050)">
  <ns0:data key="d0">Outbound Ammunition Container Seal Verification Report (CDRL 5050)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Outbound Ammunition Container Seal Verification Report verifies seals for ammunition containers, accurate to physical serial number and seal number, provided within one business day of completion.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Monthly TOT Balance Report (CDRL 5051)">
  <ns0:data key="d0">Monthly TOT Balance Report (CDRL 5051)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Monthly TOT Balance Report captures Transportation of Things expenditures for the previous month and cumulative year-to-date totals, submitted no later than the third business day of each month.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Contract Cost Plus Fixed Fee and Status Report (CCSR) (CDRL 5057)">
  <ns0:data key="d0">Contract Cost Plus Fixed Fee and Status Report (CCSR) (CDRL 5057)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Contract Cost Plus Fixed Fee and Status Report is submitted monthly or upon request, starting 30 days after contract award, concurrently with invoices, for each Task Order.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Subic Bay Management Authority (SBMA)">
  <ns0:data key="d0">Subic Bay Management Authority (SBMA)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">SBMA governs regulations for MCPP-PHIL equipment shipments in the Philippines, requiring coordinated End User Certificates and Statements of Undertaking.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Department of Foreign Affairs (DFA)">
  <ns0:data key="d0">Department of Foreign Affairs (DFA)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DFA of the Republic of the Philippines treats MCPP-PHIL prepositioned equipment shipments as commercial activity under the 2022 Foreign Investment Act.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="4.H Container Management">
  <ns0:data key="d0">4.H Container Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.H outlines requirements for container inventories, locator files, inspections, recertifications, maintenance, projections, handling, storage, and refrigerated power connectors.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="4.I Transportation and Distribution Management Operations (TMO/DMO)">
  <ns0:data key="d0">4.I Transportation and Distribution Management Operations (TMO/DMO)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.I details transportation management functions, including shipping, receiving, special handling, database maintenance, carrier performance, and expenditure monitoring.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="4.J Fiscal Requirements">
  <ns0:data key="d0">4.J Fiscal Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.J specifies responsibilities for fund management, accounting, funding authorizations, material returns, and required reports like ULO, UMT, and CCSR.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="DLA-DS">
  <ns0:data key="d0">DLA-DS</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DLA-DS handles the disposal of Code H containers where repair costs exceed 65% of acquisition cost, requiring Government approval and documentation upload.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Container Handling Equipment (CHE)">
  <ns0:data key="d0">Container Handling Equipment (CHE)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CHE is utilized alongside MHE for secure container movement per transportation regulations.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Table of Authorized Material Control Number (TAMCN)">
  <ns0:data key="d0">Table of Authorized Material Control Number (TAMCN)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">TAMCN identifies specific items like K4229 and K4230 for refrigerated shipping container power connectors that must be requisitioned and maintained.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="MIL-PRF-131K">
  <ns0:data key="d0">MIL-PRF-131K</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-PRF-131K specifies barrier material used to seal 250V, 4-wire connectors for refrigerated containers prior to embarkation.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="MIL-PRF-22191">
  <ns0:data key="d0">MIL-PRF-22191</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-PRF-22191 defines barrier material for packing the Hubbell 5-wire tactical power connector, which is heat-sealed and stowed in refrigerator units.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="MCO 4600.41B">
  <ns0:data key="d0">MCO 4600.41B</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4600.41B is the Marine Corps Distribution Manual referenced for transportation management shipping and receiving functions.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1348-1A">
  <ns0:data key="d0">DD Form 1348-1A</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1348-1A is a receipt document used in the transportation management database for tracking received shipments.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Norwegian Joint Headquarters (NJHQ)">
  <ns0:data key="d0">Norwegian Joint Headquarters (NJHQ)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NJHQ approves foreign military equipment or materiel transport across the Norwegian border for MCPP-N operations.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="USTRANSCOM">
  <ns0:data key="d0">USTRANSCOM</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">USTRANSCOM sets requirements for shipping equipment, including compliance with customs and agricultural regulations.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Norwegian Customs">
  <ns0:data key="d0">Norwegian Customs</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Norwegian Customs regulates equipment shipments for MCPP-N, requiring accurate documentation and approvals.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="2022 Foreign Investment Act">
  <ns0:data key="d0">2022 Foreign Investment Act</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The 2022 Foreign Investment Act governs commercial activity for MCPP-PHIL prepositioned equipment shipments in the Philippines.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Certificate of Registration and Tax Exemption (CRTE)">
  <ns0:data key="d0">Certificate of Registration and Tax Exemption (CRTE)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">CRTE is required for the MCMC to attain licensed commercial importer status for MCPP-PHIL equipment in the Philippines.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Visiting Forces Agreement (VFA)">
  <ns0:data key="d0">Visiting Forces Agreement (VFA)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">VFA provides tax-exemption certificates for moving MCPP-PHIL equipment from Subic Bay for military exercises or humanitarian assistance.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="U.S. Embassy">
  <ns0:data key="d0">U.S. Embassy</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Embassy coordinates import/export clearances for MCPP-PHIL equipment arriving on U.S. military vessels or moving under VFA.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="MCO 4610.37">
  <ns0:data key="d0">MCO 4610.37</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4610.37 guides transportation management, including cost-effective mode selection and PowerTrack reconciliations.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Norwegian Defense Logistics Organization (NDLO)">
  <ns0:data key="d0">Norwegian Defense Logistics Organization (NDLO)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NDLO receives shipping information for MCPP-N materiel shipments to and from Norway.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="International Traffic in Arms Regulations (ITAR)">
  <ns0:data key="d0">International Traffic in Arms Regulations (ITAR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ITAR regulates MCPP-PHIL commercial import/export clearances alongside Philippine law.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841104</ns0:data>
</ns0:node>
<ns0:node id="Export Administration Regulations (EAR)">
  <ns0:data key="d0">Export Administration Regulations (EAR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">EAR applies to MCPP-PHIL equipment shipments requiring export compliance.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Automatic Identification Technology (AIT)">
  <ns0:data key="d0">Automatic Identification Technology (AIT)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">AIT resources are procured and applied by the MCMC on outbound materiel for tracking.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="PowerTrack">
  <ns0:data key="d0">PowerTrack</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">PowerTrack is reconciled daily by the MCMC with electronic shipment records, with statements provided to BICmd.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Unliquidated Orders Report (ULO)">
  <ns0:data key="d0">Unliquidated Orders Report (ULO)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Unliquidated Orders Report (ULO) is a monthly report provided by MCMC, including reconciliations and validations for current and prior fiscal years.&lt;SEP&gt;ULO is a monthly fiscal report required for tracking unliquidated orders.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Unmatched Transaction Report (UMT)">
  <ns0:data key="d0">Unmatched Transaction Report (UMT)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Unmatched Transaction Report (UMT) is a daily report that MCMC reconciles and updates error records for on a daily basis.&lt;SEP&gt;UMT is a daily report for unmatched financial transactions in supply systems.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Budget Execution Validation (BEV)">
  <ns0:data key="d0">Budget Execution Validation (BEV)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Budget Execution Validation (BEV) is a monthly report that MCMC supports through reviews and actions on unliquidated orders from current and prior years.&lt;SEP&gt;BEV is a monthly report validating budget execution in fiscal operations.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="FAMRS Report">
  <ns0:data key="d0">FAMRS Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">FAMRS Report (General Ledger Status of Funds) is a daily report provided as part of MCMC's fiscal reporting requirements.&lt;SEP&gt;FAMRS Report provides daily status of funds in the general ledger for fiscal accounting.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Budget Execution Report (SAIF Load Balances)">
  <ns0:data key="d0">Budget Execution Report (SAIF Load Balances)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Budget Execution Report is submitted weekly to track SAIF load balances.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Reimbursable Report (General Account Re-Stock)">
  <ns0:data key="d0">Reimbursable Report (General Account Re-Stock)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Reimbursable Report is monthly for general account re-stock activities.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Re-Stock Job Order Number/Financial Information Pointer">
  <ns0:data key="d0">Re-Stock Job Order Number/Financial Information Pointer</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Re-Stock Job Order Number/Financial Information Pointer is an annual report provided by MCMC.&lt;SEP&gt;Re-Stock Job Order Number/Financial Information Pointer is an annual report for financial tracking.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Supported Activities Information File (SAIF)">
  <ns0:data key="d0">Supported Activities Information File (SAIF)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Supported Activities Information File (SAIF) is a ledger within GCSS-MC for recording authorized funding amounts and balances.&lt;SEP&gt;SAIF is the ledger in GCSS-MC used to record and authorize funding amounts for expenditures.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Material Returns Program (MRP)">
  <ns0:data key="d0">Material Returns Program (MRP)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Material Returns Program (MRP) is managed by MCMC, involving preparation of transaction reports, credit billings, and follow-ups for returns.&lt;SEP&gt;MRP involves preparation and management of material returns by the MCMC for supply-related actions.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Phase-In Requirements">
  <ns0:data key="d0">Phase-In Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contractual requirements for the phase-in period, which may result in adjustments to the contract term and cost.</ns0:data>
  <ns0:data key="d3">chunk-4c6c8cc3b4b40997aa333b8fb93d6c6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Phase-Out Requirements">
  <ns0:data key="d0">Phase-Out Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contractual requirements for the phase-out period, which may result in adjustments to the contract term and cost.</ns0:data>
  <ns0:data key="d3">chunk-4c6c8cc3b4b40997aa333b8fb93d6c6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Contract Term Change Clause">
  <ns0:data key="d0">Contract Term Change Clause</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Specific clause numbered (5) stipulating that changes to the contract term of 10 days or more due to phase-in or phase-out requirements require pro-rata revision of the contract cost including fee, based on the price of the latest option year.</ns0:data>
  <ns0:data key="d3">chunk-4c6c8cc3b4b40997aa333b8fb93d6c6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="USN Watercraft">
  <ns0:data key="d0">USN Watercraft</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">USN Watercraft are naval vessels subject to functional area reporting, technical refresh alterations, and maintenance requirements.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Functional Areas">
  <ns0:data key="d0">Functional Areas</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Functional Areas encompass systems such as Craft Equipage, Deck Equipment, Damage Control, Coating System(s), Habitability, Auxiliaries, Hull/Structural, Electrical, Communications/Navigation, Machinery Control System, Ship’s Service Diesel Generator (SSDG), Propulsion, and Main Propulsion Diesel Engine (MPDE) for watercraft.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="PMC">
  <ns0:data key="d0">PMC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">PMC refers to partial mission capable status for craft systems and components.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="NMC">
  <ns0:data key="d0">NMC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NMC refers to non-mission capable status for craft systems and components.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-039">
  <ns0:data key="d0">SOW Attachment C.6-039</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-039 provides Functional Area Breakdown logic for reporting.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="External Contracts Support">
  <ns0:data key="d0">External Contracts Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">External Contracts Support outlines MCMC responsibilities for data entry, procurement, receipt, storage, issuance, and shipping services for external contractors.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="2K Transmittal Form (CDRL 6060)">
  <ns0:data key="d0">2K Transmittal Form (CDRL 6060)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">2K Transmittal Form (CDRL 6060) is used by NAV-P to provide information and data to MCMC for external contractors, as detailed in SOW Attachment C.6-018.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="LARC Maintenance Facility">
  <ns0:data key="d0">LARC Maintenance Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">LARC Maintenance Facility provides training to NWAMS Contractor and AMA NAVMC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="NWAMS Contractor">
  <ns0:data key="d0">NWAMS Contractor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NWAMS Contractor receives LARC familiarization training from the LARC Maintenance Facility.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="AMA NAVMC">
  <ns0:data key="d0">AMA NAVMC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">AMA NAVMC receives LARC familiarization training from the LARC Maintenance Facility.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft Controls System Support (CSS)">
  <ns0:data key="d0">Navy Watercraft Controls System Support (CSS)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Watercraft Controls System Support (CSS) details MCMC tasks for technical refresh alterations, modifications, and maintenance on Navy watercraft.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Technical Refresh (TR) Alterations">
  <ns0:data key="d0">Technical Refresh (TR) Alterations</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Technical Refresh (TR) Alterations involve procuring, assembling, installing, and testing equipment on designated Navy watercraft during Phase Charlie.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Watercraft Master Schedule">
  <ns0:data key="d0">Watercraft Master Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Watercraft Master Schedule directs the timing for TR alterations and installations on Navy watercraft.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="TR Alteration Package (SOW Attachment C.6-046)">
  <ns0:data key="d0">TR Alteration Package (SOW Attachment C.6-046)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TR Alteration Package (SOW Attachment C.6-046) defines equipment for procurement and installation in TR alterations.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Control System Support (CSS) Shipping Report (SOW Attachment C.6-047)">
  <ns0:data key="d0">Control System Support (CSS) Shipping Report (SOW Attachment C.6-047)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Control System Support (CSS) Shipping Report (SOW Attachment C.6-047) is used for shipping TR kits and reporting shipments.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Control System Support Monthly TR Inventory, Kitting, and Delivery Status Report (CDRL 6061)">
  <ns0:data key="d0">Control System Support Monthly TR Inventory, Kitting, and Delivery Status Report (CDRL 6061)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Control System Support Monthly TR Inventory, Kitting, and Delivery Status Report (CDRL 6061) provides monthly status on TR activities.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Notice of Completion (CDRL 6055) (NOC) (SOW Attachment C.6-038)">
  <ns0:data key="d0">Notice of Completion (CDRL 6055) (NOC) (SOW Attachment C.6-038)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Notice of Completion (CDRL 6055) (NOC) (SOW Attachment C.6-038) confirms successful completion of control system integration testing.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Craft Condition Found Report (CDRL 6048) (CFR) (SOW Attachment C.6-048)">
  <ns0:data key="d0">Craft Condition Found Report (CDRL 6048) (CFR) (SOW Attachment C.6-048)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Craft Condition Found Report (CDRL 6048) (CFR) (SOW Attachment C.6-048) documents non-compliance with drawings during TR installations.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Lighterage Milestones (SOW Attachment C.1-3 Phase IV)">
  <ns0:data key="d0">Lighterage Milestones (SOW Attachment C.1-3 Phase IV)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Lighterage Milestones (SOW Attachment C.1-3 Phase IV) align with production cycles for controls system configuration and certification.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Navy Exemptions, Deviations and Waivers">
  <ns0:data key="d0">Navy Exemptions, Deviations and Waivers</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Exemptions, Deviations and Waivers account for tailored requirements for the MPF program, including 3M Inactive Equipment Maintenance, Compass Swing, Navy Oil Analysis Program, Diesel Engine Inspection Program, and Gauge Calibration Requirements.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Navy Shipboard Support">
  <ns0:data key="d0">Navy Shipboard Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Shipboard Support delineates surveillance, maintenance, and logistics services for Navy equipment during afloat phase on MPS.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)">
  <ns0:data key="d0">Maritime Prepositioning Navy Equipment and Supplies (MPE/S)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Navy Equipment and Supplies (MPE/S) are managed, inventoried, and maintained by MCMC during afloat phase.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Navy Small Arms Monthly Inventory Report (CDRL 6082) (SOW Attachment C.6-010)">
  <ns0:data key="d0">Navy Small Arms Monthly Inventory Report (CDRL 6082) (SOW Attachment C.6-010)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Navy Small Arms Monthly Inventory Report (CDRL 6082) (SOW Attachment C.6-010) states physical inventory of Navy weapons onboard MPF Ships.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Operator Level PMCS">
  <ns0:data key="d0">Operator Level PMCS</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Operator Level PMCS is performed on Navy MPE/S assets according to equipment manuals, including during semi-annual start-ups.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841105</ns0:data>
</ns0:node>
<ns0:node id="Navy Surveillance/Stock Checks">
  <ns0:data key="d0">Navy Surveillance/Stock Checks</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Navy Surveillance/Stock Checks include visual inspections of MPE/S every 30 days and specific maintenance like replacing lubricity fuel filters on Navy Extended Boom Fork Lift (EBFL).</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="MPS Exercises and Contingencies">
  <ns0:data key="d0">MPS Exercises and Contingencies</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">MPS Exercises and Contingencies outlines requirements for MCMC to support exercises including planning, logistics, and asset management.&lt;SEP&gt;MPS Exercises and Contingencies require MCMC to provide resource plans, logistics services, asset management, and support for offloads and backloads.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="3M Inactive Equipment Maintenance">
  <ns0:data key="d0">3M Inactive Equipment Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">3M Inactive Equipment Maintenance is tailored via NAV-P Maintenance Requirements Package (MRP) process for Standard Work Items during lay-up for the MCPP II MCMC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Compass Swing">
  <ns0:data key="d0">Compass Swing</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Compass Swing semi-annual Force Revision requirements are waived for the MCPP II MCMC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Navy Oil Analysis Program">
  <ns0:data key="d0">Navy Oil Analysis Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Navy Oil Analysis Program semi-annual Force Revision requirement is modified via 6.F.17 for the MCPP II MCMC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Diesel Engine Inspection Program">
  <ns0:data key="d0">Diesel Engine Inspection Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Diesel Engine Inspection Program semi-annual Force Revision requirements are waived for the MCPP II MCMC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Gauge Calibration Requirements">
  <ns0:data key="d0">Gauge Calibration Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Gauge Calibration Requirements are modified in accordance with SYSCOM direction and conducted per NSWCCD CRL Letter 93/115 dated 01 Dec 2014 or its successor for watercraft.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-018">
  <ns0:data key="d0">SOW Attachment C.6-018</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-018 details the 2K Transmittal Form (CDRL 6060) for providing information and data from NAV-P to MCMC for external contractors.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-027">
  <ns0:data key="d0">SOW Attachment C.6-027</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-027 specifies gauge calibration procedures for watercraft in accordance with NSWCCD CRL Letter 93/115 dated 01 Dec 2014.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Consolidated Asset Listing (CAL)">
  <ns0:data key="d0">Consolidated Asset Listing (CAL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Consolidated Asset Listing (CAL) is a government-issued listing used to document issue and receipt of MPE/S to NAVFOR RO, with updates coordinated through Navy TAAT OIC.&lt;SEP&gt;Consolidated Asset Listing (CAL) is a government-issued document used by MCMC to track and document the issue and receipt of MPE/S to NAVFOR RO during exercises and contingencies.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Equipment Density List (EDL)">
  <ns0:data key="d0">Equipment Density List (EDL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Equipment Density List (EDL) is used for issuing and receipting Navy assets in accordance with approved plans.&lt;SEP&gt;Equipment Density List (EDL) identifies Navy assets to be issued and received by MCMC in accordance with approved resource plans for exercises and contingencies.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Navy Extended Boom Fork Lift (EBFL)">
  <ns0:data key="d0">Navy Extended Boom Fork Lift (EBFL)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Navy Extended Boom Fork Lift (EBFL) is equipment requiring lubricity fuel filter replacement every 250 hours or 6 months, with service recorded in GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Deferred Maintenance Listing (DML)">
  <ns0:data key="d0">Deferred Maintenance Listing (DML)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Deferred Maintenance Listing (DML) is a list where non-mission capable equipment is added when repairs cannot be completed immediately.&lt;SEP&gt;Deferred Maintenance Listing (DML) tracks non-mission capable equipment placed in ABD SHIP status due to repair limitations aboard MPS.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="NSWCCD CRL Letter 93/115">
  <ns0:data key="d0">NSWCCD CRL Letter 93/115</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NSWCCD CRL Letter 93/115 dated 01 Dec 2014 establishes calibration procedures for watercraft gauges, or its successor document.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Annual Estimated Material Costs (CDRL 6062)">
  <ns0:data key="d0">Annual Estimated Material Costs (CDRL 6062)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Annual Estimated Material Costs (CDRL 6062) reports estimated material costs associated with MPS Navy Watercraft TR Control System Support installations as defined in the Master Schedule.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CSS Shipping Report (CDRL 6063)">
  <ns0:data key="d0">CSS Shipping Report (CDRL 6063)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CSS Shipping Report (CDRL 6063) is submitted monthly by MCMC along with copies of shipping invoices for the dedicated shipping account.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Phase D Stage 4">
  <ns0:data key="d0">Phase D Stage 4</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Phase D Stage 4 is a production milestone typically occurring at E-30, where FMC status of functional areas is assessed, requiring a Letter of Non-Conformance for any non-FMC areas.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Navy Corrective Maintenance">
  <ns0:data key="d0">Navy Corrective Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Navy Corrective Maintenance corrects non-mission capable faults on MPE/S to restore mission capable condition during afloat phase.</ns0:data>
  <ns0:data key="d3">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="USMC Blount Island Command">
  <ns0:data key="d0">USMC Blount Island Command</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">USMC Blount Island Command is the issuing organization located at 5880 Channel View Blvd, Jacksonville FL 32226, overseeing the solicitation and contract administration.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="IDIQ Contract">
  <ns0:data key="d0">IDIQ Contract</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">IDIQ Contract is a single award hybrid Indefinite Delivery Indefinite Quantity contract allowing task orders on CPFF, FFP, and Cost Reimbursable bases.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Section A">
  <ns0:data key="d0">Section A</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section A covers the Solicitation/Contract Form, including type of contract and ordering periods.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Section B">
  <ns0:data key="d0">Section B</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section B details Supplies or Services and Prices, including minimum and maximum IDIQ amounts and CLIN structures.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0001">
  <ns0:data key="d0">CLIN X0001</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0001 is a Firm Fixed Price line item for 12 months of Program Management and Risk Management support, including Phase-Out requirements.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0002">
  <ns0:data key="d0">CLIN X0002</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0002 is a Cost Plus Fixed Fee Level of Effort line item for Maintenance Production in CONUS, with government-provided hours.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0003">
  <ns0:data key="d0">CLIN X0003</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0003 is a Cost Plus Fixed Fee Level of Effort line item for Maintenance Production in OCONUS, with government-provided hours.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0004">
  <ns0:data key="d0">CLIN X0004</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0004 is a Cost Plus Fixed Fee Level of Effort line item for Other Logistics Support, including contingency and emerging requirements.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0005">
  <ns0:data key="d0">CLIN X0005</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0005 is a Cost reimbursable line item for Travel, with no fee applied.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0006">
  <ns0:data key="d0">CLIN X0006</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0006 is a Cost reimbursable line item for Other Direct Costs, with no fee applied.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN X0007">
  <ns0:data key="d0">CLIN X0007</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN X0007 is a Not Separately Priced line item for Data Requirements and CDRLs using DD Form 1423-1.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CLIN 0008">
  <ns0:data key="d0">CLIN 0008</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CLIN 0008 is a Firm Fixed Price line item for 3 months of Contract Transition for Phase-in services.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Year One">
  <ns0:data key="d0">Base Ordering Period Year One</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period Year One covers CLINs 0001-0007 for the first year of the contract.&lt;SEP&gt;First year within the base ordering period for specific contract services.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Option Period I">
  <ns0:data key="d0">Option Period I</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Option Period I covers years six through ten with CLINs 5001-9007, subject to exercise.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="CDRLs">
  <ns0:data key="d0">CDRLs</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRLs are Contract Data Requirements Lists established in the SOW using DD Form 1423-1, not separately priced.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Standard Form 33">
  <ns0:data key="d0">Standard Form 33</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Standard Form 33 is the form used for the Solicitation, Offer, and Award, with previous edition noted as unusable.&lt;SEP&gt;Standard Form 33 specifies the proposal due date and time.&lt;SEP&gt;Standard Form 33 requires completion, signing, and submission of Sections A, B, and K by offerors.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="SAM.GOV">
  <ns0:data key="d0">SAM.GOV</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">SAM.GOV is the federal platform where questions about the Draft RFP are posted for industry review and feedback.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Minimum Guarantee">
  <ns0:data key="d0">Minimum Guarantee</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Minimum Guarantee is set at $10,000.00 for the base year award only under the IDIQ Contract.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Section H">
  <ns0:data key="d0">Section H</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H outlines Special Contract Requirements, including H-21 for Phase-Out, H.10 for Travel, and H-8.3 for fee ratios in task orders.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841106</ns0:data>
</ns0:node>
<ns0:node id="Section J">
  <ns0:data key="d0">Section J</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section J includes the List of Attachments, such as Contract Attachment #9 for CDRLs, which are not separately priced.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Evaluation Factors for Award">
  <ns0:data key="d0">Evaluation Factors for Award</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Evaluation Factors for Award are specified for determining the successful offeror in the solicitation process.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Phase-Out H-21">
  <ns0:data key="d0">Phase-Out H-21</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Phase-Out (H-21) requirements are captured under the program management FFP CLIN in accordance with the Statement of Work.&lt;SEP&gt;Phase-Out H-21 is a contract requirement for transitioning out of services, captured under the Program Management CLIN.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Contract Transition">
  <ns0:data key="d0">Contract Transition</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Contract Transition is a 3-month Firm Fixed Price period for Phase-in services to support initial contract performance.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Year Two">
  <ns0:data key="d0">Base Ordering Period Year Two</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period Year Two encompasses CLINs 1001-1007 for continued services in the second year of the base period.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Year Three">
  <ns0:data key="d0">Base Ordering Period Year Three</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period Year Three encompasses CLINs 2001-2007 for services in the third year of the base period.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Year Four">
  <ns0:data key="d0">Base Ordering Period Year Four</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period Year Four encompasses CLINs 3001-3007 for services in the fourth year of the base period.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Base Ordering Period Year Five">
  <ns0:data key="d0">Base Ordering Period Year Five</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Base Ordering Period Year Five encompasses CLINs 4001-4007 for services in the fifth year of the base period.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Opt I Ordering Period Year Six">
  <ns0:data key="d0">Opt I Ordering Period Year Six</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Opt I Ordering Period Year Six encompasses CLINs 5001-5007, exercisable as part of Option Period I.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Opt I Ordering Period Year Seven">
  <ns0:data key="d0">Opt I Ordering Period Year Seven</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Opt I Ordering Period Year Seven encompasses CLINs 6001-6007, exercisable as part of Option Period I.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Opt I Ordering Period Year Nine">
  <ns0:data key="d0">Opt I Ordering Period Year Nine</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Opt I Ordering Period Year Nine encompasses CLINs 8001-8007, exercisable as part of Option Period I.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Opt I Ordering Period Year Ten">
  <ns0:data key="d0">Opt I Ordering Period Year Ten</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Opt I Ordering Period Year Ten encompasses CLINs 9001-9007, exercisable as part of Option Period I.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Standard Form 26">
  <ns0:data key="d0">Standard Form 26</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Standard Form 26 is referenced as a possible form for award notice in addition to Standard Form 33.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.232-8">
  <ns0:data key="d0">FAR 52.232-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.232-8 is the clause for Discounts for Prompt Payment, applicable to the contract terms.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.214-7">
  <ns0:data key="d0">FAR 52.214-7</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.214-7 is the provision for Late Submissions, Modifications, and Withdrawals in sealed bid solicitations.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.215-1">
  <ns0:data key="d0">FAR 52.215-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.215-1 is the provision for Late Submissions, Modifications, and Withdrawals in negotiated solicitations.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="10 U.S.C. 2304(c)">
  <ns0:data key="d0">10 U.S.C. 2304(c)</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">10 U.S.C. 2304(c) is cited as authority for using other than full and open competition if applicable.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="41 U.S.C. 253(c)">
  <ns0:data key="d0">41 U.S.C. 253(c)</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">41 U.S.C. 253(c) is cited as authority for using other than full and open competition if applicable.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Navy Section C-6">
  <ns0:data key="d0">Navy Section C-6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Section C-6 provides direction for the utilization of the RSupply application by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="User Guide">
  <ns0:data key="d0">User Guide</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">User Guide is a comprehensive embedded guide within the RSupply application.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Fleet Management Information System (FMIS)">
  <ns0:data key="d0">Fleet Management Information System (FMIS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FMIS is the HQMC-mandated IT system used for Non-Tactical Vehicles equipment management, including Preventive Maintenance Checks and Services.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Non-Tactical Vehicles (NTV)">
  <ns0:data key="d0">Non-Tactical Vehicles (NTV)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Non-Tactical Vehicles are equipment managed through FMIS for preventive maintenance checks and services.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="SOW Section C.2.B.7.a">
  <ns0:data key="d0">SOW Section C.2.B.7.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SOW Section C.2.B.7.a provides direction for utilizing FMIS by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Program Cost Summary">
  <ns0:data key="d0">Program Cost Summary</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Program Cost Summary is a software used for program-wide performance monitoring and measuring, determining historical cost data, and reporting monthly on cumulative lifecycle program costs by ship and class.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Command ISOs">
  <ns0:data key="d0">Command ISOs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Command ISOs contain specific policies governing the operation and administration of BICmd use of the Program Cost Summary.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="SharePoint">
  <ns0:data key="d0">SharePoint</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">SharePoint contains specific policies governing the operation and administration of BICmd use of the Program Cost Summary.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="KPI Reporting">
  <ns0:data key="d0">KPI Reporting</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">KPI Reporting is used by BICmd and MCMC to increase efficiency, effectiveness, and repeatability of status reporting and performance reviews for each Maritime Prepositioning Ship Maintenance Cycle.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Ship (MPS)">
  <ns0:data key="d0">Maritime Prepositioning Ship (MPS)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Ship is subject to maintenance cycles monitored through KPI reporting.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Cycle (MMC)">
  <ns0:data key="d0">Maintenance Cycle (MMC)</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Maintenance Cycle is a program management area monitored through KPI reporting for cost, schedule, and performance.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.2.C-4">
  <ns0:data key="d0">SOW Attachment C.2.C-4</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.2.C-4 illustrates the five KPI data elements in the Program Cost Summary dashboard.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Subcontracts/Supporting Contracts">
  <ns0:data key="d0">Subcontracts/Supporting Contracts</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Subcontracts/Supporting Contracts require MCMC to provide information on those employed to complete assigned tasks.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Materiel">
  <ns0:data key="d0">Materiel</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Materiel involves providing information on costs of buys supporting each ship’s evolution and ashore programs, including those through DoD procurement systems or outside methods.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Labor">
  <ns0:data key="d0">Labor</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Labor requires providing information on labor and associated burdens, plus aggregate costs for Program Management CLINs apportioned to ships and ashore programs.&lt;SEP&gt;Labor requires labor rates by category, skill mix, hours, calculations for productive hours, loading factors, inflation rates, position descriptions, and compliance with collective bargaining agreements.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841107</ns0:data>
</ns0:node>
<ns0:node id="Travel">
  <ns0:data key="d0">Travel</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Travel is provided as a task under COST pricing with no fee or markups applied, for the base ordering period two.&lt;SEP&gt;Cost reimbursable task with no fee or markups applied.&lt;SEP&gt;Travel requires providing information on travel and associated G&amp;A.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Training">
  <ns0:data key="d0">Training</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Training involves attendance by MCMC and Government personnel on weapon systems modifications and new systems, impacting availability and requiring proper planning.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="SECTION 2.D RISK AND PERFORMANCE">
  <ns0:data key="d0">SECTION 2.D RISK AND PERFORMANCE</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SECTION 2.D RISK AND PERFORMANCE sets forth responsibilities for MCMC in quality control, risk management, and ISO 9001 certification.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Control (QC)/Risk Control (RC) Program">
  <ns0:data key="d0">Quality Control (QC)/Risk Control (RC) Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Quality Control/Risk Control Program meets requirements for ISO 9001 certification, including MCMC in the scope, and uses government-provided QMSS software.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Management Support System (QMSS)">
  <ns0:data key="d0">Quality Management Support System (QMSS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">QMSS is government-provided software, including MCPIC IPrime Inspection Web and eQMS modules, used for quality control inspections, tracking non-conformances, audits, and corrective actions.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="MCPIC IPrime Inspection Web">
  <ns0:data key="d0">MCPIC IPrime Inspection Web</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MCPIC IPrime Inspection Web is a module of QMSS used for conducting and capturing quality control inspections.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="eQMS Modules">
  <ns0:data key="d0">eQMS Modules</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">eQMS Modules are part of QMSS for tracking, tracing, trending, and resolution of non-conforming products and services, as well as managing audits and corrective actions.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Commands Quality Manual (CmdO P5000.11)">
  <ns0:data key="d0">Commands Quality Manual (CmdO P5000.11)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Command’s Quality Manual (CmdO P5000.11) is to be considered and complied with for quality management.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Performance Requirement Summary (SOW Attachment 2.D-1)">
  <ns0:data key="d0">Performance Requirement Summary (SOW Attachment 2.D-1)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Performance Requirement Summary (SOW Attachment 2.D-1) describes critical services in the context of quality and risk requirements.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Inspectors (QI)">
  <ns0:data key="d0">Quality Inspectors (QI)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Quality Inspectors are dedicated personnel with knowledge of equipment, supply, and maintenance to conduct quality control of MCPP military equipment.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Process Control Analysts (PCA)">
  <ns0:data key="d0">Process Control Analysts (PCA)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Process Control Analysts are dedicated personnel supporting quality control efforts for MCPP military equipment.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Manager (QM)">
  <ns0:data key="d0">Quality Manager (QM)</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Quality Manager is an independent role to which QIs and PCAs report directly, designated for government interactions.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="QMS">
  <ns0:data key="d0">QMS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">QMS utilizes MCPIC IPrime Inspection Web and eQMS modules to record quality management system activities.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Nonconformance Reports (NCRs)">
  <ns0:data key="d0">Nonconformance Reports (NCRs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Nonconformance Reports are initiated in QMSS by Government QA, requiring MCMC response and resolution.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Nonconformance Trends (NCTs)">
  <ns0:data key="d0">Nonconformance Trends (NCTs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Nonconformance Trends are initiated in QMSS by Government QA, requiring MCMC response and resolution.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality and Risk Control Plan (Q&amp;RCP)">
  <ns0:data key="d0">Quality and Risk Control Plan (Q&amp;RCP)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quality and Risk Control Plan includes quality control and risk performance levels for deliverables and internal KPIs, subject to government review and updates for audits.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Key Performance Indicator (KPI) Control Charts">
  <ns0:data key="d0">Quality Key Performance Indicator (KPI) Control Charts</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quality Key Performance Indicator Control Charts are assessed quarterly for internal quality control elements supporting the Q&amp;RCP.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="End-of-Ship (EOS)/Period of Performance MCMC Performance Review">
  <ns0:data key="d0">End-of-Ship (EOS)/Period of Performance MCMC Performance Review</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">End-of-Ship/Period of Performance Review requires MCMC participation to review variations in cost, schedule, conformance, and risk, and lessons learned.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Continuous Process Improvement (CPI)">
  <ns0:data key="d0">Continuous Process Improvement (CPI)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Continuous Process Improvement (CPI) is intertwined with safety in all facets supporting Navy products.&lt;SEP&gt;Continuous Process Improvement involves reporting on quality management system improvements and performance gaps, using best practices and seeking government approval.&lt;SEP&gt;Continuous Process Improvement (CPI) is intertwined with safety in all facets supporting the Navy product.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Quality Control Plan (QCP)">
  <ns0:data key="d0">Quality Control Plan (QCP)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quality Control Plan details surveillance and verification of performance requirements, including procedures for communication, performance levels, defect prevention, and complaint resolution.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="SECTION C.3 – MAINTENANCE ACTIVITIES">
  <ns0:data key="d0">SECTION C.3 – MAINTENANCE ACTIVITIES</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SECTION C.3 – MAINTENANCE ACTIVITIES delineates requirements for equipment maintenance services during MPF Maintenance Cycle in support of Marine Corps and Navy equipment.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Ground Military Equipment (ME)">
  <ns0:data key="d0">Marine Corps Ground Military Equipment (ME)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Marine Corps Ground Military Equipment is subject to maintenance services by MCMC during Maintenance Cycles.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Navy Civil Engineer Support Equipment (CESE)">
  <ns0:data key="d0">Navy Civil Engineer Support Equipment (CESE)</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Navy Civil Engineer Support Equipment is subject to maintenance services by MCMC during Maintenance Cycles.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Limited Technical Inspections (LTIs)">
  <ns0:data key="d0">Limited Technical Inspections (LTIs)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Limited Technical Inspections (LTIs) are inspections performed on ME and CESE assets to assess condition, assign codes, and support disposition or investigations.&lt;SEP&gt;Limited Technical Inspections are performed on ME and CESE assets to determine condition, including road tests where applicable.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="GCSS-MC Service Request">
  <ns0:data key="d0">GCSS-MC Service Request</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">GCSS-MC Service Request is used to identify and capture maintenance requirements as individual tasks.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Special Function Tests">
  <ns0:data key="d0">Special Function Tests</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Special Function Tests are performed on ME and CESE assets to support Government QA functions without disassembly.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="American National Accreditation Board (ANAB)">
  <ns0:data key="d0">American National Accreditation Board (ANAB)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">ANAB is an accreditation body for third-party auditors validating ISO 9001:2015 certification.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Registrar Accreditation Board (RAB)">
  <ns0:data key="d0">Registrar Accreditation Board (RAB)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">RAB is an accreditation body for third-party auditors validating ISO 9001:2015 certification.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="MMSOP">
  <ns0:data key="d0">MMSOP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MMSOP is associated with CmdO 4790.1 and governs QC and QA measures for maintenance services in the SOW.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="TDM-Publications">
  <ns0:data key="d0">TDM-Publications</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">TDM-Publications is the Marine Corps website for obtaining authorized technical publications using equipment TAMCN and ID numbers.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Federal Logistics Data Catalog (FEDLOG)">
  <ns0:data key="d0">Federal Logistics Data Catalog (FEDLOG)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FEDLOG is an electronic catalog used to cross-reference National Stock Numbers with the Marine Corps Stock list for equipment identification.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="National Stock Number (NSN)">
  <ns0:data key="d0">National Stock Number (NSN)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NSN is a numbering system on equipment data plates used to determine equipment ID numbers via FEDLOG.&lt;SEP&gt;National Stock Number (NSN) is a minimum data entry element for materiel in DMLSS.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="SL 6-1/6-2">
  <ns0:data key="d0">SL 6-1/6-2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SL 6-1/6-2 is the Marine Corps Stock list of Applications Lists used for obtaining equipment ID numbers in FEDLOG.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="M6700425R0007 DRAFT RFP">
  <ns0:data key="d0">M6700425R0007 DRAFT RFP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">M6700425R0007 DRAFT RFP is the solicitation document containing the SOW sections for MCMC requirements.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="DoD Procurement Systems">
  <ns0:data key="d0">DoD Procurement Systems</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DoD Procurement Systems are standard channels for materiel buys supporting ship evolutions and ashore programs.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Program Management CLINs">
  <ns0:data key="d0">Program Management CLINs</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Program Management CLINs are contract line items for which aggregate costs are provided, apportioned to ships and ashore programs.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="G &amp; A">
  <ns0:data key="d0">G &amp; A</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">G &amp; A denotes General and Administrative costs associated with travel in program cost reporting.</ns0:data>
  <ns0:data key="d3">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="U.S. Marine Corps">
  <ns0:data key="d0">U.S. Marine Corps</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">U.S. Marine Corps is the issuing organization for the RFP and operates Blount Island Command.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville, FL">
  <ns0:data key="d0">Jacksonville, FL</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Jacksonville, FL is the city and state where proposals are to be submitted, with ZIP code 32226-3404.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841108</ns0:data>
</ns0:node>
<ns0:node id="Volume I">
  <ns0:data key="d0">Volume I</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume I is the Executive Summary providing a concise narrative of the proposal, highlights of key features, overview of organizational concept, discussion of subcontractors, and listing of assumptions.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume II">
  <ns0:data key="d0">Volume II</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume II is the Management Proposal detailing management principles, practices, structure, staffing strategies, quality control, production planning, mission essential contractor services, business intelligence technology, employee training plan, transition plan, resumes, letters of commitment, hiring process, and procedures for Planned Value, Earned Value, Actual Cost, and Estimate at Completion projections.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume III">
  <ns0:data key="d0">Volume III</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume III is the Technical Proposal for USMC describing experience and capabilities for tactical ground equipment, logistics operations, maintenance, supply, and distribution support, including methodologies for supply and distribution, maintenance and management, and manning with workload matrix.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume IV">
  <ns0:data key="d0">Volume IV</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume IV is the Technical Proposal for Navy describing experience and capabilities for supply chain support of Navy CESE, containerized capability sets, organic assets, watercraft, including methodologies for supply, maintenance, and manning with workload matrix.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume V">
  <ns0:data key="d0">Volume V</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume V is the Past Performance section requiring information on relevant efforts, including basic details, relevance to current requirements, and Past Performance Questionnaires.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume VI">
  <ns0:data key="d0">Volume VI</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume VI is the Cost/Price Proposal including all pertinent contract cost and pricing information.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Foldouts">
  <ns0:data key="d0">Foldouts</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Foldouts section (4.2.8.2) specifies requirements for tables, charts, graphs, diagrams, schematics, and figures, including size limits, page counting, font sizes, and image area constraints.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Page Limitations">
  <ns0:data key="d0">Page Limitations</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Page Limitations section (4.2.8.3) defines maximum page counts, what constitutes a page, inclusion of headers and footers, and consequences of exceeding limits.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Pages Counted">
  <ns0:data key="d0">Pages Counted</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Pages Counted section (4.2.8.4) lists exempt pages from counting, such as cover pages, table of contents, and resumes, with marking requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Distribution Submission Proposal Volumes">
  <ns0:data key="d0">Distribution Submission Proposal Volumes</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Distribution Submission Proposal Volumes section (4.2.8.5) provides instructions for sending original and electronic copies to the issuing office, marking envelopes, and consequences of incomplete submissions.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Proposal Due Date Schedule">
  <ns0:data key="d0">Proposal Due Date Schedule</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Proposal Due Date Schedule section (4.2.8.6) states that the entire contract proposal is due at RFP closing, except for Volume IX Oral Presentations, referencing SF33 Block 9.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Disposition of Unsuccessful Proposals">
  <ns0:data key="d0">Disposition of Unsuccessful Proposals</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Disposition of Unsuccessful Proposals section (4.2.8.7) requires retention of originals and destruction of copies in compliance with FAR Subpart 4.8.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Ships Program">
  <ns0:data key="d0">Maritime Prepositioning Ships Program</ns0:data>
  <ns0:data key="d1">program</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Ships Program is the context for MCPP requirements involving USMC and Navy operations.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.237-7023">
  <ns0:data key="d0">DFARS 252.237-7023</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.237-7023 addresses mission essential contractor services requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.237-7024">
  <ns0:data key="d0">DFARS 252.237-7024</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 252.237-7024 addresses mission essential contractor services requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Project">
  <ns0:data key="d0">Microsoft Project</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Project is a software tool assessed for use in the offeror's business systems to support budgetary planning, earned value management, and actual cost reporting for CLINs and task orders.&lt;SEP&gt;Microsoft Project is utilized for developing planned value, earned value, actual cost reporting, and estimate at completion projections.&lt;SEP&gt;Microsoft Project is utilized alongside Contractor Business Systems for reporting and projections associated with USMC and Navy ACRNs and Task Orders.&lt;SEP&gt;Microsoft Project is the tool specified for production planning in SOW Attachment C.1-3 MMC Notional POAM.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-3478ab61c9462db63588376af8a45cd2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.1-7">
  <ns0:data key="d0">SOW Attachment C.1-7</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.1-7 is the Employee Qualifications attachment identifying minimum education, training, certification, and experience for MCMC personnel.&lt;SEP&gt;SOW Attachment C.1-7 provides required Employee Qualifications for workload matrix traceability.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Section H-21">
  <ns0:data key="d0">Section H-21</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Contract section addressing phase-out requirements captured under program management contract line items.&lt;SEP&gt;Section H-21 outlines the transition plan and schedule requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Volume IX">
  <ns0:data key="d0">Volume IX</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume IX details Oral Presentation requirements, including identification of presenters and briefing content.&lt;SEP&gt;Volume IX covers Oral Presentations, submitted separately from other proposal volumes.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="FAR 15.208">
  <ns0:data key="d0">FAR 15.208</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 15.208 provides rules for submission, modification, and withdrawal of proposals, including handling of late proposals.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="FAR Subpart 4.8">
  <ns0:data key="d0">FAR Subpart 4.8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR Subpart 4.8 governs the disposition of government records, including unsuccessful proposals.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.219-8">
  <ns0:data key="d0">FAR 52.219-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.219-8 is a Federal Acquisition Regulation clause related to utilization of small business concerns, required for past performance submission.&lt;SEP&gt;FAR 52.219-8 mandates utilization of small business concerns in performance.&lt;SEP&gt;FAR 52.219-8 requires utilization of small business concerns.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.219-9">
  <ns0:data key="d0">FAR 52.219-9</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.219-9 is a Federal Acquisition Regulation clause on small business subcontracting plans, required for past performance submission.&lt;SEP&gt;FAR 52.219-9 requires a small business subcontracting plan.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="CPARS">
  <ns0:data key="d0">CPARS</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">CPARS is the Contractor Performance Assessment Reporting System database containing past performance information.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Workload Matrix">
  <ns0:data key="d0">Workload Matrix</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Workload Matrix analyzes manning levels by labor category, location, supervisory ratios, and traceability to employee qualifications in Volumes III and IV.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="5880 Channel View Blvd.">
  <ns0:data key="d0">5880 Channel View Blvd.</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">5880 Channel View Blvd. is the specific address at Blount Island Command for proposal delivery.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Corrosion Control">
  <ns0:data key="d0">Corrosion Control</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Corrosion Control covers maintenance for USMC motor transportation and Navy watercraft coating systems, with specific staffing adequacy concerns.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Solicitation Attachment #3">
  <ns0:data key="d0">Solicitation Attachment #3</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Solicitation Attachment #3 contains the Past Performance Questionnaire sections for completion by offerors.&lt;SEP&gt;Solicitation Attachment #3 is the Past Performance Questionnaire form for completion by offerors and assessors.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Information Sheets">
  <ns0:data key="d0">Past Performance Information Sheets</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Past Performance Information Sheets contain listed points of contact for validation and questionnaire distribution.&lt;SEP&gt;Past Performance Information Sheets detail basic contract information and relevance for Volume V submission.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Earned Value">
  <ns0:data key="d0">Earned Value</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Earned Value is part of the management procedures for reporting on COST TYPE CLIN/SLIN basis in Volume II.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841109</ns0:data>
</ns0:node>
<ns0:node id="Actual Cost">
  <ns0:data key="d0">Actual Cost</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Actual Cost is reported alongside Planned Value, Earned Value, and Estimate at Completion in proposal procedures.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Estimate at Completion">
  <ns0:data key="d0">Estimate at Completion</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Estimate at Completion projections are developed and reported on a COST TYPE basis with near real-time sharing capabilities.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="NTCSS OMMS-NG">
  <ns0:data key="d0">NTCSS OMMS-NG</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">NTCSS OMMS-NG is Naval Tactical Command Support Systems Organizational Maintenance Management System Next Generation used for recording maintenance actions.&lt;SEP&gt;NTCSS OMMS-NG is the system for Navy maintenance administration in the proposed methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Class III Packaged">
  <ns0:data key="d0">Class III Packaged</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class III Packaged is a supply class for petroleum products included in USMC distribution requirements.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Class V">
  <ns0:data key="d0">Class V</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class V is a supply class for ammunition included in USMC methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Class VIII">
  <ns0:data key="d0">Class VIII</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class VIII is a supply class for medical materials included in USMC supply.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Class IX">
  <ns0:data key="d0">Class IX</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class IX is a supply class for repair parts included in USMC distribution.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Limited Technical Inspections">
  <ns0:data key="d0">Limited Technical Inspections</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Limited Technical Inspections (LTI) is an element of USMC maintenance methodology per SOW C.2.B and C.3.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Preventative Maintenance">
  <ns0:data key="d0">Preventative Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Preventative Maintenance is part of USMC and Navy maintenance strategies to meet timelines and quality.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Corrective Maintenance">
  <ns0:data key="d0">Corrective Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Corrective Maintenance is performed on Navy Organic GSE and GFE as over-and-above work per DFARS 252.217-7028.&lt;SEP&gt;Corrective Maintenance addresses repairs in USMC and Navy methodologies.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
