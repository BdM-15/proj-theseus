  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC utilizes Defense Logistics Agency (DLA) supply systems with Job Order Numbers for requisitions.</ns0:data>
  <ns0:data key="d8">requisitions,supply</ns0:data>
