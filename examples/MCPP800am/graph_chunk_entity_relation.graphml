  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Modifications">
  <ns0:data key="d0">Modifications</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Modifications are included in USMC maintenance elements for equipment.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
</ns0:node>
<ns0:node id="Calibration">
  <ns0:data key="d0">Calibration</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Calibration is a maintenance requirement in USMC technical proposal.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841110</ns0:data>
