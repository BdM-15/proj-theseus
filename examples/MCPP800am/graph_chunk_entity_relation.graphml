  <ns0:data key="d11">1759841457</ns0:data>
</ns0:edge>
<ns0:edge source="MMC Operations" target="Work Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Work Requirements categorize MMC Operations as one of two overarching support areas for MCMC.</ns0:data>
  <ns0:data key="d8">categorization,support areas</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
