<ns0:node id="Subcontracting Plan Format">
  <ns0:data key="d0">Subcontracting Plan Format</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Subcontracting Plan Format encourages offerors to follow FAR 19.704, 19.705-4, 52.219-9, DFARS 219.704, 219.705-4, and 252.219-7003, using the format in 52.219-9.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Volume VIII">
  <ns0:data key="d0">Volume VIII</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Volume VIII addresses Proposal Documentation, including solicitation submission and exceptions to terms.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Oral Presentation">
  <ns0:data key="d0">Oral Presentation</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Oral Presentation limits attendance to five key personnel, requires a one-hour briefing on capabilities and efficiencies, and includes a clarification session.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Mission-Essential Contractor Services Plan">
  <ns0:data key="d0">Mission-Essential Contractor Services Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Mission-Essential Contractor Services Plan requires a written description of how essential services will continue during crises, per 252.237-7023.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Section M">
  <ns0:data key="d0">Section M</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section M outlines Evaluation Factors for Award, including basis for award and evaluation procedures.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor A">
  <ns0:data key="d0">Factor A</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor A evaluates Management Methodology from Volume II.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor B">
  <ns0:data key="d0">Factor B</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor B evaluates USMC Technical Methodology from Volume III.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor C">
  <ns0:data key="d0">Factor C</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor C evaluates Navy Technical Methodology from Volume IV.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor D">
  <ns0:data key="d0">Factor D</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor D evaluates Past Performance from Volume V, considering relevance and quality of prior efforts.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor E">
  <ns0:data key="d0">Factor E</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor E evaluates Cost/Price.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Factor F">
  <ns0:data key="d0">Factor F</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Factor F evaluates Small Business Participation and Subcontracting.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="52.217-5 Evaluation Of Options">
  <ns0:data key="d0">52.217-5 Evaluation Of Options</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.217-5 Evaluation Of Options is incorporated by reference from July 1990.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="252.225-7003 Report of Intended Performance Outside the United States and Canada">
  <ns0:data key="d0">252.225-7003 Report of Intended Performance Outside the United States and Canada</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">252.225-7003 requires submission with offer from January 2025.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.219-9 Alternate II">
  <ns0:data key="d0">FAR 52.219-9 Alternate II</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.219-9 Alternate II fulfills small business subcontracting plan requirements.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Small Business Concerns">
  <ns0:data key="d0">Small Business Concerns</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Small Business Concerns have a 20% goal for the acquisition.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Subcontractor Summary">
  <ns0:data key="d0">Subcontractor Summary</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Subcontractor summary identifies key elements described in (a) through (g) and must be submitted by the offeror.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="Socio-Economic Regulations">
  <ns0:data key="d0">Socio-Economic Regulations</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Socio-economic regulations promote social policy goals, apply to the acquisition, and flow down to subcontractors.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="FAR 19.704">
  <ns0:data key="d0">FAR 19.704</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 19.704 provides guidance on subcontracting plan content and format.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="FAR 19.705-4">
  <ns0:data key="d0">FAR 19.705-4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 19.705-4 outlines procedures for reviewing and approving subcontracting plans.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="DFARS 219.704">
  <ns0:data key="d0">DFARS 219.704</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 219.704 addresses Department of Defense subcontracting plan requirements.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841125</ns0:data>
</ns0:node>
<ns0:node id="DFARS 219.705-4">
  <ns0:data key="d0">DFARS 219.705-4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">DFARS 219.705-4 details post-award responsibilities for subcontracting plans in DoD acquisitions.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="252.219-7003">
  <ns0:data key="d0">252.219-7003</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">252.219-7003 requires reporting on small business subcontracting for DoD contracts.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Standard Form 30">
  <ns0:data key="d0">Standard Form 30</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Standard Form 30 is used for contract amendments and must bear original signatures.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Exceptions to Terms and Conditions">
  <ns0:data key="d0">Exceptions to Terms and Conditions</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Exceptions to Terms and Conditions require clear identification, explanation, and rationale if taken by the offeror.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="PowerPoint Slide Presentation">
  <ns0:data key="d0">PowerPoint Slide Presentation</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">PowerPoint Slide Presentation for the Oral Presentation must be submitted electronically three days prior and twelve hard copies provided at the briefing.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="SOW C.2.D.1.g">
  <ns0:data key="d0">SOW C.2.D.1.g</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SOW C.2.D.1.g mandates annual submission of the Quality Control Plan no later than 01 November.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="M-1 Basis for Award">
  <ns0:data key="d0">M-1 Basis for Award</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">M-1 Basis for Award establishes the best value tradeoff process under FAR 15.3, DFARS, and NMCARS for selecting the offeror.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Tradeoff Process">
  <ns0:data key="d0">Tradeoff Process</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Tradeoff Process involves integrated assessment of evaluation criteria to determine best value, potentially favoring higher-priced superior proposals.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Source Selection Authority">
  <ns0:data key="d0">Source Selection Authority</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Source Selection Authority decides on award based on evaluation factors, professional judgment, and may award without discussions.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="M-2 Evaluation Procedures">
  <ns0:data key="d0">M-2 Evaluation Procedures</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">M-2 Evaluation Procedures define comparison of proposals to SOW requirements, rating based on strengths, weaknesses, deficiencies, and risk assessment.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Strength">
  <ns0:data key="d0">Strength</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Strength is a proposal aspect exceeding requirements in a way advantageous to the Government.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Weakness">
  <ns0:data key="d0">Weakness</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Weakness is a flaw in the proposal increasing risk of unsuccessful performance; significant weakness appreciably increases risk.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Deficiency">
  <ns0:data key="d0">Deficiency</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Deficiency is a material failure to meet requirements or combination of significant weaknesses rendering performance unacceptable.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="M-3 Evaluation Criteria and Factors">
  <ns0:data key="d0">M-3 Evaluation Criteria and Factors</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">M-3 Evaluation Criteria and Factors outline six factors for assessing proposal merit and capability to meet acquisition objectives.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Executive Summary Volume I">
  <ns0:data key="d0">Executive Summary Volume I</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Executive Summary Volume I provides context for evaluating each technical factor.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Adjectival Ratings">
  <ns0:data key="d0">Adjectival Ratings</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Adjectival Ratings assess technical proposals as Outstanding, Good, Acceptable, Marginal, or Unacceptable based on approach, understanding, strengths, and risk.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Information Retrieval System">
  <ns0:data key="d0">Past Performance Information Retrieval System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Past Performance Information Retrieval System (PPIRS) is a database used to evaluate offeror past performance.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Federal Awardee Performance and Integrity Information System">
  <ns0:data key="d0">Federal Awardee Performance and Integrity Information System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Federal Awardee Performance and Integrity Information System (FAPIIS) provides data on awardee performance and integrity for evaluation.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Electronic Subcontract Reporting System">
  <ns0:data key="d0">Electronic Subcontract Reporting System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Electronic Subcontract Reporting System (eSRS) tracks subcontract data for past performance assessment.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Li-Ion Hold-Up Batteries">
  <ns0:data key="d0">Li-Ion Hold-Up Batteries</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Li-Ion hold-up batteries are present in communications assets installed on Alpha, Bravo, Delta, and Echo parent TAMCN military equipment and may be configured as stand-alone items, SL-3 SSRI, or SL-3 UURI.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="THHR HUBs">
  <ns0:data key="d0">THHR HUBs</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">THHR HUBs are components that require replacement if they do not charge to a minimum of 3.5 VDC and must be stored in a secured SAPS battery charger until issued.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="SAPS Battery Charger">
  <ns0:data key="d0">SAPS Battery Charger</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">SAPS battery charger is used to securely store THHRs, which must be tagged and visually identifiable to their parent end item.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Section C.4">
  <ns0:data key="d0">Section C.4</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.4 outlines requirements and responsibilities for supply, container, and distribution management in support of the Marine Corps Prepositioning Program contract.&lt;SEP&gt;Section C.4 outlines requirements for supply, container, and distribution management in support of the Marine Corps Prepositioning Program (MCPP).</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
