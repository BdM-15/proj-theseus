<ns0:edge source="Navy" target="Government Furnished Equipment (GFE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy maintains accountability of GFE using DPAS and ensures it is kept in operable condition.</ns0:data>
  <ns0:data key="d8">accountability,equipment maintenance</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
