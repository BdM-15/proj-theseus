  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841309</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CM">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains a CM program for Navy CESE to restore mission capability, requiring OMMS-NG approval and prior government authorization.</ns0:data>
  <ns0:data key="d8">program management,repair authorization</ns0:data>
