</ns0:node>
<ns0:node id="DD Form 577">
  <ns0:data key="d0">DD Form 577</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 577 is a form used for appointment letters and delegation of authority in supply functions.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 11869">
  <ns0:data key="d0">NAVMC 11869</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 11869 is a document for delegation of authority in supply administration.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
