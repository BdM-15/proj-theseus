  <ns0:data key="d11">1759841459</ns0:data>
</ns0:edge>
<ns0:edge source="Fleet Marine Forces" target="Program Operational Goals">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Program Operational Goals aim to meet Fleet Marine Forces expectations through combat readiness and data accuracy.</ns0:data>
  <ns0:data key="d8">customer expectation,readiness attainment</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841458</ns0:data>
</ns0:edge>
<ns0:edge source="Plans &amp; Data Support Contract" target="MPSs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Plans &amp; Data Support Contract develops the strategic plan for MPS rotations through BICmd.</ns0:data>
  <ns0:data key="d8">rotation schedule,strategic planning</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841457</ns0:data>
</ns0:edge>
<ns0:edge source="NAVMC" target="ABLTS Hose Reels">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NAVMC maintains custody of ABLTS Hose Reels with transfers completed to NBG Ship’s Debarkation Officer or Navy TAAT member.</ns0:data>
  <ns0:data key="d8">custody control,transfer</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841459</ns0:data>
</ns0:edge>
<ns0:edge source="NAVMC" target="LARC-V">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NAVMC holds custody of LARC-Vs requiring custodial transfers between embarked NAVMC and NBG Ship’s Debarkation Officer or Navy TAAT member.</ns0:data>
  <ns0:data key="d8">custody control,transfer</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841459</ns0:data>
</ns0:edge>
<ns0:edge source="Navy MPS Embarkation/Debarkation Support" target="OPP">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy MPS Embarkation/Debarkation Support includes handling OPP for prepositioned MPE/S.</ns0:data>
  <ns0:data key="d8">coordination,offload</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841489</ns0:data>
</ns0:edge>
<ns0:edge source="Navy MPS Embarkation/Debarkation Support" target="Armory">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy MPS Embarkation/Debarkation Support includes downloading and backloading Armory as part of prepositioned MPE/S.</ns0:data>
  <ns0:data key="d8">backload,handling</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841492</ns0:data>
</ns0:edge>
<ns0:edge source="Navy MPS Embarkation/Debarkation Support" target="Battery Blocks">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy MPS Embarkation/Debarkation Support includes downloading and backloading Battery Blocks as part of prepositioned assets.</ns0:data>
  <ns0:data key="d8">backload,handling</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
