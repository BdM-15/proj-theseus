  <ns0:data key="d11">1759841470</ns0:data>
</ns0:edge>
<ns0:edge source="Corrective Maintenance (CM)" target="Lighterage Maintenance Model">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Corrective Maintenance (CM), including organizational, intermediate, and depot levels, is part of the Lighterage Maintenance Model for Navy watercraft.</ns0:data>
  <ns0:data key="d8">maintenance type,process component</ns0:data>
