</ns0:edge>
<ns0:edge source="Class IX Battery Plan" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC prepositions Class IX Batteries, including lithium types, as directed by the government-provided Class IX Battery Plan, loading in accordance with Coast Guard, Federal Hazmat, MSC, and IMDG regulations.</ns0:data>
  <ns0:data key="d8">prepositioning,regulatory compliance</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
