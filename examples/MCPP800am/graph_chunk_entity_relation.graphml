<ns0:edge source="Subic Bay" target="Marine Corps Prepositioning Program – Philippines">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Marine Corps Prepositioning Program – Philippines establishes prepositioned equipment in Subic Bay for contingency and humanitarian support.</ns0:data>
  <ns0:data key="d8">equipment prepositioning,site establishment</ns0:data>
