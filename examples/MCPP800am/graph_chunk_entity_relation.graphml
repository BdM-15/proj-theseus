<ns0:edge source="MCPP" target="MCSF-BI">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCSF-BI in Blount Island serves as the primary location for MCPP's MMC activities and prepositioning operations.</ns0:data>
