<ns0:edge source="MCMC" target="Continuity of Operations Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits updates to the Continuity of Operations Plan for IT services and performs backups and restorations as specified.</ns0:data>
  <ns0:data key="d8">maintenance,updates</ns0:data>
