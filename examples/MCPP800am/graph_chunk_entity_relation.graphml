<ns0:edge source="Contractor" target="United States Internal Revenue Code">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor pays or credits to the Government any reduction in Federal income tax liability under the United States Internal Revenue Code due to reimbursed foreign taxes.</ns0:data>
  <ns0:data key="d8">credit reimbursement,tax liability</ns0:data>
