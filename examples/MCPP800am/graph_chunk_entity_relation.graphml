<ns0:edge source="MCO 4400.201" target="Limited Technical Inspections (LTIs)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">LTIs for investigations and beyond economic repair follow MCO 4400.201 for condition codes and actions.</ns0:data>
  <ns0:data key="d8">compliance,disposition</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841438</ns0:data>
</ns0:edge>
<ns0:edge source="Independent Public Accountant (IPA)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC supports IPA sample requirements within five days, providing KSDs and pictures to validate APSR accuracy.</ns0:data>
  <ns0:data key="d8">audit validation,support</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841142</ns0:data>
</ns0:edge>
<ns0:edge source="Internal Controls and Audit Readiness Team (ICART)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC responds to ICART directed sample requirements periodically to confirm inventory and APSR data accuracy.</ns0:data>
  <ns0:data key="d8">cooperation,testing response</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841142</ns0:data>
</ns0:edge>
<ns0:edge source="Naval Facilities Engineering Command (COMNAVFAC)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides documentation and validation for COMNAVFAC-directed samples on APSR accuracy as part of higher headquarters directives.</ns0:data>
  <ns0:data key="d8">compliance,sample provision</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
