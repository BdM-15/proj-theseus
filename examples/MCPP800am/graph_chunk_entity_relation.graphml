  <ns0:data key="d11">1759841172</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Overseas Security Advisory Council">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor affiliates with the Overseas Security Advisory Council when performing outside the United States.</ns0:data>
  <ns0:data key="d8">affiliation,security</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841173</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="252.232-7007">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">252.232-7007 limits the government's obligation, requiring the Contractor to perform up to allotted funds for incrementally funded items.</ns0:data>
  <ns0:data key="d8">funding,obligation</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841174</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Essential Contractor Service">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor performs essential contractor services during crisis situations as per the Mission-Essential Contractor Services Plan.</ns0:data>
  <ns0:data key="d8">continuity,performance</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
