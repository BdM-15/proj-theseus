<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Covered Contractor Information System">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems defines and requires safeguarding of Covered Contractor Information System to prevent unauthorized access.</ns0:data>
  <ns0:data key="d8">definition,protection scope</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Federal Contract Information">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems defines Federal Contract Information as the type of data that must be protected within covered systems.</ns0:data>
  <ns0:data key="d8">data protection,definition</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Information System">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems defines Information System as the basis for identifying systems subject to safeguarding controls.</ns0:data>
  <ns0:data key="d8">definition,foundational term</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Safeguarding">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems defines Safeguarding and mandates its application through specific security procedures.</ns0:data>
  <ns0:data key="d8">definition,security controls</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841462</ns0:data>
</ns0:edge>
<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Controlled Unclassified Information">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems references additional federal requirements for Controlled Unclassified Information established by Executive Order 13556.</ns0:data>
  <ns0:data key="d8">additional requirements,safeguarding</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841465</ns0:data>
</ns0:edge>
<ns0:edge source="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems" target="Executive Order 13556">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems cites Executive Order 13556 as the basis for controlled unclassified information safeguarding.</ns0:data>
  <ns0:data key="d8">information protection,legal basis</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="52.211-11 Liquidated Damages Supplies Services Or Research And Development" target="Bobo Class Ship">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.211-11 Liquidated Damages Supplies Services Or Research And Development specifies $46,000 per day liquidated damages for delays related to Bobo Class Ship departures.</ns0:data>
  <ns0:data key="d8">damages application,performance delay</ns0:data>
