<ns0:edge source="MCMC" target="ISO 19011">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC auditors must be certified Lead Auditors to ISO 19011, updated within one year of new versions.</ns0:data>
  <ns0:data key="d8">auditing,certification</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841526</ns0:data>
</ns0:edge>
