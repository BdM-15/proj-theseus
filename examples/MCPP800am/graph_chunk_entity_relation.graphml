  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Control System Support (Css) Monthly Shipping And Css Shipping Invoices">
  <ns0:data key="d0">Control System Support (Css) Monthly Shipping And Css Shipping Invoices</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Control System Support (Css) Monthly Shipping And Css Shipping Invoices are submitted monthly under section 6.H.2 for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Unit Deployment Listing (Udl) End Of Ship Report">
  <ns0:data key="d0">Unit Deployment Listing (Udl) End Of Ship Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Unit Deployment Listing (Udl) End Of Ship Report is submitted IAW Government published Milestones in C.1 under section 6.K.3 for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Navy Spread Load Change">
  <ns0:data key="d0">Navy Spread Load Change</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Spread Load Change is submitted within one business day under section 6.K.5.b for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Navy Leased Equipment Accident Report">
  <ns0:data key="d0">Navy Leased Equipment Accident Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Leased Equipment Accident Report is submitted within one hour under section 6.N.6 for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Organic Gfe Status Report For Mhe, Whe, And Gse">
  <ns0:data key="d0">Organic Gfe Status Report For Mhe, Whe, And Gse</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Organic Gfe Status Report For Mhe, Whe, And Gse is submitted monthly under section 6.N.8 for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Whp Appointment Letters">
  <ns0:data key="d0">Whp Appointment Letters</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Whp Appointment Letters are submitted within 30 calendar days under sections 6.Q.1.a, 6.Q.1.b, 6.Q.1.c, and 6.Q.1.d for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Whe Accident Investigation Report">
  <ns0:data key="d0">Whe Accident Investigation Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Whe Accident Investigation Report is submitted within seven calendar days under section 6.Q.1.i for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Whe Near Misses And Other Unplanned Occurrence Reports">
  <ns0:data key="d0">Whe Near Misses And Other Unplanned Occurrence Reports</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Whe Near Misses And Other Unplanned Occurrence Reports are submitted within four hours under section 6.Q.1.j for X002.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="X002">
  <ns0:data key="d0">X002</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">X002 is a designated unit or location responsible for submitting numerous reports and deliverables under various sections of the Statement Of Work.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="X003">
  <ns0:data key="d0">X003</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">X003 is a designated unit or location responsible for submitting numerous reports and deliverables under various sections of the Statement Of Work.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Mps">
  <ns0:data key="d0">Mps</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Mps refers to Maritime Prepositioning Ships involved in production cycles and maintenance reporting.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Mpf">
  <ns0:data key="d0">Mpf</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Mpf refers to Maritime Prepositioning Force associated with vessel-specific reporting and maintenance cycles.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Gcss-Mc">
  <ns0:data key="d0">Gcss-Mc</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Gcss-Mc is a logistics information system used for reporting discrepancies and inventory comparisons.</ns0:data>
  <ns0:data key="d3">chunk-aa9424078fa723e2caaae8aa59fb4397</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="MMC Execution Milestones">
  <ns0:data key="d0">MMC Execution Milestones</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">MMC Execution Milestones specify timelines for populating IPACK data elements, such as NLT E-Day (E-20 Rolling Stock LMSR/E-13 Rolling Stock BOBO/E-16 Containers LMSR/E-9 Containers BOBO).</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="IMARK Labels">
  <ns0:data key="d0">IMARK Labels</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">IMARK Labels are markings on equipment that must be checked for legibility, digital scanability, and replaced if faded, worn, or torn.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="ISO">
  <ns0:data key="d0">ISO</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The International Organization for Standardization (ISO) provides standards for pRFID tags and joint certification with the Government.&lt;SEP&gt;ISO is International Organization for Standardization, governing RFID tags.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Management">
  <ns0:data key="d0">Maintenance Management</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Maintenance Management encompasses procedures for resource use in equipment preservation, integrating policies, programs, and AIS for oversight across commodities.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Management Office Manager">
  <ns0:data key="d0">Maintenance Management Office Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Maintenance Management Office Manager is appointed in writing and responsible for all maintenance management officer duties per MCO 4790.2 and CmdO 4790.1B.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1003">
  <ns0:data key="d0">CDRL 1003</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1003 is the initial appointment letter for the Maintenance Management Office Manager, submitted NLT 10 business days after contract award.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="UND">
  <ns0:data key="d0">UND</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Urgency of Need Designator (UND) involves a Delegation of Authority Letter for “A” and “B” priorities, submitted and updated per requirements.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1004">
  <ns0:data key="d0">CDRL 1004</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1004 is the UND Delegation of Authority Letter, submitted NLT 10 business days after contract award and updates.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="Supply Support">
  <ns0:data key="d0">Supply Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Supply Support includes placing equipment into service, warranty coordination, CLS procedures, managing repair parts in layettes, and DSI inventories.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="DSI">
  <ns0:data key="d0">DSI</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Demand-Supported Items (DSI) are managed inventories of expendable and nonexpendable items based on stockage criteria, with authorization letters for On-Island, Shipboard, and MCPP-PHIL locations.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1008">
  <ns0:data key="d0">CDRL 1008</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1008 is the DSI Authorization Letter, submitted NLT specified days after contract award or task order for various locations.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="MCPIC Data Standards">
  <ns0:data key="d0">MCPIC Data Standards</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCPIC Data Standards govern the proper placement and registration of IUID and pRFID tags on items received at DMO.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="MCO 4410.28">
  <ns0:data key="d0">MCO 4410.28</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4410.28 provides policies for Item Unique Identification (IUID) of Ground Equipment, including association of IUID and pRFID tags using MCPIC applications.&lt;SEP&gt;MCO 4410.28 is a Marine Corps Order governing Item Unique Identification of ground equipment.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841068</ns0:data>
</ns0:node>
<ns0:node id="MCTP 13-10D">
  <ns0:data key="d0">MCTP 13-10D</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCTP 13-10D establishes compliance requirements for removing and replacing labels and stickers prior to staging.&lt;SEP&gt;MCTP 13-10D is a Marine Corps Tactical Publication for compliance in labeling and stickers removal.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="NTTP 3.02.3M">
  <ns0:data key="d0">NTTP 3.02.3M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NTTP 3.02.3M supports compliance in label maintenance and equipment staging procedures.&lt;SEP&gt;NTTP 3.02.3M is a Navy Tactics, Techniques, and Procedures manual for compliance in equipment labeling.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="SOUM">
  <ns0:data key="d0">SOUM</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SOUM refers to Safety-Of-Use Messages that inform of potential safety concerns for military equipment and require special maintenance actions.&lt;SEP&gt;Safety of Use Messages contain information that must be accurately updated in GCSS-MC by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MAM">
  <ns0:data key="d0">MAM</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MAM refers to Maintenance Advisory Messages providing guidance on capability limitations until corrected for military equipment.&lt;SEP&gt;Maintenance Advisory Messages provide data for updates in GCSS-MC along with supply advisories.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO P5100.34">
  <ns0:data key="d0">MCO P5100.34</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO P5100.34 directs updates to GCSS-MC based on SOUM, MAM, and supply advisories.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1005">
  <ns0:data key="d0">CDRL 1005</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1005 is the Internal Inspection Schedule submitted NLT 21 business days after contract award and updated annually.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1006">
  <ns0:data key="d0">CDRL 1006</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1006 consists of Internal Inspection Results submitted NLT 10 business days after each inspection completion.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CDRL 1007">
  <ns0:data key="d0">CDRL 1007</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1007 is the Plan of Corrective Action submitted NLT 21 business days after internal inspections to address discrepancies.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 4790.25">
  <ns0:data key="d0">MCO 4790.25</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4790.25 defines Field Level of Maintenance (LOM), Mission Capable (MC) status, and corrective maintenance procedures for ME and CESE.&lt;SEP&gt;MCO 4790.25 specifies authorized maintenance tasks based on capabilities and procedures for Contracted Logistics Support items.&lt;SEP&gt;MCO 4790.25 supports the corrective maintenance program for Navy CESE.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 4855.10C">
  <ns0:data key="d0">MCO 4855.10C</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4855.10C supports establishment of warranty coordination procedures for equipment under warranty.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 4105.2A">
  <ns0:data key="d0">MCO 4105.2A</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4105.2A covers procedures for placing newly fielded equipment into service and managing Contracted Logistics Support items.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 4855.1">
  <ns0:data key="d0">NAVMC 4855.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 4855.1 aids in warranty coordination and identification of equipment under warranty.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 4200.33">
  <ns0:data key="d0">MCO 4200.33</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4200.33 establishes procedures for service of Contracted Logistics Support items.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CLS">
  <ns0:data key="d0">CLS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Contracted Logistics Support encompasses procedures for handling items requiring service, including adherence to specified Marine Corps orders.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="SR">
  <ns0:data key="d0">SR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Service Requests organize the receipt, transfer, storage, and validation of repair parts in stage and layette sub-inventories.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="SDR">
  <ns0:data key="d0">SDR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Supply Discrepancy Report is used to document and report discrepancies, damaged parts, or unrequired items in supply support processes.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="On-Island">
  <ns0:data key="d0">On-Island</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">On-Island serves as a physical location for establishing and maintaining DSI inventories optimized via GCSS-MC Planner's Desktop.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Shipboard">
  <ns0:data key="d0">Shipboard</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Shipboard is the operational environment for DSI inventories, managed with justification for non-demand based stock and timed to production cycles.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Detailed Ship Plans">
  <ns0:data key="d0">Detailed Ship Plans</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Detailed Ship Plans are provided by the Government identifying load out/spread for ships and used for attainment deficiency reporting and production preparations.&lt;SEP&gt;Detailed Ship Plans provide ship allowance quantities and are provided to the MCMC 90 calendar days prior to the start of ships' production period.&lt;SEP&gt;Detailed Ship Plans are government-provided documents used to determine submission timelines for Shipboard DSI Authorization Letters.&lt;SEP&gt;Detailed Ship Plans identify Ship Spread quantities in the MCPIC Prepositioning Planning System.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Fielding Plans">
  <ns0:data key="d0">Fielding Plans</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Fielding Plans guide the MCMC in placing newly fielded equipment into service along with other publications.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="TMs">
  <ns0:data key="d0">TMs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Technical Manuals are equipment-specific publications used in conjunction with Fielding Plans for placing equipment into service.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="SIs">
  <ns0:data key="d0">SIs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Service Instructions are equipment-specific publications supporting equipment fielding and service procedures.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 4400.150">
  <ns0:data key="d0">MCO 4400.150</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4400.150 establishes accountability procedures for Government-owned Garrison Fabricated Tools in DPAS.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MSE">
  <ns0:data key="d0">MSE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MSE is a data element associated with load and staging plan development, and labels that require checking for legibility and replacement.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MPE">
  <ns0:data key="d0">MPE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MPE refers to items weighed at the Scale House, with weight tickets provided for input into IPACK data records.</ns0:data>
  <ns0:data key="d3">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Squadron Supervisor">
  <ns0:data key="d0">Squadron Supervisor</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Squadron Supervisor is a role within MCMC responsible for arranging temporary billeting and coordinating services aboard MPS.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="ISSA">
  <ns0:data key="d0">ISSA</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISSA is the Inter-Service Support Agreement between BICmd and Military Sealift Command providing food, lodging, and other services to contractor employees.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Chief Steward">
  <ns0:data key="d0">Chief Steward</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Chief Steward coordinates materials required for cleaning aboard the ship via the Ship's Master or Chief Mate.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Chief Mate">
  <ns0:data key="d0">Chief Mate</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Chief Mate coordinates materials required for cleaning aboard the ship alongside the Ship's Master.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="LOA">
  <ns0:data key="d0">LOA</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">LOA is the Letter of Authorization issued in the SPOT database and incorporated onto the employee's CAC for privileges at military facilities.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="SPOT">
  <ns0:data key="d0">SPOT</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">SPOT is the Synchronized Pre-deployment &amp; Operational Tracker database used to generate LOAs for employee privileges.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CAC">
  <ns0:data key="d0">CAC</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CAC is the Common Access Card that incorporates privileges from the LOA for MCMC employees.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CBRN Filters">
  <ns0:data key="d0">CBRN Filters</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CBRN filters are part of collective protective systems on prepositioned military equipment, with contingency and training sets required for vehicles like TRK, AMBULANCE, 4-LTR, ARMD.&lt;SEP&gt;CBRN Filters are chemical, biological, radiological, and nuclear filters installed on vehicles, with training and contingency types managed by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="COMSEC">
  <ns0:data key="d0">COMSEC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">COMSEC is Communications Security material requiring proper access, inventory, and reporting managed by MCMC under KMI.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Employee Expense Report">
  <ns0:data key="d0">Employee Expense Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Employee Expense Report is a required submission with receipts for employee-related costs.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MSC">
  <ns0:data key="d0">MSC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MSC coordinates bulk fuel/Class III(B) and provides MHE support aboard T-AKE ships.&lt;SEP&gt;MSC is the Military Sealift Command involved in the Inter-Service Support Agreement providing services to contractor employees and referenced in SAAR-N for network access.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="AIS">
  <ns0:data key="d0">AIS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">AIS is a system into which the MCMC inputs maintenance and management data with a minimum 95% accuracy rate, used for quality assurance inspections.&lt;SEP&gt;AIS is Government-required Automated Information Systems for which initial training is provided to MCMC personnel.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Diego Garcia">
  <ns0:data key="d0">Diego Garcia</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Diego Garcia is one of the overseas locations where the MCMC requires access for program operations and exercises.&lt;SEP&gt;Diego Garcia is a location where MCMC establishes and maintains U.S. Post Office Boxes for shipping and receiving Controlled Cryptographic Items.&lt;SEP&gt;Diego Garcia is a location requiring establishment of U.S. Post Office Boxes for shipping and receiving Controlled Cryptographic Items.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="Saipan">
  <ns0:data key="d0">Saipan</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Saipan is one of the overseas locations where the MCMC requires access for program operations and exercises.&lt;SEP&gt;Saipan is a location where MCMC establishes and maintains U.S. Post Office Boxes for shipping and receiving Controlled Cryptographic Items.&lt;SEP&gt;Saipan is a location requiring establishment of U.S. Post Office Boxes for shipping and receiving Controlled Cryptographic Items.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="TAAT">
  <ns0:data key="d0">TAAT</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">TAAT is Technical Assistance &amp; Advisory Teams deployed for crisis response and contingency operations, impacting MMC personnel.&lt;SEP&gt;TAAT coordinates with MAGTF and LOGCOM on SECREP management and refuses carcasses under certain conditions.&lt;SEP&gt;TAAT is the BICmd Technical Assistance and Advisory Team that coordinates with MCMC, COR, and operational forces for prepositioning and exercise support.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="CMS-1">
  <ns0:data key="d0">CMS-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CMS-1 is a series of Communications Security directives governing appointments, access lists, inventories, and incident reporting for KMI operations.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841069</ns0:data>
</ns0:node>
<ns0:node id="MCO 2281.1">
  <ns0:data key="d0">MCO 2281.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 2281.1 is a Marine Corps Order series for COMSEC access, personnel listings, and local element operations in KMI support.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="MSC SAAR-N">
  <ns0:data key="d0">MSC SAAR-N</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MSC SAAR-N is a form submitted by MCMC for access to shipboard networks in accordance with Government ISO procedures.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="AA&amp;E Forms">
  <ns0:data key="d0">AA&amp;E Forms</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">AA&amp;E Forms are Arms, Ammunition and Explosives Screening forms (CDRL 7010) submitted by MCMC for ammunition billets on T-AKE vessels.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Resource and Support Plan">
  <ns0:data key="d0">Resource and Support Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Resource and Support Plan is a proposed plan provided by MCMC for Contracting Officer approval, covering offload preparation, operations, and reconstitution.&lt;SEP&gt;Resource and Support Plan is a proposed plan provided by MCMC for Contracting Officer approval, including support for withdrawal, assembly, and reconstitution operations.&lt;SEP&gt;Resource and Support Plan is proposed by MCMC for contracting officer approval to support offload preparation, equipment offloads, reconstitution, backloads, and other requirements in exercises or contingencies.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 7010">
  <ns0:data key="d0">CDRL 7010</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 7010 is the contract data requirement for AA&amp;E screening forms submitted within 30 days of boarding assigned ships.</ns0:data>
  <ns0:data key="d3">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="COSIS Plan">
  <ns0:data key="d0">COSIS Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">COSIS Plan covers a full fiscal year with detailed status and updates provided on a monthly basis, including listings of materiel planned for COSIS inspection, testing, or PMCS.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="COSIS Database">
  <ns0:data key="d0">COSIS Database</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">COSIS Database tracks requirements, completed actions, and scheduled or pending actions for materiel, available for Government review in accordance with specified Marine Corps Orders and technical manuals.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Marine Depot Maintenance Command Albany">
  <ns0:data key="d0">Marine Depot Maintenance Command Albany</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Depot Maintenance Command Albany provides services under the Repair and Return program for serviceability testing that cannot be completed organically.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="MCO 4000.58">
  <ns0:data key="d0">MCO 4000.58</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4000.58 outlines requirements for Type I and Type II shelf life assets during embarkation on MPF.&lt;SEP&gt;MCO 4000.58 provides guidance on minimum shelf life for prepositioned materiel that supersedes other orders for MCMC.&lt;SEP&gt;MCO 4000.58 is a Marine Corps Order specifying shelf life requirements for operational rations.&lt;SEP&gt;MCO 4000.58 establishes prepositioning shelf life criteria for SL-3 components associated with ME and Navy CESE.&lt;SEP&gt;MCO 4000.58 is a Marine Corps Order referenced for supply chain management and operations.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Shelf Life/Service Life Expiration Report">
  <ns0:data key="d0">Quarterly Shelf Life/Service Life Expiration Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quarterly Shelf Life/Service Life Expiration Report is submitted by the MCMC within the first 10 calendar days of each fiscal year quarter and contains data elements for assets with end of service life within 18 months.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Preservation, Packaging, Packing, and Marking">
  <ns0:data key="d0">Preservation, Packaging, Packing, and Marking</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Preservation, Packaging, Packing, and Marking is conducted by the MCMC for equipment and supplies requiring storage, embarkation, or shipment in accordance with specified Marine Corps Orders and military standards.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Automatic Identification Technology">
  <ns0:data key="d0">Automatic Identification Technology</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Automatic Identification Technology resources are applied by the MCMC to materiel and assets for identification, tracking, and documentation, including passive RFID tags, IUID, and barcodes.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="DoD IUID Registry">
  <ns0:data key="d0">DoD IUID Registry</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DoD IUID Registry is utilized by the MCMC for applicable IUID-tagged asset visibility, accountability, management, and reporting.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Financial Liability Investigation of Property Loss">
  <ns0:data key="d0">Financial Liability Investigation of Property Loss</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Financial Liability Investigation of Property Loss process is initiated using DD Form 200 for situations involving lost, damaged, or destroyed Marine Corps property in MCMC possession.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 1018">
  <ns0:data key="d0">NAVMC 1018</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 1018 is a tag that must be accurate for SECREPs in the MMFAU1 account and subfloats, with copies placed on P3&amp;M crates/boxes.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1225">
  <ns0:data key="d0">DD Form 1225</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1225 is used to ensure accurate identification of SECREP condition codes in GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Rations PBA Annex">
  <ns0:data key="d0">Rations PBA Annex</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Rations PBA Annex is an agreement between DLA and I&amp;L (LF) referenced for standards in the Shelf Life/Service Life Management program.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="MREs">
  <ns0:data key="d0">MREs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MREs are rations requiring 33 months or more remaining shelf life at the time of MMC embarkation aboard MPS.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="FEDLOG">
  <ns0:data key="d0">FEDLOG</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FEDLOG is used to look up CEC/CRIT codes for repair parts and determine shelf life codes for SL-3 components.&lt;SEP&gt;FEDLOG supplies technical data for validating RIP special allowance requests alongside CAL records and physical inventory.&lt;SEP&gt;FEDLOG provides data for accurate shelf life reporting and database maintenance in the Quarterly Shelf Life/Service Life Expiration Report.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CHE">
  <ns0:data key="d0">CHE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CHE is Container Handling Equipment requiring personnel training, testing, and licensing for use in materiel/cargo handling operations.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="DoDI 8320.04">
  <ns0:data key="d0">DoDI 8320.04</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoDI 8320.04 instructs on the application of Automatic Identification Technology resources to materiel and assets.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="SOW">
  <ns0:data key="d0">SOW</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">The SOW is the Statement of Work that details work requirements, sustainment operations, and MMC operations for the contract.&lt;SEP&gt;SOW is the Statement of Work with Section C.2.A providing guidance on Automatic Identification Technology applications.&lt;SEP&gt;The SOW specifies requirements for MCPP operations, maintenance responsibilities, and overall contract performance, including during transition periods.&lt;SEP&gt;SOW is the Statement of Work that includes details on Continuous Process Improvement requirements.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="WIR">
  <ns0:data key="d0">WIR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">WIR is a Work Item Request submitted for disposition of unserviceable, obsolete, or excess equipment or supplies.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="MLSR">
  <ns0:data key="d0">MLSR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MLSR involves reporting and investigation of missing, lost, stolen, or recovered materiel.&lt;SEP&gt;MLSR encompasses Missing, Lost, Stolen, or Recovered items requiring immediate notification and causative research.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="SF-91">
  <ns0:data key="d0">SF-91</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SF-91 is a standard form for accident reporting provided by MCMC to the Government when Government-owned assets are involved in accidents.&lt;SEP&gt;SF-91 is a form completed and provided by the MCMC for accidents involving Government-owned assets.&lt;SEP&gt;SF-91 is a standard form that operators must complete if involved in an accident.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="SF-94">
  <ns0:data key="d0">SF-94</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SF-94 is a standard form provided by MCMC to the Government when applicable for accidents involving Government-owned assets.&lt;SEP&gt;SF-94 is a form provided by the MCMC when applicable for accidents involving Government-owned assets.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Section 4.C.5.d">
  <ns0:data key="d0">Section 4.C.5.d</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.C.5.d details the MCMC's development and execution of the Shelf Life/Service Life Management program, including specific requirements for Type I, Type II assets, rations, and quarterly reporting.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5028">
  <ns0:data key="d0">CDRL 5028</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5028 is the deliverable for the Monthly COSIS Surveillance Plan Update and Status Report submitted by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5029">
  <ns0:data key="d0">CDRL 5029</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5029 is the deliverable for the Quarterly Shelf Life/Service Life Expiration Report submitted by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5030">
  <ns0:data key="d0">CDRL 5030</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5030 is the deliverable for MCMC requests to the Government for redistributions, rollbacks, or dispositions of materiel.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5031">
  <ns0:data key="d0">CDRL 5031</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5031 is the deliverable for written notifications from the MCMC regarding missing, lost, stolen, or damaged Government-owned assets.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5032">
  <ns0:data key="d0">CDRL 5032</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5032 is the deliverable for DD Form 200 prepared by the MCMC for lost, damaged, or destroyed Government property.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5033">
  <ns0:data key="d0">CDRL 5033</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5033 is the completed investigation report provided by MCMC to the Government for MLSR situations and other cases of missing, lost, stolen, or damaged materiel.&lt;SEP&gt;CDRL 5033 is the deliverable for the MCMC's completed investigation report on MLSR incidents and other cases of missing, lost, stolen, or damaged materiel.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5034">
  <ns0:data key="d0">CDRL 5034</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5034 consists of completed SF-91, accident LTI, and SF-94 provided for accidents involving Government-owned assets.&lt;SEP&gt;CDRL 5034 is the deliverable for completed SF-91, accident LTI, and SF-94 provided by the MCMC for accidents involving Government-owned assets.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Draft Rfp M6700425R0007">
  <ns0:data key="d0">Draft Rfp M6700425R0007</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Draft Rfp M6700425R0007 is a 425-page request for proposal document outlining procedural guidance, applicable publications, and acronyms for Marine Corps logistics, property management, and related programs.&lt;SEP&gt;Draft Rfp M6700425R0007 is a solicitation document containing an acronym glossary across pages 71 to 80 of 425.&lt;SEP&gt;Draft RFP M6700425R0007 is the solicitation document containing the clauses and requirements.&lt;SEP&gt;Draft Request for Proposals numbered M6700425R0007 covering contract periods, clauses, and administration data across pages 324 to 329.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-55bcb4486837a866d3ae601a0bfee839&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="M38450">
  <ns0:data key="d0">M38450</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Location code designated as FOB Destination for all specified periods of performance, noted as the same as previous location.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Period Of Performance">
  <ns0:data key="d0">Period Of Performance</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Timeframe for issuing task orders starting from contract award, encompassing a five-year basic period, five-year Option I, and six additional months under clause 52.217-8, with specific dates for various entries from 4005 to 9007.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Stop Work Order">
  <ns0:data key="d0">Stop Work Order</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause 52.242-15 Alternate I (August 1989, Alternate I April 1984) incorporated by reference in the contract.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Government Delay Of Work">
  <ns0:data key="d0">Government Delay Of Work</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause 52.242-17 (April 1984) incorporated by reference in the contract.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="F-1 Performance Period">
  <ns0:data key="d0">F-1 Performance Period</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section outlining the contractual coverage for periods of performance, including phase-in upon award for 90 days, basic ordering period through five years, Option Ordering Period I for five years, and reference to clause 52.217-8.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Section G Contract Administration Data">
  <ns0:data key="d0">Section G Contract Administration Data</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section detailing contract administration, including incorporated clauses, payment instructions, and authority structures.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Billing Instructions Cost Vouchers">
  <ns0:data key="d0">Billing Instructions Cost Vouchers</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause 252.204-7006 (May 2023) incorporated by reference for billing instructions related to cost vouchers.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Wide Area Workflow Payment Instructions">
  <ns0:data key="d0">Wide Area Workflow Payment Instructions</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause 252.232-7006 (January 2023) incorporated by full text, specifying electronic invoicing procedures using Wide Area Workflow for payment requests and receiving reports.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Department Of Defense Activity Address Code">
  <ns0:data key="d0">Department Of Defense Activity Address Code</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Six-position code that uniquely identifies a unit, activity, or organization, used in Wide Area Workflow routing.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="System For Award Management">
  <ns0:data key="d0">System For Award Management</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Online system at sam.gov where contractors must designate an electronic business point of contact to access Wide Area Workflow.&lt;SEP&gt;System For Award Management is a federal registration system accessed via https://www.sam.gov where offerors complete and maintain annual representations and certifications.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Contracts Office Code 902">
  <ns0:data key="d0">Contracts Office Code 902</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Procuring contracting office located at 5880 Channel View Boulevard, Blount Island Command, Jacksonville, FL 32226-3404, responsible for contract administration.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville Fl">
  <ns0:data key="d0">Jacksonville Fl</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">City and state hosting Blount Island Command and the Contracts Office at 5880 Channel View Boulevard, zip code 32226-3404.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officer Technical Representative">
  <ns0:data key="d0">Contracting Officer Technical Representative</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Contracting Officer Technical Representative is a qualified individual designated in writing by the Contracting Officer to assist in technical monitoring or administration limited to specific technical areas.&lt;SEP&gt;Contracting Officer Technical Representative is the COTR who performs specific technical or administrative functions, monitors contractor performance, provides guidance, and reports issues without authority to modify contracts.&lt;SEP&gt;Technical representatives reporting to the Contracting Officer'S Representative, tasked with contract oversight, technical guidance, performance monitoring, deliverable approval, quality assurance, issue resolution, and compliance documentation.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Mcmc">
  <ns0:data key="d0">Mcmc</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Organization tasked with providing program management, maintenance production, logistics support, and other services under the contract.&lt;SEP&gt;Contractor entity referenced in contexts of effecting changes at its own risk without Contracting Officer authorization and handling contractual problems.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="52.217-8">
  <ns0:data key="d0">52.217-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause referenced for providing an additional 6 months to the period of performance after the basic and option periods.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Section H-8">
  <ns0:data key="d0">Section H-8</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-8 describes ordering of services under the IDIQ contract, including task order content, allowable costs, fees, and release of claims.&lt;SEP&gt;Section providing additional guidance related to task order issuance under the contract.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841070</ns0:data>
</ns0:node>
<ns0:node id="Phase-In">
  <ns0:data key="d0">Phase-In</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Phase-In covers a 90-day period after contract award as part of the overall contractual coverage and period of performance.&lt;SEP&gt;Contractual phase upon award lasting 90 days for initial implementation.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Basic Ordering Period">
  <ns0:data key="d0">Basic Ordering Period</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Initial five-year period starting from contract award date for issuing task orders.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Option Ordering Period I">
  <ns0:data key="d0">Option Ordering Period I</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Optional five-year extension following the basic ordering period for continued task order issuance.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="DFARS 252.232-7003">
  <ns0:data key="d0">DFARS 252.232-7003</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Clause defining payment request and receiving report, referenced in Wide Area Workflow Payment Instructions for electronic submissions.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Local Processing Office">
  <ns0:data key="d0">Local Processing Office</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Office responsible for payment certification when performed external to the entitlement system, as defined in Wide Area Workflow Payment Instructions.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="5880 Channel View Boulevard">
  <ns0:data key="d0">5880 Channel View Boulevard</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Specific address of the Procuring Contracting Officer and Contracts Office Code 902 in Jacksonville, FL.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Quality Assurance">
  <ns0:data key="d0">Quality Assurance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Quality Assurance is defined by the acronym QA.&lt;SEP&gt;Personnel appointed by the Contracting Officer to inspect and accept the contractor's performance under the contract.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="DFARS Appendix F">
  <ns0:data key="d0">DFARS Appendix F</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Appendix specifying requirements for receiving reports, as referenced in Wide Area Workflow Payment Instructions.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="52.216-7">
  <ns0:data key="d0">52.216-7</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Allowable Cost and Payment clause referenced for documentation in payment requests.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="52.213-1">
  <ns0:data key="d0">52.213-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Federal Acquisition Regulation clause permitting Fast Pay requests in the contract.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Fast Pay">
  <ns0:data key="d0">Fast Pay</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Payment method permitted only when FAR 52.213-1 is included, using specific WAWF document types.</ns0:data>
  <ns0:data key="d3">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Navy QAR">
  <ns0:data key="d0">Navy QAR</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Navy QAR is the Navy Quality Assurance Representative notified by MCMC for equipment tests and load banking.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="DTR 4900-R">
  <ns0:data key="d0">DTR 4900-R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DTR 4900-R is the Defense Transportation Regulation referenced for cleaning fuel containers on CESE.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Title 49 CFR">
  <ns0:data key="d0">Title 49 CFR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Title 49 CFR is a federal regulation applied in conjunction with equipment TMs for cleaning fuel containers on CESE.&lt;SEP&gt;Title 49 CFR regulates fuel container handling, cleaning, and lower explosive level testing for safety compliance.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="SUR">
  <ns0:data key="d0">SUR</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">SUR is Service Upon Receipt performed by MCMC on received CESE within 45 calendar days, following MCO 4790.2 and CmdO 4790.1.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="CM">
  <ns0:data key="d0">CM</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">CM is Corrective Maintenance program maintained by MCMC for Navy CESE to restore mission capability, using OMMS-NG and requiring prior authorization.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="C3">
  <ns0:data key="d0">C3</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">C3 is Corrosion Control and Coating executed by MCMC on CESE according to CmdO 4790.1 and related technical manuals.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="WMC">
  <ns0:data key="d0">WMC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">WMC is the Navy Watercraft Maintenance Center established and maintained by MCMC for Navy watercraft, including LARC and ABLTS.&lt;SEP&gt;WMC is the Watercraft Maintenance Center where hazardous material is managed and waste is handled in compliance with regulations.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MRP">
  <ns0:data key="d0">MRP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MRP is the Maintenance Requirements Package followed by MCMC for organizational level maintenance on Navy watercraft.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="6.E">
  <ns0:data key="d0">6.E</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.E outlines requirements for MCMC to perform maintenance on Navy CESE, including PMCS, CM, and related programs.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="6.F">
  <ns0:data key="d0">6.F</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F specifies requirements for MCMC to establish and maintain the Navy Watercraft Maintenance Center for lighterage ashore.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MTVR FOV">
  <ns0:data key="d0">MTVR FOV</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MTVR FOV is a CESE asset requiring replacement of dryer air filter and aftercooler filter during PMCS.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6037">
  <ns0:data key="d0">CDRL 6037</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6037 is the Load Bank Form used to record the load banking process for Navy generators, filed within five business days.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-023">
  <ns0:data key="d0">SOW Attachment C.6-023</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-023 provides an example of the Load Bank Form for recording generator load banking.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MCO 4690.1">
  <ns0:data key="d0">MCO 4690.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4690.1 is a Marine Corps Order referenced for inspecting ISO freight containers.&lt;SEP&gt;MCO 4690.1 outlines procedures for ISO container accountability and inspections.&lt;SEP&gt;MCO 4690.1 establishes Marine Corps policy for container management, including inspection and certification of ISO fittings on fuel and water systems.&lt;SEP&gt;MCO 4690.1 establishes policy for inspecting and certifying transportable fuel and water systems using ISO container fittings.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="CmdO 4450.1">
  <ns0:data key="d0">CmdO 4450.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 4450.1 is the COSIS Order that governs the performance of Condition of Supply Inspections Service (COSIS) on ME and CESE assets.&lt;SEP&gt;CmdO 4450.1 outlines procedures for COSIS of Class II and VII CESE assets in open storage.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MCO 4790.18">
  <ns0:data key="d0">MCO 4790.18</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4790.18 provides procedures for corrosion control and coating on CESE.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="TM 4795-OR-1">
  <ns0:data key="d0">TM 4795-OR-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 4795-OR-1 details corrosion control and coating procedures executed by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="TM 4750-OD/1">
  <ns0:data key="d0">TM 4750-OD/1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 4750-OD/1 details corrosion control and coating procedures executed by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="TMDE">
  <ns0:data key="d0">TMDE</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">TMDE refers to Test, Measurement, and Diagnostic Equipment assets, some of which are not resident in GCSS-MC and require local tracking and reporting by the MCMC.&lt;SEP&gt;TMDE is Test Measurement and Diagnostic Equipment that requires recalibration during refurbishment of military equipment.&lt;SEP&gt;TMDE are tools used for measurements requiring calibration services during MCMC production maintenance phase.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6038">
  <ns0:data key="d0">CDRL 6038</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6038 is the Navy EOS CESE Maintenance Report submitted by MCMC within five business days after production period completion.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-045">
  <ns0:data key="d0">SOW Attachment C.6-045</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-045 provides the format for the Navy EOS CESE Maintenance Report.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="LMF">
  <ns0:data key="d0">LMF</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">LMF is the LARC Maintenance Facility, a dedicated on-island element of the WMC for LARC maintenance.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MPFUB">
  <ns0:data key="d0">MPFUB</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MPFUB is a Maritime Prepositioning Force Utility Boat requiring specific fueling amounts and maintenance.&lt;SEP&gt;MPFUB is a type of maintenance task associated with Maritime Prepositioning Force Utility Boat, supported by LMF personnel when not impacting LARC maintenance.&lt;SEP&gt;MPFUB is equipment assisted by LMF personnel for maintenance alongside LARC.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="JSN/JCN">
  <ns0:data key="d0">JSN/JCN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">JSN/JCN are identifiers clearly stated on MCMC work request forms for maintenance actions.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="SOUMs">
  <ns0:data key="d0">SOUMs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOUMs are Safety of Use Messages published for special maintenance actions on CESE.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MAMs">
  <ns0:data key="d0">MAMs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MAMs are Maintenance Advisory Messages directing special maintenance on CESE.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="MIMs">
  <ns0:data key="d0">MIMs</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIMs are Maintenance Information Messages for special maintenance actions on CESE.</ns0:data>
  <ns0:data key="d3">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="GPM/A">
  <ns0:data key="d0">GPM/A</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">GPM/A refers to Ground Precautionary Messages/Advisories warning of precautions for ground equipment use and employment.&lt;SEP&gt;GPM/A are Ground Precautionary Messages/Advisories for special maintenance on CESE.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="Section K Representations, Certifications And Other Statements Of Offerors">
  <ns0:data key="d0">Section K Representations, Certifications And Other Statements Of Offerors</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section K Representations, Certifications And Other Statements Of Offerors is a section in the RFP containing clauses incorporated by reference and full text for offerors' compliance and certifications.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841071</ns0:data>
</ns0:node>
<ns0:node id="52.204-19 Incorporation By Reference Of Representations And Certifications">
  <ns0:data key="d0">52.204-19 Incorporation By Reference Of Representations And Certifications</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-19 Incorporation By Reference Of Representations And Certifications is a clause from December 2014 incorporated by reference in the RFP.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="52.222-56 Certification Regarding Trafficking In Persons Compliance Plan">
  <ns0:data key="d0">52.222-56 Certification Regarding Trafficking In Persons Compliance Plan</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.222-56 Certification Regarding Trafficking In Persons Compliance Plan is a clause from October 2020 incorporated by reference in the RFP.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="252.225-7065 Restriction On Acquisition Of Fuel For Overseas Contingency Operations">
  <ns0:data key="d0">252.225-7065 Restriction On Acquisition Of Fuel For Overseas Contingency Operations</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">252.225-7065 Restriction On Acquisition Of Fuel For Overseas Contingency Operations is a clause from October 2024 incorporated by reference in the RFP.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="252.247-7023 Transportation Of Supplies By Sea">
  <ns0:data key="d0">252.247-7023 Transportation Of Supplies By Sea</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">252.247-7023 Transportation Of Supplies By Sea is a clause from October 2024 incorporated by reference in the RFP.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="52.203-2 Certificate Of Independent Price Determination">
  <ns0:data key="d0">52.203-2 Certificate Of Independent Price Determination</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.203-2 Certificate Of Independent Price Determination is a clause from April 1985 with full text provided, certifying that offer prices are determined independently without collusion or restriction of competition.&lt;SEP&gt;52.203-2 Certificate Of Independent Price Determination applies to solicitations for firm-fixed-price contracts or fixed-price with economic price adjustment unless under simplified acquisition procedures, two-step sealed bidding, or for utility services with rates set by law or regulation.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="52.204-8 Annual Representations And Certifications">
  <ns0:data key="d0">52.204-8 Annual Representations And Certifications</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-8 Annual Representations And Certifications specifies the NAICS code 811310 for the acquisition with a small business size standard of $12,500,000 and outlines applicable representations and certifications in the System for Award Management.&lt;SEP&gt;52.204-8 Annual Representations And Certifications is a clause from January 2025 with full text provided, specifying the NAICS code and small business size standard for the acquisition.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Naics Code 811310">
  <ns0:data key="d0">Naics Code 811310</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Naics Code 811310 is the classification code for this acquisition with a small business size standard of $12,500,000.&lt;SEP&gt;Naics Code 811310 is the North American Industry Classification System code assigned to this acquisition for commercial and industrial machinery and equipment repair and maintenance.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Small Business Size Standard">
  <ns0:data key="d0">Small Business Size Standard</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Small Business Size Standard is $12,500,000 for Naics Code 811310, with additional standards of 500 employees or 150 employees for certain information technology resellers under Naics Code 541519.&lt;SEP&gt;Small Business Size Standard is set at $12,500,000 in average annual receipts for concerns under NAICS code 811310 in this acquisition.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Statement Of Work For Reoccurring Support Tasks">
  <ns0:data key="d0">Statement Of Work For Reoccurring Support Tasks</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">Statement Of Work For Reoccurring Support Tasks is a document numbered 6077, submitted within 10 business days under section 6.R.2 for recurring support tasks.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Post Exercise After Action Report">
  <ns0:data key="d0">Post Exercise After Action Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Post Exercise After Action Report is a report numbered 6088, submitted no later than 15 calendar days under section 6.J.9.f following exercises.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Contractor's Resource And Support Plan">
  <ns0:data key="d0">Contractor's Resource And Support Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Contractor's Resource And Support Plan is a report numbered 7002, submitted 10 days after RFP issuance under section 7.G.2 for resource planning.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Accident Prevention Plan">
  <ns0:data key="d0">Accident Prevention Plan</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Accident Prevention Plan is a document numbered 10014, submitted as required under section 10.B.1 for safety compliance.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Material List">
  <ns0:data key="d0">Hazardous Material List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Hazardous Material List is provided as part of Post-Production Documents by MCMC.&lt;SEP&gt;Hazardous Material List is a report numbered 10046, submitted as required under section 10.C.5.a for environmental management.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.48">
  <ns0:data key="d0">Section 6.F.48</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.48 requires MCMC to submit a weekly Watercraft Maintenance Status Report organized by ship and watercraft in FAB format.&lt;SEP&gt;Section 6.F.48 is a section in the statement of work referencing the weekly submission of the Watercraft Maintenance Status Report.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946&lt;SEP&gt;chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.50">
  <ns0:data key="d0">Section 6.F.50</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.50 requires MCMC to schedule, support, and document Operational Tests for Navy Watercraft.&lt;SEP&gt;Section 6.F.50 is a section in the statement of work referencing submission within 5 days of the Navy OPTEST Form.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946&lt;SEP&gt;chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Section 6.R.2">
  <ns0:data key="d0">Section 6.R.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.R.2 is a section in the statement of work referencing submission within 10 business days of the Statement of Work for Reoccurring Support Tasks.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Section 6.J.9.f">
  <ns0:data key="d0">Section 6.J.9.f</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.J.9.f is a section in the statement of work referencing submission no later than 15 calendar days of the Post Exercise After Action Report.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Section 10.B.1">
  <ns0:data key="d0">Section 10.B.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 10.B.1 is a section in the statement of work referencing submission as required of the Accident Prevention Plan.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="End Item Small Business Size Standard">
  <ns0:data key="d0">End Item Small Business Size Standard</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">End Item Small Business Size Standard is 500 employees for concerns furnishing an end item not manufactured by themselves, or 150 employees for information technology value-added resellers under NAICS code 541519.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Navy Small Arms Monthly Weapons Inventory Report">
  <ns0:data key="d0">Navy Small Arms Monthly Weapons Inventory Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Small Arms Monthly Weapons Inventory Report is a monthly report numbered 6082 under sections 6.C.15.a and 6.J.4 for small arms weapons inventory.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Monthly Situation Report (SITREP)">
  <ns0:data key="d0">Monthly Situation Report (SITREP)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Monthly Situation Report (SITREP) is a monthly report numbered 6083 under section 6.J.9.a for situational updates.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Semi Annual Startup (SASU) Report">
  <ns0:data key="d0">Semi Annual Startup (SASU) Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Semi Annual Startup (SASU) Report is a report numbered 6084, submitted upon SASU completion under section 6.J.9.b.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Clauses Incorporated By Reference">
  <ns0:data key="d0">Clauses Incorporated By Reference</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Compilation of standard contract clauses from FAR and DFARS incorporated into the contract by reference, covering topics including definitions, ethics, security, labor standards, pricing, payments, and specialized defense requirements.&lt;SEP&gt;Clauses Incorporated By Reference is a subsection in Section K listing clauses such as 52.204-19, 52.222-56, 252.225-7065, and 252.247-7023.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946&lt;SEP&gt;chunk-4c6c8cc3b4b40997aa333b8fb93d6c6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Clauses Incorporated By Full Text">
  <ns0:data key="d0">Clauses Incorporated By Full Text</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Clauses Incorporated By Full Text is a subsection in Section K providing the complete text of clauses such as 52.203-2 and 52.204-8.</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Department Of Defense">
  <ns0:data key="d0">Department Of Defense</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Department Of Defense issues instructions, directives, manuals, and regulations covering accountability, financial management, security, and logistics for government property and equipment.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps">
  <ns0:data key="d0">Marine Corps</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Marine Corps is involved in operations, maintenance cycles, and equipment support aligned with the MCPP contract.&lt;SEP&gt;Marine Corps oversees prepositioning programs, including MCPP-N and MCPP-PHIL, and provides manuals and commands for system usage.&lt;SEP&gt;Marine Corps issues orders, bulletins, and manuals on topics including equipment readiness, prepositioning programs, maintenance, environmental compliance, and property management.&lt;SEP&gt;Marine Corps is an equipment ownership group responsible for funding portions of contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Environmental Protection Agency">
  <ns0:data key="d0">Environmental Protection Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Environmental Protection Agency issues Title V Air Operational Permit related to air emissions and compliance.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Occupational Safety And Health Administration">
  <ns0:data key="d0">Occupational Safety And Health Administration</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Occupational Safety And Health Administration provides standards and instructions on confined spaces, medical surveillance, and voluntary protection programs.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="DodI 4161.02">
  <ns0:data key="d0">DodI 4161.02</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DodI 4161.02 addresses accountability and management of government contract property.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Mco 4400.201">
  <ns0:data key="d0">Mco 4400.201</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Mco 4400.201 covers management of property in the possession of the Marine Corps.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Navmc 2907">
  <ns0:data key="d0">Navmc 2907</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Navmc 2907 outlines prepositioning objective for maritime prepositioning force and Marine Corps prepositioning program in Norway.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Ship Set">
  <ns0:data key="d0">Ship Set</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Ship Set refers to all materiel associated with Navmc 2907 designated for a specific maritime prepositioning ships vessel according to detailed ship-level plans.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Set">
  <ns0:data key="d0">Set</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Set refers to all materiel associated with Navmc 2907 designated for Marine Corps Prepositioning Program in Continental United States, Marine Corps Prepositioning Program Norway, Marine Corps Prepositioning Program Philippines, and future programs.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Continental United States">
  <ns0:data key="d0">Continental United States</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Continental United States is referenced as Conus in the context of Marine Corps prepositioning programs.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Ships">
  <ns0:data key="d0">Maritime Prepositioning Ships</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Ships are afloat locations for supply management operations and associated sub-custody accounts.&lt;SEP&gt;Maritime Prepositioning Ships are Navy-owned vessels strategically located around the world to carry equipment and supplies for Marine Corps operations.&lt;SEP&gt;Maritime Prepositioning Ships are vessels that rotate through BICmd for MMC, carrying equipment and supplies for prepositioning.&lt;SEP&gt;Maritime Prepositioning Ships are vessels designated for specific ship sets of prepositioned materiel under Navmc 2907.&lt;SEP&gt;Maritime Prepositioning Ships are loaded with Marine Corps go-to-war capability sets or stored ashore in prepositioning programs.&lt;SEP&gt;Maritime Prepositioning Ships is defined by the acronym MPS.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2&lt;SEP&gt;chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Global Combat Support System - Marine Corps">
  <ns0:data key="d0">Global Combat Support System - Marine Corps</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Global Combat Support System - Marine Corps is an automated information system for logistics and support operations.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="MCO 4400.16H">
  <ns0:data key="d0">MCO 4400.16H</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4400.16H establishes the uniform materiel movement and issue priority system for the Marine Corps.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="MCO 5090.2">
  <ns0:data key="d0">MCO 5090.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 5090.2 serves as the environmental compliance and protection manual for the Marine Corps.&lt;SEP&gt;MCO 5090.2 requires MCMC to conduct pollution prevention surveys, attend meetings, and handle military munitions waste.&lt;SEP&gt;MCO 5090.2 is a Marine Corps Order governing environmental compliance, hazardous materials, waste management, pollution prevention, and EPCRA reporting.</ns0:data>
  <ns0:data key="d3">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Defense Logistics Agency">
  <ns0:data key="d0">Defense Logistics Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Defense Logistics Agency is involved in logistics support, disposition services, and energy management for DoD activities.&lt;SEP&gt;Defense Logistics Agency receives Quality Deficiency Reports from MCMC for equipment that fails operational tests.&lt;SEP&gt;Defense Logistics Agency is utilized in offeror processes for government system purchases in lieu of open market buys.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Commandant Of The Marine Corps">
  <ns0:data key="d0">Commandant Of The Marine Corps</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Commandant Of The Marine Corps issues directives and messages, such as the replacement reference for UM 4000-125.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Corrosion Prevention And Control Program">
  <ns0:data key="d0">Corrosion Prevention And Control Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Corrosion Prevention And Control Program, abbreviated as CPAC, is a Marine Corps initiative for preventing and controlling corrosion in equipment.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841072</ns0:data>
</ns0:node>
<ns0:node id="Arms Ammunition And Explosives">
  <ns0:data key="d0">Arms Ammunition And Explosives</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Arms Ammunition And Explosives, abbreviated as AA&amp;E, pertains to sensitive items requiring specific security and accountability measures.</ns0:data>
  <ns0:data key="d3">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Force">
  <ns0:data key="d0">Maritime Prepositioning Force</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Force describes the combat capability achieved by integrating Marine forces with prepositioned assets on ships.&lt;SEP&gt;Maritime Prepositioning Force involves operations and objectives for prepositioned materiel on ships, as outlined in related Marine Corps publications.&lt;SEP&gt;Maritime Prepositioning Force is defined by the acronym MPF.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="BICmd KOAM">
  <ns0:data key="d0">BICmd KOAM</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">BICmd KOAM receives submissions of inventory results, spot check results, training rosters, and certificates from MCMC.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="US Embassy in the Philippines">
  <ns0:data key="d0">US Embassy in the Philippines</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">US Embassy in the Philippines is where MCMC establishes an FPO/AP address for shipping and receiving Controlled Cryptographic Items.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville Florida">
  <ns0:data key="d0">Jacksonville Florida</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Jacksonville Florida is the location of MCSF-BI where MCMC performs equipment support and management.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="CMS 1 Series">
  <ns0:data key="d0">CMS 1 Series</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CMS 1 Series is a document referenced for inventory, returning materiel, training, and other COMSEC procedures.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="MCO 2281.1 Series">
  <ns0:data key="d0">MCO 2281.1 Series</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 2281.1 Series is a document referenced for inventory, returning materiel, training, and other COMSEC procedures.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="DODINST 4660.2">
  <ns0:data key="d0">DODINST 4660.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DODINST 4660.2 is a document referenced for maintenance training and experience records and KMI awareness training.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1435">
  <ns0:data key="d0">DD Form 1435</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1435 is the COMSEC Maintenance Training and Experience Record required for personnel performing maintenance on cryptographic equipment.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="SD 572">
  <ns0:data key="d0">SD 572</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SD 572 is the Cryptographic Access Certification and Termination Form submitted upon assignment of LE personnel.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="DD Form 2625">
  <ns0:data key="d0">DD Form 2625</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 2625 is the Controlled Cryptographic Item Briefing and COMSEC Briefing and Acknowledgment Form required for LE personnel.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Controlled Cryptographic Items CCI">
  <ns0:data key="d0">Controlled Cryptographic Items CCI</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Controlled Cryptographic Items are items shipped and received using established P.O. Boxes and addresses, and accounted for by shipboard personnel.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="COMSEC Materiel">
  <ns0:data key="d0">COMSEC Materiel</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">COMSEC Materiel includes mobile items returned to parent KMI accounts and handled by designated personnel.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="SECTION C.9 Port Operations Support">
  <ns0:data key="d0">SECTION C.9 Port Operations Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SECTION C.9 outlines requirements for MCMC to support offload and backload operations of Marine Corps Maritime Prepositioning Ships.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="SECTION C.10 Installation Support Services">
  <ns0:data key="d0">SECTION C.10 Installation Support Services</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SECTION C.10 details MCMC responsibilities for equipment management and maintenance at Marine Corps Support Facility Blount Island.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Maritime Prepositioning Force MPF">
  <ns0:data key="d0">Marine Corps Maritime Prepositioning Force MPF</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Maritime Prepositioning Force is supported by MCMC during maintenance cycles involving offload and backload evolutions.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Maritime Prepositioning Ships MPS">
  <ns0:data key="d0">Marine Corps Maritime Prepositioning Ships MPS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Marine Corps Maritime Prepositioning Ships are involved in offload and backload operations supported by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Cycle MMC">
  <ns0:data key="d0">Maintenance Cycle MMC</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Maintenance Cycle is a periodic event where MCMC supports port operations for prepositioning ships.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Offload Backload Operations">
  <ns0:data key="d0">Offload Backload Operations</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Offload and backload operations are evolutions supported by MCMC for equipment and supplies aboard prepositioning ships.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="KMI Awareness Training">
  <ns0:data key="d0">KMI Awareness Training</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">KMI Awareness Training is completed annually by personnel performing maintenance on cryptographic equipment, with rosters submitted to BICmd KOAM.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="COMSEC Refresher Training">
  <ns0:data key="d0">COMSEC Refresher Training</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">COMSEC Refresher Training is provided by BICmd KOAM to Primary or Alternate LE personnel prior to redeployment.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.B.5">
  <ns0:data key="d0">8.B.5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.B.5 requires MCMC to provide monthly spot checks and forward results to BICmd KOAM within 10 business days.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.C.1">
  <ns0:data key="d0">8.C.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.C.1 mandates MCMC to establish and maintain U.S. Post Office Boxes in Diego Garcia and Saipan, and an FPO/AP address at the US Embassy in the Philippines for CCI handling.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.C.2">
  <ns0:data key="d0">8.C.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.C.2 requires MCMC to return mobile COMSEC materiel to parent KMI accounts and handle inventory and removal of CCI from vehicles.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.D.1">
  <ns0:data key="d0">8.D.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.D.1 ensures personnel performing maintenance on cryptographic equipment have updated DD Form 1435.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.D.2">
  <ns0:data key="d0">8.D.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.D.2 requires annual KMI awareness training for maintenance personnel with submission of rosters to BICmd KOAM.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.D.3">
  <ns0:data key="d0">8.D.3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.D.3 mandates submission of SD 572 and DD Form 2625 for LE personnel within 10 business days of assignment.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.E.1">
  <ns0:data key="d0">8.E.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.E.1 requires Primary or Alternate Local Element personnel to complete KMI CBT modules before formal training.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.E.2">
  <ns0:data key="d0">8.E.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.E.2 mandates monthly COMSEC training for handlers with rosters submitted to BICmd KOAM by the first week of the following month.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="8.E.3">
  <ns0:data key="d0">8.E.3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">8.E.3 requires COMSEC refresher training from BICmd KOAM for LE personnel prior to redeployment, including an end-of-course test.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="9.A.1">
  <ns0:data key="d0">9.A.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.1 requires MCMC to support maintenance actions and embarkation per vessel LOI, POA&amp;M, and Ship Confirmation Brief, including recovery for deadlined items.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="9.A.4">
  <ns0:data key="d0">9.A.4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.4 mandates staging of vehicles for MPS backload per BICmd Port Operations list, with debris removal per USDA Compliance Agreement.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="9.B.1">
  <ns0:data key="d0">9.B.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.B.1 specifies fuel level requirements for military equipment prior to staging, varying by vessel class and location.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="10.A.1">
  <ns0:data key="d0">10.A.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">10.A.1 outlines general requirements for MCMC to provide labor, management, and equipment for support at MCSF-BI.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Transportation Manager">
  <ns0:data key="d0">Transportation Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Transportation Manager is a key personnel role with 5 years experience in managing transportation operations, distinct from WHE Manager.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="WHE Operation and Maintenance Manager">
  <ns0:data key="d0">WHE Operation and Maintenance Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">WHE Operation and Maintenance Manager is a key role with 10 years experience in weight handling equipment, including 5 years in supervision.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="LOI">
  <ns0:data key="d0">LOI</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">LOI is Letter of Instruction used for maintenance actions and embarkation support for Navy equipment.&lt;SEP&gt;LOI is the Letter of Instruction used for current vessel maintenance actions and embarkation support.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="POA&amp;M">
  <ns0:data key="d0">POA&amp;M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">POA&amp;M is Plan of Action and Milestones referenced for ship confirmation and operations.&lt;SEP&gt;POA&amp;M refers to Planning Objectives and Milestones governing ship operations, staging, and timelines.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="USDA Compliance Agreement">
  <ns0:data key="d0">USDA Compliance Agreement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">USDA Compliance Agreement governs removal of debris and garbage from vehicles and washing of containers.&lt;SEP&gt;USDA Compliance Agreement specifies requirements for removing debris from vehicles and washing containers prior to staging.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-209">
  <ns0:data key="d0">MIL-STD-209</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-209 is the military standard for securing mobile loads to prevent damage during transport.&lt;SEP&gt;MIL-STD-209 is a military standard for securing Navy mobile loads to prevent damage during offload, backload, and transportation.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="MCRP 4-11.3">
  <ns0:data key="d0">MCRP 4-11.3</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCRP 4-11.3 is a Marine Corps Reference Publication for securing mobile loads.&lt;SEP&gt;MCRP 4-11.3 is a Marine Corps reference publication for securing mobile loads.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="JP-5 Fuel">
  <ns0:data key="d0">JP-5 Fuel</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">JP-5 Fuel is the registered aviation fuel required for filling military equipment tanks to specified levels.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="T-AKE Class Vessels">
  <ns0:data key="d0">T-AKE Class Vessels</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">T-AKE Class Vessels are a specific class of prepositioning ships requiring empty fuel tanks for stowed military equipment.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="DOT-SP 12362">
  <ns0:data key="d0">DOT-SP 12362</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DOT-SP 12362, Eighth Revision, provides regulations for disconnecting vehicle batteries to prevent damage and spillage.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="Military Sealift Command MSC">
  <ns0:data key="d0">Military Sealift Command MSC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Military Sealift Command operates ships requiring manatee watch support during movements at Blount Island.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="NTVE">
  <ns0:data key="d0">NTVE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NTVE refers to Non-Tactical Vehicle Equipment, including emergency vehicles, buses, automobiles, and other fleet items subject to prioritized maintenance and downtime standards.&lt;SEP&gt;NTVE encompasses Non-Tactical Vehicles and Equipment subject to prioritized maintenance and operational standards.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="MCO 11240.106">
  <ns0:data key="d0">MCO 11240.106</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 11240.106 is a document referenced for direction in utilizing FMIS for Non-Tactical Vehicles.&lt;SEP&gt;MCO 11240.106 provides guidelines for vehicle markings, maintenance, inspections, and history files.&lt;SEP&gt;MCO 11240.106 is a Marine Corps Order providing standards for vehicle maintenance, records, one-time repair limits, and operator checklists.&lt;SEP&gt;MCO 11240.106 provides standards for Non-Tactical Vehicles and Equipment operators.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="CDRL 9001">
  <ns0:data key="d0">CDRL 9001</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 9001 is the deliverable for listing hazardous containers by number and IMO code.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841073</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.1-3">
  <ns0:data key="d0">SOW Attachment C.1-3</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.1-3 details the Lighterage Maintenance Model, including phases and tasks in Tables 1 through 3.&lt;SEP&gt;SOW Attachment C.1-3 is the MMC Notional Plan of Action &amp; Milestones defining phasing of operations for Marine Corps and Navy equipment.&lt;SEP&gt;SOW Attachment C.1-3 details Phase IV timelines, the Lighterage Maintenance Model, and Navy support requirements.&lt;SEP&gt;SOW Attachment C.1-3 is a Statement of Work attachment for MMC Notional POA&amp;M.&lt;SEP&gt;SOW Attachment C.1-3 contains the published MMC Notional POA&amp;M for staging operations.&lt;SEP&gt;SOW Attachment C.1-3 details Phase IV milestones used for scheduling Post-MATs NLT E-56.&lt;SEP&gt;SOW Attachment C.1-3 is the MMC Notional POAM used for production planning.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.A.2">
  <ns0:data key="d0">9.A.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.2 requires the MCMC to download and backload prepositioned COSIS, OPP, POL, Armory, and Battery Blocks per approved LOI, POA&amp;M, and Ship Confirmation Brief.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.A.3">
  <ns0:data key="d0">9.A.3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.3 mandates the MCMC to execute lighterage offload and backload operations per approved LOI, POA&amp;M, Section C.6 Navy, and Ship Confirmation Brief.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.A.5">
  <ns0:data key="d0">9.A.5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.5 requires the MCMC to stage and wash containers for MPS backload per Container Staging List and USDA Compliance Agreement.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.A.6">
  <ns0:data key="d0">9.A.6</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.A.6 requires the MCMC to secure mobile loads per MIL-STD-209 and MCRP 4-11.3 without exceeding transport weights.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.B.2">
  <ns0:data key="d0">9.B.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.B.2 mandates the MCMC to drain and purge fuel cells in containerized, mobile loaded, and square loaded MPE/S aboard T-AKE and MPS ME.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="9.C.2">
  <ns0:data key="d0">9.C.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">9.C.2 requires the MCMC to provide a listing of hazardous containers by Container Number and IMO code per MMC Notional POA&amp;M (CDRL 9001).</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="10.A.2.b">
  <ns0:data key="d0">10.A.2.b</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">10.A.2.b specifies personnel qualifications, including certifications, training, and licensing for NTVE, WHE, and electric vehicle work.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="Priority 1 NTVE">
  <ns0:data key="d0">Priority 1 NTVE</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 1 NTVE includes emergency vehicles requiring immediate maintenance start and notification if down over 24 hours.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="Priority 2 NTVE">
  <ns0:data key="d0">Priority 2 NTVE</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 2 NTVE includes buses and cranes requiring maintenance completion within specified hours and notification if down over 48 hours.</ns0:data>
  <ns0:data key="d3">chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="Investigation Report">
  <ns0:data key="d0">Investigation Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Investigation Report is a document formatted with Preliminary Statement, Findings of Facts, Opinions, Recommendations, and corresponding accident LTI or repair estimate, provided within 15 calendar days of MLSR incident notification.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="TM 4700.15/1">
  <ns0:data key="d0">TM 4700.15/1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 4700.15/1 is a technical manual referenced for accident reporting procedures.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="MCO P11240.106">
  <ns0:data key="d0">MCO P11240.106</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO P11240.106 is a Marine Corps Order governing accident reporting and Non-Tactical Vehicle programs.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5035">
  <ns0:data key="d0">CDRL 5035</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5035 includes requests for property record adjustments submitted via voucher requests.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="MVGL">
  <ns0:data key="d0">MVGL</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MVGL is Money Value Gain Loss notices generated in APSR and routed to the Government for endorsement.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="MFC">
  <ns0:data key="d0">MFC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MFC is Monthly Field Change processed in GCSS-MC, involving updates to core data and requiring supply transactions.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="BICmd NTV Program">
  <ns0:data key="d0">BICmd NTV Program</ns0:data>
  <ns0:data key="d1">program</ns0:data>
  <ns0:data key="d2">BICmd NTV Program is maintained by MCMC including operations for Non-Tactical Vehicles such as dispatching, accountability, maintenance, and accident reporting.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="FMIS Fleet Focus">
  <ns0:data key="d0">FMIS Fleet Focus</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">FMIS Fleet Focus is the Federal Fleet Management Information System used for life cycle management of GME fleet assets.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5036">
  <ns0:data key="d0">CDRL 5036</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5036 is a detailed monthly report submitted by MCMC reconciling MMV420 GCSS-MC data against NEIMS UICs.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="DFSP">
  <ns0:data key="d0">DFSP</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">DFSP is the Defense Fuel Support Point at MCSF-BI operated by MCMC for fuel storage, ordering, receiving, and distribution.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5037">
  <ns0:data key="d0">CDRL 5037</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5037 is the accurate and complete DD Form 2921 submitted daily for fuel consumption and inventory levels.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1348-8">
  <ns0:data key="d0">DD Form 1348-8</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1348-8 is submitted monthly for fuel reporting within two business days after the end of the month.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5038">
  <ns0:data key="d0">CDRL 5038</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5038 is the Attainment Deficiency Report identifying ME deficiencies for upcoming ship or ashore programs in the MPF Maintenance Cycle.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="ME Attainment Deficiency Report">
  <ns0:data key="d0">ME Attainment Deficiency Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">ME Attainment Deficiency Report highlights equipment shortfalls comparing available assets to Detailed Ship Plans requirements, submitted NLT 75 calendar days prior to ship production.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5040">
  <ns0:data key="d0">CDRL 5040</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5040 is the Sustainment Block Status Report identifying excesses and deficiencies relative to Ship Spread in Detailed Ship Plans.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="SKOT">
  <ns0:data key="d0">SKOT</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SKOT refers to Sets, Kits, Outfits, and Tools managed in supply operations by MCMC.&lt;SEP&gt;SKOT refers to Sets, Kits, Outfits, and Tools that require SL-3 inventories and requisitions during MMC production.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="CmdO 11240.1">
  <ns0:data key="d0">CmdO 11240.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 11240.1 is a command order for operating and licensing Non-Tactical Vehicles.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="MCO 11240.66">
  <ns0:data key="d0">MCO 11240.66</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 11240.66 is a Marine Corps Order for implementing vehicle licensing programs.&lt;SEP&gt;MCO 11240.66 details procedures for tactical and organic vehicle licensing programs.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="TM 11240-15/3">
  <ns0:data key="d0">TM 11240-15/3</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TM 11240-15/3 is a technical manual for Non-Tactical Vehicle operations.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="NDLO">
  <ns0:data key="d0">NDLO</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NDLO is a counterpart organization contacted by MCMC for causative research in supply reconciliation.&lt;SEP&gt;NDLO is the Norway Detachment Logistics Officer involved in weekly validations and reconciliations with the MCMC Norway section.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="DLA Energy">
  <ns0:data key="d0">DLA Energy</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DLA Energy establishes procedures for capitalized fuel storage and operations at the DFSP.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="DOD 4140.25-M">
  <ns0:data key="d0">DOD 4140.25-M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DOD 4140.25-M is a Department of Defense manual for operating the Defense Fuel Support Point.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="DLA Troop Support">
  <ns0:data key="d0">DLA Troop Support</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DLA Troop Support collaborates with MCMC on MRE stock rotation for sustainment blocks.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="MRE">
  <ns0:data key="d0">MRE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MRE is Meals Ready to Eat included in Class I sustainment blocks, requiring rotation to maintain 33 months shelf life.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.4-6">
  <ns0:data key="d0">SOW Attachment C.4-6</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.4-6 is the Government-provided CBRN Inspection Log used to record inspection results, retained for at least six years.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="Operational Rations PBA Annex">
  <ns0:data key="d0">Operational Rations PBA Annex</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Operational Rations PBA Annex is an agreement between DLA and HQMC governing MRE rotation procedures.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="GOCO">
  <ns0:data key="d0">GOCO</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">GOCO describes the operational model for the MCSF-BI DFSP as Government-owned and Contractor-operated.</ns0:data>
  <ns0:data key="d3">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841074</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officers Representative">
  <ns0:data key="d0">Contracting Officers Representative</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Contracting Officer’s Representative is appointed to assist in technical monitoring and administration of the contract.&lt;SEP&gt;Contracting Officer’s Representative is the COR who oversees inspection and monitoring of services, appoints technical personnel, and receives reports.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Task Order">
  <ns0:data key="d0">Task Order</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Task Order outlines the content, allowable costs, fees, release of claims, and close-out procedures for individual orders under the contract.&lt;SEP&gt;Task Order is defined by the acronym TO.&lt;SEP&gt;Task Order is issued under the contract, specifying funding, performance periods, work descriptions, and applicable clauses for services.&lt;SEP&gt;Task order is an order issued under the base IDIQ contract specifying performance requirements, subject to extension options and limitations.&lt;SEP&gt;Task Order represents individual orders under the contract linked to USMC and Navy ACRNs for performance reporting.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-55bcb4486837a866d3ae601a0bfee839&lt;SEP&gt;chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Contract Line-Item Number">
  <ns0:data key="d0">Contract Line-Item Number</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Contract Line-Item Number is the CLIN used in invoicing and task orders to reference specific items, quantities, and costs.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="SubCLIN">
  <ns0:data key="d0">SubCLIN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SubCLIN is the SLIN referenced in separate invoices for each task order, including accounting and appropriation data.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Contract Cost and Status Report">
  <ns0:data key="d0">Contract Cost and Status Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Contract Cost and Status Report is the CCSR provided monthly by MCMC, including contract details, costs, funding balances, and narratives on variances.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Navy Support Element">
  <ns0:data key="d0">Navy Support Element</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy Support Element is an equipment ownership group for funding contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Naval Beach Group">
  <ns0:data key="d0">Naval Beach Group</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Naval Beach Group is an equipment ownership group for funding contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Prepositioning Program – Norway">
  <ns0:data key="d0">Marine Corps Prepositioning Program – Norway</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Prepositioning Program – Norway maintains equipment and supplies in Norway for defense and global deployment support.&lt;SEP&gt;Marine Corps Prepositioning Program – Norway is an equipment ownership group for funding contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Prepositioning Program – Philippines">
  <ns0:data key="d0">Marine Corps Prepositioning Program – Philippines</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Prepositioning Program – Philippines prepositioned equipment in the Philippines to support training exercises and contingency operations.&lt;SEP&gt;Marine Corps Prepositioning Program – Philippines is an equipment ownership group for funding contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Standard Workday">
  <ns0:data key="d0">Standard Workday</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Standard Workday is defined as eight hours of productive labor during core business hours from 5 a.m. to 5 p.m., Monday through Friday, with alterations requiring government approval.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section G-3">
  <ns0:data key="d0">Section G-3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G-3 covers invoicing, vouchering, and payment instructions, requiring monthly submissions via Wide Area Workflow with detailed backups.&lt;SEP&gt;Section G-3 outlines the procedures for reimbursing overtime under the contract.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section G-4">
  <ns0:data key="d0">Section G-4</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G-4 addresses accounting and appropriation data for task orders, including funding methods and notification requirements.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section G-5">
  <ns0:data key="d0">Section G-5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G-5 details segregation of costs by equipment ownership groups, requiring accurate charging and monthly reporting.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section G-6">
  <ns0:data key="d0">Section G-6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G-6 specifies the Contract Cost and Status Report format and content for monthly submission.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section G-7">
  <ns0:data key="d0">Section G-7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section G-7 outlines indirect cost rates, with government obligation limited to negotiated ceiling rates and adjustments for final rates.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-1">
  <ns0:data key="d0">Section H-1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-1 defines the standard workday and requirements for performance beyond normal hours.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-2">
  <ns0:data key="d0">Section H-2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-2 lists observed holidays and conditions for MCMC personnel work during holidays without premium compensation.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-3">
  <ns0:data key="d0">Section H-3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-3 addresses destructive weather procedures, including facility closure determinations by Blount Island Command.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-5">
  <ns0:data key="d0">Section H-5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-5 allows the KO to direct removal of MCMC personnel for security risks, violations, or legal issues, with costs borne by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-6">
  <ns0:data key="d0">Section H-6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-6 requires MCMC personnel to be identifiable as contractors through distinctive clothing or badges on government facilities.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Section H-7">
  <ns0:data key="d0">Section H-7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H-7 restricts employment of active duty DoD personnel by MCMC without KO approval to avoid conflicts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Any Additional Marine Corps Prepositioning Program - Ashore Sites">
  <ns0:data key="d0">Any Additional Marine Corps Prepositioning Program - Ashore Sites</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Any Additional Marine Corps Prepositioning Program - Ashore Sites is an equipment ownership group for funding contract efforts.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Firm Fixed Price">
  <ns0:data key="d0">Firm Fixed Price</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Firm Fixed Price is defined by the acronym FFP.&lt;SEP&gt;Firm Fixed Price is the FFP basis for support services consolidated on overarching task orders without apportionment to CPFF CLINs.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-46778545759b6a3b0240557a9acb9577</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Cost Plus Fixed Fee">
  <ns0:data key="d0">Cost Plus Fixed Fee</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Cost Plus Fixed Fee is the CPFF basis for task orders where the government pays a fixed fee identified on award, subject to adjustments.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Cost Reimbursable">
  <ns0:data key="d0">Cost Reimbursable</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Cost Reimbursable is the basis for reimbursing overtime, materials, other direct costs, and travel without fee, except G&amp;A on travel.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Release of Claims">
  <ns0:data key="d0">Release of Claims</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Release of Claims is a document furnished by MCMC to the Contracting Officer after task order completion and before final invoice submission.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Destructive Weather">
  <ns0:data key="d0">Destructive Weather</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Destructive Weather refers to hurricanes and foul weather that may threaten operations, prompting facility closure decisions.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Government Holidays">
  <ns0:data key="d0">Government Holidays</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Government Holidays include New Year’s Day, Birthday of Martin Luther King, Jr., Washington’s Birthday, Memorial Day, Independence Day, Juneteenth, Labor Day, Columbus Day, Veterans Day, Thanksgiving Day, Christmas, and other days designated by federal statute, executive order, or presidential proclamation.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Indirect Cost Rates">
  <ns0:data key="d0">Indirect Cost Rates</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Indirect Cost Rates are negotiated with ceiling limits, where the government is not obligated beyond ceilings and final rates may adjust payments downward if lower.&lt;SEP&gt;Indirect Cost Rates provides breakouts by fiscal year aligning to ordering periods, ceiling rates established by DCMA/DCAA, and explanations of methodology and bases.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft Maintenance Center (WMC)">
  <ns0:data key="d0">Navy Watercraft Maintenance Center (WMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy Watercraft Maintenance Center (WMC) is established and maintained by MCMC for maintenance and repair of Navy Watercraft, including LARC and ABLTS, with dedicated personnel.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="LARC Maintenance Facility (LMF)">
  <ns0:data key="d0">LARC Maintenance Facility (LMF)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">LMF is an element of the WMC focused on LARC maintenance, requiring supervisory, electrical, mechanical, and material handler skill sets.&lt;SEP&gt;LARC Maintenance Facility (LMF) is an on-island dedicated facility considered an element of the WMC, used for LARC maintenance and potentially dual purposes with COR approval.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Requirements Package (MRP)">
  <ns0:data key="d0">Maintenance Requirements Package (MRP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MRP (SOW Attachment C.6-024) outlines organizational level maintenance for Phase Delta.&lt;SEP&gt;Maintenance Requirements Package (MRP) specifies basic maintenance for LARC familiarization training.&lt;SEP&gt;Maintenance Requirements Package (MRP) outlines maintenance tasks for Navy Watercraft, including organizational and intermediate levels, and is used for PMCS and other activities.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3&lt;SEP&gt;chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Tailored Navy Watercraft Production Schedule">
  <ns0:data key="d0">Tailored Navy Watercraft Production Schedule</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Tailored Navy Watercraft Production Schedule is produced and maintained for each ship and its associated Navy Watercraft and ABLTS, due for approval NLT WDC-III, with notifications for changes.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Pre-MAT">
  <ns0:data key="d0">Pre-MAT</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Pre-MAT is Pre-MPF Maintenance Cycle Assessment Trials conducted to identify maintenance issues for Navy Watercraft, documented jointly and completed within 45 calendar days of ship download.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Post-MAT">
  <ns0:data key="d0">Post-MAT</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Post-MAT is Post-MPF Maintenance Cycle Acceptance Trials performed waterborne NLT E-45 day for Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Work Definition Conference (WDC-I)">
  <ns0:data key="d0">Work Definition Conference (WDC-I)</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Work Definition Conference (WDC-I) is held NLT Offload + 90 O Day, scheduled and led by MCMC, to identify as-found conditions and provide maintenance recommendations for Phase Charlie.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Work Definition Conference (WDC-II)">
  <ns0:data key="d0">Work Definition Conference (WDC-II)</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Work Definition Conference (WDC-II) is scheduled NLT E-360, Government scheduled and led, providing authorized maintenance strategy based on WDC-I information.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Work Definition Conference (WDC-III)">
  <ns0:data key="d0">Work Definition Conference (WDC-III)</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Work Definition Conference (WDC-III) is held at E-345, scheduled and led by MCMC, presenting projects for Phase Charlie and Delta including requirements from prior WDCs.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Boat Information Book (BIB)">
  <ns0:data key="d0">Boat Information Book (BIB)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Boat Information Book (BIB) is produced and maintained for each Watercraft and ABLTS, including hull history, mechanical history, and other reports, submitted NLT E-4 for review.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Bill of Material (BOM)">
  <ns0:data key="d0">Bill of Material (BOM)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Bill of Material (BOM) is produced and ordered per MRP and WDC-II for Navy Watercraft production, including POLs, filters, and consumables, ordered NLT E-236 and managed via OMMS-NG.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Navy EOS CESE Maintenance Report">
  <ns0:data key="d0">Navy EOS CESE Maintenance Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Navy EOS CESE Maintenance Report (CDRL 6038) is submitted complete and accurate for all CESE scheduled during the current production period within five business days after completion.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841075</ns0:data>
</ns0:node>
<ns0:node id="Accident LTI">
  <ns0:data key="d0">Accident LTI</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Accident LTI documents physical damages for tactical assets or GSA leased assets, provided with MCMC investigation within 15 calendar days after accident.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.Q">
  <ns0:data key="d0">Section 6.Q</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.Q provides reference for accidents involving cranes and associated rigging gear.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.E.6">
  <ns0:data key="d0">Section 6.E.6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.E.6 specifies submission requirements for Navy EOS CESE Maintenance Report by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F">
  <ns0:data key="d0">Section 6.F</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F outlines requirements for Navy Watercraft (Lighterage) Ashore in Phases Bravo, Charlie, and Delta, including maintenance, scheduling, and reporting.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.1">
  <ns0:data key="d0">Section 6.F.1</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.1 requires MCMC to establish and maintain WMC for Navy Watercraft maintenance per MRP, with outsourcing criteria and scheduling IAW Maintenance Model.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.1.a">
  <ns0:data key="d0">Section 6.F.1.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.1.a describes LMF as part of WMC, with team for LARC maintenance and potential dual use with COR approval.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.2">
  <ns0:data key="d0">Section 6.F.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.2 requires production and maintenance of Government-approved Navy Master Schedule, with delivery timelines for revisions.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.3">
  <ns0:data key="d0">Section 6.F.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.3 requires production and adherence to COR-approved production schedule for each ship, including minimal milestone requirements for Navy Watercraft handling and maintenance.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.3.a">
  <ns0:data key="d0">Section 6.F.3.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.3.a requires tracking of schedules relative to Master Schedule and milestones, with notifications to COR at 50% and 75% of Phase C, and Letters of Non-Conformance for delays.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.3.b">
  <ns0:data key="d0">Section 6.F.3.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.3.b requires scheduling of authorized work in FAB format to support reporting, emphasizing sequence and interdependencies.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.4">
  <ns0:data key="d0">Section 6.F.4</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.4 requires performance of PMCS for Navy Watercraft in Phase Delta per MRP and schedules, using OMMS-NG.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.5">
  <ns0:data key="d0">Section 6.F.5</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.5 requires production and maintenance of BIB for each Watercraft and ABLTS, submitted NLT E-4.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.6">
  <ns0:data key="d0">Section 6.F.6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.6 requires production and ordering of BOM per MRP and WDC-II for Navy Watercraft production.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.6.a">
  <ns0:data key="d0">Section 6.F.6.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.6.a requires inventory of unused BOM materials at end of production, with reasons and return to NSC.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.6.b">
  <ns0:data key="d0">Section 6.F.6.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.6.b specifies ordering BOM material from Annual Sustainment Task Order.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.7">
  <ns0:data key="d0">Section 6.F.7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.7 requires participation in three joint WDCs, detailing purposes and timelines for each.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.8">
  <ns0:data key="d0">Section 6.F.8</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.8 requires maintenance of technical library at WMC per latest Force Revision, including manuals and updates NLT 20 business days.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.9">
  <ns0:data key="d0">Section 6.F.9</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.9 requires maintenance of onboard hardcopy technical library for each Navy Watercraft in Phase Delta, updated prior to Stage 4.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.10">
  <ns0:data key="d0">Section 6.F.10</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.10 requires maintenance of NAV-P MRP per latest Force Revision, with updates NLT specified timelines.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.11">
  <ns0:data key="d0">Section 6.F.11</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.11 requires provision of records of tests, inspections, and maintenance within one business day of NAV-P request.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.12">
  <ns0:data key="d0">Section 6.F.12</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.12 requires performance of operator functional testing for communication systems in watercraft per schedules and TMs.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.13">
  <ns0:data key="d0">Section 6.F.13</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.13 requires input of maintenance status into NTCSS OMMS-NG, with accurate entries and close-outs.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.14">
  <ns0:data key="d0">Section 6.F.14</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.14 requires scheduling and documentation of joint Pre-MATs for Navy Watercraft, completed within 45 calendar days of download.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.15">
  <ns0:data key="d0">Section 6.F.15</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.15 requires performance and documentation of electrical and electronic grooming in Phase Delta per plans and schedule.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.16">
  <ns0:data key="d0">Section 6.F.16</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.16 requires replacement of POL and filters for Navy Watercraft in Phase Delta per TMs and MRP.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.17">
  <ns0:data key="d0">Section 6.F.17</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.17 requires drawing and providing oil and water samples for analysis, with report delivery within 5 business days.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.18">
  <ns0:data key="d0">Section 6.F.18</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.18 requires load testing of hull fittings and davits as directed in Phase Delta, with certification provision.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Section 6.F.19">
  <ns0:data key="d0">Section 6.F.19</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 6.F.19 requires maintenance and inspections on wire and fiber rope and rigging per NSTM 613, with data sheet provision.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Support Facility - Blount Island (MCSF-BI)">
  <ns0:data key="d0">Marine Corps Support Facility - Blount Island (MCSF-BI)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">MCSF-BI is a facility with limitations on maintenance work, serving as an organized maintenance and staging area for Navy operations.&lt;SEP&gt;Marine Corps Support Facility - Blount Island (MCSF-BI) is the site for receiving and staging Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Navy Technical Library">
  <ns0:data key="d0">Navy Technical Library</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Navy Technical Library is maintained onsite at WMC, including technical manuals, standards, and updates per Force Revision.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Onboard Watercraft Technical Library">
  <ns0:data key="d0">Onboard Watercraft Technical Library</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Onboard Watercraft Technical Library is a hardcopy library maintained for each Navy Watercraft, including manuals and EOSS, updated prior to Stage 4.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="NAV-P Maintenance Requirements Package">
  <ns0:data key="d0">NAV-P Maintenance Requirements Package</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAV-P Maintenance Requirements Package consists of categories for routine tasks, local procedures, corrective maintenance, and situational requirements, updated per Force Revision.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft and ABLTS Load Test Certification">
  <ns0:data key="d0">Navy Watercraft and ABLTS Load Test Certification</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Watercraft and ABLTS Load Test Certification (CDRL 6045) is provided for periodic and situational load test requirements.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Fibrous and Wire Rope Service Life Data Sheet">
  <ns0:data key="d0">Fibrous and Wire Rope Service Life Data Sheet</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Fibrous and Wire Rope Service Life Data Sheet (CDRL 6046) is provided for maintenance on wire and fiber rope and rigging.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Lighterage Maintenance Milestones">
  <ns0:data key="d0">Lighterage Maintenance Milestones</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Lighterage Maintenance Milestones outline key requirements for Navy Watercraft maintenance phases, referenced in schedules and production planning per SOW Attachment C.1-3 Phase IV.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Preventative Maintenance Checks and Services (PMCS)">
  <ns0:data key="d0">Preventative Maintenance Checks and Services (PMCS)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Preventative Maintenance Checks and Services (PMCS) include daily, weekly, monthly, quarterly, semi-annual, and annual checks for Navy Watercraft performed in Phase Delta IAW MRP and schedules.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="INLS">
  <ns0:data key="d0">INLS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">INLS refers to Inland Navigation Lighterage Systems watercraft that undergo oil sampling, load testing, and maintenance.&lt;SEP&gt;INLS refers to Integrated Navigation Logistics System components, including watercraft, bridle fittings, and calibration requirements for Navy assets.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="NTCSS">
  <ns0:data key="d0">NTCSS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">NTCSS is a multi-application command and control support system for Navy maintenance and logistics management, merging legacy programs for ships, submarines, and aviation.&lt;SEP&gt;NTCSS is the system into which maintenance status for Navy Watercraft is input, encompassing OMMS-NG for tracking deficiencies and work candidates.&lt;SEP&gt;NTCSS is a record-keeping system for which historical records are provided by the incumbent during phase-out.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="NSTM 613">
  <ns0:data key="d0">NSTM 613</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NSTM 613 is the Naval Ships' Technical Manual chapter for wire and fiber rope and rigging maintenance and inspections on Navy Watercraft.&lt;SEP&gt;NSTM 613 is the Naval Ships' Technical Manual for wire and fiber rope and rigging maintenance and inspections on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-85b50b451f72c11f155dc39b516d8dd3&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="52.209-7 Information Regarding Responsibility Matters">
  <ns0:data key="d0">52.209-7 Information Regarding Responsibility Matters</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.209-7 Information Regarding Responsibility Matters defines terms such as administrative proceeding and requires offerors with federal contracts over $10,000,000 to report responsibility information in the Federal Awardee Performance And Integrity Information System.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Federal Awardee Performance And Integrity Information System">
  <ns0:data key="d0">Federal Awardee Performance And Integrity Information System</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Federal Awardee Performance And Integrity Information System is the system where offerors enter details on criminal, civil, or administrative proceedings related to federal contracts or grants.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="52.230-1 Cost Accounting Standards Notices And Certification">
  <ns0:data key="d0">52.230-1 Cost Accounting Standards Notices And Certification</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.230-1 Cost Accounting Standards Notices And Certification provides notices in three parts regarding Cost Accounting Standards applicability and requires submission of a Disclosure Statement for contracts subject to 48 Cfr Chapter 99.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Cost Accounting Standards">
  <ns0:data key="d0">Cost Accounting Standards</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Cost Accounting Standards are requirements under 48 Cfr Chapter 99 applicable to contracts exceeding the threshold in Far 30.201-4(b), excluding exempt contracts as specified in 48 Cfr 9903.201-1.&lt;SEP&gt;Cost Accounting Standards (CAS) apply to contracts exceeding specified thresholds, requiring disclosure of cost accounting practices under 48 CFR Chapter 99.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Disclosure Statement">
  <ns0:data key="d0">Disclosure Statement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Disclosure Statement is required for offerors submitting proposals that may result in contracts subject to 48 CFR Chapter 99, disclosing cost accounting practices.&lt;SEP&gt;Disclosure Statement discloses cost accounting practices and must be submitted as part of the offer for contracts subject to Cost Accounting Standards, using Form No. Casb Ds-1 or Casb Ds-2.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Cost Accounting Standards Board">
  <ns0:data key="d0">Cost Accounting Standards Board</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Cost Accounting Standards Board establishes requirements under 48 CFR Chapter 99 for contracts subject to cost accounting standards.&lt;SEP&gt;Cost Accounting Standards Board issues standards in 48 Cfr Chapter 99 and oversees requirements for cost accounting practices in federal contracts.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Solicitation M6700425R0007">
  <ns0:data key="d0">Solicitation M6700425R0007</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Solicitation M6700425R0007 is a Draft Rfp that includes various Federal Acquisition Regulation provisions on representations, certifications, and cost accounting standards across pages 392 to 397.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="Offeror Certification Provision">
  <ns0:data key="d0">Offeror Certification Provision</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Offeror Certification Provision requires each signature on the offer to certify that the signatory is responsible for prices or an authorized agent and has not participated in actions contrary to specified subparagraphs.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841076</ns0:data>
</ns0:node>
<ns0:node id="North American Industry Classification System">
  <ns0:data key="d0">North American Industry Classification System</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">North American Industry Classification System is the classification framework under which the acquisition is coded as 811310 with a small business size standard of $12,500,000.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
</ns0:node>
<ns0:node id="HUBZone">
  <ns0:data key="d0">HUBZone</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HUBZone is a small business program that provides price evaluation preferences in certain acquisitions set aside for small businesses or regardless of dollar value unless waived by the offeror.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
</ns0:node>
<ns0:node id="8(a)">
  <ns0:data key="d0">8(a)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">8(a) is a small business set-aside or sole-source award program applicable regardless of dollar value for eligible concerns.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
</ns0:node>
<ns0:node id="Service-Disabled Veteran-Owned Small Business">
  <ns0:data key="d0">Service-Disabled Veteran-Owned Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Service-Disabled Veteran-Owned Small Business has a 1% goal for the acquisition.&lt;SEP&gt;Service-Disabled Veteran-Owned Small Business is a category with a 1% subcontracting goal.&lt;SEP&gt;Service-Disabled Veteran-Owned Small Business is a type of small business set-aside or sole-source award applicable regardless of dollar value.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-939c604b9027c9cc38a7fb31f4c86c29</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
</ns0:node>
<ns0:node id="Economically Disadvantaged Women-Owned Small Business">
  <ns0:data key="d0">Economically Disadvantaged Women-Owned Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Economically Disadvantaged Women-Owned Small Business is a type of small business set-aside or sole-source award applicable regardless of dollar value.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
</ns0:node>
<ns0:node id="Women-Owned Small Business">
  <ns0:data key="d0">Women-Owned Small Business</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Women-Owned Small Business is a type of small business set-aside or sole-source award applicable regardless of dollar value.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841077</ns0:data>
