</ns0:edge>
<ns0:edge source="MCMC" target="Export Administration Regulations">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with Export Administration Regulations for MCPP-PHIL operations.</ns0:data>
  <ns0:data key="d8">compliance,export control</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
