<ns0:edge source="MCMC" target="Navy Watercraft and ABLTS Load Test Certification">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Navy Watercraft and ABLTS Load Test Certification (CDRL 6045) for load testing per schedule.</ns0:data>
  <ns0:data key="d8">certification,provision</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
