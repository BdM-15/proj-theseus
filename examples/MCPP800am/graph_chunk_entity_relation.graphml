  <ns0:data key="d11">1759841307</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SOW">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">MCMC is responsible for executing all SOW requirements, including sustainment and MMC operations.&lt;SEP&gt;MCMC applies Automatic Identification Technology in accordance with Section C.2.A of the SOW.&lt;SEP&gt;The MCMC performs all tasks, including transition activities, in accordance with the requirements of the SOW.</ns0:data>
  <ns0:data key="d8">application,compliance,compliance obligation,execution responsibility,performance alignment</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
