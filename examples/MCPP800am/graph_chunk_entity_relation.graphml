  <ns0:data key="d3">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d2">Section 4.C.3.a directs conduct of cyclical physical inventories for perpetual inventory at intermediate levels.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841246</ns0:data>
</ns0:node>
