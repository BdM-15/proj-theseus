</ns0:edge>
<ns0:edge source="MCMC" target="Navy Assemblies and Class IX Shortage Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Navy Assemblies and Class IX Shortage Report separately for NSE and NCE five business days after production completion.</ns0:data>
  <ns0:data key="d8">reporting,shortage tracking</ns0:data>
  <ns0:data key="d9">chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
