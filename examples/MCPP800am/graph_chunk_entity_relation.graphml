  <ns0:data key="d11">1759841304</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quarterly Shelf Life/Service Life Expiration Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Quarterly Shelf Life/Service Life Expiration Report within the first 10 calendar days of each fiscal year quarter.</ns0:data>
  <ns0:data key="d8">reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
