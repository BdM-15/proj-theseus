<ns0:edge source="MCMC" target="SAPS Battery Charger">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses SAPS battery charger to securely store THHRs until issuance, ensuring they are tagged and identifiable.</ns0:data>
  <ns0:data key="d8">security,storage</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
