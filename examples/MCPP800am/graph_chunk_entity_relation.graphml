<ns0:edge source="Department of Defense" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor receives antiterrorism/force protection information from the Department of Defense for personnel traveling abroad.</ns0:data>
  <ns0:data key="d8">awareness,force protection</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
