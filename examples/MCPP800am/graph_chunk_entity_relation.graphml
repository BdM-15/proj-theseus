  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Navy Production Assembly and Class IX Inventory Short List (CDRL 6027) is generated using TOAVIEWER for inventories.</ns0:data>
  <ns0:data key="d8">inventory tool,shortage</ns0:data>
