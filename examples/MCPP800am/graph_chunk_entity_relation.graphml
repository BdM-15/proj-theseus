<ns0:edge source="Department of Defense" target="CMC Code POS-10">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CMC Code POS-10 serves as the contact for DoD antiterrorism/force protection guidance for contractors.</ns0:data>
  <ns0:data key="d8">contact,guidance provision</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
