  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Prompt Payment Act provides interest penalties not applicable to contract financing payments.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
