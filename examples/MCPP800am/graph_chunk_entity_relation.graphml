<ns0:edge source="Clause 52.229-8 Taxes-Foreign Cost-Reimbursement Contracts" target="United States Government">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Clause 52.229-8 exempts taxes and duties from allowable costs where the United States Government is exempt by foreign agreements.</ns0:data>
  <ns0:data key="d8">cost allowability,tax exemption</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
