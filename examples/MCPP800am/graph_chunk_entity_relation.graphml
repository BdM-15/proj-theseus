  <ns0:data key="d11">1759841214</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 1149" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits signed DD Form 1149 for Navy weapons receipt as an alternative to DD Form 1348-1.</ns0:data>
  <ns0:data key="d8">documentation,submission</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
