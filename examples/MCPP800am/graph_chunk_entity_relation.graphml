  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Consent to Subcontract" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor seeks and obtains the Contracting Officer's consent before entering subcontracts that meet specified criteria under Clause 52.244-2.</ns0:data>
  <ns0:data key="d8">approval seeking,subcontract entry</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841136</ns0:data>
</ns0:edge>
<ns0:edge source="Clause 52.244-2 Subcontracts" target="Micro-Purchase Threshold">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Clause 52.244-2 applies different approval levels for subcontracts based on the Micro-Purchase Threshold and other dollar values.</ns0:data>
  <ns0:data key="d8">approval levels,threshold application</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
