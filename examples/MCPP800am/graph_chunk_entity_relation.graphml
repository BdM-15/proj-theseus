<ns0:edge source="Department of Defense" target="DD Form 254">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Department of Defense provides DD Form 254 for contract security classification as an attachment.</ns0:data>
  <ns0:data key="d8">issuance,security requirements</ns0:data>
