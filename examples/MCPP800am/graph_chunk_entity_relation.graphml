<ns0:edge source="MCMC" target="P3&amp;M">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts P3&amp;M operations for ME, SKOTs, and containerized assets in support of MMC production.</ns0:data>
  <ns0:data key="d8">execution,preservation standards</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
