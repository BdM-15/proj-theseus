  <ns0:data key="d11">1759841245</ns0:data>
</ns0:edge>
<ns0:edge source="OPP Plan" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC configures and prepositions Marine and Navy Offload Preparation Party Blocks as directed by the government-provided OPP Plan, consisting of materials for equipment offload preparation outside MAGTF Table of Equipment.</ns0:data>
  <ns0:data key="d8">configuration,support</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841256</ns0:data>
</ns0:edge>
<ns0:edge source="PP&amp;P Plan" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC assembles and packages T-AKE Preservation, Packaging, and Packing Blocks as directed by the government-provided PP&amp;P Plan for use by operational forces in offload or reconstitution.</ns0:data>
  <ns0:data key="d8">assembly,operational support</ns0:data>
