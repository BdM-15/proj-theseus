  <ns0:data key="d11">1759841534</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Inventory Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs inventory management including physical inventories, adjustments, and care of supplies in storage.</ns0:data>
  <ns0:data key="d8">accountability procedures,operational requirement</ns0:data>
