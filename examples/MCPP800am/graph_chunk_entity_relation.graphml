  <ns0:data key="d11">1759841535</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Preservation, Packing, Packaging and Marking">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC implements preservation, packing, packaging, and marking of materiel as part of supply responsibilities.</ns0:data>
  <ns0:data key="d8">materiel preparation,supply operations</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
