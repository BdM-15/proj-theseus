<ns0:edge source="Minimum Insurance Requirements" target="Worker's Compensation and Employer's Liability">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Minimum Insurance Requirements mandate compliance with statutes for Worker's Compensation and Employer's Liability with at least $100,000 coverage.</ns0:data>
  <ns0:data key="d8">compliance,insurance type</ns0:data>
