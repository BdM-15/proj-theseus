  <ns0:data key="d11">1759841476</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Prepositioned Weapons">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC issues and recovers Navy Prepositioned Weapons following documentation and coordination requirements in the approved Resource Plan.</ns0:data>
  <ns0:data key="d8">issuance,recovery</ns0:data>
