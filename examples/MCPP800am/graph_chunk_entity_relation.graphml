<ns0:edge source="MCMC" target="E-1 Inspection/Monitoring Of Performance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC performs inspection and monitoring of services in accordance with its approved quality control plan.</ns0:data>
  <ns0:data key="d8">performance monitoring,quality control</ns0:data>
  <ns0:data key="d9">chunk-2829fe507a5073eafb2e5fb0cc5e85c9</ns0:data>
