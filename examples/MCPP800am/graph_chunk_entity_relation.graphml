  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Federal Acquisition Regulation Subpart 31.2 determines allowable costs for reimbursements under the contract.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
