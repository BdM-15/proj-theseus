  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.215-19 Notification Of Ownership Changes applies to subcontracts meeting the requirement of Far 15.408(k).</ns0:data>
  <ns0:data key="d8">applicability,subcontract inclusion</ns0:data>
