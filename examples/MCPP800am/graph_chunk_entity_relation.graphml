<ns0:edge source="MCMC" target="Corrective Maintenance (CM)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates and performs Corrective Maintenance for MCPP-PHIL assets exceeding contractor capability.&lt;SEP&gt;MCMC performs Corrective Maintenance (CM) exclusively on COMM/ELEC assets at MCPP-N.</ns0:data>
  <ns0:data key="d8">asset serviceability,execution,limitation,performance</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841393</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DoDI 3020.37">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides all MCPP-PHIL services as mission essential functions in accordance with DoDI 3020.37 Section 6 during crises.</ns0:data>
  <ns0:data key="d8">compliance,mission essential</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841393</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Exercise Support Letters">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC sources personnel and resources for exercises in direct support of operating forces as specified in Exercise Support Letters.</ns0:data>
  <ns0:data key="d8">compliance,resourcing</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841393</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Production Planning and Execution Team (P-PET)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Production Planning and Execution Team leads periodic meetings to monitor MCMC's MMC operations and materiel management.</ns0:data>
  <ns0:data key="d8">monitoring,production oversight</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841393</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Joint Quality Management Support System (QMSS)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC documents service and product quality in the Joint Quality Management Support System used with BICmd.</ns0:data>
  <ns0:data key="d8">joint use,quality documentation</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841394</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Business Operating Systems/Accountable Property Systems of Record">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures assets are preserved, packaged, and accurately identified in Business Operating Systems/Accountable Property Systems of Record per paragraph 2.C.1.</ns0:data>
  <ns0:data key="d8">asset accountability,identification</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841394</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Two-Person Integrity Rule">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to the Two-Person Integrity Rule for managing the MCPP-N KMI Local Element subaccount.</ns0:data>
  <ns0:data key="d8">compliance,security</ns0:data>
  <ns0:data key="d9">chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841395</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.34">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes the requirements of Section 6.F.34 for spot maintenance and coating systems on Navy Watercraft, LARCs, and ABLTS, collaborating with the Government on scope.</ns0:data>
  <ns0:data key="d8">compliance,execution</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841395</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Tool Control Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and maintains the Tool Control Program for managing tools and test equipment used in Navy Watercraft maintenance.</ns0:data>
  <ns0:data key="d8">establishment,maintenance</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841395</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Joint Limited Technical Inspection">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC participates in and performs JLTI to support custody transfer of Navy Watercraft and ABLTS as directed by the Government.</ns0:data>
  <ns0:data key="d8">participation,support</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841396</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Watercraft Maintenance Status Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the weekly Watercraft Maintenance Status Report to NAV-P in FAB format, detailing task statuses for various phases.</ns0:data>
  <ns0:data key="d8">organization,submission</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841396</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Functional Area Breakdown">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes the Functional Area Breakdown format to assess and report on Navy Watercraft systems' mission capability.</ns0:data>
  <ns0:data key="d8">reporting,utilization</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841396</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCSF-BI">
  <ns0:data key="d6">4.0</ns0:data>
  <ns0:data key="d7">MCMC complies with CmdO 5560.1 for MCSF-BI badges and vehicle registration to gain installation access.&lt;SEP&gt;MCMC provides advance notification for QA checks at locations near MCSF-BI and ensures access for government personnel at the facility.&lt;SEP&gt;The MCMC conducts operations at MCSF-BI, designated as a Large Quantity Generator for hazardous waste.&lt;SEP&gt;MCMC provides voice, video, and data services in support of MCSF-BI at Blount Island.</ns0:data>
  <ns0:data key="d8">access,access compliance,generator status,notification,operations location,service support</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841397</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Watercraft Monitoring Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC monitors Navy Watercraft per Watercraft Monitoring Requirements and submits the attachment to NAV-P for approval.</ns0:data>
  <ns0:data key="d8">monitoring,submission</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841397</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.35">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with Section 6.F.35 to keep Navy Watercraft, LARCs, and ABLTS clean and dewatered for agricultural inspections.</ns0:data>
  <ns0:data key="d8">compliance,maintenance</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841398</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.36">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs high pressure washing as required by Section 6.F.36 for Navy Watercraft after saltwater exposure or prior to redeployment.</ns0:data>
  <ns0:data key="d8">execution,washing</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841398</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.41">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with Section 6.F.41 for hazardous material and waste management per Section 6.T.</ns0:data>
  <ns0:data key="d8">compliance,management</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841398</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.42">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides facility access and coordinates with NAV-P personnel under Section 6.F.42 for concurrent work without impeding operations.</ns0:data>
  <ns0:data key="d8">access,coordination</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841398</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.43">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides advance notifications as specified in Section 6.F.43 for QA checks based on distance from MCSF-BI.</ns0:data>
  <ns0:data key="d8">QA checks,notification</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.45">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs and supports JLTI under Section 6.F.45 for custody transfers using the JLTI Custody Transfer Package.</ns0:data>
  <ns0:data key="d8">inspection,participation</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.46">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes preparation tasks for MPS embarkation and backload per Section 6.F.46, including configuration and tug services.</ns0:data>
  <ns0:data key="d8">embarkation,preparation</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.47">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Watercraft End of Ship Report and Incomplete Work List under Section 6.F.47 NLT E-3.</ns0:data>
  <ns0:data key="d8">reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841400</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.49">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC implements safeguarding measures and a security plan compliant with NSI 009-72 as per Section 6.F.49.</ns0:data>
  <ns0:data key="d8">safeguarding,security</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841400</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.50">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC supports and documents OPTEST under Section 6.F.50, delivering forms via CDRL 6058.</ns0:data>
  <ns0:data key="d8">documentation,support</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841401</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.51">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC stages Navy Watercraft and delivers Readiness Reports per Section 6.F.51 NLT E+3 for backload.</ns0:data>
  <ns0:data key="d8">delivery,staging</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841401</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.52">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages hazardous materials at WMC and submits 40 CFR reports under Section 6.F.52.</ns0:data>
  <ns0:data key="d8">inventory,reporting</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841401</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.53">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC schedules and provides assessments during the hotwash meeting under Section 6.F.53 to discuss production improvements.</ns0:data>
  <ns0:data key="d8">assessment,meeting</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841402</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.F.54">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses FAB format under Section 6.F.54 to report FMC, PMC, and NMC statuses, issuing Letters of Non-Conformance if needed.</ns0:data>
  <ns0:data key="d8">assessment,reporting</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841402</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 6.G">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides data entry, procurement, storage, and shipping support for external contracts under Section 6.G as required by NAV-P.</ns0:data>
  <ns0:data key="d8">services,support</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841402</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Watercraft End of Ship Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Watercraft End of Ship Report including details on incomplete work and unused inventory.</ns0:data>
  <ns0:data key="d8">inclusion,submission</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="USDA Regulations">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures Navy Watercraft comply with USDA Regulations through cleaning and dewatering to pass inspections.</ns0:data>
  <ns0:data key="d8">cleaning,compliance</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="40 CFR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits monthly inventory reports and hazardous waste manifests to the Government per 40 CFR.</ns0:data>
  <ns0:data key="d8">reporting,waste management</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Microsoft Dynamics 365">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses Microsoft Dynamics 365 as the PPC tool for hardware, security, user permissions, and production planning.</ns0:data>
  <ns0:data key="d8">administration,system usage</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841404</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="QMSS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses QMSS for recording nonconformities and KPI reporting on cost, schedule, and conformance for MMC performance reviews.</ns0:data>
  <ns0:data key="d8">KPI monitoring,quality management</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841404</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NTCSS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses NTCSS applications like OMMS-NG and RSupply for Navy maintenance and supply requirements.</ns0:data>
  <ns0:data key="d8">logistics,maintenance execution</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841405</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="KPI">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts daily QC checks and provides status charts covering KPIs of cost, schedule, and conformance.</ns0:data>
  <ns0:data key="d8">performance measurement,reporting</ns0:data>
  <ns0:data key="d9">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51</ns0:data>
