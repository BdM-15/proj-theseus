  <ns0:data key="d11">1759841523</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Intermediate Maintenance Team (IMT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides an IMT capability for intermediate and depot level maintenance using existing personnel and skill sets.</ns0:data>
  <ns0:data key="d8">establishment,maintenance capability</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
