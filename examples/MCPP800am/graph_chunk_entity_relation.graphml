  <ns0:data key="d11">1759841398</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MCPP-N Weekly Equipment Clearance Report (CDRL 5049)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits the MCPP-N Weekly Equipment Clearance Report for equipment transported across the Norwegian border.</ns0:data>
  <ns0:data key="d8">clearance,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Outbound Ammunition Container Seal Verification Report (CDRL 5050)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC completes and provides the Outbound Ammunition Container Seal Verification Report within one business day of ammunition container download from MPS.</ns0:data>
  <ns0:data key="d8">reporting,verification</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Monthly TOT Balance Report (CDRL 5051)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC monitors and reports Transportation of Things expenditures via the Monthly TOT Balance Report submitted monthly.</ns0:data>
  <ns0:data key="d8">expenditure tracking,financial reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841399</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Contract Cost Plus Fixed Fee and Status Report (CCSR) (CDRL 5057)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC delivers the CCSR for each Task Order on a monthly basis or upon request.</ns0:data>
  <ns0:data key="d8">contract compliance,financial reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841400</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Subic Bay Management Authority (SBMA)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC attains import/export clearances for MCPP-PHIL equipment through coordination with SBMA using End User Certificates.</ns0:data>
  <ns0:data key="d8">coordination,regulatory compliance</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841402</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="DLA-DS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC disposes of Code H containers via DLA-DS after obtaining Government approval and uploading shipping documentation.</ns0:data>
  <ns0:data key="d8">approval,disposal</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Container Handling Equipment (CHE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC employs CHE for secure and damage-free container handling per DTR requirements.</ns0:data>
  <ns0:data key="d8">handling,usage</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Table of Authorized Material Control Number (TAMCN)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC requisitions and maintains power connectors identified by TAMCNs such as K4229 and K4230.</ns0:data>
  <ns0:data key="d8">maintenance,requisition</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841404</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MIL-PRF-131K">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC wraps connectors in VCI-treated material sealed with MIL-PRF-131K barrier material prior to embarkation.</ns0:data>
  <ns0:data key="d8">packaging,preservation</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841404</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MIL-PRF-22191">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">#&gt;|The MCMC packs the Hubbell 5-wire connector in MIL-PRF-22191 barrier material, heat-seals it, and stows it in the refrigerator unit.</ns0:data>
  <ns0:data key="d8">packaging,storage</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841405</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MCO 4600.41B">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts transportation management functions in accordance with MCO 4600.41B Marine Corps Distribution Manual.</ns0:data>
  <ns0:data key="d8">compliance,operations</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841405</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="DD Form 1348-1A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses DD Form 1348-1A in the transportation database to reflect received shipments.</ns0:data>
  <ns0:data key="d8">documentation,tracking</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841407</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Norwegian Joint Headquarters (NJHQ)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC obtains prior approval from NJHQ for MCPP-N equipment transport across the Norwegian border.</ns0:data>
  <ns0:data key="d8">approval,clearance</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841408</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="USTRANSCOM">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC ensures all shipments meet USTRANSCOM requirements, including documentation and customs processes.</ns0:data>
  <ns0:data key="d8">compliance,regulations</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841409</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Norwegian Customs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides accurate shipping documentation to comply with Norwegian Customs for MCPP-N shipments.</ns0:data>
  <ns0:data key="d8">compliance,documentation</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841409</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="2022 Foreign Investment Act">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to the 2022 Foreign Investment Act for treating MCPP-PHIL shipments as commercial activity.</ns0:data>
  <ns0:data key="d8">commercial activity,compliance</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841409</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Certificate of Registration and Tax Exemption (CRTE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC attains CRTE as part of becoming a licensed commercial importer for MCPP-PHIL.</ns0:data>
  <ns0:data key="d8">attainment,licensing</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Visiting Forces Agreement (VFA)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC facilitates documentation under VFA for tax-exempt movement of MCPP-PHIL equipment from Subic Bay.</ns0:data>
  <ns0:data key="d8">coordination,exemption</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="U.S. Embassy">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides required documentation to facilitate U.S. Embassy coordination for MCPP-PHIL import/export clearances.</ns0:data>
  <ns0:data key="d8">clearance,coordination</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MCO P4030.19">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts shipping functions per MCO P4030.19, including IMDG Code for hazardous materials.</ns0:data>
  <ns0:data key="d8">compliance,shipping</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841411</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="MCO 4610.37">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC selects cost-effective transportation modes per MCO 4610.37 and reconciles PowerTrack.</ns0:data>
  <ns0:data key="d8">compliance,mode selection</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841411</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Norwegian Defense Logistics Organization (NDLO)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides shipping information electronically to NDLO for MCPP-N materiel movements.</ns0:data>
  <ns0:data key="d8">information sharing,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841414</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="International Traffic in Arms Regulations (ITAR)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC coordinates MCPP-PHIL clearances in accordance with ITAR and Philippine regulations.</ns0:data>
  <ns0:data key="d8">compliance,export</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841414</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Export Administration Regulations (EAR)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC ensures MCPP-PHIL shipments comply with EAR for export controls.</ns0:data>
  <ns0:data key="d8">compliance,export</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Automatic Identification Technology (AIT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC procures and applies AIT resources on outbound materiel per MCO 4000.51C.</ns0:data>
  <ns0:data key="d8">application,procurement</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="PowerTrack">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC reconciles PowerTrack daily with shipment records and notifies BICmd of completed cycles.</ns0:data>
  <ns0:data key="d8">monitoring,reconciliation</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Unliquidated Orders Report (ULO)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits ULO monthly as part of required fiscal reports.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841416</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Unmatched Transaction Report (UMT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides UMT daily for transaction matching in financial systems.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841417</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Budget Execution Validation (BEV)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits BEV monthly to validate budget execution.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841417</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="FAMRS Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC delivers FAMRS Report daily for general ledger status of funds.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841418</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Budget Execution Report (SAIF Load Balances)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits the Budget Execution Report weekly for SAIF load balances.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841418</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Reimbursable Report (General Account Re-Stock)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides the Reimbursable Report monthly for general account re-stock.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841418</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Re-Stock Job Order Number/Financial Information Pointer">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits the Re-Stock Job Order Number/Financial Information Pointer annually.</ns0:data>
  <ns0:data key="d8">fiscal,reporting</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Supported Activities Information File (SAIF)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC ensures expenditures align with authorized amounts in the SAIF ledger within GCSS-MC.</ns0:data>
  <ns0:data key="d8">funding,ledger</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="Marine Corps Maintenance Coordinator (MCMC)" target="Material Returns Program (MRP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages the MRP by preparing and providing documentation for material returns.</ns0:data>
  <ns0:data key="d8">management,returns</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="Contract Cost Plus Fixed Fee and Status Report (CCSR) (CDRL 5057)" target="4.J Fiscal Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.J outlines submission of the CCSR as part of fiscal management and accounting responsibilities.</ns0:data>
  <ns0:data key="d8">financial reporting,section requirements</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
