  <ns0:data key="d11">1759841478</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Service Upon Receipt (SUR)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs SUR for received ME and CESE assets, reviewing warranties and completing within specified timelines.</ns0:data>
  <ns0:data key="d8">implementation,receipt processing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841479</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Operational Function Tests">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs operational function tests on pumping mechanisms and specific fuel-related equipment.</ns0:data>
  <ns0:data key="d8">conduct,testing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841479</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fuel Container Purging and Cleaning">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC purges, cleans, and dries fuel containers to mitigate risks during maintenance.</ns0:data>
  <ns0:data key="d8">execution,safety preparation</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841479</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Lower Explosive Level Testing">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC tests lower explosive levels on bulk fuel carriers and records results in GCSS-MC or local folders.</ns0:data>
  <ns0:data key="d8">documentation,performance</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841479</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Elastomeric Service Life Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages the elastomeric service life program for TFS, including inspections and replacements based on standards.</ns0:data>
  <ns0:data key="d8">certification,management</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841480</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fuel Filtration Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs fuel filtration on ME and CESE assets to clean fuel cells during production and receipt.</ns0:data>
  <ns0:data key="d8">cleaning,processing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Lubrication Service">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC applies fresh lubricant to service points after washing and before final staging.</ns0:data>
  <ns0:data key="d8">application,post-maintenance</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="In-Process Inspections">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC supports In-Process Inspections by notifying the government QA supervisor within 24 hours before operational function tests.</ns0:data>
  <ns0:data key="d8">facilitation,notification</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Operator Functional Testing">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes Operator Functional Testing on tactical communication systems in accordance with government-approved schedules.</ns0:data>
  <ns0:data key="d8">compliance,execution</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Load Lifting Certification">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts Load Lifting Certification with 24-hour advance notification to the government during production periods.</ns0:data>
  <ns0:data key="d8">conduct,prior notification</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841482</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Service Life Certification Inspections">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes Service Life Certification Inspections using personnel trained to MOS 1390 or 1391 equivalents for TFS components.</ns0:data>
  <ns0:data key="d8">execution,personnel qualification</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841482</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Lead-Acid Batteries">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC tests, services, and maintains Lead-Acid Batteries per TM 9-6140-200-13 in conjunction with PMCS and COSIS.</ns0:data>
  <ns0:data key="d8">servicing,testing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841482</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Uninterruptible Power Supplies (UPS)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC shall properly store and charge UPS for ME in accordance with TI 2000-OR/ and equipment TM, potentially separately from parent items.&lt;SEP&gt;#&gt;|MCMC stores and charges Uninterruptible Power Supplies (UPS) for ME according to TI 2000-OR, ensuring separation if needed from parent items.</ns0:data>
  <ns0:data key="d8">charging,storage</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841483</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Wash and Clean">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC completes Wash and Clean on ME and CESE assets post-production to ensure cleanliness of all compartments and surfaces.</ns0:data>
  <ns0:data key="d8">completion,thoroughness</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841483</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="High-Pressure Wash">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC applies High-Pressure Wash after PMCS and reapplies lubricant to wash-affected points before FMC or staging.</ns0:data>
  <ns0:data key="d8">application,lubrication follow-up</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841483</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Engine Coolant Systems">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC tests and services Engine Coolant Systems with ethylene glycol antifreeze to meet freeze point and nitrite concentration requirements during PMCS.</ns0:data>
  <ns0:data key="d8">concentration control,testing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841484</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Ether Cylinders">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC disconnects and secures Ether Cylinders or installs unactivated replacements during designated production periods.</ns0:data>
  <ns0:data key="d8">disconnection,securing</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841484</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Hearing Conservation Program (HCP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC administers the Hearing Conservation Program in accordance with 29 CFR 1910.95 and MCO 5100.29 for noise-exposed personnel.</ns0:data>
  <ns0:data key="d8">administration,compliance</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841484</ns0:data>
