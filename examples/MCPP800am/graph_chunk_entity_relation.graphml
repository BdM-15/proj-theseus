</ns0:edge>
<ns0:edge source="DoD 4160.21-M" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC executes redistribution, rollback, or disposition of excess materiel in accordance with DoD 4160.21-M.&lt;SEP&gt;MCMC executes redistribution, rollback, or disposition of materiel according to DoD 4160.21-M.</ns0:data>
  <ns0:data key="d8">compliance,disposition</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
