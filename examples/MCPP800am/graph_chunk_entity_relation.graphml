<ns0:edge source="52.216-7 Allowable Cost And Payment" target="Federal Acquisition Regulation Subpart 31.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.216-7 Allowable Cost And Payment uses Federal Acquisition Regulation Subpart 31.2 to determine allowable costs for payments.</ns0:data>
  <ns0:data key="d8">cost allowability,governance</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="52.216-7 Allowable Cost And Payment" target="Prompt Payment Act">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.216-7 Allowable Cost And Payment exempts contract financing payments from the interest penalty provisions of the Prompt Payment Act.</ns0:data>
  <ns0:data key="d8">exemption,interest penalties</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="52.216-7 Allowable Cost And Payment" target="Subpart 42.7 Of The Federal Acquisition Regulation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.216-7 Allowable Cost And Payment establishes final indirect cost rates in accordance with Subpart 42.7 Of The Federal Acquisition Regulation.</ns0:data>
  <ns0:data key="d8">indirect rates,procedure</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
