<ns0:edge source="Afloat Phase" target="Portable Fire Extinguishers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Monthly and annual inspections for portable fire extinguishers are waived during MPF Afloat Phase.</ns0:data>
  <ns0:data key="d8">MPF specific,inspection waiver</ns0:data>
