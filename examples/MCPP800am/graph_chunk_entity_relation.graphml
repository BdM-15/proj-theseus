  <ns0:data key="d11">1759841303</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="COSIS Database">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains an active COSIS Database to track requirements, actions, and schedules for materiel, ensuring accuracy with physical inventory.</ns0:data>
  <ns0:data key="d8">maintenance,tracking</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
