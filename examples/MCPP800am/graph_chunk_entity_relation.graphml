  <ns0:data key="d11">1759841514</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MAC-50 Crane">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates NDT for MAC-50 Crane components, requesting on-site testing at BICmd due to size and weight.</ns0:data>
  <ns0:data key="d8">NDT coordination,component testing</ns0:data>
