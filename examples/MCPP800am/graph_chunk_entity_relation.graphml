<ns0:edge source="MCMC" target="Post Exercise Discrepancy Listing (PEDL) (CDRL 6086)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers Post Exercise Discrepancy Listing (PEDL) (CDRL 6086) detailing equipment damages after exercises.</ns0:data>
  <ns0:data key="d8">discrepancy reporting,electronic submission</ns0:data>
