<ns0:edge source="MCMC" target="Biomedical Waste Management Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages biomedical waste in accordance with the Biomedical Waste Management Plan and maintains the disposal permit.</ns0:data>
  <ns0:data key="d8">waste management</ns0:data>
