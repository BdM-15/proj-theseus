</ns0:edge>
<ns0:edge source="MCMC" target="ACOR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers shipboard reports including SITREPs, PEDL, and cost estimates to ACOR for review and approval.</ns0:data>
  <ns0:data key="d8">oversight,report delivery</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841477</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="RFID">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC places and associates passive RFID tags on items in accordance with ISO standards and MCPIC for operational tracking.</ns0:data>
  <ns0:data key="d8">data association,tagging</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841478</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Exercise Support Letter">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides exercise support including overtime, materials, and travel as required in the Government-provided Exercise Support Letter.&lt;SEP&gt;MCMC provides exercise support as required in the government-provided Exercise Support Letter, including CLIN allocations and ODCs.</ns0:data>
  <ns0:data key="d8">compliance,funding,guidance,support provision</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841478</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maintenance Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures compliance with maintenance requirements outlined in the section for all applicable assets.</ns0:data>
  <ns0:data key="d8">compliance,execution</ns0:data>
  <ns0:data key="d9">chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
