</ns0:edge>
<ns0:edge source="Contracting Officer" target="Cognizant Auditor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer or cognizant auditor establishes billing rates for Government reimbursement to the Contractor.</ns0:data>
  <ns0:data key="d8">authorization,rate establishment</ns0:data>
