</ns0:edge>
<ns0:edge source="MCMC" target="Navy Container Contents Packing List">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers the Navy Container Contents Packing List to NAV-P within two business days after container completion.</ns0:data>
  <ns0:data key="d8">delivery,packaging</ns0:data>
  <ns0:data key="d9">chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
