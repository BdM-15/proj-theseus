<ns0:edge source="MCMC" target="Section 4.D.6">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC follows Section 4.D.6 for conducting supply operations associated with SKOT and SL-3 requirements.</ns0:data>
  <ns0:data key="d8">compliance,procedural adherence</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841348</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 4.D.10">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to Section 4.D.10 for logistics support of downloaded weapons including inventories and shipments.</ns0:data>
  <ns0:data key="d8">compliance,weapon logistics</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
