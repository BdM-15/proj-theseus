<ns0:edge source="MCMC" target="Marine Corps (USMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to Marine Corps orders such as MCO 5100.29 and MCO 5090.2 for safety and environmental programs.</ns0:data>
  <ns0:data key="d8">compliance,order adherence</ns0:data>
