<ns0:edge source="Section B" target="CLIN X0001">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section B specifies the pricing and details for CLIN X0001 as FFP Program Management.</ns0:data>
  <ns0:data key="d8">deliverables,pricing</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841414</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN X0001" target="Phase-Out H-21">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN X0001 captures Phase-Out H-21 requirements as part of FFP Program Management support.</ns0:data>
  <ns0:data key="d8">service inclusion</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN X0004" target="Section H">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H-8.3 establishes the fixed fee ratio for Contingency/Exercise/Emerging Requirements under CLIN X0004.</ns0:data>
  <ns0:data key="d8">fee determination</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN X0005" target="Section H">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H.10 specifies that no fee or markups apply to Travel costs under CLIN X0005.</ns0:data>
  <ns0:data key="d8">cost application</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0008" target="Base Ordering Period Year One">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Base Ordering Period Year One includes CLIN 0008 for Contract Transition Phase-in services.</ns0:data>
  <ns0:data key="d8">period coverage,transition</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="CLIN 0008" target="Contract Transition">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLIN 0008 provides Firm Fixed Price funding for the 3-month Contract Transition period for Phase-in services.</ns0:data>
  <ns0:data key="d8">period definition</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="Base Ordering Period Year One" target="Travel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Travel is reimbursable during Base Ordering Period Year One with no fee applied.</ns0:data>
  <ns0:data key="d8">cost reimbursement,period applicability</ns0:data>
  <ns0:data key="d9">chunk-f0bef8ac155e28eb1ccd0095250383c3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841468</ns0:data>
</ns0:edge>
<ns0:edge source="Base Ordering Period Year One" target="Data Requirements / Cdrl S">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Data Requirements and CDRLs are delivered during Base Ordering Period Year One not separately priced.</ns0:data>
  <ns0:data key="d8">data provision,period applicability</ns0:data>
  <ns0:data key="d9">chunk-f0bef8ac155e28eb1ccd0095250383c3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841469</ns0:data>
</ns0:edge>
<ns0:edge source="Option Period I" target="Opt I Ordering Period Year Six">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Opt I Ordering Period Year Six is exercisable under Option Period I, covering CLINs 5001-5007.</ns0:data>
  <ns0:data key="d8">option exercise</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="Standard Form 33" target="Award">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Standard Form 33 is the primary form for the Solicitation, Offer, and Award, with Standard Form 26 as an alternative.</ns0:data>
  <ns0:data key="d8">form usage</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841416</ns0:data>
</ns0:edge>
<ns0:edge source="Standard Form 33" target="Distribution Submission Proposal Volumes">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Distribution instructions reference the date/time on Standard Form 33 for proposal submission to the issuing office.</ns0:data>
  <ns0:data key="d8">instructions,submission deadline</ns0:data>
