  <ns0:data key="d11">1759841176</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="U.S. Embassy">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor personnel who are U.S. nationals must register with the U.S. Embassy when in-country on a non-transitory basis under 252.225-7043.</ns0:data>
  <ns0:data key="d8">registration,security</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
