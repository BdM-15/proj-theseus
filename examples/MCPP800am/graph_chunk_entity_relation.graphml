<ns0:edge source="Government Furnished Property" target="Marine Corps Maintenance Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Marine Corps Maintenance Contractor uses Government Furnished Property for efficient performance of contractual tasks.</ns0:data>
  <ns0:data key="d8">contractual obligation,resource utilization</ns0:data>
