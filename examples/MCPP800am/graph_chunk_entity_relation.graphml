</ns0:edge>
<ns0:edge source="52.211-11 Liquidated Damages Supplies Services Or Research And Development" target="Lmsr Class Ship">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.211-11 Liquidated Damages Supplies Services Or Research And Development specifies $84,000 per day liquidated damages for delays related to Lmsr Class Ship departures.</ns0:data>
  <ns0:data key="d8">damages application,performance delay</ns0:data>
