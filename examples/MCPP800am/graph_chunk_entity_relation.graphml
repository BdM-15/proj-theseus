  <ns0:data key="d11">1759841536</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Reparable Issue Points">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC supports and participates in annual RIP recomputations with LOGCOM, providing manpower for joint inventory teams.</ns0:data>
  <ns0:data key="d8">inventory participation,recomputation support</ns0:data>
