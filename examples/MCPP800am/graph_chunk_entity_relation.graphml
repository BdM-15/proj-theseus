</ns0:edge>
<ns0:edge source="RSupply" target="User Guide">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">User Guide is embedded within RSupply to provide comprehensive instructions for its use.</ns0:data>
  <ns0:data key="d8">guidance,integration</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841416</ns0:data>
</ns0:edge>
<ns0:edge source="DoDI 5000.64" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to DoDI 5000.64 for accountability and management of DoD equipment under the contract.</ns0:data>
  <ns0:data key="d8">accountability rules,compliance standard</ns0:data>
  <ns0:data key="d9">chunk-f736781b685dec5629d8433e71c666e4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841147</ns0:data>
</ns0:edge>
<ns0:edge source="DoDI 5000.64" target="APSR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">DoDI 5000.64 mandates the use of APSR for accurate materiel accountability of government property.</ns0:data>
  <ns0:data key="d8">accountability framework,property management</ns0:data>
  <ns0:data key="d9">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841191</ns0:data>
</ns0:edge>
<ns0:edge source="DoDI 5000.64" target="Marine Corps">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Marine Corps applies DoDI 5000.64 for accountability and management of DoD equipment and accountable property.</ns0:data>
  <ns0:data key="d8">property management,references</ns0:data>
  <ns0:data key="d9">chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841299</ns0:data>
</ns0:edge>
<ns0:edge source="Status and Progress Report" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides the weekly Status and Progress Report on Navy work, including progress percentages and Over and Above Work Requests per DFARS 252.217-7028.&lt;SEP&gt;MCMC provides a weekly Status and Progress Report on Navy work, including subcontractor support.</ns0:data>
  <ns0:data key="d8">progress tracking,reporting,reporting requirement,submission</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Physical Inventory Control Plan (PICP)" target="MCMC">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">MCMC submits and executes the annual PICP, providing inventory results in RSupply or GCSS-MC, with adjustments approved prior to submission.&lt;SEP&gt;The MCMC submits the annual Physical Inventory Control Plan as CDRL 5018 for government approval.&lt;SEP&gt;MCMC submits an annual Physical Inventory Control Plan (PICP) and updates it annually in accordance with specified documents.</ns0:data>
  <ns0:data key="d8">compliance,execution,planning,submission,submission requirement</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841136</ns0:data>
</ns0:edge>
<ns0:edge source="Physical Inventory Control Plan (PICP)" target="MARCORLOGCOMO 4440.1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Physical Inventory Control Plan is developed in accordance with MARCORLOGCOMO 4440.1 for inventory frequencies and percentages.</ns0:data>
  <ns0:data key="d8">inventory standards,planning compliance</ns0:data>
  <ns0:data key="d9">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841186</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Supply Center (NSC)" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and maintains the dedicated NSC to perform supply chain functions in accordance with NAVSUP P-485.&lt;SEP&gt;MCMC establishes a dedicated NSC to handle supply chain, warehousing, and CAPSET container production.</ns0:data>
  <ns0:data key="d8">establishment,management,supply management</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841136</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Supply Center (NSC)" target="Navy Quality Control Manager (QCM)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">QCM manages quality control for NSC as part of Navy operations.</ns0:data>
  <ns0:data key="d8">process management,quality oversight</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841505</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Supply Center (NSC)" target="Navy Program Manager">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Navy Program Manager oversees NSC as part of dedicated support functionalities.</ns0:data>
  <ns0:data key="d8">organizational structure,supervisory oversight</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841505</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Supply Center (NSC)" target="Capability Set (CAPSET)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NSC accomplishes CAPSET container production as part of its occupational skill sets.</ns0:data>
  <ns0:data key="d8">production management,supply function</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841506</ns0:data>
</ns0:edge>
<ns0:edge source="Section 6.A" target="Section 6.B">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 6.A operational requirements integrate with Section 6.B fiscal responsibilities for accounting and reporting of Navy funds and costs.</ns0:data>
  <ns0:data key="d8">fiscal support,operational integration</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Section 6.B" target="Section 6.C">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 6.B fiscal tracking supports Section 6.C supply chain and warehousing activities, including cost reporting for materiel and equipment.</ns0:data>
  <ns0:data key="d8">logistics integration,supply management</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Operational Tests" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC personnel support Operational Tests through irregular hours work, including weekends and shiftwork, with flex hours authorized upon Government approval.&lt;SEP&gt;MCMC schedules, supports, participates in, and documents OPTEST for Navy Watercraft, delivering completed forms to NAV-P.</ns0:data>
  <ns0:data key="d8">documentation,personnel availability,scheduling,support</ns0:data>
  <ns0:data key="d9">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841137</ns0:data>
</ns0:edge>
<ns0:edge source="Ship Offload/Backload Events" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides support for Ship Offload/Backload Events via irregular hours and shiftwork as needed.</ns0:data>
  <ns0:data key="d8">operational assistance,support</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841137</ns0:data>
</ns0:edge>
<ns0:edge source="Over and Above Work Requests" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC includes all Over and Above Work Requests in the weekly Status and Progress Report, detailing routing status, progress, and compliance with DFARS 252.217-7028.</ns0:data>
  <ns0:data key="d8">documentation,reporting</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841138</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officers Representative (COR)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC notifies the COR of GFE issues, submits investigation reports, inventory results, and EAC projections, and follows COR directions for repairs and designations.</ns0:data>
  <ns0:data key="d8">direction,notification,submission</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841138</ns0:data>
</ns0:edge>
<ns0:edge source="Accountable Property Officer (APO)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits RI designation letters to the APO for concurrence, provides quarterly inventory reports, and seeks approvals for property actions under Navy UIC N32264.</ns0:data>
  <ns0:data key="d8">approval,reporting</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841138</ns0:data>
</ns0:edge>
<ns0:edge source="Original Equipment Manufacturer (OEM)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC inquires with OEM vendors and submits warranty repair claims for defective Navy equipment, notifying NAV-P within 72 hours of identification.</ns0:data>
  <ns0:data key="d8">inquiry,warranty claims</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841139</ns0:data>
</ns0:edge>
<ns0:edge source="Material Handling Equipment (MHE)" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC operates and maintains Navy-owned MHE using the ODCL in accordance with NAVSUP P-538 for warehouse activities.&lt;SEP&gt;The MCMC manages training and licensing for Material Handling Equipment (MHE) operators.</ns0:data>
  <ns0:data key="d8">compliance,maintenance,operation,training</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841139</ns0:data>
</ns0:edge>
<ns0:edge source="Material Handling Equipment (MHE)" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses MHE properly for container movement to prevent damage during handling and storage.</ns0:data>
  <ns0:data key="d8">handling,usage</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841403</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 200" target="MCMC">
  <ns0:data key="d6">4.0</ns0:data>
  <ns0:data key="d7">MCMC prepares and routes DD Form 200 for initiating FLIPL processes for lost or damaged property.&lt;SEP&gt;MCMC accompanies voucher requests with DD Form 200 for physical loss adjustments requiring Government approval.&lt;SEP&gt;MCMC prepares and routes DD Form 200 for lost, damaged, or destroyed Government property within five business days of discovery.&lt;SEP&gt;MCMC reports all GFE property losses via DD Form 200 as part of investigations submitted to appropriate Navy officials.</ns0:data>
  <ns0:data key="d8">adjustment documentation,preparation,property loss,reporting,routing,submission</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-4c2c73655d1d9f038ea8945f49a05a1f&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841139</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 200" target="Financial Liability Investigation of Property Loss (FLIPL)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">DD Form 200 is used to initiate the Financial Liability Investigation of Property Loss (FLIPL) for property adjustments.</ns0:data>
  <ns0:data key="d8">initiation,process</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841164</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 200" target="MCBUL 4440.4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">DD Form 200 is completed in accordance with MCBUL 4440.4 for initiating FLIPL processes.</ns0:data>
  <ns0:data key="d8">completion,guidance</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841169</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 200" target="CDRL 5032">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CDRL 5032 defines DD Form 200 for property loss as a required deliverable.</ns0:data>
  <ns0:data key="d8">deliverable specification</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841288</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 200" target="Marine Corps Maintenance Contractor (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC completes and submits DD Form 200 for missing items within 30 calendar days in accordance with MCO 4400.201.</ns0:data>
  <ns0:data key="d8">loss reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-a9aba44b05f751488f4a50faebf206cb</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841484</ns0:data>
</ns0:edge>
<ns0:edge source="GSA Form 1627" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC completes GSA Form 1627 as part of initial accident notifications for Navy GSA Fleet vehicles within one hour of occurrence.</ns0:data>
  <ns0:data key="d8">accident reporting,completion</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841140</ns0:data>
</ns0:edge>
<ns0:edge source="Actual Cost of Work Performed (ACWP) Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC updates the ACWP Report daily for executed purchases and subcontracts on Navy efforts, correcting identified errors within one business day and limiting to no more than two errors per month.</ns0:data>
  <ns0:data key="d8">daily update,error correction</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841140</ns0:data>
</ns0:edge>
<ns0:edge source="Navy End-of-Ship MPF Maintenance Cycle (MMC) Life Cycle Cost Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the MMC Life Cycle Cost Report NLT 60 days after MPS embarkation, reporting costs by serial number for Navy Watercraft including LARC and ABLTS systems, with corrections within one business day.</ns0:data>
  <ns0:data key="d8">cost detailing,submission</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841140</ns0:data>
</ns0:edge>
<ns0:edge source="Status of Funds Report" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides the Status of Funds Report (CDRL 5055) weekly, including authorizations, obligations, and balances.&lt;SEP&gt;MCMC submits the Status of Funds Report weekly to NAV-P, detailing authorizations, obligations, balances, allocations, and credits using approved accounting procedures.</ns0:data>
  <ns0:data key="d8">financial tracking,weekly provision</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841141</ns0:data>
</ns0:edge>
<ns0:edge source="Estimate At Completion (EAC) Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">#&gt;|MCMC submits the EAC Report NLT the tenth business day of each month, including 12-month projections by CLIN and subsequent actuals for Navy tracking.</ns0:data>
  <ns0:data key="d8">fiscal execution,monthly projection</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841141</ns0:data>
</ns0:edge>
<ns0:edge source="Navy Invoice Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the detailed Navy Invoice Report NLT the first weekday of each month prior to payment, including labor, material, subcontract, and travel costs with backup.</ns0:data>
  <ns0:data key="d8">monthly detailing,payment support</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841141</ns0:data>
</ns0:edge>
<ns0:edge source="Contract Cost and Status Report (CCSR)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the CCSR monthly concurrent with invoices for each Task Order, covering costs, funding, EAC, variances, and references to MCO P7300.21 and DoD FMR.</ns0:data>
  <ns0:data key="d8">monthly submission,task order monitoring</ns0:data>
  <ns0:data key="d9">chunk-4c2c73655d1d9f038ea8945f49a05a1f</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841141</ns0:data>
</ns0:edge>
<ns0:edge source="MCO P7300.21" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
