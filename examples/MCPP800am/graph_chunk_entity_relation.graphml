<ns0:node id="Priority 1 Maintenance">
  <ns0:data key="d0">Priority 1 Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 1 Maintenance is the highest level of effort for critical Navy GSE, requiring immediate initiation of work upon non-operation and notification within one hour.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="Priority 2 Maintenance">
  <ns0:data key="d0">Priority 2 Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 2 Maintenance is the level of effort for Navy GSE supporting maintenance efforts, requiring work as soon as practical and notification within one day.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
<ns0:node id="Priority 3 Maintenance">
  <ns0:data key="d0">Priority 3 Maintenance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 3 Maintenance is the level of effort for Navy GSE supporting watercraft maintenance, requiring repairs within 30 days or COR consent for deviation.</ns0:data>
  <ns0:data key="d3">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841124</ns0:data>
</ns0:node>
