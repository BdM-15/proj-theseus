  <ns0:data key="d11">1759841305</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DoD IUID Registry">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses the DoD IUID Registry for accountability and reporting of IUID-tagged materiel.</ns0:data>
  <ns0:data key="d8">reporting,utilization</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841306</ns0:data>
