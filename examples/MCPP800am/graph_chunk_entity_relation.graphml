</ns0:node>
<ns0:node id="DD 1898-e">
  <ns0:data key="d0">DD 1898-e</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD 1898-e is a form used for fuel transactions and maintained as key supporting documents.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="QR Codes">
  <ns0:data key="d0">QR Codes</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">QR Codes are quick response codes issued for fuel procurement and tracked in the Fuel Logbook.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="EEBP">
  <ns0:data key="d0">EEBP</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">EEBP is a system used for posting and reconciling fuel obligations.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="IPA">
  <ns0:data key="d0">IPA</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">IPA refers to Independent Public Accountant supporting inventory testing and audit requirements.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="FSMAO">
  <ns0:data key="d0">FSMAO</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">FSMAO is the Field Supply and Maintenance Analysis Office conducting inventory testing.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="SECNAVINST 7320.10">
  <ns0:data key="d0">SECNAVINST 7320.10</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SECNAVINST 7320.10 provides instructions on materiel accountability and property management.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5020">
  <ns0:data key="d0">CDRL 5020</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5020 is the deliverable for Responsible Officer Nomination Packages submitted for government approval.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="#&gt;|CDRL 5021">
  <ns0:data key="d0">#&gt;|CDRL 5021</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5021 is the deliverable for Physical Inventory Control Plan Consumer Level Account Inventory Results reported monthly.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="MPF">
  <ns0:data key="d0">MPF</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MPF refers to Maritime Prepositioning Force ships used for embarkation of materiel with specified minimum shelf life remaining.&lt;SEP&gt;MPF is the Maritime Prepositioning Force program involving afloat and ashore-based prepositioning of equipment and supplies.&lt;SEP&gt;MPF is the Maritime Prepositioning Force involving maintenance cycles and afloat assets.&lt;SEP&gt;MPF is the Maritime Prepositioning Force supported through maintenance cycles, ship production, and sustainment blocks.&lt;SEP&gt;MPF is the Maritime Prepositioning Force, involving exercises where consumables and expendables are issued and inspected, with waivers for certain phases.&lt;SEP&gt;MPF is the source from which weapons and materiel are downloaded during the MMC production period for inspection, repair, and backload.&lt;SEP&gt;MPF is Maritime Prepositioning Force mission supported by Navy GSE.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="KSDs">
  <ns0:data key="d0">KSDs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">KSDs are Key Supporting Documents including exercise support letters, asset lists, and other documents ensuring chain of custody.&lt;SEP&gt;KSDs are Key Supporting Documents required for inventory validations and chain of custody.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="NTV">
  <ns0:data key="d0">NTV</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NTV stands for Non-Tactical Vehicles accounted for in DPAS.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="Perpetual Inventory">
  <ns0:data key="d0">Perpetual Inventory</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Perpetual Inventory involves ongoing accountability of supplies and equipment using GCSS-MC, including cyclical physical inventories.&lt;SEP&gt;Perpetual Inventory involves ongoing accurate accountability of materiel in MPF and ashore prepositioning programs.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="Unique Item Identifier">
  <ns0:data key="d0">Unique Item Identifier</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Unique Item Identifier is a set of data elements marked on items that is globally unique and unambiguous, including a concatenated unique item identifier or a DoD recognized unique identification equivalent.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="Unique Item Identifier Type">
  <ns0:data key="d0">Unique Item Identifier Type</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Unique Item Identifier Type is a designator indicating the method used for uniquely identifying a part, with a current list maintained at a specified URL.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-130">
  <ns0:data key="d0">MIL-STD-130</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-130 is a standard for identification marking of U.S. military property.&lt;SEP&gt;MIL-STD-130 is the Identification Marking of U.S. Military Property standard, latest version, providing criteria for marking items with unique item identifier data elements.&lt;SEP&gt;MIL-STD-130 standardizes identification marking for preservation, packaging, and packing processes.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="ISO/IEC International Standard 16022">
  <ns0:data key="d0">ISO/IEC International Standard 16022</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISO/IEC International Standard 16022 is the Information technology--International symbology specification--Data matrix; ECC200 data matrix specification, used for marking unique item identifier component data elements.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Wide Area Workflow">
  <ns0:data key="d0">Wide Area Workflow</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Wide Area Workflow is a system used for reporting end items via receiving report capability in accordance with clause 252.232-7003.&lt;SEP&gt;Wide Area Workflow is utilized by MCMC for submitting monthly invoices.&lt;SEP&gt;Electronic system for processing vendor payment requests and receiving reports, requiring contractor registration and use of specific document types for invoicing.</ns0:data>
  <ns0:data key="d3">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="IUID Registry">
  <ns0:data key="d0">IUID Registry</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">IUID Registry is a system for direct data submission of embedded items following specified procedures and formats.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-129">
  <ns0:data key="d0">MIL-STD-129</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-129 establishes standards for marking SECREPs placed in P3&amp;M crates/boxes.&lt;SEP&gt;MIL-STD-129 provides military marking standards for shipment and storage, applied to shipping containers.&lt;SEP&gt;MIL-STD-129 is a standard for military marking of shipments.&lt;SEP&gt;MIL-STD-129 is a military standard for marking of shipments, packing material, and containers used in logistics operations.&lt;SEP&gt;MIL-STD-129 is the Military Marking for Shipment and Storage standard, latest version, used for labeling shipments, storage containers, and packages containing uniquely identified items.</ns0:data>
  <ns0:data key="d3">chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-2073-1">
  <ns0:data key="d0">MIL-STD-2073-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-2073-1 is a military standard establishing practices for preservation, packaging, packing, and storage of materiel.&lt;SEP&gt;MIL-STD-2073-1 is the Standard Practice for Military Packaging, used for items requiring military-grade protection.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Command Order 4035.1">
  <ns0:data key="d0">Command Order 4035.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Command Order 4035.1 directs the assembly of Capability Sets in accordance with the Capability Set Letter.&lt;SEP&gt;Command Order 4035.1 is a requirement for preserving, packaging, packing, and marking supplies and materials under the contract.</ns0:data>
  <ns0:data key="d3">chunk-5fcb066f3ce0c1cfffc65441135b96e1&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Section D">
  <ns0:data key="d0">Section D</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section D outlines general packaging requirements, packaging specifications, marking requirements, unique identification marking, RFID tagging requirements, export controlled items, and delivery, inspection, and acceptance.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Section E">
  <ns0:data key="d0">Section E</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section E specifies inspection and acceptance terms for supplies and services at destination by the government for various CLINs.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Contract Line Item Number">
  <ns0:data key="d0">Contract Line Item Number</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Contract Line Item Number refers to identifiers such as 0001 through 9014 for which supplies and services are inspected and accepted at destination by the government.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="DRAFT RFP">
  <ns0:data key="d0">DRAFT RFP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DRAFT RFP is the document containing the contract provisions, spanning pages 311 to 317 of 425.&lt;SEP&gt;DRAFT RFP outlines acquisition requirements, including volumes and evaluation factors.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-2">
  <ns0:data key="d0">52.246-2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-2 is the Inspection of Supplies--Fixed Price clause incorporated by reference, dated August 1996.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-3">
  <ns0:data key="d0">52.246-3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-3 is the Inspection of Supplies Cost-Reimbursement clause incorporated by reference, dated May 2001.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-4">
  <ns0:data key="d0">52.246-4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-4 is the Inspection of Services--Fixed Price clause incorporated by reference, dated August 1996.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-5">
  <ns0:data key="d0">52.246-5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-5 is the Inspection of Services Cost-Reimbursement clause incorporated by reference, dated April 1984.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-16">
  <ns0:data key="d0">52.246-16</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-16 is the Responsibility for Supplies clause incorporated by reference, dated April 1984.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="52.246-11">
  <ns0:data key="d0">52.246-11</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.246-11 is the Higher-Level Contract Quality Requirement clause incorporated by full text, dated December 2014, requiring compliance with higher-level quality standards.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="FAR 2.101">
  <ns0:data key="d0">FAR 2.101</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">FAR 2.101 defines special tooling and special test equipment.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="ISO/IEC International Standard 15434">
  <ns0:data key="d0">ISO/IEC International Standard 15434</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISO/IEC International Standard 15434 specifies the transfer structure, syntax, and coding of messages and data formats for Format Indicators 05, 06, and 12 used in unique item identifiers.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="ISO/IEC International Standard 15418">
  <ns0:data key="d0">ISO/IEC International Standard 15418</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISO/IEC International Standard 15418 provides information on EAN/UCC Application Identifiers and Fact Data Identifiers and Maintenance.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="ANSI MH 10.8.2">
  <ns0:data key="d0">ANSI MH 10.8.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ANSI MH 10.8.2 is the Data Identifier and Application Identifier Standard used in conjunction with ISO/IEC International Standard 15418.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Air Transport Association Common Support Data Dictionary">
  <ns0:data key="d0">Air Transport Association Common Support Data Dictionary</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Air Transport Association Common Support Data Dictionary is referenced for Text Element Identifiers in unique item identifier encoding.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1423">
  <ns0:data key="d0">DD Form 1423</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1423 is the Contract Data Requirements List used as a deliverable attachment for Unique Item Identifier Report for Embedded Items via WAWF.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="252.232-7003">
  <ns0:data key="d0">252.232-7003</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">252.232-7003 is the clause governing the use of receiving report capability in Wide Area Workflow for reporting end items.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="DoD">
  <ns0:data key="d0">DoD</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DoD is the Department of Defense, including organizations that MCMC communicates with on behalf of BICmd.&lt;SEP&gt;DoD is the Department of Defense, which maintains standards and registries for unique item identification and packaging.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Special Tooling">
  <ns0:data key="d0">Special Tooling</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Special Tooling is an item defined in FAR 2.101 that may require unique item identification if designated for preservation and storage for a Major Defense Acquisition Program.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Special Test Equipment">
  <ns0:data key="d0">Special Test Equipment</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Special Test Equipment is an item defined in FAR 2.101 that may require unique item identification if designated for preservation and storage for a Major Defense Acquisition Program.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Major Defense Acquisition Program">
  <ns0:data key="d0">Major Defense Acquisition Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Major Defense Acquisition Program is a program for which certain items of special tooling or special test equipment are designated for preservation and storage.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="ITAR">
  <ns0:data key="d0">ITAR</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">ITAR is the International Traffic in Arms Regulations that the MCMC must comply with, especially for personnel in host nations.&lt;SEP&gt;ITAR is the International Traffic in Arms Regulations that the MCMC must comply with for MCPP-PHIL operations.&lt;SEP&gt;ITAR is the International Traffic in Arms Regulations applied to export controlled items, requiring specific package markings.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="EAR">
  <ns0:data key="d0">EAR</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">EAR is the Export Administration Regulations applied to export controlled items, requiring specific package markings.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="49 CFR">
  <ns0:data key="d0">49 CFR</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">49 CFR contains DOT regulations for ground transport of hazardous materials.&lt;SEP&gt;49 CFR regulates transportation of hazardous materials and commercial driver's licenses.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="IATA Dangerous Goods Regulations">
  <ns0:data key="d0">IATA Dangerous Goods Regulations</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">IATA Dangerous Goods Regulations govern air transport of hazardous materials.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="United Nations Hazardous Materials Classification System">
  <ns0:data key="d0">United Nations Hazardous Materials Classification System</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">United Nations Hazardous Materials Classification System is used for classifying hazardous materials in shipments.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="National Stock Number">
  <ns0:data key="d0">National Stock Number</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">National Stock Number is defined by the acronym NSN.&lt;SEP&gt;National Stock Number is a required marking on each package, or Manufacturer Part Number if NSN is not available.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="CAGE Code">
  <ns0:data key="d0">CAGE Code</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CAGE Code is the manufacturer's code required as part of package markings.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="RFID Tagging">
  <ns0:data key="d0">RFID Tagging</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">RFID Tagging involves passive RFID tags applied to shipping containers or vehicles in accordance with DoD logistics guidance and WAWF requirements.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Military Shipping Label">
  <ns0:data key="d0">Military Shipping Label</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Military Shipping Label is required for shipments to DoD facilities, including linear and 2D barcodes for automated tracking per MIL-STD-129.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Hazardous Materials">
  <ns0:data key="d0">Hazardous Materials</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Hazardous Materials require specific markings, labels, placards, and handling instructions compliant with 49 CFR, IATA, and UN standards.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Packing List">
  <ns0:data key="d0">Packing List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Packing List is included inside the primary shipping container for each shipment, detailing contract number, items, quantities, serial numbers, and safety data sheets if applicable.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841056</ns0:data>
</ns0:node>
<ns0:node id="Enterprise Identifier">
  <ns0:data key="d0">Enterprise Identifier</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Enterprise Identifier is a component data element of the unique item identifier, encoded within the data matrix symbol.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Issuing Agency Code">
  <ns0:data key="d0">Issuing Agency Code</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Issuing Agency Code is a data element of the unique item identifier, derived from the data qualifier for the enterprise identifier and not placed directly on the item.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Serial Number">
  <ns0:data key="d0">Serial Number</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Serial Number is defined by the acronym SN.&lt;SEP&gt;Serial Number is a component of the unique item identifier used for serialization within the enterprise identifier, part, lot, or batch number.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577&lt;SEP&gt;chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Application Identifiers">
  <ns0:data key="d0">Application Identifiers</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Application Identifiers are one type of data qualifiers used to encode data elements of the unique item identifier, per Format Indicator 05 of ISO/IEC International Standard 15434.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Data Identifiers">
  <ns0:data key="d0">Data Identifiers</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Data Identifiers are one type of data qualifiers used to encode data elements of the unique item identifier, per Format Indicator 06 of ISO/IEC International Standard 15434.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Text Element Identifiers">
  <ns0:data key="d0">Text Element Identifiers</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Text Element Identifiers are one type of data qualifiers used to encode data elements of the unique item identifier, per Format Indicator 12 of ISO/IEC International Standard 15434.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Subcontracts">
  <ns0:data key="d0">Subcontracts</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Subcontracts for items requiring unique item identification must include this clause, including provisions for commercial products or services.&lt;SEP&gt;Subcontracts summarizes proposed subcontractors exceeding $350,000, including descriptions, contract types, values, hours, pricing basis, and treatment in compliance with disclosure statement.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Commercial Products">
  <ns0:data key="d0">Commercial Products</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Commercial Products are items acquired by subcontract that may require inclusion of the unique item identification clause.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Commercial Services">
  <ns0:data key="d0">Commercial Services</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Commercial Services are services acquired by subcontract that may require inclusion of the unique item identification clause.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Material Inspection and Receiving Report">
  <ns0:data key="d0">Material Inspection and Receiving Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Material Inspection and Receiving Report is used to report unique item identifier information at the time of delivery for items under the contract.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Warranty">
  <ns0:data key="d0">Warranty</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Warranty is a requirement for certain items that triggers unique item identification for subassemblies, components, and parts.</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Distribution Management Office (DMO)">
  <ns0:data key="d0">Distribution Management Office (DMO)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Distribution Management Office (DMO) is integrated with the MCMC for communication regarding warehouse receiving, issue points, and document management.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Product Data Reporting and Evaluation Program (PDREP)">
  <ns0:data key="d0">Product Data Reporting and Evaluation Program (PDREP)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Product Data Reporting and Evaluation Program (PDREP) is a system used for submitting Supply Discrepancy Reports (SDR).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="DLA Customer Service Help Desk">
  <ns0:data key="d0">DLA Customer Service Help Desk</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">DLA Customer Service Help Desk is a service point for submitting Supply Discrepancy Reports (SDR).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Reconciliation Log Report (CDRL 6018)">
  <ns0:data key="d0">Navy Reconciliation Log Report (CDRL 6018)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Reconciliation Log Report (CDRL 6018) is a report delivered by the MCMC to NAV-P documenting reconciliations between NSC Supply and Maintenance Commodities.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Small Arms Monthly Inventory Report (CDRL 6082)">
  <ns0:data key="d0">Navy Small Arms Monthly Inventory Report (CDRL 6082)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Small Arms Monthly Inventory Report (CDRL 6082) is a monthly report of physical inventory of Navy weapons onboard MPF Ships and MCSF-BI Armory, submitted to NAV-P RO, ACOR, and COR.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Armory">
  <ns0:data key="d0">MCSF-BI Armory</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">MCSF-BI Armory is a site where Navy weapons are inventoried as part of the monthly report.&lt;SEP&gt;MCSF-BI Armory serves as the storage and transfer point for Navy weapons during MCMC logistics support operations for MPS offload and backload.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Transportation and Distribution Management Operation (TMO/DMO)">
  <ns0:data key="d0">Transportation and Distribution Management Operation (TMO/DMO)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Transportation and Distribution Management Operation (TMO/DMO) supports NSC and NAV-P shipping requirements, including receiving functions and special handling.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Cargo Movement Operations System (CMOS)">
  <ns0:data key="d0">Cargo Movement Operations System (CMOS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CMOS is the DoD-designated system for recording freight receiving and tracking shipments, including data fields like date received, TCN, and NSN.&lt;SEP&gt;Cargo Movement Operations System (CMOS) is the DoD-designated system used by the MCMC to record freight receiving.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Class V Ammunition">
  <ns0:data key="d0">Class V Ammunition</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class V Ammunition refers to inbound shipments processed by the MCMC, including container seal verification reports.&lt;SEP&gt;Class V ammunition requires special processing for inbound and outbound shipments, including seal verification reports and protective services documentation.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Container Seal Verification Report">
  <ns0:data key="d0">Container Seal Verification Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Container Seal Verification Report is a report provided by the MCMC upon completion of ammunition container inspections, including serial and seal numbers.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Deficiency Report (CDRL 6020)">
  <ns0:data key="d0">Navy Deficiency Report (CDRL 6020)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Deficiency Report (CDRL 6020) identifies deficiencies for upcoming ships in the MPF Maintenance Cycle, listing Class of Supply shortages by NSN, quantity, and nomenclature.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="DODAAC Documents Report (CDRL 6021)">
  <ns0:data key="d0">DODAAC Documents Report (CDRL 6021)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">DODAAC Documents Report (CDRL 6021) is a daily updated report for fiscal reconciliation of Navy supply system transactions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Daily Purchasing System Report (CDRL 6022)">
  <ns0:data key="d0">Daily Purchasing System Report (CDRL 6022)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Daily Purchasing System Report (CDRL 6022) lists updated purchasing system material and subcontract services ordered for Navy expenditures tracking.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="ULO Report (CDRL 6023)">
  <ns0:data key="d0">ULO Report (CDRL 6023)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">ULO Report (CDRL 6023) reconciles unliquidated obligations in Navy supply system documents and is provided monthly to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Defense Fuel Support Point (DFSP)">
  <ns0:data key="d0">MCSF-BI Defense Fuel Support Point (DFSP)</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">MCSF-BI Defense Fuel Support Point (DFSP) is operated by the MCMC to support Navy fuel requirements.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Container Program">
  <ns0:data key="d0">Navy Container Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Navy Container Program is managed by the MCMC, encompassing accountability, storage, inspection, recertification, maintenance, inventory, production, marking, and use of ISO containers for intermodal transport.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Container Management Report (CDRL 6024)">
  <ns0:data key="d0">Navy Container Management Report (CDRL 6024)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Container Management Report (CDRL 6024) documents inventory and inspections of MPS downloaded Navy containers.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Production Attainment Report (CDRL 6026)">
  <ns0:data key="d0">Navy Production Attainment Report (CDRL 6026)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Production Attainment Report (CDRL 6026) is a weekly report submitted by the MCMC on production progress.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Containerized Equipment Maintenance Transfer Log (CDRL 6028)">
  <ns0:data key="d0">Navy Containerized Equipment Maintenance Transfer Log (CDRL 6028)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Containerized Equipment Maintenance Transfer Log (CDRL 6028) tracks delivery and maintenance of containerized CESE and equipment.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Logistics Over-the-Shore (LOTS) Rotational Pool (RP) (CDRL 6019)">
  <ns0:data key="d0">Logistics Over-the-Shore (LOTS) Rotational Pool (RP) (CDRL 6019)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Logistics Over-the-Shore (LOTS) Rotational Pool (RP) (CDRL 6019) maintains assets updated as equipment is rotated or inventory revised.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="NSC">
  <ns0:data key="d0">NSC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NSC is the Naval Support Command involved in supply, maintenance, shipping, and production schedules coordinated with the MCMC.&lt;SEP&gt;NSC coordinates with MCMC maintenance commodities for the accomplishment of required maintenance on Navy containerized CESE and equipment.&lt;SEP&gt;NSC is the Navy Support Command responsible for appointing a Navy Plans and Data POC to manage squadron and ship level plans.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Navy Production Assembly and Class IX Inventory Short List (CDRL 6027)">
  <ns0:data key="d0">Navy Production Assembly and Class IX Inventory Short List (CDRL 6027)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Production Assembly and Class IX Inventory Short List (CDRL 6027) identifies shortages and non-conforming items from inventories of Navy assemblies and Class IX Blocks during ship production, submitted to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="WEBVLIPS">
  <ns0:data key="d0">WEBVLIPS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">WEBVLIPS is a system researched by the MCMC for receipt validations and tracer actions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Planning Consideration Letter (PCL)">
  <ns0:data key="d0">Planning Consideration Letter (PCL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Planning Consideration Letter (PCL) provides guidance for receipting, storing, and distributing Navy weapons and for containerized equipment maintenance.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="DTR 4500.9-R">
  <ns0:data key="d0">DTR 4500.9-R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DTR 4500.9-R is the Defense Transportation Regulation referenced for container handling, inspections, transportation, and shipping functions.&lt;SEP&gt;DTR 4500.9-R Part VI governs management, accountability, inspections, and maintenance of ISO containers.&lt;SEP&gt;DTR 4500.9-R is the Defense Transportation Regulation governing protective services for shipment of sensitive items like weapons.&lt;SEP&gt;DTR 4500.9-R Part II outlines transportation management receiving functions and processing of inbound shipments, including Class V ammunition.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="DoD 4500.32-R">
  <ns0:data key="d0">DoD 4500.32-R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD 4500.32-R is the regulation for management, acquisition, and use of commercial transportation services in DoD.&lt;SEP&gt;DoD 4500.32-R is referenced for transportation management receiving functions conducted by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="MCO 4450.14">
  <ns0:data key="d0">MCO 4450.14</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4450.14 governs COSIS database maintenance, operational checks on SECREPs, and other materiel management procedures.&lt;SEP&gt;MCO 4450.14 is a Marine Corps Order on storage and warehousing operations.&lt;SEP&gt;MCO 4450.14 governs transportation management, cargo handling, and materiel movement operations.</ns0:data>
  <ns0:data key="d3">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="DoD 5100.76-M">
  <ns0:data key="d0">DoD 5100.76-M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD 5100.76-M outlines physical security requirements for sensitive conventional arms, ammunition, and explosives.&lt;SEP&gt;DoD 5100.76-M governs physical security of sensitive conventional arms, ammunition, and explosives for special handling shipments.&lt;SEP&gt;DoD 5100.76-M provides procedures for processing shipments requiring special handling or expedited delivery.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-30e4e078d2ff5ac82b96140f8c79e3f2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Arms, Ammunition, and Explosives (AA&amp;E)">
  <ns0:data key="d0">Arms, Ammunition, and Explosives (AA&amp;E)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Arms, Ammunition, and Explosives (AA&amp;E) are categories of materiel requiring special handling in inbound shipments processed by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Controlled Cryptographic Items (CCI)">
  <ns0:data key="d0">Controlled Cryptographic Items (CCI)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Controlled Cryptographic Items (CCI) are security-required materiel processed with special handling by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Military Surface Deployment and Distribution Command (SDDC)">
  <ns0:data key="d0">Military Surface Deployment and Distribution Command (SDDC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">SDDC manages requirements for overseas and export shipments, including export release requests and TCMDs.&lt;SEP&gt;Military Surface Deployment and Distribution Command (SDDC) sets requirements for overseas and export shipments, including export release requests and TCMDs.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Integrated Booking System (IBS)">
  <ns0:data key="d0">Integrated Booking System (IBS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">IBS is used by the MCMC to obtain routing for release units in overseas/export shipment processes.&lt;SEP&gt;Integrated Booking System (IBS) is used for obtaining routing for release units in export shipments.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Transportation Control and Movement Documents (TCMDs)">
  <ns0:data key="d0">Transportation Control and Movement Documents (TCMDs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TCMDs are prepared for overseas/export shipments per SDDC requirements.&lt;SEP&gt;Transportation Control and Movement Documents (TCMDs) are prepared by the MCMC for overseas and export shipments.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Cargo Handling Equipment (CHE)">
  <ns0:data key="d0">Cargo Handling Equipment (CHE)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Cargo Handling Equipment (CHE) is managed through a personnel training, testing, and licensing program for distribution operations.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Preservation, Packaging, and Packing (P3)">
  <ns0:data key="d0">Preservation, Packaging, and Packing (P3)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Preservation, Packaging, and Packing (P3) is conducted by the MCMC for equipment and supplies requiring storage, embarkation, or shipment.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-2073-1E">
  <ns0:data key="d0">MIL-STD-2073-1E</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-2073-1E is a military standard referenced for marking AMAL/ADAL Environmental Container Systems.&lt;SEP&gt;MIL-STD-2073-1E provides standards for preservation, packaging, and packing of equipment and supplies.&lt;SEP&gt;MIL-STD-2073-1E is a military standard for packaging that MCMC shall perform in accordance with for weapons, parts, and gear.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="NAVSUP P-700">
  <ns0:data key="d0">NAVSUP P-700</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSUP P-700-CNP details common naval packaging procedures, including Level A packing for weapons and gear.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Other Direct Cost (ODC)">
  <ns0:data key="d0">Other Direct Cost (ODC)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Other Direct Cost (ODC) funding is authorized for the MCMC in emergency situations for limited supply chain functions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Class of Supply (COS)">
  <ns0:data key="d0">Class of Supply (COS)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class of Supply (COS) includes Classes II, III, IV, VII, VIII, and IX, with attainment deficiencies listed in the Navy Deficiency Report.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Defense Logistics Agency (DLA)">
  <ns0:data key="d0">Defense Logistics Agency (DLA)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Defense Logistics Agency (DLA) provides supply system requisitions using Navy Job Order Numbers and procedures for fuel support.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841057</ns0:data>
</ns0:node>
<ns0:node id="Job Order Number (JON)">
  <ns0:data key="d0">Job Order Number (JON)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Job Order Number (JON) is utilized by the MCMC for Defense Logistics Agency supply system requisitions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="DA Form 2404">
  <ns0:data key="d0">DA Form 2404</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DA Form 2404 is used for ISO container inspection forms, retained until next inspection or lease return.&lt;SEP&gt;DA Form 2404 is the inspection form retained by the MCMC for leased containers until lease return and for all containers until the next completed inspection.&lt;SEP&gt;DA Form 2404 is completed with cost estimates for Navy container repairs and provided to NAV-P for approval.&lt;SEP&gt;DA Form 2404 is the inspection form retained on each container by MCMC, with copies provided to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-30ad74540c8224cf4aff1f3de36d3780&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="Navy Consolidated Memorandum Receipt (CMR)">
  <ns0:data key="d0">Navy Consolidated Memorandum Receipt (CMR)</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Navy Consolidated Memorandum Receipt (CMR) is submitted quarterly in conjunction with the Navy Container Management Report.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="Civil Engineer Support Equipment (CESE)">
  <ns0:data key="d0">Civil Engineer Support Equipment (CESE)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Civil Engineer Support Equipment (CESE) is containerized and requires maintenance, operational checks, and labeling with stickers.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="TOAVIEWER">
  <ns0:data key="d0">TOAVIEWER</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">TOAVIEWER is used by the MCMC for inventory of Navy assemblies and Class IX Blocks during ship production.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="DoD 4140.65-M">
  <ns0:data key="d0">DoD 4140.65-M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD 4140.65-M is a Department of Defense manual for handling, storage, and preservation in P3&amp;M operations.&lt;SEP&gt;DoD 4140.65-M governs packaging standards for weapons, electronic parts, and other gear in Level A packing.&lt;SEP&gt;DoD 4140.65-M is a standard for packaging and handling that MCMC shall follow for container packing and mobile loads.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-001">
  <ns0:data key="d0">SOW Attachment C.6-001</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-001 provides the format for the Navy Deficiency Report (CDRL 6020).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-002">
  <ns0:data key="d0">SOW Attachment C.6-002</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-002 details requirements for maintaining the Logistics Over-the-Shore (LOTS) Rotational Pool assets (CDRL 6019).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-003">
  <ns0:data key="d0">SOW Attachment C.6-003</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-003 specifies the format for the DODAAC Documents Report (CDRL 6021).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-011">
  <ns0:data key="d0">SOW Attachment C.6-011</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-011 outlines the Navy Production Attainment Report (CDRL 6026).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-012">
  <ns0:data key="d0">SOW Attachment C.6-012</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-012 describes the Navy Container Management Report (CDRL 6024) and container ownership database.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-013">
  <ns0:data key="d0">SOW Attachment C.6-013</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-013 defines the Navy Production Assembly and Class IX Inventory Short List (CDRL 6027).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-019">
  <ns0:data key="d0">SOW Attachment C.6-019</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-019 provides the format for the Navy Containerized Equipment Maintenance Transfer Log (CDRL 6028).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.6-021">
  <ns0:data key="d0">SOW Attachment C.6-021</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.6-021 relates to the Navy Consolidated Memorandum Receipt (CMR).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="SOW Section 4.D.2">
  <ns0:data key="d0">SOW Section 4.D.2</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SOW Section 4.D.2 specifies operations for the MCSF-BI Defense Fuel Support Point (DFSP).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.13.d">
  <ns0:data key="d0">6.C.13.d</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.13.d requires the MCMC to maintain audit trails for requisition, receipt, issuance of material, and other key supply documents.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.14">
  <ns0:data key="d0">6.C.14</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.14 mandates monthly reconciliations by the MCMC and delivery of the Navy Reconciliation Log Report (CDRL 6018) to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.15">
  <ns0:data key="d0">6.C.15</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.15 directs the MCMC to receipt, store, and distribute Navy weapons using specified forms and coordination.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.15.a">
  <ns0:data key="d0">6.C.15.a</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.15.a requires the MCMC to submit the Navy Small Arms Monthly Inventory Report (CDRL 6082) monthly.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16">
  <ns0:data key="d0">6.C.16</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16 outlines the MCMC's support for NSC and NAV-P shipping requirements through the TMO/DMO.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.a">
  <ns0:data key="d0">6.C.16.a</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.a specifies transportation management receiving functions using CMOS and referenced regulations.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.b">
  <ns0:data key="d0">6.C.16.b</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.b details processing of special handling shipments, including notification and delivery.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.c">
  <ns0:data key="d0">6.C.16.c</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.c requires maintenance of a transportation management database for received shipments.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.d">
  <ns0:data key="d0">6.C.16.d</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.d covers requirements for overseas/export shipments, including SDDC processes.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.e">
  <ns0:data key="d0">6.C.16.e</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.e mandates maintenance of a database for pending and completed shipments.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.16.f">
  <ns0:data key="d0">6.C.16.f</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.16.f addresses materiel/cargo handling with MHE/CHE, including training and licensing.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.17">
  <ns0:data key="d0">6.C.17</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.17 requires the MCMC to conduct P3 for equipment and supplies.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.18">
  <ns0:data key="d0">6.C.18</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.18 authorizes ODC funding for emergencies in supply chain functions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.19">
  <ns0:data key="d0">6.C.19</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.19 directs maintenance of LOTS Rotational Pool assets (CDRL 6019).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.20">
  <ns0:data key="d0">6.C.20</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.20 requires submission of the Navy Deficiency Report (CDRL 6020) 130 days prior to ship production.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.21">
  <ns0:data key="d0">6.C.21</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.21 mandates attaining approved Navy material deficiencies within five business days.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.22">
  <ns0:data key="d0">6.C.22</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.22 requires daily updates to the DODAAC Documents Report (CDRL 6021) with minimal errors.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.23">
  <ns0:data key="d0">6.C.23</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.23 directs provision of a daily purchasing report (CDRL 6022) for expenditure tracking.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.24">
  <ns0:data key="d0">6.C.24</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.24 requires monitoring of Navy Receipt/Due File and daily actions on DoD supply transactions.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.25">
  <ns0:data key="d0">6.C.25</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.25 mandates monthly ULO reconciliation and reporting (CDRL 6023) to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.C.26">
  <ns0:data key="d0">6.C.26</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.C.26 requires operation of the MCSF-BI DFSP to support Navy fuel needs.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1">
  <ns0:data key="d0">6.D.1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1 outlines management of the Navy ISO container program, including accountability and maintenance.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.a">
  <ns0:data key="d0">6.D.1.a</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.a requires inventory and inspection of downloaded Navy containers, with report submission (CDRL 6024).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.b">
  <ns0:data key="d0">6.D.1.b</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.b directs removal of contents from Navy equipment containers per production schedule.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.c">
  <ns0:data key="d0">6.D.1.c</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.c ensures sufficient RFI containers through repairs and certification, with DA Form 2404 submission.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.d">
  <ns0:data key="d0">6.D.1.d</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.d requires maintenance of a Navy container ownership database accessible to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.e">
  <ns0:data key="d0">6.D.1.e</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.e mandates weekly submission of the Navy Production Attainment Report (CDRL 6026).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.f">
  <ns0:data key="d0">6.D.1.f</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.f requires labeling of Navy owned containers with unit owner identifiers.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.g">
  <ns0:data key="d0">6.D.1.g</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.g directs inventory of assemblies and Class IX Blocks using TOAVIEWER, with short list submission (CDRL 6027).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.h">
  <ns0:data key="d0">6.D.1.h</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.h requires download and delivery of containerized CESE for maintenance, with log maintenance (CDRL 6028).</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.1.i">
  <ns0:data key="d0">6.D.1.i</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.1.i requires provision of a container production project per 6.O.2.a for NAV-P approval.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841058</ns0:data>
</ns0:node>
<ns0:node id="6.D.2">
  <ns0:data key="d0">6.D.2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.2 directs attainment of material shortages from the short list (SOW Attachment C.6-013) within two business days.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="6.D.3">
  <ns0:data key="d0">6.D.3</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.3 requires Level A packing of specified gear per production schedules and standards.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="6.D.4">
  <ns0:data key="d0">6.D.4</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">6.D.4 mandates completion of Assembly and Class IX Block Packaging.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="6.D">
  <ns0:data key="d0">6.D</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.D covers Navy Containerized Capset Production, including container program management and material attainment.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Force (MPF)">
  <ns0:data key="d0">Maritime Prepositioning Force (MPF)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Maritime Prepositioning Force (MPF) is a program supported by MCMC for supply functions, medical management, and shelf-life requirements with a 36-month minimum expiration.&lt;SEP&gt;Maritime Prepositioning Force Program includes Navy elements supported by MCMC for equipment readiness.&lt;SEP&gt;MPF refers to the force supported by maintenance activities during the Maintenance Cycle for prepositioning ships and programs.&lt;SEP&gt;Maritime Prepositioning Force (MPF) involves ships where Navy weapons are inventoried and maintained in the MPF Maintenance Cycle.</ns0:data>
  <ns0:data key="d3">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="National Security Command (NSC)">
  <ns0:data key="d0">National Security Command (NSC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">National Security Command (NSC) is supported by the MCMC in supply, maintenance, shipping, and production activities.</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Continuation of Essential Contractor Services">
  <ns0:data key="d0">Continuation of Essential Contractor Services</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Continuation of Essential Contractor Services is a clause that outlines the contractor's responsibility to perform essential services during crisis situations, including notification procedures, government rights, cost adjustments, and inclusion in subcontracts.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Notice of Continuation of Essential Contractor Services">
  <ns0:data key="d0">Notice of Continuation of Essential Contractor Services</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Notice of Continuation of Essential Contractor Services is a provision requiring the offeror to provide a written plan for continuing essential contractor services during crises, addressing personnel, resources, challenges, and communication.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Ordering from Government Supply Sources">
  <ns0:data key="d0">Ordering from Government Supply Sources</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">Ordering from Government Supply Sources is a clause detailing procedures for contractors to place orders under federal schedules, nonmandatory contracts, and government stock, including authorizations, statements, compliance, and payment requirements.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Minimum Insurance Requirements">
  <ns0:data key="d0">Minimum Insurance Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Minimum Insurance Requirements specify the types and minimum amounts of insurance that the MCMC must maintain, including general liability, automobile liability, and worker's compensation, along with certification and notice provisions.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Section J List of Documents, Exhibits and Other Attachments">
  <ns0:data key="d0">Section J List of Documents, Exhibits and Other Attachments</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section J List of Documents, Exhibits and Other Attachments enumerates various attachments to the RFP, including technical libraries, wage determinations, collective bargaining agreements, forms, and S-attachments that pertain to the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Technical Library">
  <ns0:data key="d0">Technical Library</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Technical Library is Attachment #1 provided at the time of RFP issuance.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Wage Determination WD-15-4539">
  <ns0:data key="d0">Wage Determination WD-15-4539</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Wage Determination WD-15-4539 is Attachment #2 from the Department of Labor, revised -5.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Collective Bargaining Agreement">
  <ns0:data key="d0">Collective Bargaining Agreement</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Collective Bargaining Agreement is Attachment #3 and #10, incorporated at the time of contract award, including the UNITED STEEL WORKERS (USW).&lt;SEP&gt;The Collective Bargaining Agreement defines common tools as those available from commercial sources used daily by employees, excluding power-driven or calibrated tools, and requires employees to furnish them except for shipboard personnel.&lt;SEP&gt;Collective Bargaining Agreement outlines conditions for personnel compensation, requiring compliance under FAR 22.1008-2 and 41 U.S.C. 6707(c).</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-2fcdd71246fc4a058f5f995cbe6b3531&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="DD Form 254">
  <ns0:data key="d0">DD Form 254</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 254 is the contract attachment specifying security classification requirements and facility clearance needs for the contract.&lt;SEP&gt;DD Form 254 is Attachment #4, the Department of Defense Contract Security Classification.&lt;SEP&gt;DD Form 254 must be completed and submitted at proposal time, serving as Contract Attachment 4 for security requirements.</ns0:data>
  <ns0:data key="d3">chunk-939c604b9027c9cc38a7fb31f4c86c29&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachments/Samples">
  <ns0:data key="d0">SOW Attachments/Samples</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachments/Samples is Attachment #5.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Government Furnished Property List">
  <ns0:data key="d0">Government Furnished Property List</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Government Furnished Property List is Attachment #6.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="Cost Model">
  <ns0:data key="d0">Cost Model</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Cost Model is Attachment #7, incorporated at the time of contract award.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
