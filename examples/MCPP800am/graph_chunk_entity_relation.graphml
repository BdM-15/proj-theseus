<ns0:edge source="WHE" target="NAVFAC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">WHE, including cranes, requires adherence to NAVFAC P-307 for load tests, operator training, and incident reporting.</ns0:data>
  <ns0:data key="d8">crane safety,standards compliance</ns0:data>
  <ns0:data key="d9">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
