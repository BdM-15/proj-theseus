  <ns0:data key="d11">1759841534</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Demand Planning and Forecasting">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes demand planning and forecasting by identifying and sourcing materiel shortfalls with Government approval.</ns0:data>
  <ns0:data key="d8">planning execution,requirement identification</ns0:data>
