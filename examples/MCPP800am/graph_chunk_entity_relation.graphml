  <ns0:data key="d0">Accountable Officer</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Accountable Officer is the Government official who approves all property record adjustments and formally appoints Responsible Officers upon MCMC nomination.</ns0:data>
