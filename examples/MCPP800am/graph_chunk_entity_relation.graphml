<ns0:edge source="GSE" target="Priority 1 Maintenance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Critical Navy GSE such as cranes and transporters are assigned Priority 1 Maintenance LOE for immediate repair.</ns0:data>
