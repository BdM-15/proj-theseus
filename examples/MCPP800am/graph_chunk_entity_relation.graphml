  <ns0:data key="d0">Bravo</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Bravo is a site where parent TAMCN military equipment with Li-Ion hold-up batteries is installed.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Delta">
  <ns0:data key="d0">Delta</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Delta is a site where parent TAMCN military equipment with Li-Ion hold-up batteries is installed.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Echo">
  <ns0:data key="d0">Echo</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Echo is a site where parent TAMCN military equipment with Li-Ion hold-up batteries is installed.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="TI 2000-OR/">
  <ns0:data key="d0">TI 2000-OR/</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">TI 2000-OR/ provides technical instructions for storing and charging Uninterruptible Power Supplies (UPS) for ME.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Modification Instructions (MIs)">
  <ns0:data key="d0">Modification Instructions (MIs)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Modification Instructions (MIs) are identified and performed on ME and CESE assets during designated production periods.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Non-Destructive Testing (NDT)">
  <ns0:data key="d0">Non-Destructive Testing (NDT)</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Non-Destructive Testing (NDT) is performed on load-sustaining components of Tactical Ground Load Lifting Equipment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="KBR">
  <ns0:data key="d0">KBR</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">KBR is responsible for inspecting and servicing fire bottles in individual fire suppression systems of vehicles such as AAV, LAV, LVSR, MTVR, JLTV, and ECV FOV.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MI 11569A-23/1">
  <ns0:data key="d0">MI 11569A-23/1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MI 11569A-23/1 specifies the installation of a retrieval hitch on Medium Crawler Tractor equipped with ripper attachment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Medium Crawler Tractor">
  <ns0:data key="d0">Medium Crawler Tractor</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Medium Crawler Tractor (TAMCN B0060) is military equipment equipped with a ripper attachment requiring retrieval hitch installation to meet production plan requirements.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Ripper Attachment">
  <ns0:data key="d0">Ripper Attachment</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Ripper Attachment (TAMCN B0079) is an attachment for Medium Crawler Tractor on which a retrieval hitch must be installed.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MAC-50 Crane">
  <ns0:data key="d0">MAC-50 Crane</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">MAC-50 Crane (TAMCN B0038) is equipment requiring Non-Destructive Testing (NDT) with special coordination due to the size and weight of its hook and block.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="TRK Ambulance 4-LTR ARMD">
  <ns0:data key="d0">TRK Ambulance 4-LTR ARMD</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">TRK Ambulance 4-LTR ARMD (TAMCN D1001) is a vehicle with a CBRN collective protective system requiring specific contingency and training CBRN filters.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MDSS-II">
  <ns0:data key="d0">MDSS-II</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MDSS-II is an embarkation data Automated Information System (AIS) used to capture and log storage locations of portable fire extinguishers separated from parent equipment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MIM">
  <ns0:data key="d0">MIM</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MIM refers to Maintenance Information Messages communicating maintenance-related information for military equipment.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Test, Measurement, and Diagnostic Equipment (TMDE)">
  <ns0:data key="d0">Test, Measurement, and Diagnostic Equipment (TMDE)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Test, Measurement, and Diagnostic Equipment (TMDE) are tools requiring calibration services to perform qualitative and quantitative measurements on ME and CESE assets.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="CBRN Collective Protective System">
  <ns0:data key="d0">CBRN Collective Protective System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CBRN Collective Protective System includes CBRN filters installed on prepositioned military equipment vehicles for protection.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Tactical Ground Load Lifting Equipment">
  <ns0:data key="d0">Tactical Ground Load Lifting Equipment</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Tactical Ground Load Lifting Equipment includes components requiring Non-Destructive Testing (NDT) on load-sustaining parts.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="Organic Support Assets">
  <ns0:data key="d0">Organic Support Assets</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Organic Support Assets are assets on which MCMC conducts PMCS per applicable timeframes and methods in equipment technical manuals.&lt;SEP&gt;Organic Support Assets are Government Furnished Equipment (Non-PO) subject to PMCS in accordance with equipment TMs and established rosters.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="IDIV Environmental Office">
  <ns0:data key="d0">IDIV Environmental Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">IDIV Environmental Office provides consultation on rare species and sensitive habitats and determines designated winter months for manatee watch.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="CETEP">
  <ns0:data key="d0">CETEP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CETEP is the Government-provided Comprehensive Environmental Training and Education Plan Microsoft Access Database used for tracking employee training attendance.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 265">
  <ns0:data key="d0">40 CFR 265</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">40 CFR 265 defines training requirements for a Large Quantity Generator facility associated with hazardous and regulated wastes.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Integrated Solid Waste Management Plan">
  <ns0:data key="d0">MCSF-BI Integrated Solid Waste Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Integrated Solid Waste Management Plan outlines compliance requirements for solid waste management and recycling of waste streams.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841126</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Green Procurement Plan">
  <ns0:data key="d0">MCSF-BI Green Procurement Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Green Procurement Plan specifies processes for acquiring consumables, materials, and equipment in compliance with federal laws and policies.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Pollution Prevention Management Plan">
  <ns0:data key="d0">MCSF-BI Pollution Prevention Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Pollution Prevention Management Plan details compliance with pollution prevention programs, including surveys and data collection.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Integrated Natural Resource Management Plan">
  <ns0:data key="d0">MCSF-BI Integrated Natural Resource Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Integrated Natural Resource Management Plan governs natural resources management, including manatee watch requirements.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="INRMP">
  <ns0:data key="d0">INRMP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">INRMP is the MCSF-BI Integrated Natural Resource Management Plan that outlines compliance for natural resources protection and manatee watch.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10052">
  <ns0:data key="d0">CDRL 10052</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10052 is the after-action log for manatee watch provided monthly.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 761">
  <ns0:data key="d0">40 CFR 761</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">40 CFR 761 governs the management of PCB contaminated waste.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCS-BI Environmental Management System Manual">
  <ns0:data key="d0">MCS-BI Environmental Management System Manual</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCS-BI Environmental Management System Manual outlines participation in ISO 14001 site certification and EMS programs.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="EMS">
  <ns0:data key="d0">EMS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">EMS is the Environmental Management System that includes policies, objectives, audits, and training for environmental compliance.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10053">
  <ns0:data key="d0">CDRL 10053</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10053 is the notification report for releases or spills of oil and hazardous substances.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Integrated Contingency Plan">
  <ns0:data key="d0">MCSF-BI Integrated Contingency Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Integrated Contingency Plan provides procedures for spill response, notifications, and containment.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 300">
  <ns0:data key="d0">40 CFR 300</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">40 CFR 300 regulates response to spills of hazardous materials, substances, waste, and regulated gases.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="OSHA 40-Hour HAZWOPER Training">
  <ns0:data key="d0">OSHA 40-Hour HAZWOPER Training</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">OSHA 40-Hour HAZWOPER Training is required for the MCMC boat crew handling spill responses.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="National Incident Management System Training">
  <ns0:data key="d0">National Incident Management System Training</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">National Incident Management System Training courses 100c, 200c, and ICS 300 are required for the boat crew supervisor as an alternate Incident Commander.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10054">
  <ns0:data key="d0">CDRL 10054</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10054 is the monthly Spill Kit Inventory Form provided to the Government.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="7 CFR 330.400">
  <ns0:data key="d0">7 CFR 330.400</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">7 CFR 330.400 regulates inspection of garbage derived from plant or animal material.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="SECTION C.11">
  <ns0:data key="d0">SECTION C.11</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SECTION C.11 specifies requirements for communication support systems, including voice, video, and data services for preposition sites.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MITSC East">
  <ns0:data key="d0">MITSC East</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MITSC East is the regional IT center directing network operations and support for the contract.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="GOGO-CS">
  <ns0:data key="d0">GOGO-CS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">GOGO-CS is the Government Owned, Government Operated - MCMC Supported Enterprise Network strategy.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCCOG">
  <ns0:data key="d0">MCCOG</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MCCOG is the Marine Corps Cyber-Security Operations Group directing overall NetOps and Cyber Network Operations.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Help Desk">
  <ns0:data key="d0">Help Desk</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Help Desk is the service operated by MCMC for resolving video and data issues during normal business hours.&lt;SEP&gt;Help Desk is operated by MCMC during normal business hours (0600-1630 Monday through Friday, excluding Federal holidays) to resolve voice, video, and data service delivery problems, including recording calls and service requests.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Microsoft Office Products">
  <ns0:data key="d0">Microsoft Office Products</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Office Products are software installed, configured, and maintained by MCMC for end-user devices.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="DODI 8570">
  <ns0:data key="d0">DODI 8570</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">DODI 8570 governs minimum qualifications and certifications for the Information Assurance Workforce.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="DODD 8140">
  <ns0:data key="d0">DODD 8140</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">DODD 8140 sets standards for IAWF positions, requiring level II technical certification for IT support.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="9 CFR 94.5">
  <ns0:data key="d0">9 CFR 94.5</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">9 CFR 94.5 governs the handling and storage of regulated garbage.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Environmental Management System Manual">
  <ns0:data key="d0">MCSF-BI Environmental Management System Manual</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCSF-BI Environmental Management System Manual outlines participation in ISO 14001 site certification and EMS programs.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="POLs">
  <ns0:data key="d0">POLs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">POLs refers to Petroleum, Oils, and Lubricants that personnel routinely handle, requiring spill response training within 30 days of hire or transfer.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Manatee Watch">
  <ns0:data key="d0">Manatee Watch</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Manatee Watch is conducted by MCMC with 30 minutes notification for ship movements in the slipway, except during designated winter months.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Boat Crew">
  <ns0:data key="d0">Boat Crew</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Boat Crew is the MCMC team serving as initial response for spills in the slipway, deploying containment booms, and conducting manatee watch.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Regulated Garbage">
  <ns0:data key="d0">Regulated Garbage</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Regulated Garbage consists of waste material from fruits, vegetables, meats, or other plant or animal sources, requiring inspection and separate storage.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="IAWF">
  <ns0:data key="d0">IAWF</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">IAWF is the Information Assurance Workforce, with IT support positions requiring level II technical certification under DODI 8570 and DODD 8140.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="ISO 14001">
  <ns0:data key="d0">ISO 14001</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">ISO 14001 is the international standard for environmental management systems, applicable to the installation's site certification.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="40 CFR 260">
  <ns0:data key="d0">40 CFR 260</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">40 CFR 260 defines military munitions for compliance purposes.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="National Association of State Boating Law Administrators Class">
  <ns0:data key="d0">National Association of State Boating Law Administrators Class</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">National Association of State Boating Law Administrators Class or equivalent is required certification for all MCMC employees involved in manatee watch using government boats.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841127</ns0:data>
</ns0:node>
<ns0:node id="Facility Response Plan">
  <ns0:data key="d0">Facility Response Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Facility Response Plan is the document that the MCMC boat crew must be familiar with for spill response training and exercises.</ns0:data>
  <ns0:data key="d3">chunk-0395bdbad90a448875b2a66efe14f948</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Organizational Maintenance Management System - Next Generation (OMMS-NG)">
  <ns0:data key="d0">Organizational Maintenance Management System - Next Generation (OMMS-NG)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">OMMS-NG is a module used for documenting Navy supply and maintenance administration.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Phase Alpha">
  <ns0:data key="d0">Phase Alpha</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Phase Alpha is the Afloat Phase with watercraft embarked aboard Maritime Prepositioning Ships (MPS), lasting 36-42 months, involving maintenance under NWAMS.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Watercraft Maintenance Center (WMC)">
  <ns0:data key="d0">Watercraft Maintenance Center (WMC)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">WMC is an organization that maintains marine technicians for accomplishing Maintenance Requirements Package (MRP) and troubleshooting.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Repair Support Team (RST)">
  <ns0:data key="d0">Repair Support Team (RST)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">RST manages and oversees subcontract repair work on Navy lighterage, providing quality control oversight.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Operations Support Team (OST)">
  <ns0:data key="d0">Operations Support Team (OST)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">OST supports operational tests, troubleshooting, watercraft movement, and associated functions like lifting and fueling.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Navy Program Manager">
  <ns0:data key="d0">Navy Program Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Navy Program Manager is key personnel directly supported by purchasing, financial, 3M data, plans/projects, quality control, and subcontract management.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Controls System Support (CSS)">
  <ns0:data key="d0">Controls System Support (CSS)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">CSS maintains skill sets for Machinery Control System Technical Refresh, FSB installation, and electronic support.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Integration Manager (MIM)">
  <ns0:data key="d0">Maintenance Integration Manager (MIM)</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Maintenance Integration Manager manages integration between WMC, CSS, and RST to produce watercraft CAPSETs and is key personnel.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Navy Quality Control Manager (QCM)">
  <ns0:data key="d0">Navy Quality Control Manager (QCM)</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Navy Quality Control Manager manages quality control processes for Navy operations including WMC, RST, CSS, NSC, and OST.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Augment Team (MAT)">
  <ns0:data key="d0">Maintenance Augment Team (MAT)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MAT provides scalable surge capability to augment maintenance sections with skill sets for corrective maintenance actions.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Intermediate Maintenance Team (IMT)">
  <ns0:data key="d0">Intermediate Maintenance Team (IMT)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">IMT provides capability for intermediate and minor to mid-grade depot level maintenance with specific occupational skill sets.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Organizational Chart">
  <ns0:data key="d0">Organizational Chart</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Organizational Chart (CDRL 6002) differentiates personnel supporting MCPP II efforts and Navy Operations, due within 30 days of award or change.&lt;SEP&gt;Organizational Chart is part of the PPSP, differentiating personnel dedicated to MCPP efforts and Navy Operations.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Personnel Roster">
  <ns0:data key="d0">Personnel Roster</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The Personnel Roster (CDRL 6001) includes titles and assigned numbers of Navy MCMC personnel, due within 30 days of award or change.&lt;SEP&gt;Personnel Roster is part of the PPSP, including titles and assigned numbers for all MCMC personnel.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="SOW Section 6.G">
  <ns0:data key="d0">SOW Section 6.G</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SOW Section 6.G details requirements for maintenance administration, shipping, and supply support for the Afloat Maintenance Activity (AMA).</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="SOW Section 6.F">
  <ns0:data key="d0">SOW Section 6.F</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">SOW Section 6.F depicts requirements for Phase Bravo, including condition assessments.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="SYSCOM">
  <ns0:data key="d0">SYSCOM</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">SYSCOM sponsors maintenance requirements, issues Fleet Service Bulletins, Safety of Use Messages, Engineering Change Notices, and System Alterations, and provides on-site support for Control System configuration during Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Navy Watercraft Afloat Maintenance Services (NWAMS)">
  <ns0:data key="d0">Navy Watercraft Afloat Maintenance Services (NWAMS)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NWAMS is a separate contract that accomplishes preventive and corrective maintenance for afloat watercraft during the Afloat Maintenance Activity in Phase Alpha.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Maritime Prepositioning Ships (MPS)">
  <ns0:data key="d0">Maritime Prepositioning Ships (MPS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MPS are ships on which watercraft are embarked during Phase Alpha, marking the beginning of the Lighterage Maintenance Model.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Afloat Maintenance Activity (AMA)">
  <ns0:data key="d0">Afloat Maintenance Activity (AMA)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">AMA involves maintenance for watercraft afloat, supported by administration, shipping, and supply requirements detailed in SOW Section 6.G.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Work Definition Conference (WDC)">
  <ns0:data key="d0">Work Definition Conference (WDC)</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">WDC is a process during which follow-on work packages for Phase Charlie are detailed based on condition assessments from Phase Bravo.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Inspection and Survey (INSURV)">
  <ns0:data key="d0">Inspection and Survey (INSURV)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">INSURV designates Materiel Inspection Teams that may be involved in Phase Bravo assessments.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Lighter Amphibious Resupply Cargo (LARC)">
  <ns0:data key="d0">Lighter Amphibious Resupply Cargo (LARC)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">LARC is a type of Navy watercraft subject to maintenance processes, with its own dedicated maintenance facility as part of the WMC.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Capability Set (CAPSET)">
  <ns0:data key="d0">Capability Set (CAPSET)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CAPSET involves container production managed by the Navy Supply Center as part of supply chain and warehousing functions.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Fleet Service Bulletins (FSBs)">
  <ns0:data key="d0">Fleet Service Bulletins (FSBs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">FSBs are issued by SYSCOM and may identify over and above maintenance requirements tasked to MCMC.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Safety of Use Messages (SOUMs)">
  <ns0:data key="d0">Safety of Use Messages (SOUMs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOUMs are issued by SYSCOM and may identify over and above maintenance requirements tasked to MCMC.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="System Alterations (SYSALTs)">
  <ns0:data key="d0">System Alterations (SYSALTs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SYSALTs are issued by SYSCOM and may identify over and above maintenance requirements tasked to MCMC.</ns0:data>
  <ns0:data key="d3">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Equal Opportunity Clause for Protected Veterans">
  <ns0:data key="d0">Equal Opportunity Clause for Protected Veterans</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause at 41 CFR 60-300.5(a) prohibits discrimination against qualified protected veterans and requires affirmative action to employ and advance them in employment.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="52.222-36 Equal Opportunity for Workers with Disabilities">
  <ns0:data key="d0">52.222-36 Equal Opportunity for Workers with Disabilities</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause at 41 CFR 60-741.5(a) prohibits discrimination against qualified individuals with disabilities and requires affirmative action to employ and advance them in employment.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="52.222-42 Statement of Equivalent Rates for Federal Hires">
  <ns0:data key="d0">52.222-42 Statement of Equivalent Rates for Federal Hires</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause identifies classes of service employees expected under the contract and states wages and fringe benefits payable if employed by the contracting agency, in compliance with the Service Contract Labor Standards statute and 29 CFR part 4.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="52.223-3 Hazardous Material Identification and Material Safety Data">
  <ns0:data key="d0">52.223-3 Hazardous Material Identification and Material Safety Data</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause defines hazardous material per Federal Standard No. 313 and requires the offeror to list any such materials for delivery, submit Material Safety Data Sheets, and update the list during contract performance.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="52.223-7 Notice of Radioactive Materials">
  <ns0:data key="d0">52.223-7 Notice of Radioactive Materials</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause requires written notice three days prior to delivery or servicing of items containing radioactive materials meeting specified criteria, including details on the materials, and mandates marking per MIL-STD 129.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="52.229-8 Tax">
  <ns0:data key="d0">52.229-8 Tax</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">The clause addresses tax-related provisions in the contract.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Office of Federal Contract Compliance Programs">
  <ns0:data key="d0">Office of Federal Contract Compliance Programs</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The office that specifies actions for the Contractor to enforce equal opportunity clause terms, including for noncompliance.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="U.S. Department of Labor">
  <ns0:data key="d0">U.S. Department of Labor</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The department whose Director oversees enforcement of contract compliance programs and whose Secretary issues rules, regulations, or orders for exemptions.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841128</ns0:data>
</ns0:node>
<ns0:node id="Secretary of Labor">
  <ns0:data key="d0">Secretary of Labor</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The official referenced for exemptions from subcontract insertion requirements via rules, regulations, or orders.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Material Safety Data Sheet">
  <ns0:data key="d0">Material Safety Data Sheet</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">A document required for each hazardous material, meeting 29 CFR 1910.1200(g) and Federal Standard No. 313, to be submitted prior to award and updated if needed.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Federal Standard No. 313">
  <ns0:data key="d0">Federal Standard No. 313</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The federal standard used to define hazardous materials and for submitting data on them under the contract.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="41 CFR 60-300.5(a)">
  <ns0:data key="d0">41 CFR 60-300.5(a)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Code of Federal Regulations section containing the equal opportunity clause that prohibits discrimination against qualified protected veterans and requires affirmative action for their employment and advancement.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="41 CFR 60-741.5(a)">
  <ns0:data key="d0">41 CFR 60-741.5(a)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Code of Federal Regulations section containing the equal opportunity clause that prohibits discrimination against qualified individuals with disabilities and requires affirmative action for their employment and advancement.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="29 CFR Part 4">
  <ns0:data key="d0">29 CFR Part 4</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Code of Federal Regulations part outlining the regulations of the Secretary of Labor for the Service Contract Labor Standards statute, applicable to wages and fringe benefits for service employees.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="5 U.S.C. 5341">
  <ns0:data key="d0">5 U.S.C. 5341</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The United States Code section providing provisions for the wage system applicable to federal hires referenced in the statement of equivalent rates.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="5 U.S.C. 5332">
  <ns0:data key="d0">5 U.S.C. 5332</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The United States Code section providing provisions for the wage system applicable to federal hires referenced in the statement of equivalent rates.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="FAR 22.1303(a)">
  <ns0:data key="d0">FAR 22.1303(a)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">The Federal Acquisition Regulation section specifying the threshold for inserting equal opportunity terms in subcontracts related to protected veterans.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="FAR 22.1408(a)">
  <ns0:data key="d0">FAR 22.1408(a)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">The Federal Acquisition Regulation section specifying the threshold for including equal opportunity terms in subcontracts or purchase orders related to workers with disabilities.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Director, Office of Federal Contract Compliance Programs">
  <ns0:data key="d0">Director, Office of Federal Contract Compliance Programs</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The official within the U.S. Department of Labor who specifies actions for the Contractor to enforce equal opportunity clause terms, including measures for noncompliance.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Service Employee Classes">
  <ns0:data key="d0">Service Employee Classes</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">The identified classes of service employees expected under the contract, including job titles such as AAV Mechanic, Ammunition Technician, and others, with corresponding monetary wages and fringe benefits for federal hire equivalents.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="29 CFR 1910.1200(g)">
  <ns0:data key="d0">29 CFR 1910.1200(g)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">The Code of Federal Regulations section specifying requirements for Material Safety Data Sheets related to hazardous materials.</ns0:data>
  <ns0:data key="d3">chunk-b535073f97c759a4e2ee7105ea8bc467</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Key Personnel">
  <ns0:data key="d0">Key Personnel</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Key Personnel includes positions such as Program Manager, Deputy Program Manager, and others that report directly to management and cannot be removed or replaced without Contracting Officer approval.&lt;SEP&gt;Key Personnel are proposed individuals whose past performance information may be considered by the Government in evaluating the offeror's ability to perform.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Common Access Card">
  <ns0:data key="d0">Common Access Card</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Common Access Card is an identification card required for network access, issued based on favorable personnel security investigations.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Contracting Lines of Authority">
  <ns0:data key="d0">Contracting Lines of Authority</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Contracting Lines of Authority is a figure outlining roles and responsibilities of Contracting Officer, Contracting Officer Representative, Contracting Officer Technical Representative, and Quality Assurance Representative.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="1.H Personnel">
  <ns0:data key="d0">1.H Personnel</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.H Personnel is a section detailing general personnel requirements, disciplines, specialties, security considerations, and surge support for the contract.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="Staffing Report">
  <ns0:data key="d0">Staffing Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Staffing Report is a monthly CDRL deliverable including billet titles, planned personnel numbers, vacancies, durations, and hiring comments.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="ISO 19011">
  <ns0:data key="d0">ISO 19011</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">ISO 19011 is the current version standard to which MCMC auditors must be certified as Lead Auditors.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="PMP">
  <ns0:data key="d0">PMP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">PMP is a special certification that personnel requiring it must have maintained for the most recent three years.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="ASQ CMQ/OE">
  <ns0:data key="d0">ASQ CMQ/OE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">ASQ CMQ/OE is the Manager of Quality/Organizational Excellence Certification that the MCMC Quality Manager must possess or obtain within two years of contract award.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="DAWIA">
  <ns0:data key="d0">DAWIA</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">DAWIA certifications may be submitted as an alternative to PMI and ASQ certifications for personnel.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="FAC">
  <ns0:data key="d0">FAC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">FAC certifications may be submitted as an alternative to PMI and ASQ certifications for personnel.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 1200.1">
  <ns0:data key="d0">NAVMC 1200.1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 1200.1 is the Military Occupational Specialties Manual used for training personnel in accordance with Marine Corps directives.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="MCO 5510.18B">
  <ns0:data key="d0">MCO 5510.18B</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 5510.18B is the manual for personnel security investigations, requiring T1 or T3 for certain MCMC personnel.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="DoD Directive 5220.22-M">
  <ns0:data key="d0">DoD Directive 5220.22-M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD Directive 5220.22-M is the National Industrial Security Program Operating Manual (NISPOM) that the MCMC and subcontractors must adhere to.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="NISPOM">
  <ns0:data key="d0">NISPOM</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NISPOM is the National Industrial Security Program Operating Manual governing security compliance for the contract.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841129</ns0:data>
</ns0:node>
<ns0:node id="DISS">
  <ns0:data key="d0">DISS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DISS is the Defense Information System for Security used to manage personnel security records and CAC eligibility for MCMC employees.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="DBIDS">
  <ns0:data key="d0">DBIDS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">DBIDS is the Defense Biometric Identification System for badges providing facility and base access without network access.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="USINDOPACOM">
  <ns0:data key="d0">USINDOPACOM</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">USINDOPACOM is the United States Indo-Pacific Command area of responsibility where MCPP-PHIL services are primarily conducted.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="1.H.1 General Personnel Requirements">
  <ns0:data key="d0">1.H.1 General Personnel Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.H.1 General Personnel Requirements details citizenship, compliance with laws, and hiring provisions for OCN personnel in the SOW.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="1.H.2 MCMC Personnel, Disciplines, and Specialties">
  <ns0:data key="d0">1.H.2 MCMC Personnel, Disciplines, and Specialties</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.H.2 MCMC Personnel, Disciplines, and Specialties outlines qualifications, training, staffing reports, key personnel procedures, and resume formats.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="1.H.3 Security Considerations and Classification">
  <ns0:data key="d0">1.H.3 Security Considerations and Classification</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.H.3 Security Considerations and Classification specifies facility clearances, investigations, CAC requirements, and identification cards for personnel.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="1.H.4 Surge Support Personnel">
  <ns0:data key="d0">1.H.4 Surge Support Personnel</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.H.4 Surge Support Personnel requires the MCMC to staff three surge teams of five to seven members for maintenance support.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="1.I Equipment and Materiel Accountability">
  <ns0:data key="d0">1.I Equipment and Materiel Accountability</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">1.I Equipment and Materiel Accountability assigns the MCMC responsibility for maintaining accountability of government-owned equipment and supply accounts.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.1-6">
  <ns0:data key="d0">SOW Attachment C.1-6</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.1-6 outlines annual government-required training for MCMC employees.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Secret Facility Security Clearance">
  <ns0:data key="d0">Secret Facility Security Clearance</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Secret Facility Security Clearance is required for the MCMC in accordance with DD Form 254.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="T1 Investigation">
  <ns0:data key="d0">T1 Investigation</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">T1 Investigation is the minimum acceptable personnel security investigation for CAC eligibility.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="T3 Investigation">
  <ns0:data key="d0">T3 Investigation</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">T3 Investigation is required for manager, supervisory, IT, AA&amp;E, and ordnance maintenance personnel, as well as those in secure spaces.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="BICmd Security Office">
  <ns0:data key="d0">BICmd Security Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">BICmd Security Office handles security violation reports, fingerprint submissions, and coordination for pre-employment security processes.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Base Commander">
  <ns0:data key="d0">Base Commander</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Base Commander issues rules and regulations to which MCMC personnel in host nations are subject regarding base operations, safety, and discipline.</ns0:data>
  <ns0:data key="d3">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Information Retrieval System (PPIRS)">
  <ns0:data key="d0">Past Performance Information Retrieval System (PPIRS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Past Performance Information Retrieval System (PPIRS) is a database used by the Government to review relevant past performance information.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Federal Awardee Performance and Integrity Information System (FAPIIS)">
  <ns0:data key="d0">Federal Awardee Performance and Integrity Information System (FAPIIS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Federal Awardee Performance and Integrity Information System (FAPIIS) is a database accessed by the Government for evaluating offeror performance and integrity.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Electronic Subcontract Reporting System (eSRS)">
  <ns0:data key="d0">Electronic Subcontract Reporting System (eSRS)</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Electronic Subcontract Reporting System (eSRS) is a system utilized by the Government to assess subcontracting compliance and performance.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Request for Proposal (RFP)">
  <ns0:data key="d0">Request for Proposal (RFP)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Request for Proposal (RFP) outlines the requirements, evaluation factors, and procedures for the acquisition, including past performance and cost/price assessments.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Oral Presentations">
  <ns0:data key="d0">Oral Presentations</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Oral Presentations are considered by the Government in assessing the offeror's past performance relevant to MCPP requirements and proposed efficiencies.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="MCPP Requirements">
  <ns0:data key="d0">MCPP Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">MCPP Requirements encompass the logistics services, efficiencies, and areas of concern identified by the Government in the RFP.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Evaluation Factor">
  <ns0:data key="d0">Past Performance Evaluation Factor</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Past Performance Evaluation Factor assesses the offeror's and subcontractors' recent and relevant performance records, including management, cost performance, and compliance with small business clauses.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Relevancy Ratings">
  <ns0:data key="d0">Past Performance Relevancy Ratings</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Past Performance Relevancy Ratings categorize efforts as Very Relevant, Relevant, Somewhat Relevant, or Not Relevant based on complexity, magnitude, scope, and period of performance compared to the RFP.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Confidence Assessments">
  <ns0:data key="d0">Past Performance Confidence Assessments</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Past Performance Confidence Assessments rate the offeror's ability to perform as Substantial Confidence, Satisfactory Confidence, Neutral Confidence, Limited Confidence, or No Confidence based on recent/relevant performance records.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Cost/Price Factor">
  <ns0:data key="d0">Cost/Price Factor</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Cost/Price Factor evaluates the offeror's proposed costs and prices for all CLINs, including assessments of completeness, reasonableness, realism, and analysis of employee compensation and business systems.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Small Business Participation and Subcontracting Factor">
  <ns0:data key="d0">Small Business Participation and Subcontracting Factor</ns0:data>
  <ns0:data key="d1">evaluation_factor</ns0:data>
  <ns0:data key="d2">Small Business Participation and Subcontracting Factor assesses the offeror's commitment to small business utilization and subcontracting plans, rated as Outstanding, Good, Acceptable, Marginal, or Unacceptable.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.219-8 Utilization of Small Business Concerns">
  <ns0:data key="d0">FAR 52.219-8 Utilization of Small Business Concerns</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.219-8 Utilization of Small Business Concerns requires compliance by all offerors in utilizing small business concerns in contract performance.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.219-9 Small Business Subcontracting Plan">
  <ns0:data key="d0">FAR 52.219-9 Small Business Subcontracting Plan</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.219-9 Small Business Subcontracting Plan applies to offerors identified as other than small, requiring a plan for small business subcontracting.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Contractor Performance Assessment Reviews (CPARs)">
  <ns0:data key="d0">Contractor Performance Assessment Reviews (CPARs)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Contractor Performance Assessment Reviews (CPARs) are performance evaluations obtained and used by the Government to assess an offeror's ability to perform contract requirements.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Past Performance Questionnaires">
  <ns0:data key="d0">Past Performance Questionnaires</ns0:data>
  <ns0:data key="d1">submission_instruction</ns0:data>
  <ns0:data key="d2">Past Performance Questionnaires are tools employed by the Government to collect information on an offeror's past performance from relevant sources.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Area Wage Determination (AWD)">
  <ns0:data key="d0">Area Wage Determination (AWD)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Area Wage Determination (AWD) specifies prevailing wage rates and fringe benefits for labor categories in the contract's geographic area.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Collective Bargaining Agreement (CBA)">
  <ns0:data key="d0">Collective Bargaining Agreement (CBA)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Collective Bargaining Agreement (CBA) defines negotiated terms, including wages and benefits, for unionized employees performing under the contract.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="CLINs">
  <ns0:data key="d0">CLINs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CLINs refer to contract line item numbers that structure the proposed costs and prices for evaluation, including both firm-fixed-price and cost-type items.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Optional Order Period">
  <ns0:data key="d0">Optional Order Period</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Optional Order Period encompasses additional CLINs evaluated in the cost/price assessment without obligating the Government to exercise the options.</ns0:data>
  <ns0:data key="d3">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Supply Demand Planning">
  <ns0:data key="d0">Supply Demand Planning</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Supply Demand Planning involves monitoring and tracking Military Equipment excesses and deficiencies relative to established allowances.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Table of Organization and Equipment Change Requests">
  <ns0:data key="d0">Table of Organization and Equipment Change Requests</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Table of Organization and Equipment Change Requests (TOECR) (CDRL 5003) are draft requests for validated excesses and deficiencies requiring changes to T/E allowances.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Secondary Reparable Excess and Deficiency Report">
  <ns0:data key="d0">Secondary Reparable Excess and Deficiency Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Secondary Reparable Excess and Deficiency Report (CDRL 5006) reports excesses and deficiencies for RIP accounts on a monthly basis.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="Non-Tactical Vehicle Priority Procurement List">
  <ns0:data key="d0">Non-Tactical Vehicle Priority Procurement List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Non-Tactical Vehicle Priority Procurement List (CDRL 5009) requests additional Government-owned or leased equipment for transportation operations and is submitted annually.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="UURI/Additional Authorized List Authorization Letter">
  <ns0:data key="d0">UURI/Additional Authorized List Authorization Letter</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">UURI/Additional Authorized List Authorization Letter (CDRL 5010) authorizes quantities of Using Unit Responsibility Items and is submitted annually.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841130</ns0:data>
</ns0:node>
<ns0:node id="MMV420">
  <ns0:data key="d0">MMV420</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">MMV420 is the MCPP-N account for which monthly excess/deficiency reports are provided.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="MMV777">
  <ns0:data key="d0">MMV777</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">MMV777 is the MCPP-PHIL account for which monthly excess/deficiency reports are provided.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Support Facility">
  <ns0:data key="d0">Marine Corps Support Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Marine Corps Support Facility (MCSF-BI) is a location where supply, container, and distribution management operations are performed.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Technical Manuals">
  <ns0:data key="d0">Technical Manuals</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Technical Manuals (TM) outline timeframes and methods for PMCS on Government Furnished Equipment and Organic Support Assets.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="OEM Manuals">
  <ns0:data key="d0">OEM Manuals</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">OEM Manuals provide guidance for PMCS on equipment in accordance with applicable standards.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="PMCS Roster">
  <ns0:data key="d0">PMCS Roster</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">PMCS Roster establishes schedules for PMCS on Government Furnished Equipment.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Materiel Accountability">
  <ns0:data key="d0">Materiel Accountability</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Materiel Accountability is maintained by MCMC through inventory management, property records, and sub-custody procedures.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Demand Planning and Forecasting">
  <ns0:data key="d0">Demand Planning and Forecasting</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Demand Planning and Forecasting involves monitoring materiel requirements relative to Government-established allowances.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Inventory Management">
  <ns0:data key="d0">Inventory Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Inventory Management includes accountability, physical inventories, property record adjustments, warehousing, stock rotation, care of supplies in storage, and shelf life management.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Container Management">
  <ns0:data key="d0">Container Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Container Management encompasses updates to property records, inspections, repairs, and re-certification within an Automated Information System.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Preservation, Packing, Packaging and Marking">
  <ns0:data key="d0">Preservation, Packing, Packaging and Marking</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Preservation, Packing, Packaging and Marking (P3&amp;M) of materiel is executed by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Reparable Issue Points">
  <ns0:data key="d0">Reparable Issue Points</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Reparable Issue Points (RIP) include maintenance floats and sub-floats, with annual recomputations and monthly excess/deficiency reports.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Table of Equipment">
  <ns0:data key="d0">Table of Equipment</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Table of Equipment (T/E) within TFSMS provides established allowances for the organic Port T/E account (M92502).</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.4-1">
  <ns0:data key="d0">SOW Attachment C.4-1</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.4-1 lists supply accounts, associated DODAACs, descriptions of materiel, and purposes for the accounts.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="TFSMS">
  <ns0:data key="d0">TFSMS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">TFSMS is the system containing the Table of Equipment for organic Port T/E account allowances.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Weekly Class of Supply Report">
  <ns0:data key="d0">Weekly Class of Supply Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Weekly Class of Supply Report (CDRL 4002) for MCPP-N and MCPP-PHIL covers all classes of supply with a Prepositioning Objective and is submitted weekly.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.4-12">
  <ns0:data key="d0">SOW Attachment C.4-12</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.4-12 specifies the format for the Weekly Class of Supply Report in MS Excel.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Secondary Reparable Recomputation">
  <ns0:data key="d0">Secondary Reparable Recomputation</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Secondary Reparable (SECREP) Recomputation is an annual on-site event conducted by LOGCOM CSM team simultaneous with physical inventory.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.4-8">
  <ns0:data key="d0">SOW Attachment C.4-8</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">SOW Attachment C.4-8 provides example support requirements for annual inventory and recomputation led by LOGCOM.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="RIP Special Allowance Requests">
  <ns0:data key="d0">RIP Special Allowance Requests</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">RIP Special Allowance Requests (CDRL 5007) are submitted for review and approval when excesses persist without disposition requests.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="CATALYST">
  <ns0:data key="d0">CATALYST</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CATALYST via USMC Appian Platform provides technical data for RIP special allowance requests.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="USMC Appian Platform">
  <ns0:data key="d0">USMC Appian Platform</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">USMC Appian Platform hosts CATALYST for accessing technical data in allowance requests.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="DoD 7000.14-R">
  <ns0:data key="d0">DoD 7000.14-R</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD 7000.14-R (FMR) provides financial management regulation guidance for spend planning.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Using Unit Responsibility Item Review">
  <ns0:data key="d0">Using Unit Responsibility Item Review</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Using Unit Responsibility Item (UURI) Review is conducted annually to determine authorization quantities for SL-3 items.</ns0:data>
  <ns0:data key="d3">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Continuity of Operations Plan">
  <ns0:data key="d0">Continuity of Operations Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Continuity of Operations Plan for IT services ensures survivability and access to mission critical data and technology in the event of a disaster, with annual reviews and updates submitted to the Cyber Security Manager.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Defense Information Systems Agency">
  <ns0:data key="d0">Defense Information Systems Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Defense Information Systems Agency provides Security Technical Implementation Guidelines used for configuring hardware and software.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Department of the Navy Application Database Management System">
  <ns0:data key="d0">Department of the Navy Application Database Management System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Department of the Navy Application Database Management System is used by MCMC to verify approval of software products prior to installation.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Configuration Control Board">
  <ns0:data key="d0">Configuration Control Board</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Configuration Control Board approves changes to Blount Island network architecture, server architecture, or software configurations.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Marine Corps Cyber-Security Operations Group">
  <ns0:data key="d0">Marine Corps Cyber-Security Operations Group</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Corps Cyber-Security Operations Group directs overall NetOps/Cyber Network Operations for the Marine Corps Enterprise Network.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="CmdO 4790.2">
  <ns0:data key="d0">CmdO 4790.2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CmdO 4790.2 provides guidance on documenting maintenance actions, including parts requisitions and labor debriefs within GCSS-MC.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Section 11.E">
  <ns0:data key="d0">Section 11.E</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 11.E covers MCMC's network administration services for Blount Island LAN/BAN/WAN, including updates to the Continuity of Operations Plan and IT backup and restoration procedures.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Section 11.F">
  <ns0:data key="d0">Section 11.F</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 11.F requires MCMC to provide recommendations for life cycle management of voice, video, and data systems and prepare Determinations and Findings forms for IT procurement requests.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Section 11.G">
  <ns0:data key="d0">Section 11.G</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 11.G mandates MCMC to provide annual proof of Information Assurance certifications in accordance with NIST SP 800 Series, DoD 8570.01M, DoD 8140, and Enterprise Cyber Security Manual 024.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Section 11.H">
  <ns0:data key="d0">Section 11.H</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 11.H requires MCMC to obtain approval from the Blount Island Command IT Configuration Control Board prior to network or software changes.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Commercial Off-the-Shelf">
  <ns0:data key="d0">Commercial Off-the-Shelf</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Commercial Off-the-Shelf products are hardware and supporting software that MCMC installs, configures, and maintains accountability for in data service delivery.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841131</ns0:data>
</ns0:node>
<ns0:node id="Government Off-the-Shelf">
  <ns0:data key="d0">Government Off-the-Shelf</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Government Off-the-Shelf products are hardware and supporting software that MCMC installs and tracks licenses and installations for.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Security Technical Implementation Guide">
  <ns0:data key="d0">Security Technical Implementation Guide</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Security Technical Implementation Guide includes applicable DISA guidelines and USMC baseline parameters used by MCMC for configuring hardware and software.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="DoD 8570.01M">
  <ns0:data key="d0">DoD 8570.01M</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DoD 8570.01M is a Department of Defense directive referenced for annual Information Assurance certifications provided by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Enterprise Cyber Security Manual 024">
  <ns0:data key="d0">Enterprise Cyber Security Manual 024</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Enterprise Cyber Security Manual 024 provides guidelines for Information Assurance certifications in the Marine Corps context.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Regional Network Operations Support Centers">
  <ns0:data key="d0">Regional Network Operations Support Centers</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Regional Network Operations Support Centers form part of the four regional centers in the Marine Corps Enterprise Network's regionalized strategy.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Marine Air Ground Task Force IT Centers">
  <ns0:data key="d0">Marine Air Ground Task Force IT Centers</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Marine Air Ground Task Force IT Centers are eight sub-regional support entities designed to provide IT services to garrison forces and establishments.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Regional Network Battalions">
  <ns0:data key="d0">Regional Network Battalions</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Regional Network Battalions are responsible for IT transport equipment and services within the Marine Corps Enterprise Network.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="SOW Attachment C.1-2">
  <ns0:data key="d0">SOW Attachment C.1-2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SOW Attachment C.1-2 lists identified Government Furnished Equipment, including Information Technology items.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Cyber Security Manager">
  <ns0:data key="d0">Cyber Security Manager</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Cyber Security Manager approves updates to the Blount Island Continuity of Operations Plan submitted by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="MCMC IS Manager">
  <ns0:data key="d0">MCMC IS Manager</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">MCMC IS Manager is notified by S-6 in the event of an emergency regarding required support.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="Deputy S-6">
  <ns0:data key="d0">Deputy S-6</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Deputy S-6 is authorized to provide verbal overtime approval for emergency or unscheduled support services in response to MCMC.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="S-6 Installation Operations Officer">
  <ns0:data key="d0">S-6 Installation Operations Officer</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">S-6 Installation Operations Officer is authorized to provide verbal overtime approval for emergency or unscheduled support services.</ns0:data>
  <ns0:data key="d3">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841132</ns0:data>
</ns0:node>
<ns0:node id="DoD 4140.27">
  <ns0:data key="d0">DoD 4140.27</ns0:data>
  <ns0:data key="d3">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d2">Shelf Life/Service Life Management Program is executed in accordance with DoD 4140.27 for managing shelf life assets.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841163</ns0:data>
</ns0:node>
<ns0:node id="Receipt and Acceptance">
  <ns0:data key="d0">Receipt and Acceptance</ns0:data>
  <ns0:data key="d3">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d2">Receipt and Acceptance process ensures compliance with DoD FMR for financial accountability of received materiel.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841168</ns0:data>
</ns0:node>
<ns0:node id="Receipt Management">
  <ns0:data key="d0">Receipt Management</ns0:data>
  <ns0:data key="d3">chunk-c2bae9a24e71825050f79fc141b2e181</ns0:data>
  <ns0:data key="d2">Receipt management and processing by MCMC complies with SECNAVINST 4855.3 for physical and virtual receiving.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841170</ns0:data>
</ns0:node>
<ns0:node id="Export Controlled Items">
  <ns0:data key="d0">Export Controlled Items</ns0:data>
  <ns0:data key="d3">chunk-282e59d5d28c9bf1f8c358524d50c08c</ns0:data>
  <ns0:data key="d2">Export Controlled Items subject to ITAR must be marked with specific warnings like “EXPORT CONTROLLED – ITAR RESTRICTED”.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841194</ns0:data>
</ns0:node>
