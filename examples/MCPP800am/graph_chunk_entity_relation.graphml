  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Disputes Clause">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Failure to agree on changes under Clause 52.243-2 constitutes a dispute under the Disputes Clause, but the Contractor must continue performance.</ns0:data>
  <ns0:data key="d8">dispute resolution,performance continuation</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Limitation of Cost Clause">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Limitation of Cost Clause prevents the Contractor from incurring costs beyond the estimated amount without a contract modification.</ns0:data>
  <ns0:data key="d8">cost limitation,performance obligation</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841135</ns0:data>
</ns0:edge>
<ns0:edge source="Contractor" target="Safer Federal Workforce Task Force">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor complies with guidance from the Safer Federal Workforce Task Force for workplace safety protocols.</ns0:data>
  <ns0:data key="d8">compliance,guidance</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
