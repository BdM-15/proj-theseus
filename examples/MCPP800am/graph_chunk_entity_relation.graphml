<ns0:edge source="Department of Defense" target="Small Business Subcontracting Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Department of Defense Subcontracting Goals form the basis for small business goals in the Small Business Subcontracting Plan.</ns0:data>
