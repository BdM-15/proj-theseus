  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Hazardous Material Management requirements, including SDS submission per CDRL 10046 and exposure control plans per CDRL 10047.</ns0:data>
  <ns0:data key="d8">compliance,training</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
