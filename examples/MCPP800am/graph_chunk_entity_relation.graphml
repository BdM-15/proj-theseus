<ns0:edge source="MCMC" target="MDSS-II">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses MDSS-II to log storage locations of portable fire extinguishers separated from parent ME.</ns0:data>
  <ns0:data key="d8">data logging,embarkation</ns0:data>
