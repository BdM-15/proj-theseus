<ns0:edge source="Employee Compensation Plan" target="FAR 52.237-10">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Employee Compensation Plan complies with FAR 52.237-10 by addressing uncompensated overtime and workload analysis.</ns0:data>
