<ns0:edge source="IPACK" target="Scale House">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Scale House provides weight tickets for MPE that MCMC enters into IPACK records to ensure accurate stowed weight data.</ns0:data>
  <ns0:data key="d8">data entry,weighing</ns0:data>
