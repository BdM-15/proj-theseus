  <ns0:data key="d11">1759841181</ns0:data>
</ns0:edge>
<ns0:edge source="Section C.4 Supply" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC maintains accountability and disposes of hardware and IT equipment in accordance with Section C.4 Supply.&lt;SEP&gt;MCMC maintains accountability of hardware and disposes of excess IT equipment in accordance with Section C.4 Supply.</ns0:data>
  <ns0:data key="d8">accountability,accountability compliance,disposition</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-789ddbe0005097425aa3559f9388ad80</ns0:data>
