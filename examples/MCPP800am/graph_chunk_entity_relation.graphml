  <ns0:data key="d11">1759841451</ns0:data>
</ns0:edge>
<ns0:edge source="Section H-8.3" target="Initial Contract Award">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Initial contract award provides the fee ratio used in Section H-8.3 for task orders.</ns0:data>
  <ns0:data key="d8">fee basis,ratio application</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
