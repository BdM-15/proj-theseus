<ns0:edge source="MCMC" target="Section 4.J">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.J assigns fiscal, accounting, reconciliation, and reporting responsibilities to MCMC.</ns0:data>
  <ns0:data key="d8">responsibility assignment</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841460</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 4.K">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.K outlines exemptions and waivers for MCMC regarding property adjustments, small arms, and shelf-life policies.</ns0:data>
  <ns0:data key="d8">exemption,policy adherence</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841460</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section C.5">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section C.5 sets forth MCMC requirements for Class VIII medical material management and support services.</ns0:data>
  <ns0:data key="d8">requirement specification</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Unmatched Transaction Report (UMT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC reconciles the Unmatched Transaction Report (UMT) daily and corrects errors on the same day or notifies the Government.</ns0:data>
  <ns0:data key="d8">error correction,reconciliation</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Budget Execution Validation (BEV)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts monthly validations and takes actions on documents for Budget Execution Validation (BEV) reviews of unliquidated orders.</ns0:data>
  <ns0:data key="d8">corrective action,validation</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="FAMRS Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the FAMRS Report (General Ledger Status of Funds) on a daily basis as part of fiscal requirements.</ns0:data>
  <ns0:data key="d8">frequency,reporting</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Budget Execution Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC includes the Budget Execution Report (SAIF Load Balances) in weekly status reports to track funding.</ns0:data>
  <ns0:data key="d8">balance monitoring,reporting</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841462</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Reimbursable Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the monthly Reimbursable Report (CDRL 5056) detailing general account charges by the 5th of each month.</ns0:data>
  <ns0:data key="d8">detailing,submission</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841462</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Naval Surface Warfare Center Crane Division (NSWC Crane)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC processes small arms transactions but the Government handles reporting and verification with Naval Surface Warfare Center Crane Division (NSWC Crane).</ns0:data>
  <ns0:data key="d8">exemption,reporting delegation</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841463</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DNR Unmatched Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts daily reconciliations of the DNR Unmatched Report and updates error records.</ns0:data>
  <ns0:data key="d8">daily reconciliation</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841464</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DMLSS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes DMLSS for line-item accountability of Class VIII medical materials.</ns0:data>
  <ns0:data key="d8">accountability,utilization</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841464</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCPIC Prepositioning Planning System (PPS)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC references AMAL/ADAL ship spread loads in MCPIC Prepositioning Planning System (PPS) for medical sustainment.</ns0:data>
  <ns0:data key="d8">planning,reference</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841465</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NAVMC 4000.2A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs receiving, accountability, and prepositioning functions in accordance with NAVMC 4000.2A.</ns0:data>
  <ns0:data key="d8">compliance,procedures</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841465</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NAVMED P-5132">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows NAVMED P-5132 for shelf-life items, package integrity, and completing discrepancy reports.</ns0:data>
  <ns0:data key="d8">compliance,discrepancy handling</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841465</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SF-361 Transportation Discrepancy Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC completes the SF-361 Transportation Discrepancy Report for any receiving discrepancies.</ns0:data>
  <ns0:data key="d8">completion,reporting</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="True Attainment Rate (TAR)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC calculates True Attainment Rate (TAR) for each AMAL and ADAL at the end of production using specified formulas.</ns0:data>
  <ns0:data key="d8">calculation,measurement</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Prepositioned Attainment Rate">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC calculates Prepositioned Attainment Rate for prepositioned materiel in AMAL/ADAL capability sets.</ns0:data>
  <ns0:data key="d8">calculation,readiness assessment</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 4000.58">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC follows MCO 4000.58 for minimum shelf life duration on materiel at embarkation, superseding other orders.&lt;SEP&gt;MCMC ensures SL-3 components meet prepositioning shelf life criteria per MCO 4000.58 (Ch 4, par 4.a.) and removes non-compliant material.</ns0:data>
  <ns0:data key="d8">compliance,prepositioning,shelf life criteria,shelf-life guidance</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4&lt;SEP&gt;chunk-13a4841aefad66042f059edb023e607b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841467</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="AMAL/ADAL Spread Load">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the AMAL/ADAL Spread Load (CDRL 5058) to the Government within 30 days after production.</ns0:data>
  <ns0:data key="d8">post-production delivery</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841467</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="AMAL/ADAL Attainment Status Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the AMAL/ADAL Attainment Status Report (CDRL 5059) including attainment rates within 30 days post-production.</ns0:data>
  <ns0:data key="d8">post-production reporting</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841467</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Medical Container Data Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers the Medical Container Data Report (CDRL 5060) within 30 calendar days after production completion.</ns0:data>
  <ns0:data key="d8">post-production submission</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841468</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="AMAL/ADAL Fly-in-Echelon (FIE) Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the AMAL/ADAL Fly-in-Echelon (FIE) Report (CDRL 5061) detailing deferred, short, and short shelf life items post-production.</ns0:data>
  <ns0:data key="d8">post-production detailing</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841468</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Container Asset/Location Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Container Asset/Location Report (CDRL 5063) within 30 days after production.</ns0:data>
  <ns0:data key="d8">post-production reporting</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841468</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Hazardous Material Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides the Hazardous Material Report (CDRL 5064) to the Government within 30 days post-production.</ns0:data>
  <ns0:data key="d8">post-production delivery</ns0:data>
  <ns0:data key="d9">chunk-8a136ea2c9ab7ea9bb718fd0abd010d4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841469</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Program Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers program and risk management support under Program Management as specified in sections C.1, C.2.A, C.2.B, C.2.C, and C.2.D of the Statement of Work.</ns0:data>
  <ns0:data key="d8">risk management,support delivery</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841469</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maintenance Production CONUS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides necessary resources to execute Maintenance Production (CONUS) tasks to established standards per the Statement of Work.</ns0:data>
  <ns0:data key="d8">maintenance execution,resource allocation</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841469</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maintenance Production OCONUS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides necessary resources to execute Maintenance Production (OCONUS) tasks to established standards per the Statement of Work.</ns0:data>
  <ns0:data key="d8">maintenance execution,resource allocation</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841470</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Other Logistics Support">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides contingency, exercise, and emerging requirements support under Other Logistics Support per the Statement of Work.</ns0:data>
  <ns0:data key="d8">contingency support,emerging requirements</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841470</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Data Requirements CDRLs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides data requirements, reports, and submittals under Data Requirements / CDRLs using DD Form 1423-1 as per the Statement of Work.</ns0:data>
  <ns0:data key="d8">data delivery,reporting obligation</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841470</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Base Ordering Period Two">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides services under various CLINs during Base Ordering Period Two.</ns0:data>
  <ns0:data key="d8">period applicability,service timing</ns0:data>
  <ns0:data key="d9">chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841471</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="AGSE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">AGSE is maintained by a separate contractor, with Government monitoring joint use between MCMC and that contractor.</ns0:data>
  <ns0:data key="d8">exclusion of responsibility,joint use</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841471</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="S&amp;RTS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs sustainment and refurbishment after ships are offloaded by S&amp;RTS and before backloading.</ns0:data>
  <ns0:data key="d8">interdependent services,ship handling</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841471</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality Assurance Representative">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The Quality Assurance Representative provides oversight to ensure MCMC compliance with contractual requirements.&lt;SEP&gt;MCMC works with Quality Assurance Representative who provides quality oversight to ensure compliance with contractual requirements.</ns0:data>
  <ns0:data key="d8">compliance,oversight,oversight compliance,quality evaluation</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841472</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Organizational Responsibility">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Organizational Responsibility holds MCMC directly responsible for SOW execution and Government coordination.</ns0:data>
  <ns0:data key="d8">communication lines,execution duty</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841473</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Personnel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Personnel section mandates that MCMC personnel be United States citizens and comply with regulations.</ns0:data>
  <ns0:data key="d8">citizenship compliance,staff requirements</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841474</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Monthly Situation Report (SITREP) (CDRL 6083)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC prepares and submits Monthly Situation Report (SITREP) (CDRL 6083) to Navy COR summarizing logistics and maintenance activities.</ns0:data>
  <ns0:data key="d8">report generation,submission</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841474</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Semi-Annual Startup (SASU) Report (CDRL 6084)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits Semi-Annual Startup (SASU) Report (CDRL 6084) every six months including startup results and battery evaluations.</ns0:data>
  <ns0:data key="d8">periodic submission,report preparation</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
