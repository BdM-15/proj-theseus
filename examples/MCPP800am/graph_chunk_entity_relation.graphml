  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC conducts Preservation, Packaging, and Packing (P3) for storage and shipment needs.</ns0:data>
  <ns0:data key="d8">execution,standards</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
