  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC verifies software products in the Department of the Navy Application Database Management System prior to installation.</ns0:data>
  <ns0:data key="d8">software approval,verification</ns0:data>
