  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="IPACK" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC enters accurate stowed weight data into IPACK for PEIs and containers using Scale House tickets.&lt;SEP&gt;MCMC utilizes IPACK to produce accurate UDLs and manage data for prepositioning ships.</ns0:data>
  <ns0:data key="d8">data entry,data production,system usage,utilization</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
