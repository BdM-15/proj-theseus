<ns0:edge source="Tactical Fuel Systems (TFS)" target="Elastomeric Service Life Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">TFS components are managed under the Elastomeric Service Life Program with specific unused and used condition standards.</ns0:data>
  <ns0:data key="d8">component lifecycle,management</ns0:data>
