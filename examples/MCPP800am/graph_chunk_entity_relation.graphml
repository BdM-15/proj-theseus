  <ns0:data key="d11">1759841305</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Automatic Identification Technology">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC applies Automatic Identification Technology resources to materiel for identification, tracking, and documentation.</ns0:data>
  <ns0:data key="d8">application,tracking</ns0:data>
