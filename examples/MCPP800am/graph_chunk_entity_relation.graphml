  <ns0:data key="d11">1759841515</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="INRMP">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with the INRMP for minimizing interference with wildlife and conducting manatee watch.</ns0:data>
  <ns0:data key="d8">compliance,natural resources</ns0:data>
