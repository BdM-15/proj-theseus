<ns0:edge source="MCMC" target="CBRN Collective Protective System">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC verifies training CBRN filters are installed and packs contingency filters in the CBRN Collective Protective System of prepositioned vehicles prior to FMC status.</ns0:data>
  <ns0:data key="d8">filter management,verification</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
