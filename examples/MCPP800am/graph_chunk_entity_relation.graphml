  <ns0:data key="d0">MPF Ships</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d2">The Navy Small Arms Monthly Inventory Report (CDRL 6082) includes physical inventory of weapons onboard MPF Ships.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841217</ns0:data>
</ns0:node>
<ns0:node id="MPF Maintenance Cycle (MMC)">
  <ns0:data key="d0">MPF Maintenance Cycle (MMC)</ns0:data>
  <ns0:data key="d3">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d2">The Navy Deficiency Report (CDRL 6020) identifies deficiencies for ships in the MPF Maintenance Cycle 130 days prior.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841218</ns0:data>
</ns0:node>
