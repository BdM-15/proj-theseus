  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides CDRL 6078 itemized cost estimates for recurring support tasks within 10 business days of requirement identification.</ns0:data>
  <ns0:data key="d8">estimation,recurring tasks</ns0:data>
