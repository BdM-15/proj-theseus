<ns0:edge source="ISO Freight Containers" target="JCM">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">JCM is used by MCMC as the sole system for managing Marine Corps ISO container inventory.</ns0:data>
  <ns0:data key="d8">data accuracy,inventory management</ns0:data>
