<ns0:node id="Section 6.C.15.a">
  <ns0:data key="d0">Section 6.C.15.a</ns0:data>
  <ns0:data key="d3">chunk-28d6e3bcda588a7e152c62f52269f946</ns0:data>
  <ns0:data key="d2">Section 6.C.15.a governs the monthly submission requirement for the Navy Small Arms Monthly Weapons Inventory Report.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841296</ns0:data>
