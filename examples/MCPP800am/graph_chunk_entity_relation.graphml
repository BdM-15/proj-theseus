  <ns0:data key="d11">1759841291</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Mcmc">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer holds authority over changes directed to Mcmc, with unauthorized changes at Mcmc's risk.</ns0:data>
  <ns0:data key="d8">authority enforcement,risk management</ns0:data>
  <ns0:data key="d9">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841291</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Quality Assurance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer appoints Quality Assurance personnel to assist in inspecting and accepting contractor performance.</ns0:data>
  <ns0:data key="d8">appointment authority,performance inspection</ns0:data>
  <ns0:data key="d9">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
