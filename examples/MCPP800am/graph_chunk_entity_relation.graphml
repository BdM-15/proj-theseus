<ns0:edge source="APSR" target="OH">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">OH quantities are compared to APSR quantities in inventory results to determine differences and variance.</ns0:data>
  <ns0:data key="d8">inventory accuracy,quantity comparison</ns0:data>
