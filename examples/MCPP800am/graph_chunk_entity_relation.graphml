<ns0:edge source="Marine Corps Program Management Team" target="Intermediate Maintenance Activities">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Marine Corps Program Management Team provides overflow maintenance to Intermediate Maintenance Activities to maintain workforce skills.</ns0:data>
  <ns0:data key="d8">overflow support,skill sustainment</ns0:data>
