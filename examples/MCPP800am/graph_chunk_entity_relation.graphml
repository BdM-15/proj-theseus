  <ns0:data key="d11">1759841521</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Personnel Roster">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides the Personnel Roster including titles and numbers for Navy personnel.&lt;SEP&gt;MCMC includes Personnel Roster in the semi-annual PPSP for government review.</ns0:data>
  <ns0:data key="d8">deliverable,deliverable provision,personnel management,planning</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841522</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Program Manager">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes a dedicated Navy Program Manager as key personnel supported by purchasing, financial, 3M data, plans/projects, quality control, and subcontract management.</ns0:data>
  <ns0:data key="d8">establishment,key personnel</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841522</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Operations Support Team (OST)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and maintains a dedicated OST to perform operational tests, troubleshooting, and watercraft support functions.</ns0:data>
  <ns0:data key="d8">establishment,support provision</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841523</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Repair Support Team (RST)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes a dedicated RST to manage and oversee subcontract repair work on Navy lighterage with quality control.</ns0:data>
  <ns0:data key="d8">establishment,oversight</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841523</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maintenance Augment Team (MAT)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes a dedicated MAT to provide scalable surge for corrective maintenance actions.</ns0:data>
  <ns0:data key="d8">establishment,surge capability</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
