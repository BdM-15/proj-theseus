  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.J includes annual Re-Stock Job Order Number/Financial Information Pointer report.</ns0:data>
  <ns0:data key="d8">reporting requirement</ns0:data>
