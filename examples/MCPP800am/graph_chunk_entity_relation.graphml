<ns0:edge source="MCSF-BI" target="Large Quantity Generator">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCSF-BI is designated as a Large Quantity Generator, requiring the MCMC to meet associated regulatory requirements.</ns0:data>
