<ns0:edge source="CAL" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes and updates the CAL to document MPE/S issuance to MAGTF's Responsible Officer during exercises.</ns0:data>
  <ns0:data key="d8">asset management,updates</ns0:data>
  <ns0:data key="d9">chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841263</ns0:data>
</ns0:edge>
<ns0:edge source="CAL" target="NSE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The NSE RO signs the CAL as a sub-custody receipt for temporary loans to MAGTF.</ns0:data>
  <ns0:data key="d8">signature requirement,sub-custody validation</ns0:data>
