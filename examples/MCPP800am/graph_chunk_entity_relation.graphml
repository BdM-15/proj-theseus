<ns0:edge source="System for Award Management" target="Solicitation">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Solicitation may include FAR 52.204-7, affecting how offerors use the System for Award Management for representations.</ns0:data>
  <ns0:data key="d8">inclusion,provision</ns0:data>
