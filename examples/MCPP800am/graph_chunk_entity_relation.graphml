  <ns0:data key="d11">1759841488</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="Option To Extend Services">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Government may exercise the Option to Extend Services by written notice to require continued Contractor performance for up to 6 months.</ns0:data>
  <ns0:data key="d8">exercise,performance extension</ns0:data>
  <ns0:data key="d9">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841488</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="Task Order">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Government issues task orders under the indefinite quantity contract to authorize Contractor delivery or performance.</ns0:data>
  <ns0:data key="d8">issuance,performance authorization</ns0:data>
  <ns0:data key="d9">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841489</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="Ships Planning Considerations Letter">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Government produces the Ship’s Planning Considerations Letter to direct MCMC production plans IAW CmdO 4850.1.</ns0:data>
  <ns0:data key="d8">direction,production</ns0:data>
  <ns0:data key="d9">chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
