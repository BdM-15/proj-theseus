<ns0:edge source="Employee Compensation Plan" target="Cost/Price Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Employee Compensation Plan is reviewed as part of the Cost/Price Factor for realism and compliance with FAR 52.222-46.</ns0:data>
