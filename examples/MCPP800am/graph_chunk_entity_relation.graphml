<ns0:node id="Sustainment Operations">
  <ns0:data key="d0">Sustainment Operations</ns0:data>
  <ns0:data key="d1">strategic_theme</ns0:data>
  <ns0:data key="d2">Sustainment Operations involve logistics support to maintain core MMC operations requirements, including reporting and issue resolution.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841113</ns0:data>
</ns0:node>
<ns0:node id="MMC Operations">
  <ns0:data key="d0">MMC Operations</ns0:data>
  <ns0:data key="d1">strategic_theme</ns0:data>
  <ns0:data key="d2">MMC Operations support materiel management, production, refurbishment, replacement, and restocking of MCPP equipment and materiel.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="AGSE">
  <ns0:data key="d0">AGSE</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">AGSE is Aviation Ground Support Equipment maintained by a separate contractor and not under MCMC responsibility.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Principal End Items">
  <ns0:data key="d0">Principal End Items</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Principal End Items are key equipment items, averaging 700 per ship, including ground tactical military equipment.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="RFID">
  <ns0:data key="d0">RFID</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">RFID is Radio Frequency Identification used for applying tags to equipment for total asset visibility and preservation.&lt;SEP&gt;RFID is Radio Frequency Identification technology using ISO 18000-7 tags applied and associated by MCMC for item tracking in MCPIC.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Fleet Marine Forces">
  <ns0:data key="d0">Fleet Marine Forces</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Fleet Marine Forces are the external customers of MCPP, requiring combat-ready prepositioned materiel.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Contracting Officers Technical Representatives">
  <ns0:data key="d0">Contracting Officers Technical Representatives</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Contracting Officer’s Technical Representatives are designated to assist in specific technical areas of contract monitoring.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="S&amp;RTS">
  <ns0:data key="d0">S&amp;RTS</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">S&amp;RTS is the Stevedoring &amp; Related Terminal Services contract responsible for offloading and backloading ships.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="HADR">
  <ns0:data key="d0">HADR</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">HADR is Humanitarian and Disaster Relief, with assets prepositioned in secured storage locations in the Philippines.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 2907">
  <ns0:data key="d0">NAVMC 2907</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 2907 is a manual referenced for assembling AMAL/ADAL blocks according to the MPF production order and approved schedules.&lt;SEP&gt;NAVMC 2907 contains the Prepositioning Objective for various prepositioning accounts.&lt;SEP&gt;NAVMC 2907 is the publication that establishes the approved inventory list for the Prepositioning Objective in MPF and ashore programs.</ns0:data>
  <ns0:data key="d3">chunk-a9aba44b05f751488f4a50faebf206cb&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Export Administration Regulations">
  <ns0:data key="d0">Export Administration Regulations</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Export Administration Regulations govern compliance for MCMC operations involving exports.&lt;SEP&gt;Export Administration Regulations are requirements that the MCMC must comply with for MCPP-PHIL operations.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="MCPIC iPrime Inspection Web">
  <ns0:data key="d0">MCPIC iPrime Inspection Web</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">MCPIC iPrime Inspection Web is a module of the Enterprise QMSS used for tracking, trending, and tracing performance.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="DESERT STORM">
  <ns0:data key="d0">DESERT STORM</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">DESERT STORM was a historical contingency operation involving deployment and reconstitution of prepositioned materiel.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="IRAQI FREEDOM I">
  <ns0:data key="d0">IRAQI FREEDOM I</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">IRAQI FREEDOM I was a historical operation requiring retrograding and resetting of equipment at Blount Island.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="GCC">
  <ns0:data key="d0">GCC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">GCC refers to Geographic Combatant Commands whose war plans and requirements influence MCPP operations and on-station time.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="MARFOR">
  <ns0:data key="d0">MARFOR</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MARFOR is Marine Forces, aligned with MEF requirements for cost-efficient prepositioning support.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Plans &amp; Data Support Contract">
  <ns0:data key="d0">Plans &amp; Data Support Contract</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Plans &amp; Data Support Contract is a separate government-approved contract that develops the strategic plan for MPS rotations.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Work Requirements">
  <ns0:data key="d0">Work Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Work Requirements categorizes MCMC support into Sustainment Operations and MMC Operations, including reporting protocols.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Program Complexity">
  <ns0:data key="d0">Program Complexity</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Program Complexity describes interdependencies, detail, and scope challenges in the MCPP environment.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Program Operational Goals">
  <ns0:data key="d0">Program Operational Goals</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Program Operational Goals focus on meeting FMF expectations through attainment of Prepositioning Objective and combat readiness.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Organizational Responsibility">
  <ns0:data key="d0">Organizational Responsibility</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Organizational Responsibility outlines MCMC's execution duties and communication lines with Government.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Contract Authority">
  <ns0:data key="d0">Contract Authority</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Contract Authority specifies that MCMC responds only to directives from the Contracting Officer.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Personnel">
  <ns0:data key="d0">Personnel</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Personnel details general requirements for MCMC staff, including citizenship and compliance with regulations.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Offload Preparation Party (OPP)">
  <ns0:data key="d0">Offload Preparation Party (OPP)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Offload Preparation Party (OPP) involves operations for equipment offloads and related support activities.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Navy TAAT OIC">
  <ns0:data key="d0">Navy TAAT OIC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Navy TAAT OIC coordinates changes to CAL and receives notifications for planning deviations.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="USMC COTR">
  <ns0:data key="d0">USMC COTR</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">USMC COTR is assigned for coordination of equipment fueling, defueling, and other operational tasks.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="NAVMC">
  <ns0:data key="d0">NAVMC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVMC manages custody of certain containers and assets like RRDF CCS, EBL, and watercraft.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Monthly Situation Report (SITREP) (CDRL 6083)">
  <ns0:data key="d0">Monthly Situation Report (SITREP) (CDRL 6083)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Monthly Situation Report (SITREP) (CDRL 6083) summarizes logistics services, maintenance, inventories, and issues provided by MCMC to Navy COR.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Semi-Annual Startup (SASU) Report (CDRL 6084)">
  <ns0:data key="d0">Semi-Annual Startup (SASU) Report (CDRL 6084)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Semi-Annual Startup (SASU) Report (CDRL 6084) includes startup results, battery evaluations, plans, and training records submitted upon completion.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Pre-Exercise Status Report (CDRL 6085)">
  <ns0:data key="d0">Pre-Exercise Status Report (CDRL 6085)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Pre-Exercise Status Report (CDRL 6085) covers equipment serviceability, battery conditions, and deficiencies for offload support.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Post Exercise Discrepancy Listing (PEDL) (CDRL 6086)">
  <ns0:data key="d0">Post Exercise Discrepancy Listing (PEDL) (CDRL 6086)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Post Exercise Discrepancy Listing (PEDL) (CDRL 6086) lists equipment damages from offload, exercise, backload, and validation, submitted electronically.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Post Exercise Cost Estimate (CDRL 6087)">
  <ns0:data key="d0">Post Exercise Cost Estimate (CDRL 6087)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Post Exercise Cost Estimate (CDRL 6087) reports total costs for Navy supplies and services in support of exercises.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841114</ns0:data>
</ns0:node>
<ns0:node id="Post Exercise After Action Report (CDRL 6088)">
  <ns0:data key="d0">Post Exercise After Action Report (CDRL 6088)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Post Exercise After Action Report (CDRL 6088) identifies risks, issues, and recommendations from exercise planning and execution.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="120 Day Pre-MMC Report (CDRL 6089)">
  <ns0:data key="d0">120 Day Pre-MMC Report (CDRL 6089)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">120 Day Pre-MMC Report (CDRL 6089) includes maintenance issues, battery lists, and turn-in lists prior to MMC offload.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Unit Deployment Listing (UDL)">
  <ns0:data key="d0">Unit Deployment Listing (UDL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Unit Deployment Listing (UDL) is produced via MCPIC for equipment and supplies embarked on MPS, including NSN-level data.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Navy Plans and Data Management">
  <ns0:data key="d0">Navy Plans and Data Management</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Navy Plans and Data Management requires MCMC to execute and manage squadron and ship-level plans for equipment configuration and stowing.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Navy Exercise and Surge Support">
  <ns0:data key="d0">Navy Exercise and Surge Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy Exercise and Surge Support details MCMC's role in providing personnel, resources, and maintenance for USMC/USN operations using MPE/S.&lt;SEP&gt;Navy Exercise and Surge Support is a section outlining MCMC's responsibilities for providing exercise support using Maritime Prepositioning Equipment and Supplies.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Navy MPS Embarkation/Debarkation Support">
  <ns0:data key="d0">Navy MPS Embarkation/Debarkation Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Navy MPS Embarkation/Debarkation Support outlines MCMC responsibilities for loading and unloading operations on prepositioning ships.&lt;SEP&gt;Navy MPS Embarkation/Debarkation Support is a section detailing MCMC's tasks for downloading, backloading, and staging Navy prepositioned assets.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="NAVFOR RO">
  <ns0:data key="d0">NAVFOR RO</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVFOR RO receives issued MPE/S documented through the Consolidated Asset Listing with coordination via Navy TAAT OIC.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="JLTI">
  <ns0:data key="d0">JLTI</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">JLTI is the Joint Logistics Theater Support process during which equipment records, folders, and keys are accounted for prior to MPS backload.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Navy Prepositioned Weapons">
  <ns0:data key="d0">Navy Prepositioned Weapons</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Navy Prepositioned Weapons are issued, recovered, and documented by MCMC in accordance with the approved Resource Plan and associated requirements.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="ABLTS Hose Reels">
  <ns0:data key="d0">ABLTS Hose Reels</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">ABLTS Hose Reels are embarked Navy watercraft assets maintained under NAVMC custody with custodial transfers to NBG Ship’s Debarkation Officer or Navy TAAT member.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="LARC-V">
  <ns0:data key="d0">LARC-V</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">LARC-Vs are lighter amphibious resupply cargo vehicles that are embarked Navy watercraft under NAVMC custody requiring custodial transfers.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="ACOR">
  <ns0:data key="d0">ACOR</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">ACOR is the Assistant Contracting Officer Representative who receives shipboard reports and deliverables from MCMC alongside Navy COR.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="MCPP II SOW">
  <ns0:data key="d0">MCPP II SOW</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">MCPP II SOW is the Statement of Work governing the execution and management of detailed plans for Maritime Prepositioning Ships.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Navy Plans and Data POC">
  <ns0:data key="d0">Navy Plans and Data POC</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Navy Plans and Data POC is appointed by NSC to execute and manage all squadron and ship level detailed plans in accordance with MCPP II SOW.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Dangerous Cargo Manifest (DCM)">
  <ns0:data key="d0">Dangerous Cargo Manifest (DCM)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Dangerous Cargo Manifest (DCM) is generated in ICODES using specific data elements like NSN, UN CODE, and IMO CODE for hazardous Navy MPE/S.</ns0:data>
  <ns0:data key="d3">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="52.204-21 Basic Safeguarding Of Covered Contractor Information Systems">
  <ns0:data key="d0">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-21 Basic Safeguarding Of Covered Contractor Information Systems is a FAR clause dated November 2021 that defines key terms and requires contractors to implement basic security controls to protect covered contractor information systems handling federal contract information.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Covered Contractor Information System">
  <ns0:data key="d0">Covered Contractor Information System</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Covered Contractor Information System is an information system owned or operated by a contractor that processes, stores, or transmits federal contract information.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Federal Contract Information">
  <ns0:data key="d0">Federal Contract Information</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Federal Contract Information is information not intended for public release that is provided by or generated for the government under a contract to develop or deliver a product or service to the government, excluding public or transactional information.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Information System">
  <ns0:data key="d0">Information System</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Information System is a discrete set of information resources organized for the collection, processing, maintenance, use, sharing, dissemination, or disposition of information as defined under 44 U.S.C. 3502.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Safeguarding">
  <ns0:data key="d0">Safeguarding</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Safeguarding is measures or controls prescribed to protect information systems from unauthorized access or compromise.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="52.211-11 Liquidated Damages Supplies Services Or Research And Development">
  <ns0:data key="d0">52.211-11 Liquidated Damages Supplies Services Or Research And Development</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.211-11 Liquidated Damages Supplies Services Or Research And Development is a FAR clause dated September 2000 that establishes liquidated damages for delays in delivery or performance, including specific daily amounts for ship classes and reinspections of nonconforming services.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Bobo Class Ship">
  <ns0:data key="d0">Bobo Class Ship</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Bobo Class Ship is a ship class subject to $46,000 per calendar day liquidated damages for delays in ship departure under the contract.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="Lmsr Class Ship">
  <ns0:data key="d0">Lmsr Class Ship</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">Lmsr Class Ship is a ship class subject to $84,000 per calendar day liquidated damages for delays in ship departure under the contract.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841115</ns0:data>
</ns0:node>
<ns0:node id="52.215-19 Notification Of Ownership Changes">
  <ns0:data key="d0">52.215-19 Notification Of Ownership Changes</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
