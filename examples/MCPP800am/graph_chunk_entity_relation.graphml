<ns0:edge source="MCMC" target="Navy Watercraft Master Schedule">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC creates baseline production plans and maintains the Navy Watercraft Master Schedule on a continuous rolling three-year basis.</ns0:data>
