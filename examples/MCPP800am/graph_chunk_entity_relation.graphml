</ns0:edge>
<ns0:edge source="MCMC" target="Universal Waste Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages universal wastes including batteries, lamps, mercury equipment, and pesticides per 40 CFR 273.</ns0:data>
  <ns0:data key="d8">waste handling</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
