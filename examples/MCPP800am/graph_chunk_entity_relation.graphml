</ns0:edge>
<ns0:edge source="Subcontract" target="Consent to Subcontract">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Consent to subcontract requires the Contracting Officer's written approval for specified subcontract types and values under Clause 52.244-2.</ns0:data>
  <ns0:data key="d8">approval process,regulatory compliance</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
