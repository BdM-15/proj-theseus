  <ns0:data key="d11">1759841447</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="EPA">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with EPA regulations such as 40 CFR 64 for air resources, 40 CFR 112 for POL storage, and 40 CFR 260-370 for hazardous waste.&lt;SEP&gt;MCMC adheres to EPA regulations for environmental and radioactive waste management.</ns0:data>
  <ns0:data key="d8">environmental,regulatory compliance</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
