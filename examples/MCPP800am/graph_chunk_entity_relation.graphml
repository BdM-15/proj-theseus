  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Medium Crawler Tractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC installs retrieval hitch onto each Medium Crawler Tractor equipped with ripper attachment in accordance with MI 11569A-23/1.</ns0:data>
  <ns0:data key="d8">hitch installation,production compliance</ns0:data>
