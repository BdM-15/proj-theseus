  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841296</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MAM">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC accurately updates GCSS-MC based on Maintenance Advisory Messages.</ns0:data>
  <ns0:data key="d8">advisory messaging,update requirement</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841296</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO P5100.34">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC updates GCSS-MC in accordance with MCO P5100.34 for SOUM, MAM, and supply advisories.</ns0:data>
  <ns0:data key="d8">compliance,system maintenance</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841296</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CDRL 1005">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits the Internal Inspection Schedule (CDRL 1005) to the Government for approval and annual updates.</ns0:data>
  <ns0:data key="d8">inspection scheduling,submission</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841297</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CDRL 1006">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC provides Internal Inspection Results (CDRL 1006) NLT 10 business days after each inspection.</ns0:data>
  <ns0:data key="d8">inspection outcomes,reporting</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841297</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CDRL 1007">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits the Plan of Corrective Action (CDRL 1007) NLT 21 business days after inspections to correct identified discrepancies.</ns0:data>
  <ns0:data key="d8">corrective action,discrepancy resolution</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841297</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 4790.25">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs corrective maintenance and special actions in accordance with MCO 4790.25 for Field Level of Maintenance and Mission Capable status.&lt;SEP&gt;The MCMC performs only authorized maintenance tasks based on capabilities as per MCO 4790.25.</ns0:data>
  <ns0:data key="d8">capability limits,compliance,maintenance level,task authorization</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841298</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CLS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to procedures for Contracted Logistics Support items requiring service per MCO 4105.2A and related orders.</ns0:data>
  <ns0:data key="d8">logistics support,service procedures</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841298</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC organizes repair parts in layette sub-inventories designated for specific Service Requests.</ns0:data>
  <ns0:data key="d8">inventory tracking,parts organization</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841298</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SDR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses the Supply Discrepancy Report process to document and correct issues with received parts.</ns0:data>
  <ns0:data key="d8">discrepancy reporting,supply correction</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841299</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="On-Island">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC establishes and maintains DSI inventories at On-Island locations using GCSS-MC Planner's Desktop.</ns0:data>
  <ns0:data key="d8">inventory establishment,location management</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841299</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Shipboard">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC manages Shipboard DSI inventories timed to ship production cycles or Detailed Ship Plans provision.</ns0:data>
  <ns0:data key="d8">inventory timing,production alignment</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841300</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Detailed Ship Plans">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">MCMC uses Detailed Ship Plans provided by the Government to prepare attainment deficiency reports and sustainment blocks for ship production.&lt;SEP&gt;The MCMC uses Detailed Ship Plans for ship allowance quantities and production timelines.&lt;SEP&gt;The MCMC uses Detailed Ship Plans to determine submission dates for Shipboard DSI Authorization Letters.</ns0:data>
  <ns0:data key="d8">compliance,planning,planning guidance,submission basis,timing reference</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b&lt;SEP&gt;chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841300</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 4400.150">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC accounts for Government-owned Garrison Fabricated Tools in DPAS per MCO 4400.150.</ns0:data>
  <ns0:data key="d8">accountability compliance,tool tracking</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841300</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fielding Plans">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC places newly fielded equipment into service according to Fielding Plans and related publications.</ns0:data>
  <ns0:data key="d8">equipment integration,service entry</ns0:data>
  <ns0:data key="d9">chunk-89b1a9fa6c0722adcd478e665df09141</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841301</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="ISSA">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes ISSA for government-furnished services like food, lodging, and personal services for employees aboard MPS.</ns0:data>
  <ns0:data key="d8">service provision,support agreement</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841301</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CBRN Filters">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC packs unused contingency CBRN filters and verifies training filters are installed in vehicle collective protective systems.&lt;SEP&gt;MCMC manages installation, replacement, and briefing of CBRN filters on prepositioned assets without removal unless directed.</ns0:data>
  <ns0:data key="d8">maintenance,packing,replacement procedures,verification</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841302</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MSC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates MHE support with MSC staff for warehousing operations aboard T-AKE ships.&lt;SEP&gt;MCMC submits MSC SAAR-N to MSC for shipboard network access and utilizes ISSA services coordinated with MSC.</ns0:data>
  <ns0:data key="d8">MHE support,equipment coordination,network access,service agreement</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841302</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="TAAT">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates CAL changes and delivers draft PEDL to TAAT OIC for exercise and prepositioning support.</ns0:data>
  <ns0:data key="d8">coordination,reporting</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841303</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CMS-1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows CMS-1 directives for KMI administrative requirements, inventories, and incident reporting.</ns0:data>
  <ns0:data key="d8">compliance,procedural guidance</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841303</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 2281.1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to MCO 2281.1 for appointing personnel, access lists, and conducting local element operations.</ns0:data>
  <ns0:data key="d8">access management,compliance</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841303</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="COSIS Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC develops and executes the COSIS Plan covering a full fiscal year with monthly updates on materiel inspections.</ns0:data>
  <ns0:data key="d8">planning,reporting</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
