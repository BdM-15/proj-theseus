<ns0:edge source="MCSF-BI" target="MCO 5090.2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCSF-BI requires MCMC to comply with MCO 5090.2 for dealing with military munitions waste.</ns0:data>
  <ns0:data key="d8">compliance,munitions handling</ns0:data>
