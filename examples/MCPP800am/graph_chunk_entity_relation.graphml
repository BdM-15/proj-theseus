</ns0:edge>
<ns0:edge source="Clause 252.203-7004 Display of Hotline Posters" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor prominently displays DoD and, if applicable, DHS hotline posters in work areas performing under the contract as required by Clause 252.203-7004.</ns0:data>
  <ns0:data key="d8">compliance,poster display</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
