<ns0:edge source="Marine Corps Program Management Team" target="Depots">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Marine Corps Program Management Team allocates additional maintenance to depots during reduced logistics periods at Blount Island.</ns0:data>
  <ns0:data key="d8">contingencies,support allocation</ns0:data>
