  <ns0:data key="d11">1759841226</ns0:data>
</ns0:edge>
<ns0:edge source="DA Form 2404" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC retains DA Form 2404 for container inspections until lease return or the next completed inspection.</ns0:data>
