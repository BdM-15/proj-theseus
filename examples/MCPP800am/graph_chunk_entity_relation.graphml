  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC shall replace THHR HUBs that do not charge to a minimum of 3.5 VDC and store them in SAPS battery chargers.</ns0:data>
  <ns0:data key="d8">maintenance,replacement</ns0:data>
