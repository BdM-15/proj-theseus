</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contracting Lines of Authority">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Lines of Authority outlines the role and warrant authority of the Contracting Officer in contract administration.</ns0:data>
  <ns0:data key="d8">authority structure,roles</ns0:data>
