  <ns0:data key="d11">1759841364</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="L-3 Pre-Award Survey of Prospective Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Government may conduct a pre-award survey through L-3 to assess contractor capabilities in technical, production, and financial areas.</ns0:data>
  <ns0:data key="d8">capability assessment,evaluation process</ns0:data>
  <ns0:data key="d9">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841383</ns0:data>
</ns0:edge>
<ns0:edge source="Government" target="Request for Proposal M67004-25-R-0007">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Government issues and evaluates proposals under Request for Proposal M67004-25-R-0007, assuming no prior knowledge of offeror experience.</ns0:data>
  <ns0:data key="d8">evaluation basis,solicitation authority</ns0:data>
  <ns0:data key="d9">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
