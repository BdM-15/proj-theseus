  <ns0:data key="d7">MCMC personnel are subject to Base Commander rules in host nations regarding operations, safety, and discipline.</ns0:data>
  <ns0:data key="d8">regulatory compliance</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841532</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Government Furnished Equipment">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC conducts PMCS on Government Furnished Equipment in accordance with technical manuals and PMCS Roster.&lt;SEP&gt;MCMC requires Government approval prior to utilizing peripherals associated with Government Furnished Equipment.</ns0:data>
  <ns0:data key="d8">PMCS execution,approval,asset maintenance,utilization</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
