  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures fire watch training and designated areas comply with NFPA 51B for hot work activities.</ns0:data>
  <ns0:data key="d8">fire prevention,hot work standards</ns0:data>
