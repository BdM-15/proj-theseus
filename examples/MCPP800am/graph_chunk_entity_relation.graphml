  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers CDRL 6079 Statements of Work for government-identified maintenance on organic lighterage within 10 business days.</ns0:data>
  <ns0:data key="d8">organic lighterage,sow provision</ns0:data>
