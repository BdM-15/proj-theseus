<ns0:edge source="CDRL 6080" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits CDRL 6080 itemized cost estimates for organic equipment repairs supporting Navy missions within 10 business days.</ns0:data>
  <ns0:data key="d8">estimation,organic repairs</ns0:data>
