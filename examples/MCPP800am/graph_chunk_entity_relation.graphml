  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841244</ns0:data>
</ns0:edge>
<ns0:edge source="SECREPs" target="Global CAL">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Global CAL is reviewed by MCMC to highlight enterprise excesses for lateral support of SECREP deficiencies in MMFAU1.</ns0:data>
