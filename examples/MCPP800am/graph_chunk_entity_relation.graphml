  <ns0:data key="d11">1759841223</ns0:data>
</ns0:edge>
<ns0:edge source="MIL-STD-2073-1E" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC applies MIL-STD-2073-1E standards in preservation and packing.&lt;SEP&gt;MCMC performs level A packing for specified gear in accordance with MIL-STD-2073-1E.</ns0:data>
  <ns0:data key="d8">compliance,packaging</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841223</ns0:data>
</ns0:edge>
<ns0:edge source="NAVSUP P-700" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC performs Level A packing according to NAVSUP P-700-CNP.</ns0:data>
  <ns0:data key="d8">compliance,naval packaging</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841224</ns0:data>
</ns0:edge>
<ns0:edge source="Other Direct Cost (ODC)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses Other Direct Cost (ODC) funding as authorized for supply chain emergencies.</ns0:data>
  <ns0:data key="d8">emergencies,funding</ns0:data>
