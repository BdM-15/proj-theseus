  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="System for Award Management" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor uses the System for Award Management for active registration and electronic submission of representations and certifications.</ns0:data>
  <ns0:data key="d8">compliance,registration</ns0:data>
  <ns0:data key="d9">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841171</ns0:data>
