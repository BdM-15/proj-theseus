<ns0:edge source="Department of Defense" target="Volume VII Small Business Participation and Subcontracting Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Volume VII Small Business Participation and Subcontracting Plan aligns with Department of Defense subcontracting goals and regulations.</ns0:data>
