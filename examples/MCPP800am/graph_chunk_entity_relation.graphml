<ns0:edge source="NSC" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC integrates with NSC for supply, maintenance, shipping, and production activities.&lt;SEP&gt;NSC coordinates with MCMC for accomplishing required maintenance on containerized CESE and equipment.</ns0:data>
  <ns0:data key="d8">coordination,integration,maintenance,support</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
