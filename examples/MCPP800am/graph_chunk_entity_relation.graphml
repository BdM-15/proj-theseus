<ns0:edge source="MEP-831A" target="4HN Series Battery">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MEP-831A generators require installation of 4HN Series Battery in lieu of Concorde RG-24 battery.</ns0:data>
  <ns0:data key="d8">installation requirement,substitution</ns0:data>
