<ns0:edge source="CAL" target="Section 4.C.4.c">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 4.C.4.c uses CAL for issuing prepositioning ME on temporary loan basis to MAGTF.</ns0:data>
  <ns0:data key="d8">exercise issuance,temporary loan</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
