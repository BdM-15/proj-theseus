<ns0:edge source="WHE" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides certified personnel and oversight for WHE operations and maintenance.&lt;SEP&gt;MCMC includes complete and accurate WHE inventory in the monthly Crane Metrics Report CDRL 6071.</ns0:data>
  <ns0:data key="d8">certification,inventory,metrics reporting,operations management</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78&lt;SEP&gt;chunk-4ef5ed78269155f4369ff9bd9b69ddc8</ns0:data>
