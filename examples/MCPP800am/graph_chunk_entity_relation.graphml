<ns0:edge source="Clause 252.204-7007 Alternate A, Annual Representations and Certifications" target="System for Award Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Clause 252.204-7007 allows Offerors with active System for Award Management registration to use its representations instead of completing individual ones in the solicitation.</ns0:data>
  <ns0:data key="d8">representation submission,solicitation applicability</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
