<ns0:edge source="DoD FMR" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC adheres to DoD FMR for accurate accounting of funds in DoD supply systems.</ns0:data>
  <ns0:data key="d8">accounting,compliance</ns0:data>
