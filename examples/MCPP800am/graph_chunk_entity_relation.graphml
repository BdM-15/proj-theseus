  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Navy End of Ship Class II, III, IV, VII, and IX Attainment Percentage Reports five business days after production completion.</ns0:data>
  <ns0:data key="d8">attainment tracking,reporting</ns0:data>
  <ns0:data key="d9">chunk-5edf02307c6ad1788f6967955fbea6ff</ns0:data>
