  <ns0:data key="d11">1759841451</ns0:data>
</ns0:edge>
<ns0:edge source="Sustainment Operations" target="MMC Operations">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Sustainment Operations provide the stable base needed to facilitate core MMC Operations requirements.</ns0:data>
  <ns0:data key="d8">logistics base,support integration</ns0:data>
  <ns0:data key="d9">chunk-93752a7bd8aca85ef0ce5fea3701dc32</ns0:data>
