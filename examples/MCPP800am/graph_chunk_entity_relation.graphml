<ns0:edge source="IDIQ Contract" target="Section A">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section A describes the IDIQ Contract type and outlines the Base and Option Ordering Periods.</ns0:data>
  <ns0:data key="d8">description,periods</ns0:data>
