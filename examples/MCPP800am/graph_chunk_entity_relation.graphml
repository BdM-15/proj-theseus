  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Load Lifting Certification for Marine Corps equipment adheres to procedures in MCO 11262.2.</ns0:data>
  <ns0:data key="d8">certification,procedure adherence</ns0:data>
