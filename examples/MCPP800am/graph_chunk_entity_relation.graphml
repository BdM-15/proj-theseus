<ns0:edge source="MCMC" target="Fibrous and Wire Rope Service Life Data Sheet">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Fibrous and Wire Rope Service Life Data Sheet (CDRL 6046) for rope and rigging maintenance.</ns0:data>
