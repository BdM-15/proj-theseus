<ns0:edge source="Contracting Officer" target="Quality Assurance Representatives">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer notifies MCMC in writing of the names, duties, and limitations of Quality Assurance Representatives.</ns0:data>
  <ns0:data key="d8">appointment,notification</ns0:data>
