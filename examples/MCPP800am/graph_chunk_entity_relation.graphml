  <ns0:data key="d11">1759841512</ns0:data>
</ns0:edge>
<ns0:edge source="Request for Proposal (RFP)" target="Past Performance Evaluation Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Past Performance Evaluation Factor is defined and applied as described in the Request for Proposal (RFP).</ns0:data>
  <ns0:data key="d8">evaluation criteria,solicitation alignment</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841512</ns0:data>
</ns0:edge>
<ns0:edge source="Request for Proposal (RFP)" target="Small Business Participation and Subcontracting Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Small Business Participation and Subcontracting Factor evaluates compliance with small business objectives in the Request for Proposal (RFP).</ns0:data>
  <ns0:data key="d8">objective alignment,participation assessment</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841512</ns0:data>
</ns0:edge>
<ns0:edge source="Oral Presentations" target="Past Performance Evaluation Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Oral Presentations contribute to the assessment of the Past Performance Evaluation Factor, particularly regarding proposed efficiencies for MCPP requirements.</ns0:data>
  <ns0:data key="d8">assessment method,efficiency review</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="MCPP Requirements" target="Past Performance Evaluation Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Past Performance Evaluation Factor evaluates how well past performance aligns with MCPP Requirements, including management and technical proficiency.</ns0:data>
  <ns0:data key="d8">relevancy assessment,requirement alignment</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="MCPP Requirements" target="Cost/Price Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Cost/Price Factor assesses realism and reasonableness relative to the understanding of MCPP Requirements.</ns0:data>
  <ns0:data key="d8">cost realism,work understanding</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="Past Performance Evaluation Factor" target="Past Performance Relevancy Ratings">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Past Performance Relevancy Ratings are used within the Past Performance Evaluation Factor to determine the influence on confidence assessments.</ns0:data>
  <ns0:data key="d8">confidence influence,rating subcategory</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="Past Performance Evaluation Factor" target="Past Performance Confidence Assessments">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Past Performance Confidence Assessments provide the adjectival ratings for the Past Performance Evaluation Factor based on recent/relevant records.</ns0:data>
  <ns0:data key="d8">performance prediction,rating mechanism</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841514</ns0:data>
</ns0:edge>
<ns0:edge source="Past Performance Evaluation Factor" target="Small Business Participation and Subcontracting Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Past Performance Evaluation Factor includes evaluation of the offeror's past performance in meeting subcontracting goals, linking to the Small Business Participation and Subcontracting Factor.</ns0:data>
  <ns0:data key="d8">integrated assessment,subcontracting goals</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841514</ns0:data>
</ns0:edge>
<ns0:edge source="Past Performance Evaluation Factor" target="Contractor Performance Assessment Reviews (CPARs)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contractor Performance Assessment Reviews (CPARs) serve as a discretionary source for the Government to evaluate the Past Performance Evaluation Factor.</ns0:data>
  <ns0:data key="d8">information source,performance validation</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="Past Performance Evaluation Factor" target="Past Performance Questionnaires">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Past Performance Questionnaires are utilized by the Government to obtain information contributing to the Past Performance Evaluation Factor.</ns0:data>
  <ns0:data key="d8">data collection,relevancy assessment</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="Cost/Price Factor" target="CLINs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Cost/Price Factor involves analyzing proposed costs and prices for all CLINs, including firm-fixed-price and cost-type items, for reasonableness and realism.</ns0:data>
  <ns0:data key="d8">item evaluation,price analysis</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841515</ns0:data>
</ns0:edge>
<ns0:edge source="Cost/Price Factor" target="Optional Order Period">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">CLINs associated with the Optional Order Period are included in the Cost/Price Factor evaluation without committing the Government to exercise them.</ns0:data>
  <ns0:data key="d8">non-obligation,option assessment</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841516</ns0:data>
</ns0:edge>
<ns0:edge source="Small Business Participation and Subcontracting Factor" target="FAR 52.219-8 Utilization of Small Business Concerns">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">FAR 52.219-8 Utilization of Small Business Concerns is considered in the Small Business Participation and Subcontracting Factor for all offerors.</ns0:data>
  <ns0:data key="d8">compliance requirement,utilization evaluation</ns0:data>
  <ns0:data key="d9">chunk-3478ab61c9462db63588376af8a45cd2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841513</ns0:data>
