</ns0:edge>
<ns0:edge source="MCMC" target="Common Access Card">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures personnel obtain and maintain Common Access Cards for network access based on favorable security investigations.</ns0:data>
  <ns0:data key="d8">access requirement,security</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
