  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">APP is prepared in accordance with 29 CFR 1910, incorporating site-specific safety elements.</ns0:data>
  <ns0:data key="d8">regulatory compliance,safety standards</ns0:data>
