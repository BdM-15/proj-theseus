<ns0:edge source="MCMC" target="Electronics End-of-Life Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC recycles or disposes of electronics waste in accordance with 40 CFR 260-262 and installation instructions.</ns0:data>
  <ns0:data key="d8">waste disposal</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
