<ns0:edge source="Elastomeric Service Life Program" target="Elastomeric Components">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Elastomeric Service Life Program applies standards to Elastomeric Components in TFS, requiring replacement if expired.</ns0:data>
  <ns0:data key="d8">replacement,standard application</ns0:data>
