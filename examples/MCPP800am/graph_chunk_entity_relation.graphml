<ns0:edge source="COSIS" target="PMCS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">PMCS is performed as follow-on corrective action in COSIS to restore assets to ready-for-issue condition.</ns0:data>
