<ns0:node id="Administrative Proceeding">
  <ns0:data key="d0">Administrative Proceeding</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Administrative Proceeding is a non-judicial adjudicatory process to determine fault or liability, including those at federal or state levels related to federal contracts or grants, excluding audits, site visits, or inspections.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
