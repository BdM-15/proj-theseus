<ns0:edge source="NAVFAC-P-300" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes redistribution and disposal of excess Navy materiel in accordance with NAVFAC-P-300, completing forms like DD 1348-1 and DD 1149.</ns0:data>
  <ns0:data key="d8">compliance,disposal procedures</ns0:data>
