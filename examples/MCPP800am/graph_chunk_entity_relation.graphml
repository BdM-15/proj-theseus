</ns0:edge>
<ns0:edge source="MCMC" target="5 CFR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with 5 CFR for applicable federal contractor requirements.</ns0:data>
  <ns0:data key="d8">compliance,federal regulations</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
