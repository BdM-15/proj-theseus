  <ns0:data key="d11">1759841384</ns0:data>
</ns0:edge>
<ns0:edge source="MCPP" target="Production Planning and Control">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Production Planning and Control supports MCPP mission accomplishment through scheduling, forecasting, and performance analysis.</ns0:data>
  <ns0:data key="d8">mission support,planning strategy</ns0:data>
