  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841455</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contracting Officers Technical Representatives">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer’s Technical Representatives are designated by the Contracting Officer for specific technical areas.</ns0:data>
  <ns0:data key="d8">support,technical designation</ns0:data>
