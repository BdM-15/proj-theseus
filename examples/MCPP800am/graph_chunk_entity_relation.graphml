  <ns0:data key="d11">1759841256</ns0:data>
</ns0:edge>
<ns0:edge source="MAGTF" target="MCMC">
  <ns0:data key="d6">3.0</ns0:data>
  <ns0:data key="d7">The MCMC issues equipment to MAGTF on temporary loan basis using CAL for exercises and contingencies.&lt;SEP&gt;MCMC issues MPE/S to MAGTF Responsible Officer using CAL during exercises and operations.&lt;SEP&gt;MCMC issues MPE/S to MAGTF's Responsible Officer and provides equipment records during exercises.</ns0:data>
