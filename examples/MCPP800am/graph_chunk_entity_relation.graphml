<ns0:edge source="PGP Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits PGP Report monthly detailing personnel aboard ships to COR and ship captains.</ns0:data>
