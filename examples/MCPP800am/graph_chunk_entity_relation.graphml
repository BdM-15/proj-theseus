  <ns0:data key="d11">1759841349</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="BICmd Temporary Weapons Facility">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC stores weapons in the BICmd Temporary Weapons Facility during periods when direct shipment to LOGCOM is not possible.</ns0:data>
  <ns0:data key="d8">storage management,weapon security</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
