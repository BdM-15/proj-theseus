  <ns0:data key="d11">1759841415</ns0:data>
</ns0:edge>
<ns0:edge source="IDIQ Contract" target="Minimum Guarantee">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The IDIQ Contract obligates a minimum guarantee amount of $10,000.00 solely for the base year.</ns0:data>
  <ns0:data key="d8">funding obligation</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
