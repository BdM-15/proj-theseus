  <ns0:data key="d11">1759841327</ns0:data>
</ns0:edge>
<ns0:edge source="WHE" target="Facility-Mounted Weight Handling Equipment (WHE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Facility-Mounted Weight Handling Equipment (WHE) is maintained through a dedicated PM program to ensure proper operation and minimize breakdowns.</ns0:data>
  <ns0:data key="d8">PM focus,program implementation</ns0:data>
  <ns0:data key="d9">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841356</ns0:data>
</ns0:edge>
<ns0:edge source="MMCT" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to 30-day MMCT for GSE maintenance and submits extension requests as needed.&lt;SEP&gt;MCMC is prohibited from intentionally postponing or delaying maintenance actions or closing work orders to circumvent MMCT.</ns0:data>
  <ns0:data key="d8">adherence,extension,maintenance compliance,prohibition</ns0:data>
  <ns0:data key="d9">chunk-93c4a54422e967728929a60f73e593e2&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841160</ns0:data>
</ns0:edge>
<ns0:edge source="TEU" target="Container Estimate Worksheet">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Container Estimate Worksheet tracks container numbers and alerts to TEU capacity limits for ships.</ns0:data>
  <ns0:data key="d8">capacity management,monitoring</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841228</ns0:data>
</ns0:edge>
<ns0:edge source="COSIS" target="MCMC">
  <ns0:data key="d6">7.0</ns0:data>
  <ns0:data key="d7">MCMC performs COSIS on ME and CESE in open storage and on PO assets for MCPP-PHIL to ensure functionality.&lt;SEP&gt;The MCMC establishes and maintains a COSIS program for inspections and corrective actions on stored materiel.&lt;SEP&gt;The MCMC includes COSIS in baseline production plans and schedules for MCPP activities as directed by P-PET letters.&lt;SEP&gt;MCMC provides COSIS for prepositioned materiel while ships are forward deployed.&lt;SEP&gt;MCMC performs COSIS actions, including filter replacements, on Navy equipment.&lt;SEP&gt;MCMC performs COSIS on Class II and VII CESE assets in open storage per CmdO 4450.1.&lt;SEP&gt;MCMC includes COSIS in production plans and schedules for MCPP II maintenance requirements.</ns0:data>
  <ns0:data key="d8">cece inspection,condition assessment,custody maintenance,forward deployment,inclusion,inspection,maintenance,materiel preservation,performance,planning,planning inclusion,storage care,storage maintenance,surveillance program</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5&lt;SEP&gt;chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-67bad1bd73dd9a9a7549acb855ae5e55&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-5edf02307c6ad1788f6967955fbea6ff&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9&lt;SEP&gt;chunk-f808346dbf233cd47e4c673a7cf87022</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841269</ns0:data>
</ns0:edge>
<ns0:edge source="COSIS" target="MCO 4450.14">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 4450.14 outlines requirements for COSIS surveillance and care of supplies in storage.</ns0:data>
  <ns0:data key="d8">guidance provision,storage care</ns0:data>
  <ns0:data key="d9">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841269</ns0:data>
