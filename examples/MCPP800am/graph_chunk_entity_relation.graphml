  <ns0:data key="d11">1759841505</ns0:data>
</ns0:edge>
<ns0:edge source="GSE" target="MPF">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy GSE supports the MPF mission and requirements.</ns0:data>
  <ns0:data key="d8">mission,support</ns0:data>
