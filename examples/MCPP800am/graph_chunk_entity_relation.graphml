  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841418</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Notice of Completion (CDRL 6055) (NOC) (SOW Attachment C.6-038)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits Notice of Completion (CDRL 6055) (NOC) (SOW Attachment C.6-038) after successful integration testing.</ns0:data>
  <ns0:data key="d8">reporting,testing completion</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Craft Condition Found Report (CDRL 6048) (CFR) (SOW Attachment C.6-048)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits Craft Condition Found Report (CDRL 6048) (CFR) (SOW Attachment C.6-048) for configuration discrepancies.</ns0:data>
  <ns0:data key="d8">non-conformance documentation</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Exemptions, Deviations and Waivers">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to exemptions and waivers such as tailored 3M Inactive Equipment Maintenance and waived Compass Swing requirements.</ns0:data>
  <ns0:data key="d8">compliance tailoring</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Shipboard Support">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">#&gt;|MCMC performs surveillance, inventory management, PMCS, and corrective maintenance under Navy Shipboard Support during afloat phase.</ns0:data>
  <ns0:data key="d8">logistics services,surveillance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841419</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages physical inventory, performs PMCS, and conducts corrective maintenance on MPE/S during afloat phase.</ns0:data>
  <ns0:data key="d8">inventory management,maintenance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841420</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Small Arms Monthly Inventory Report (CDRL 6082) (SOW Attachment C.6-010)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits Navy Small Arms Monthly Inventory Report (CDRL 6082) (SOW Attachment C.6-010) for weapons onboard MPF Ships.</ns0:data>
  <ns0:data key="d8">inventory reporting</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841420</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MPS Exercises and Contingencies">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs tasks outlined in MPS Exercises and Contingencies, including providing Resource and Support Plan and logistics services.&lt;SEP&gt;MCMC provides resource plans and logistics services for offloads, backloads, and asset management during MPS Exercises and Contingencies.</ns0:data>
  <ns0:data key="d8">logistics execution,operational support,planning,support planning</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841420</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="3M Inactive Equipment Maintenance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to tailored 3M Inactive Equipment Maintenance requirements via the NAV-P MRP process for inactive equipment lay-up.</ns0:data>
  <ns0:data key="d8">requirement tailoring,waiver adherence</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841421</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Compass Swing">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC applies the waiver for Compass Swing semi-annual Force Revision requirements as specified for the MCPP II program.</ns0:data>
  <ns0:data key="d8">waiver application</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841421</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Oil Analysis Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with the modified Navy Oil Analysis Program requirements as detailed in section 6.F.17.</ns0:data>
  <ns0:data key="d8">modification compliance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841421</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Diesel Engine Inspection Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC applies the waiver for Diesel Engine Inspection Program semi-annual Force Revision requirements.</ns0:data>
  <ns0:data key="d8">waiver application</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841422</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Gauge Calibration Requirements">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts gauge calibration for watercraft in accordance with SYSCOM direction and SOW Attachment C.6-027 referencing NSWCCD CRL Letter 93/115.</ns0:data>
  <ns0:data key="d8">calibration execution</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841422</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SOW Attachment C.6-018">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC receives information and data via the 2K Transmittal Form as specified in SOW Attachment C.6-018 for OMMS-NG data entry services.</ns0:data>
  <ns0:data key="d8">data transmittal</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841423</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Consolidated Asset Listing (CAL)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes and updates Consolidated Asset Listing (CAL) for documenting issue and receipt of MPE/S.&lt;SEP&gt;MCMC utilizes and updates the government-provided Consolidated Asset Listing (CAL) to document MPE/S issue and receipt during MPS offloads and backloads.</ns0:data>
  <ns0:data key="d8">asset documentation,asset tracking,updates</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841423</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Equipment Density List (EDL)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC issues and receipts Navy assets according to Equipment Density List (EDL) and approved Resource Plan.&lt;SEP&gt;MCMC issues and receives Navy assets according to the approved Equipment Density List (EDL) and Resource and Support Plan for exercises and contingencies.</ns0:data>
  <ns0:data key="d8">asset issuance,compliance</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841424</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Extended Boom Fork Lift (EBFL)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs lubricity fuel filter replacement on Navy Extended Boom Fork Lift (EBFL) every 250 hours or 6 months as part of Navy Surveillance/Stock Checks.</ns0:data>
  <ns0:data key="d8">filter maintenance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841424</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Deferred Maintenance Listing (DML)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC adds non-mission capable equipment to Deferred Maintenance Listing (DML) in GCSS-MC when repairs are not possible.&lt;SEP&gt;MCMC adds equipment to the Deferred Maintenance Listing (DML) when repairs cannot be completed due to space, tools, or parts limitations, placing it in ABD SHIP status in GCSS-MC.</ns0:data>
  <ns0:data key="d8">deferred repair tracking,maintenance management,status update</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841426</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NSWCCD CRL Letter 93/115">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows NSWCCD CRL Letter 93/115 for gauge calibration procedures on watercraft as referenced in SOW Attachment C.6-027.</ns0:data>
  <ns0:data key="d8">calibration guidance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841426</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Annual Estimated Material Costs (CDRL 6062)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits Annual Estimated Material Costs (CDRL 6062) by 1 June each year for TR Control System Support on MPS Navy Watercraft.</ns0:data>
  <ns0:data key="d8">cost estimation reporting</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841426</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CSS Shipping Report (CDRL 6063)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits CSS Shipping Report (CDRL 6063) with shipping invoices by the second Monday of every month for the dedicated shipping account.</ns0:data>
  <ns0:data key="d8">shipping documentation</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841427</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Resource and Support Plan">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides Resource and Support Plan for Contracting Officer approval to support offload and reconstitution operations.&lt;SEP&gt;MCMC provides a proposed Resource and Support Plan for approval no later than 10 business days after receiving the Government RFP for exercises or contingencies.</ns0:data>
  <ns0:data key="d8">approval process,plan submission,planning submission</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841427</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Phase D Stage 4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC assesses functional areas for FMC status at Phase D Stage 4 (typically E-30) and issues Letters of Non-Conformance as needed.</ns0:data>
  <ns0:data key="d8">milestone assessment</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841428</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Statement of Work">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC is obligated to perform all tasks in the Statement of Work, including maintenance activities and logistics support.&lt;SEP&gt;MCMC provides various support services including program management, maintenance, and logistics in accordance with the Statement of Work.</ns0:data>
  <ns0:data key="d8">compliance,obligations,performance,service provision</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841428</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CDRLs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC is required to provide data requirements and reports as CDRLs under the contract.</ns0:data>
  <ns0:data key="d8">deliverables,reporting</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841429</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fleet Management Information System (FMIS)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC utilizes FMIS for Non-Tactical Vehicles equipment management as mandated by HQMC and directed in SOW Section C.2.B.7.a and MCO 11240.106.</ns0:data>
  <ns0:data key="d8">mandate,utilization</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841429</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="KPI Reporting">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses KPI Reporting to increase effectiveness and repeatability of status reporting for Maintenance Cycles.</ns0:data>
  <ns0:data key="d8">efficiency,monitoring</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841430</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Subcontracts/Supporting Contracts">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides information on subcontracts and supporting contracts used to complete assigned tasks.</ns0:data>
  <ns0:data key="d8">information provision,task completion</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841430</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Materiel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides information on materiel buy costs supporting ship evolutions and ashore programs through DoD systems or other methods.</ns0:data>
  <ns0:data key="d8">cost reporting,procurement</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841430</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Labor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides information on labor costs, burdens, and aggregate Program Management CLINs apportioned to ships and programs.</ns0:data>
  <ns0:data key="d8">burden,cost reporting</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841431</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Travel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides information on travel costs and associated G&amp;A.</ns0:data>
  <ns0:data key="d8">G&amp;A,cost reporting</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841431</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Training">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages training attendance for weapon systems and new materiel to minimize impacts on product and service delivery.</ns0:data>
  <ns0:data key="d8">impact management,planning</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841431</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SECTION 2.D RISK AND PERFORMANCE">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">SECTION 2.D RISK AND PERFORMANCE outlines MCMC responsibilities for quality control, risk management, and ISO 9001 certification.</ns0:data>
  <ns0:data key="d8">compliance,responsibility</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841432</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality Control (QC)/Risk Control (RC) Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and manages Quality Control/Risk Control Program to meet ISO 9001 requirements and uses QMSS.</ns0:data>
  <ns0:data key="d8">establishment,management</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841432</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality Management Support System (QMSS)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses QMSS for quality inspections and non-conformance management, with government-provided training within 60 days of contract award.</ns0:data>
  <ns0:data key="d8">training,usage</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841433</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Commands Quality Manual (CmdO P5000.11)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC complies with Command’s Quality Manual (CmdO P5000.11) for quality and risk operations.</ns0:data>
  <ns0:data key="d8">adherence,compliance</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841434</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Nonconformance Reports (NCRs)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC responds to and resolves Nonconformance Reports initiated in QMSS within specified timelines.</ns0:data>
  <ns0:data key="d8">resolution,response</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841434</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Nonconformance Trends (NCTs)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC responds to and resolves Nonconformance Trends initiated in QMSS within specified timelines.</ns0:data>
  <ns0:data key="d8">resolution,response</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841434</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality and Risk Control Plan (Q&amp;RCP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC develops Q&amp;RCP for government review within 30 and 60 days, including performance levels and KPIs, updated for audits.</ns0:data>
  <ns0:data key="d8">assessment,development</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841435</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality Key Performance Indicator (KPI) Control Charts">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Quality KPI Control Charts quarterly for internal elements supporting Q&amp;RCP, in accordance with CmdO P5000.11 and CmdO 5201.1.</ns0:data>
  <ns0:data key="d8">assessment,provision</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841435</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="End-of-Ship (EOS)/Period of Performance MCMC Performance Review">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC participates in End-of-Ship Review to assess variations from baselines and lessons learned per CmdO P5000.11.</ns0:data>
  <ns0:data key="d8">participation,review</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841435</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Continuous Process Improvement (CPI)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC reports on CPI for quality management and seeks approval for implementations per CmdO P5000.11, providing summaries at reviews.</ns0:data>
  <ns0:data key="d8">implementation,reporting</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841436</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Quality Control Plan (QCP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Quality Control Plan annually by 01 November, detailing surveillance, verification, and procedures for SOW requirements.</ns0:data>
  <ns0:data key="d8">annual submission,provision</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841436</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SECTION C.3 – MAINTENANCE ACTIVITIES">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">SECTION C.3 – MAINTENANCE ACTIVITIES specifies maintenance services to be accomplished by MCMC during Maintenance Cycles for ME and CESE.</ns0:data>
  <ns0:data key="d8">delineation,requirements</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841436</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Marine Corps Ground Military Equipment (ME)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance on Marine Corps Ground Military Equipment during MPF Maintenance Cycles per MCO 3000.17 and TM 4790-14/2.</ns0:data>
  <ns0:data key="d8">maintenance,support</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841437</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Civil Engineer Support Equipment (CESE)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance on Navy Civil Engineer Support Equipment during MPF Maintenance Cycles per MCO 3000.17 and TM 4790-14/2.</ns0:data>
  <ns0:data key="d8">maintenance,support</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841437</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Limited Technical Inspections (LTIs)">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs LTIs on ME and CESE assets to determine condition and assign codes.&lt;SEP&gt;MCMC performs Limited Technical Inspections on ME and CESE per TM 4700-15/1, MCO 4400.201, and UM 4000-125, including condition codes and road tests.</ns0:data>
  <ns0:data key="d8">condition assessment,inspection,performance</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3&lt;SEP&gt;chunk-c10c3b1cc4c0a5d44aa2c137a52eaf0b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841437</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="GCSS-MC Service Request">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses GCSS-MC Service Request to identify and capture maintenance requirements as tasks per CmdO 4790.1 (MMSOP).</ns0:data>
  <ns0:data key="d8">task capture,usage</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841438</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Special Function Tests">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs Special Function Tests on ME and CESE to support Government QA without needing disassembly or unpackaging.</ns0:data>
  <ns0:data key="d8">QA support,performance</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841438</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="TDM-Publications">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC uses TDM-Publications to obtain technical publications by equipment TAMCN and ID numbers.</ns0:data>
  <ns0:data key="d8">publication access,usage</ns0:data>
  <ns0:data key="d9">chunk-432adfa735f19522f81538c1e139e7a3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841438</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Automated External Defibrillators">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC inspects AEDs monthly and returns inoperable ones to IDIV Safety Office for replacement.</ns0:data>
  <ns0:data key="d8">inspection,maintenance</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841439</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fire Wardens">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC designates competent persons as primary and alternate Fire Wardens and provides rosters annually.</ns0:data>
  <ns0:data key="d8">compliance,designation</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841439</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Fire Drills">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts semi-annual fire drills and submits after-action reports to the installation safety office.</ns0:data>
  <ns0:data key="d8">conduct,reporting</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841440</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Recordable Injuries or Illnesses">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC investigates and reports recordable injuries or illnesses, including root cause analysis.</ns0:data>
  <ns0:data key="d8">investigation,reporting</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841440</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="WHE Accident">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts investigations for WHE accidents, submits reports, and halts operations until corrective actions are approved.</ns0:data>
  <ns0:data key="d8">compliance,investigation</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841440</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Safety Inspections">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs daily safety inspections of work areas and submits reports upon government request.</ns0:data>
  <ns0:data key="d8">conduct,monitoring</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841441</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Hazard Reporting and Abatement Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC develops and implements the Hazard Reporting and Abatement Program for confidential hazard reporting.</ns0:data>
  <ns0:data key="d8">development,reporting</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841441</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Respiratory Protection Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes the Respiratory Protection Program and provides lists of assigned personnel.</ns0:data>
  <ns0:data key="d8">establishment,listing</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841442</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Environmental Manager">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides an Environmental Manager to ensure adherence to environmental policies and sustainability requirements.&lt;SEP&gt;The MCMC provides the Environmental Manager responsible for ensuring compliance with environmental policies and sustainability requirements.</ns0:data>
  <ns0:data key="d8">provision,responsibility</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841442</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 5100.29">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to MCO 5100.29 for accident reporting, radiation safety, vehicle operations, and environmental requirements.</ns0:data>
  <ns0:data key="d8">compliance,reference</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841442</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CmdO P5104.3">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to CmdO P5104.3 for radiation training, notifications, and inventories.</ns0:data>
  <ns0:data key="d8">compliance,radiation safety</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841442</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="EPA 40 CFR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages radioactive material storage areas in accordance with EPA 40 CFR.</ns0:data>
  <ns0:data key="d8">compliance,storage</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841443</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NRC 10 CFR Part 20">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows NRC 10 CFR Part 20 for radiation safety in material handling.</ns0:data>
  <ns0:data key="d8">compliance,radiation protection</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841443</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="CmdO 11240.1C">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows CmdO 11240.1C for all vehicle safety requirements.</ns0:data>
  <ns0:data key="d8">compliance,vehicle operations</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841443</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 11240.66">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC implements vehicle licensing programs according to MCO 11240.66.</ns0:data>
  <ns0:data key="d8">compliance,licensing</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841444</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 11240.118">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages equipment licensing in line with MCO 11240.118.</ns0:data>
  <ns0:data key="d8">certification,compliance</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841444</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 8400.6">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to MCO 8400.6 for vehicle and equipment safety.</ns0:data>
  <ns0:data key="d8">compliance,safety standards</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841444</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="TM 11275-15/4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC references TM 11275-15/4 for vehicle safety and licensing procedures.</ns0:data>
  <ns0:data key="d8">compliance,technical guidance</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
