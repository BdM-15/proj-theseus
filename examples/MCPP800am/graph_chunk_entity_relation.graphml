  <ns0:data key="d11">1759841354</ns0:data>
</ns0:edge>
<ns0:edge source="Department of Defense" target="DPAS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Department of Defense uses DPAS for property accountability, maintenance, utilization, and warehouse management.</ns0:data>
  <ns0:data key="d8">property accountability,system utilization</ns0:data>
