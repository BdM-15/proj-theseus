<ns0:edge source="Government" target="Final Indirect Cost Rates">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Government executes a written understanding with the Contractor setting forth final indirect cost rates, bases, and periods.</ns0:data>
  <ns0:data key="d8">agreement,settlement</ns0:data>
  <ns0:data key="d9">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
