</ns0:edge>
<ns0:edge source="Contracting Officer" target="Smoking Policy">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer identifies designated smoking areas and receives enforcement-related notifications under the Smoking Policy.</ns0:data>
  <ns0:data key="d8">enforcement,identification</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841423</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contracting Officers Representative">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contracting Officer’s Representative is appointed by the Contracting Officer to assist in contract technical monitoring.</ns0:data>
  <ns0:data key="d8">appointment,assistance role</ns0:data>
