<ns0:edge source="MCMC" target="Pollution Prevention">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Pollution Prevention requirements and participates in the Navy’s program per Executive Order 13423.</ns0:data>
  <ns0:data key="d8">compliance,participation</ns0:data>
