</ns0:node>
<ns0:node id="6.F.16">
  <ns0:data key="d0">6.F.16</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.16 specifies that MCMC shall replace all POL, including filters, for Navy Watercraft, LARCs, and ABLTS every ship cycle in Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.17">
  <ns0:data key="d0">6.F.17</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.17 requires MCMC to draw and provide lubricating oil and Jacket Water samples for analysis on offloaded INLS Watercraft during Phase Bravo, delivering CDRL 6044 within 5 business days.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.18">
  <ns0:data key="d0">6.F.18</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.18 directs MCMC to perform load testing of hull fittings and J-bar davits for Navy Watercraft and ABLTS in Phase Delta, providing CDRL 6045.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.19">
  <ns0:data key="d0">6.F.19</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.19 mandates MCMC to perform maintenance and inspections on wire and fiber rope and rigging for Navy Watercraft, including LARCs and ABLTS in Phase Delta, providing CDRL 6046.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.20">
  <ns0:data key="d0">6.F.20</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.20 describes Post-MMC Acceptance Trials where Navy Watercraft and ABLTS enter full operational mode, with MCMC documenting results via CDRL 6043 and scheduling per master schedule.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.21">
  <ns0:data key="d0">6.F.21</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.21 requires MCMC to perform NAV-P approved corrective maintenance to MPF Navy Watercraft, including LARCs and ABLTS in Phase Charlie, using OMMS-NG for documentation.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.21.a">
  <ns0:data key="d0">6.F.21.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.21.a specifies that newly discovered work requirements during maintenance shall be communicated via Condition Found Report (CDRL 6048) not later than five business days.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.22">
  <ns0:data key="d0">6.F.22</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.22 requires MCMC to provide weight certificates for all Navy Watercraft and ABLTS with dry and as-loaded weights not later than E-21, accurate within 1000 lbs.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.23">
  <ns0:data key="d0">6.F.23</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.23 directs MCMC to deliver all Navy Watercraft and ABLTS to the departing ship with specified JP-5 fuel amounts in Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.24">
  <ns0:data key="d0">6.F.24</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.24 requires MCMC to submit the Navy Watercraft and ABLTS Fuel Status Report (CDRL 6049) not later than E-21.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.25">
  <ns0:data key="d0">6.F.25</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.25 mandates MCMC to replace lube oil and hydraulic hoses on all Navy Watercraft, including LARCs and ABLTS in Phase Delta as required.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.26">
  <ns0:data key="d0">6.F.26</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.26 requires MCMC to provide a Selective Interchange Request Letter (CDRL 6050) to NAV-P Director prior to any parts exchange.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.27">
  <ns0:data key="d0">6.F.27</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.27 directs MCMC to perform corrosion control and coating systems repairs to Navy Watercraft, LARCs, and ABLTS in Phase Charlie, submitting Corrosion Survey Reports.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.27.a">
  <ns0:data key="d0">6.F.27.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.27.a requires MCMC to provide joint quality checkpoints for coating system repairs, submitting CDRL 6052 not later than two business days after completion.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.27.b">
  <ns0:data key="d0">6.F.27.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.27.b states that RST shall manage watercraft coating system maintenance utilizing MCSF-BI CRF, while organizational maintenance is managed by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.28">
  <ns0:data key="d0">6.F.28</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.28 requires MCMC to inventory, order, replace/repair, test, and maintain outfitting/equipage for Navy Watercraft from Phase Bravo through Delta, submitting CDRL 6053.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.29">
  <ns0:data key="d0">6.F.29</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.29 directs OST to provide movement services for Navy Watercraft and ABLTS per approved schedules and docking plans from Phase Bravo through Delta.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841092</ns0:data>
</ns0:node>
<ns0:node id="6.F.29.a">
  <ns0:data key="d0">6.F.29.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.29.a requires MCMC to create, maintain, and update the Navy Watercraft and ABLTS Movement Schedule (CDRL 6054) not later than three business days prior to changes.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.30">
  <ns0:data key="d0">6.F.30</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.30 requires MCMC to perform and report shipping of Navy Watercraft and ABLTS equipment, providing shipping documents to NAV-P.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.31">
  <ns0:data key="d0">6.F.31</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.31 mandates MCMC to accomplish known FSBs, Deviations, SYSALTs, Class Advisories, and Safety of Use Messages, submitting CDRL 6055.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.32">
  <ns0:data key="d0">6.F.32</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.32 requires MCMC to support prototype and operational testing for maintenance of various Navy Watercraft systems in support of alterations and projects.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.33">
  <ns0:data key="d0">6.F.33</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.33 directs MCMC to report and perform emergent repairs or services to Navy Watercraft, notifying NAV-P within one hour for approval.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.34">
  <ns0:data key="d0">6.F.34</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.34 requires MCMC to perform organizational level corrosion control and coating systems maintenance to Navy Watercraft from Phase Bravo through Delta.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.34.a">
  <ns0:data key="d0">6.F.34.a</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.34.a specifies priorities for organizational level coating system maintenance: shipset in production, organic equipment, watercraft in maintenance, other assets.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="6.F.34.b">
  <ns0:data key="d0">6.F.34.b</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">6.F.34.b states that watercraft not scheduled for depot level repairs shall be maintained to mitigate progressive corrosion.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Requirements Package">
  <ns0:data key="d0">Maintenance Requirements Package</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Maintenance Requirements Package outlines applicable maintenance standards for Navy Watercraft, LARCs, and ABLTS.&lt;SEP&gt;Maintenance Requirements Package (MRP) is an element of Navy maintenance methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Post-MATs">
  <ns0:data key="d0">Post-MATs</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Post-MATs are Government-led trials post-MMC acceptance to verify maintenance effectiveness on Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="RST">
  <ns0:data key="d0">RST</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">RST manages watercraft coating system maintenance at depot level utilizing MCSF-BI CRF.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="OST">
  <ns0:data key="d0">OST</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">OST provides movement services for Navy Watercraft and ABLTS per approved schedules.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="American Bureau of Shipping">
  <ns0:data key="d0">American Bureau of Shipping</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">American Bureau of Shipping provides rules for building and classing steel vessels referenced in corrective maintenance standards for Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="JP-5">
  <ns0:data key="d0">JP-5</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">JP-5 is the jet fuel type provided in specified optimal amounts for different Navy Watercraft types during delivery in Phase Delta.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="CFPMs">
  <ns0:data key="d0">CFPMs</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CFPMs are Navy Watercraft requiring 400-450 gallons of JP-5 fuel per delivery.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="BMs">
  <ns0:data key="d0">BMs</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">BMs are Navy Watercraft requiring 200-250 gallons of JP-5 fuel per delivery.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="CCS">
  <ns0:data key="d0">CCS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">CCS are Navy Watercraft requiring 95 gallons of JP-5 fuel per delivery.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Corrosion Survey Report">
  <ns0:data key="d0">Corrosion Survey Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Corrosion Survey Report (SOW Attachment C.6-025) documents spot preservation annotations and is submitted to the Government for review and approval.&lt;SEP&gt;Corrosion Survey Report is submitted by MCMC to document corrosion assessments and repairs on Navy Watercraft, LARCs, and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Master Schedule">
  <ns0:data key="d0">Master Schedule</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Master Schedule provides timelines for Post-MATs, lighterage milestones, and overall Navy Watercraft operations.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Lighterage Milestones">
  <ns0:data key="d0">Lighterage Milestones</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Lighterage Milestones are key scheduling points for Navy Watercraft and ABLTS activities NLT E-56 in Phase IV.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="OPNAVINST 4790.4">
  <ns0:data key="d0">OPNAVINST 4790.4</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">OPNAVINST 4790.4 is the instruction for Ships Maintenance and Material Management applied in corrective maintenance for Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Emergent Repairs">
  <ns0:data key="d0">Emergent Repairs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Emergent Repairs are immediate actions required to protect life, property, environment, or for time-sensitive operations on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="FSBs">
  <ns0:data key="d0">FSBs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">FSBs are Fleet Support Bulletins that MCMC shall accomplish on Navy Watercraft with Notice of Completion reporting.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="SYSALTs">
  <ns0:data key="d0">SYSALTs</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SYSALTs are system alterations that MCMC shall perform on Navy Watercraft as part of known requirements.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Caterpillar">
  <ns0:data key="d0">Caterpillar</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Caterpillar provides SOS testing reports for Jacket Water analysis in Navy Watercraft oil reporting.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA Standard 009-63">
  <ns0:data key="d0">NAVSEA Standard 009-63</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA Standard 009-63 is the standard followed for providing Navy Watercraft Oil Analysis Reports.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-2035">
  <ns0:data key="d0">MIL-STD-2035</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-2035 is the military standard referenced for corrective maintenance on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="AWS Structural Welding Code">
  <ns0:data key="d0">AWS Structural Welding Code</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">AWS Structural Welding Code D1.1 through D1.6 provides guidelines for structural welding in Navy Watercraft maintenance.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NAVSUP P-307">
  <ns0:data key="d0">NAVSUP P-307</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSUP P-307 is the publication used for issuing weight certificates for Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA Publication S6430-AE-TED-010">
  <ns0:data key="d0">NAVSEA Publication S6430-AE-TED-010</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA Publication S6430-AE-TED-010 guides the replacement of lube oil and hydraulic hoses on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC 1600471">
  <ns0:data key="d0">NAVFAC 1600471</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVFAC 1600471 specifies the INLS Paint Schedule and Deck Covering for corrosion control on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NSTM 631">
  <ns0:data key="d0">NSTM 631</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NSTM 631 is a naval ships' technical manual used for coating systems maintenance procedures on Navy Watercraft, LARCs, and ABLTS.&lt;SEP&gt;NSTM 631 is the Naval Ships' Technical Manual for preservation and corrosion control applied to Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NSTM 634">
  <ns0:data key="d0">NSTM 634</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NSTM 634 is a naval ships' technical manual referenced for corrosion control and maintenance on Navy Watercraft.&lt;SEP&gt;NSTM 634 is the Naval Ships' Technical Manual for deck coverings and painting on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA STD Item 009-32">
  <ns0:data key="d0">NAVSEA STD Item 009-32</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA STD Item 009-32 is a standard item referenced for performing organizational level corrosion control and coating systems maintenance on Navy Watercraft.&lt;SEP&gt;NAVSEA STD Item 009-32 is the standard item for painting and coating systems repairs on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Corrosion Repair Facility">
  <ns0:data key="d0">Corrosion Repair Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Corrosion Repair Facility is a shared facility on the installation that MCMC coordinates with other organizations under government guidance.&lt;SEP&gt;Corrosion Repair Facility is the MCSF-BI depot-level facility used for watercraft coating system maintenance by RST.</ns0:data>
  <ns0:data key="d3">chunk-c12bdd730383e0d5968b0354d37c6d8a&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Docking Plans">
  <ns0:data key="d0">Docking Plans</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Docking Plans are provided by NAV-P to guide OST in movement services for Navy Watercraft and ABLTS.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="Draft RFP">
  <ns0:data key="d0">Draft RFP</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Draft RFP is a preliminary Request for Proposal issued to solicit industry feedback, not for formal submissions, with responses due by 3 July.&lt;SEP&gt;The Draft RFP outlines instructions, conditions, and notices for bidders in a government acquisition process.&lt;SEP&gt;Draft RFP is the solicitation document providing detailed instructions for offeror submissions in volumes V, VI, and VII.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="CASB DS-1">
  <ns0:data key="d0">CASB DS-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CASB DS-1 is a form used for submitting Disclosure Statements to the cognizant Administrative Contracting Officer or Federal official.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="CASB DS-2">
  <ns0:data key="d0">CASB DS-2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CASB DS-2 is a form applicable for submitting Disclosure Statements related to cost accounting practices.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841093</ns0:data>
</ns0:node>
<ns0:node id="52.230-7">
  <ns0:data key="d0">52.230-7</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.230-7 is a provision requiring offerors to disclose cost accounting practice changes if the contract award will result in such changes.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Section L">
  <ns0:data key="d0">Section L</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section L contains Instructions, Conditions, and Notices to Offerors, referencing provisions like 52.214-7 and 52.215-1 for late submissions and modifications.&lt;SEP&gt;Section L provides instructions, conditions, and notices to bidders, including clauses incorporated by reference and full text.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Timothy L. Rivers">
  <ns0:data key="d0">Timothy L. Rivers</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">Timothy L. Rivers is the Contracting Officer responsible for the solicitation, with contact email timothy.l.rivers@usmc.mil and telephone number 904-696-5360.&lt;SEP&gt;Timothy L. Rivers is the point of contact for site visit requests and Contract Reference Library issuance at Blount Island Command.&lt;SEP&gt;Timothy L. Rivers is the contact for submitting questions and requests for clarification via email at timothy.l.rivers@usmc.mil no later than 8:00 AM on 2 July 2025.&lt;SEP&gt;Timothy L. Rivers is the Contract Specialist at Blount Island Command responsible for receiving proposals.&lt;SEP&gt;Timothy L. Rivers is the contact for emailing completed past performance questionnaires to at timothy.l.rivers@usmc.mil.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726&lt;SEP&gt;chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville">
  <ns0:data key="d0">Jacksonville</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Jacksonville is the city in Florida where USMC Blount Island Command is located.&lt;SEP&gt;Jacksonville is the city in Florida where Blount Island Command is located and the site visit will occur.</ns0:data>
  <ns0:data key="d3">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Industry Day">
  <ns0:data key="d0">Industry Day</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Industry Day is scheduled for 24 June 2025 at Blount Island Command to provide information on the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Site Visit">
  <ns0:data key="d0">Site Visit</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">The Site Visit is held on 24 June 2025 at Blount Island Command, Jacksonville, Florida, allowing offerors to inspect the performance site.&lt;SEP&gt;The Site Visit is an interactive event starting promptly at 09:00 AM EDT in Building 109 at Blount Island, allowing contractors to inspect the site and understand SOW requirements; late arrivals are not included.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Organizational Conflict of Interest">
  <ns0:data key="d0">Organizational Conflict of Interest</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Organizational Conflict of Interest (OCI) is addressed in Section H, Paragraph H-16, requiring avoidance in the solicitation process.&lt;SEP&gt;Organizational Conflict of Interest is a matter addressed in Section H, Paragraph H-16, to which offerors' attention is directed under L-2 for avoidance per FAR 9.5.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Pre-Award Survey">
  <ns0:data key="d0">Pre-Award Survey</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Pre-Award Survey evaluates prospective contractors' technical capability, production capability, and other areas if their response is favorably considered.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Government Accountability Office">
  <ns0:data key="d0">Government Accountability Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Government Accountability Office (GAO) receives copies of protests filed against the agency.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Florida">
  <ns0:data key="d0">Florida</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Florida is the state hosting the Blount Island Command facility and the scheduled Industry Day and site visit.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Jacksonville Port Authority">
  <ns0:data key="d0">Jacksonville Port Authority</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Jacksonville Port Authority (JaxPort) owns the western half of Blount Island and is collocated with the Marine Corps Support Facility.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="48 CFR Chapter 99">
  <ns0:data key="d0">48 CFR Chapter 99</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">48 CFR Chapter 99 contains the Cost Accounting Standards established by the Cost Accounting Standards Board.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="52.215-20">
  <ns0:data key="d0">52.215-20</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.215-20 specifies requirements for certified cost or pricing data and allows exceptions via written request in the solicitation.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="52.216-1">
  <ns0:data key="d0">52.216-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.216-1 indicates the contemplated contract type as a Cost Reimbursement/Firm Fixed Price Hybrid, Indefinite Delivery Indefinite Quantity.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="52.233-2">
  <ns0:data key="d0">52.233-2</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.233-2 outlines procedures for serving protests on the Contracting Officer at Blount Island Command.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="52.237-1">
  <ns0:data key="d0">52.237-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.237-1 requires offerors to inspect the site and clarifies that failure to do so does not constitute grounds for claims post-award.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="52.252-1">
  <ns0:data key="d0">52.252-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.252-1 incorporates solicitation provisions by reference and provides access to full text via acquisition.gov.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="L-1 Preproposal Information">
  <ns0:data key="d0">L-1 Preproposal Information</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">L-1 provides instructions for requesting the Contract Reference Library, attending Industry Day, and site visit procedures.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="L-2 Notice of Organizational Conflict of Interest">
  <ns0:data key="d0">L-2 Notice of Organizational Conflict of Interest</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">L-2 references Section H, Paragraph H-16 for Organizational Conflict of Interest avoidance requirements.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="L-3 Pre-Award Survey of Prospective Contractor">
  <ns0:data key="d0">L-3 Pre-Award Survey of Prospective Contractor</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">L-3 Pre-Award Survey of Prospective Contractor involves a survey team contacting organizations to evaluate abilities in areas like technical capability, production capability, and financial capability if responses are favorably considered.&lt;SEP&gt;L-3 describes the potential pre-award survey evaluating areas such as technical capability, production capability, and quality assurance.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Administrative Contracting Officer">
  <ns0:data key="d0">Administrative Contracting Officer</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">The Administrative Contracting Officer (ACO) receives original and copies of Disclosure Statements and serves as the cognizant official.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Building 109">
  <ns0:data key="d0">Building 109</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Building 109 at Blount Island Command is the assembly point for the Industry Day and site visit participants.&lt;SEP&gt;Building 109 is the starting point for the Site Visit at 09:00 AM EDT.</ns0:data>
  <ns0:data key="d3">chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="DSI Authorization Letter">
  <ns0:data key="d0">DSI Authorization Letter</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1008 is a document provided by the MCMC for authorizing DSI inventories, submitted no later than specified timelines after contract award or task order award.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Shipboard DSI">
  <ns0:data key="d0">Shipboard DSI</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Shipboard DSI inventories are established and maintained by the MCMC, including non-demand based stock with justification, using GCSS-MC for management.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Special Tools Allowance Letter">
  <ns0:data key="d0">Special Tools Allowance Letter</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1009 is a letter submitted by the MCMC for accounting Government-owned Garrison Fabricated Tools in DPAS, provided after contract award and annually.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Weekly On Island Equipment Status Report">
  <ns0:data key="d0">Weekly On Island Equipment Status Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1012 is a report produced by the MCMC in MS Excel for MCPP-N and MCPP-PHIL, due no later than close of business each Tuesday.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Calibration Control Program">
  <ns0:data key="d0">Calibration Control Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Calibration Control Program is established and maintained by the MCMC for ME, Navy CESE, and containerized assets in accordance with specified orders and technical manuals.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Calibration Inventory">
  <ns0:data key="d0">Calibration Inventory</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 1013 consists of results from the annual inventory conducted by the MCMC during December, submitted after task order award and initially after contract award.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Modification Control Program">
  <ns0:data key="d0">Modification Control Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Modification Control Program is established and maintained by the MCMC in accordance with specified orders and executed per modification instruction timelines.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Product Quality Deficiency Reports">
  <ns0:data key="d0">Product Quality Deficiency Reports</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">PQDR procedures are adhered to by the MCMC for submission and resolution in accordance with specified orders and forms.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Publication Control Program">
  <ns0:data key="d0">Publication Control Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Publication Control Program is established and maintained by the MCMC, including technical and non-technical publication libraries within TDM-Publications.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Equipment Availability">
  <ns0:data key="d0">Equipment Availability</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Operational status of ME is reported by the MCMC in GCSS-MC daily, with no more than a 24-hour lag between actual readiness and reporting.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Preventive Maintenance Checks and Services Program">
  <ns0:data key="d0">Preventive Maintenance Checks and Services Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">PMCS program is maintained by the MCMC for MCPP materiel and Organic GFE in accordance with specified orders and technical publications.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Corrective Maintenance Program">
  <ns0:data key="d0">Corrective Maintenance Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Corrective Maintenance Program is maintained by the MCMC for equipment in accordance with specified orders and technical publications.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Deferred Maintenance and Repairs">
  <ns0:data key="d0">Deferred Maintenance and Repairs</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">DM&amp;R management for military equipment is overseen and executed by the MCMC, including documentation and resource allocation.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Cannibalization and Selective Interchange">
  <ns0:data key="d0">Cannibalization and Selective Interchange</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Procedures for Cannibalization and Selective Interchange are complied with by the MCMC, including preparation of authorization letters.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Load Lifting Certification Program">
  <ns0:data key="d0">Load Lifting Certification Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">The Load Lifting Certification Program is maintained by the MCMC in accordance with specified orders and technical documents.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Corrosion Control and Coating">
  <ns0:data key="d0">Corrosion Control and Coating</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">C3 is executed by the MCMC in accordance with assessments and prescribed maintenance timelines.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841094</ns0:data>
</ns0:node>
<ns0:node id="Using Unit Account Manager Program">
  <ns0:data key="d0">Using Unit Account Manager Program</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">UUAM program is maintained by the MCMC, including submission of validated GCSS-MC user accounts lists quarterly.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Business Intelligence and Key Performance Indicators">
  <ns0:data key="d0">Business Intelligence and Key Performance Indicators</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 2.C outlines business systems and deliverables for deriving contract performance ratings for Program Management Effectiveness based on KPIs related to cost, schedule, and conformance.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Production Planning and Control Tool">
  <ns0:data key="d0">Production Planning and Control Tool</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Microsoft Dynamic 365 is used by the MCMC as the enterprise tool for production planning and control, including administration and execution support.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Business Operating Systems">
  <ns0:data key="d0">Business Operating Systems</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">BOSs and APSRs are systems included for contract performance, subject to updates or replacements during the contract period.&lt;SEP&gt;Business Operating Systems are enterprise tools used for production planning, control, and data management, subject to updates during the contract period.</ns0:data>
  <ns0:data key="d3">chunk-bee5e6b5db1fe2dc611fc5fc2b227a51&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="DSI Request Letter">
  <ns0:data key="d0">DSI Request Letter</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">The DSI Request Letter is a document completed by the MCMC in accordance with the government-provided template for managing Shipboard DSIs.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="On-Island DSI">
  <ns0:data key="d0">On-Island DSI</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">On-Island DSI inventories are established and maintained by the MCMC as part of physical storage locations in accordance with specified guidelines.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="PREPODEP">
  <ns0:data key="d0">PREPODEP</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">PREPODEP is the entity to which the MCMC provides the Weekly On Island Equipment Status Report for MCPP-N and MCPP-PHIL.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Norway Branch">
  <ns0:data key="d0">Norway Branch</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Norway Branch is the Government entity with which the MCMC coordinates validations, reconciliations, notifications, and approvals for MCPP-N activities.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Philippines Branch">
  <ns0:data key="d0">Philippines Branch</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Philippines Branch is the Government entity with which the MCMC coordinates notifications and approvals for MCPP-PHIL activities, including electronic publications and modifications.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="RPAs">
  <ns0:data key="d0">RPAs</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">RPAs are Robotic Process Automations used by the MCMC to automate routine tasks in the APSR, enhancing data accuracy and reducing manual interventions.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="PME">
  <ns0:data key="d0">PME</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">PME is Program Management Effectiveness, derived from KPIs assessing cost, schedule, and conformance across production, sustainment, and OCONUS operations.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="PPC">
  <ns0:data key="d0">PPC</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">PPC is Production Planning and Control, encompassing enterprise functions like administration, scheduling, and execution support using Microsoft Dynamics 365.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="P-PET">
  <ns0:data key="d0">P-PET</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">P-PET is the Production Planning and Execution Team that issues planning letters and conducts cyclical meetings attended by the MCMC.&lt;SEP&gt;P-PET is the Production Planning and Execution Team that leads periodic meetings to monitor MMC activities.</ns0:data>
  <ns0:data key="d3">chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="MEB">
  <ns0:data key="d0">MEB</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MEB is the Marine Expeditionary Brigade participating in weekly validations and reconciliations via Teams or teleconference with the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="MCO 3000.11E">
  <ns0:data key="d0">MCO 3000.11E</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 3000.11E is a Marine Corps Order referenced for reporting the operational status of ME.</ns0:data>
  <ns0:data key="d3">chunk-a0a00a7bb666b381893da579a6b228c9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Crane Accident Review Board (CARB)">
  <ns0:data key="d0">Crane Accident Review Board (CARB)</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Crane Accident Review Board (CARB) reviews crane accidents and incidents and receives information from the Contractor.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="NTVE/MHE">
  <ns0:data key="d0">NTVE/MHE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">NTVE/MHE refers to Non-Tactical Vehicles and Equipment and Material Handling Equipment that require fueling, dispatching, and maintenance services.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="GSA Leased Vehicles">
  <ns0:data key="d0">GSA Leased Vehicles</ns0:data>
  <ns0:data key="d1">other</ns0:data>
  <ns0:data key="d2">GSA Leased Vehicles are vehicles managed under General Services Administration leases requiring maintenance, repairs, and support services.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="UFC 460-01/03">
  <ns0:data key="d0">UFC 460-01/03</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">UFC 460-01/03 specifies standards for fuel storage operations and product receipt and issue.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="DLA P-2">
  <ns0:data key="d0">DLA P-2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DLA P-2 governs accurate fuel record maintenance for delivery accountability.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="AWP">
  <ns0:data key="d0">AWP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">AWP refers to Aerial Work Platforms that requires maintenance, inspections, testing, and certification.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10005">
  <ns0:data key="d0">CDRL 10005</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10005 authorizes selective exchange of parts between vehicles or equipment.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10006">
  <ns0:data key="d0">CDRL 10006</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10006 requires submission of Vehicle Accident Reports.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10007">
  <ns0:data key="d0">CDRL 10007</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10007 provides an updated monthly PM/Certification and Testing schedule for WHE, MHE, and OHE.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10008">
  <ns0:data key="d0">CDRL 10008</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10008 requires report responses for audits, evaluations, and investigations within 20 days.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10009">
  <ns0:data key="d0">CDRL 10009</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10009 submits a Schedule for Testing and Certification of equipment.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10010">
  <ns0:data key="d0">CDRL 10010</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10010 submits Testing and Certification Qualifications including personnel names and qualifications.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10011">
  <ns0:data key="d0">CDRL 10011</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10011 submits a Maintenance Inspection Specification and Record for WHE.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10012">
  <ns0:data key="d0">CDRL 10012</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 10012 submits a PM Schedule for preventive maintenance inspections.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Dispatching Services">
  <ns0:data key="d0">Dispatching Services</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Dispatching Services section outlines timely vehicle dispatching using Fleet Focus during Government working hours.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Maintenance of Non-Tactical Vehicles and Equipment (NTVE)">
  <ns0:data key="d0">Maintenance of Non-Tactical Vehicles and Equipment (NTVE)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Maintenance of Non-Tactical Vehicles and Equipment (NTVE) section specifies maintenance, repairs, and alterations to ensure operational condition.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841095</ns0:data>
</ns0:node>
<ns0:node id="Facility-Mounted Weight Handling Equipment (WHE)">
  <ns0:data key="d0">Facility-Mounted Weight Handling Equipment (WHE)</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Facility-Mounted Weight Handling Equipment (WHE) section requires a PM program for jib and rail WHE to minimize breakdowns.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Federal Motor Carrier Safety Regulations">
  <ns0:data key="d0">Federal Motor Carrier Safety Regulations</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Federal Motor Carrier Safety Regulations govern the operation of vehicles transporting hazardous materials as prescribed by relevant authorities.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="GSA Fleet Guide">
  <ns0:data key="d0">GSA Fleet Guide</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">GSA Fleet Guide provides guidelines for compliance in dispatching, accident reporting, and vehicle management.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="OHE">
  <ns0:data key="d0">OHE</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">OHE refers to Other Handling Equipment that requires inclusion in PM/Certification and Testing schedules.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="ANSI Standards">
  <ns0:data key="d0">ANSI Standards</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ANSI Standards, such as ANSI 92.2, apply to the maintenance, inspections, and operations of equipment like Aerial Work Platforms.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA SWO23">
  <ns0:data key="d0">NAVSEA SWO23</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA SWO23 provides standards for maintenance and support services on NTVE, WHE, MHE, and AWP.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA OP5">
  <ns0:data key="d0">NAVSEA OP5</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA OP5 governs the inspection, testing, and certification of WHE, MHE, AWP, and OHE.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="AH-WHM-010">
  <ns0:data key="d0">AH-WHM-010</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">AH-WHM-010 outlines requirements for engineer support services and maintenance of weight handling equipment.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="B-351 Organic Maintenance">
  <ns0:data key="d0">B-351 Organic Maintenance</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">B-351 Organic Maintenance is the designated facility where the Contractor picks up and drops off newly received, reassigned, and replaced GSA vehicles and equipment.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Support Services">
  <ns0:data key="d0">Support Services</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Support Services encompass dispatching services and management of GSA leased vehicles to meet NTVE/MHE requirements.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="New and Reassigned Vehicles and Equipment Services">
  <ns0:data key="d0">New and Reassigned Vehicles and Equipment Services</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">New and Reassigned Vehicles and Equipment Services include initial inspections, preparations, and history establishment for added fleet units.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Preventative Maintenance, Inspection, Load Test and Certification Support of WHE, MHE, and AWP">
  <ns0:data key="d0">Preventative Maintenance, Inspection, Load Test and Certification Support of WHE, MHE, and AWP</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">This section mandates annual and post-modification inspections, testing, and certification of WHE, MHE, AWP, and OHE per applicable standards.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Preventive Maintenance Inspections of NTVE">
  <ns0:data key="d0">Preventive Maintenance Inspections of NTVE</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Preventive Maintenance Inspections of NTVE require safety, reliability checks, and services based on intervals, mileage, or hours, including corrosion control.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Maintenance (Government-Owned) Equipment">
  <ns0:data key="d0">Maintenance (Government-Owned) Equipment</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Maintenance (Government-Owned) Equipment covers repairs and alterations of non-IT Government-owned equipment to maintain operational condition.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Fuel Program Requirements">
  <ns0:data key="d0">Fuel Program Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Fuel Program Requirements detail the use of GFE for dispensing fuel and ensuring accountability and calibration.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="History Jacket">
  <ns0:data key="d0">History Jacket</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">History Jacket is a record file maintained for the life of vehicles and equipment, including Shop Repair Orders and service history.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Shop Repair Order">
  <ns0:data key="d0">Shop Repair Order</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Shop Repair Order is prepared and submitted for all work performed on vehicles and equipment, with copies maintained in history files.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Operators Daily Checklist (ODCL)">
  <ns0:data key="d0">Operators Daily Checklist (ODCL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Operator’s Daily Checklist (ODCL) is used for inspections that may identify repairs in a single occurrence.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Operator Trouble Report">
  <ns0:data key="d0">Operator Trouble Report</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Operator Trouble Report documents issues leading to repairs as part of a single inspection occurrence.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Crane Condition Inspection Report (CCIR)">
  <ns0:data key="d0">Crane Condition Inspection Report (CCIR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Crane Condition Inspection Report (CCIR) is part of inspections identifying repair needs for cranes.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Maintenance Inspection Specification Record (MISR)">
  <ns0:data key="d0">Maintenance Inspection Specification Record (MISR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Maintenance Inspection Specification Record (MISR) details specifications for maintenance inspections.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Spec Item 10.A.2.f">
  <ns0:data key="d0">Spec Item 10.A.2.f</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Spec Item 10.A.2.f sets workmanship standards for corrosion control repairs and coatings.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Monthly Operators Check List (MOCL)">
  <ns0:data key="d0">Monthly Operators Check List (MOCL)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Monthly Operators Check List (MOCL) is performed on all jib and bridge cranes, with repairs addressed as needed.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Armory Custodian Nomination Letters">
  <ns0:data key="d0">Armory Custodian Nomination Letters</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Armory Custodian Nomination Letters are provided in writing by MCMC prior to contract execution, annually, and within 24 hours of personnel changes.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Frigard Temporary Weapons Facility">
  <ns0:data key="d0">Frigard Temporary Weapons Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Frigard Temporary Weapons Facility requires nomination of designated personnel for access by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Armory Access Nomination Letters">
  <ns0:data key="d0">Armory Access Nomination Letters</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Armory Access Nomination Letters are provided in writing by MCMC prior to contract execution, annually, and within 24 hours of personnel changes.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="NFPA 10-18">
  <ns0:data key="d0">NFPA 10-18</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NFPA 10-18 standards are adhered to by MCMC for inspection, maintenance, and testing of portable fire extinguishers.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="T-AKE Ships">
  <ns0:data key="d0">T-AKE Ships</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">T-AKE Ships are vessels involved in supply operations, issuing stocks to MAGTF, and warehousing for MPF exercises.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Class V (W)">
  <ns0:data key="d0">Class V (W)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class V (W) represents war reserve ammunition issued at unit pack level and recovered unexpended from MAGTF.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="T-AKE Post-Exercise Consumption List">
  <ns0:data key="d0">T-AKE Post-Exercise Consumption List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">T-AKE Post-Exercise Consumption List (CDRL 5045) tracks and reports issuance of consumables, expendables, and secondary reparables to MAGTF, updated daily and finalized post-exercise.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="OIS-PC">
  <ns0:data key="d0">OIS-PC</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">OIS-PC is used to update inventory status for recovered unexpended Class V (W) stocks.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="ISO Freight Containers">
  <ns0:data key="d0">ISO Freight Containers</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">ISO freight containers are managed, inspected, recertified, and maintained by the MCMC, including tracking physical locations, serial numbers, and compliance with various standards.&lt;SEP&gt;ISO Freight Containers are managed by MCMC for accountability, storage, inspection, recertification, maintenance, and transport in prepositioning programs.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="MCO 4690.1B">
  <ns0:data key="d0">MCO 4690.1B</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4690.1B outlines procedures for ISO container management and support for DoD inventories.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Annual Container Inventory Discrepancy Report">
  <ns0:data key="d0">Annual Container Inventory Discrepancy Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Annual Container Inventory Discrepancy Report (CDRL 5046) reports physical vs. system discrepancies for ISO containers, submitted by October 1.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="JCM">
  <ns0:data key="d0">JCM</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">JCM is the system for managing Marine Corps 20ft ISO container inventory, ensuring data accuracy.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Government Exercise Support Letter">
  <ns0:data key="d0">Government Exercise Support Letter</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Government Exercise Support Letter provides specific guidance for exercises, including supply issuance and recovery procedures.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Section C.7 Shipboard">
  <ns0:data key="d0">Section C.7 Shipboard</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.7 Shipboard outlines shipboard operations and support requirements for MPF exercises.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Post Exercise Discrepancy List">
  <ns0:data key="d0">Post Exercise Discrepancy List</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Post Exercise Discrepancy List identifies Class IX(C) parts and SECREPs not issued from T-AKE, requiring service requests post-exercise.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841096</ns0:data>
</ns0:node>
<ns0:node id="Container Management Plan">
  <ns0:data key="d0">Container Management Plan</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Container Management Plan covers rotation, acquisition, repair, and disposal of ISO containers for prepositioning programs.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Quarterly Container Readiness Reports">
  <ns0:data key="d0">Quarterly Container Readiness Reports</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Quarterly Container Readiness Reports are submitted by MCMC for ISO container management.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="49 CFR 452">
  <ns0:data key="d0">49 CFR 452</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">49 CFR 452 is a federal regulation referenced for container inspections.&lt;SEP&gt;49 CFR 452 provides standards for ISO freight container inspections.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="MIL-STD-3037">
  <ns0:data key="d0">MIL-STD-3037</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MIL-STD-3037 is a military standard referenced for container recertification, maintenance, and markings.&lt;SEP&gt;MIL-STD-3037 outlines requirements for ISO container maintenance, recertification, and markings.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="ISO Standards Handbook">
  <ns0:data key="d0">ISO Standards Handbook</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISO Standards Handbook: Freight Containers is referenced for container inspections, recertifications, maintenance, and markings.&lt;SEP&gt;ISO Standards Handbook: Freight Containers specifies certification, maintenance, and marking standards for ISO containers.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Code H Containers">
  <ns0:data key="d0">Code H Containers</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Code H Containers are those with repair costs exceeding 65% of replacement value.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="PPS">
  <ns0:data key="d0">PPS</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">PPS is the Prepositioning Planning System application within MCPIC for managing ship plans and package IDs.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="MMFAQ61">
  <ns0:data key="d0">MMFAQ61</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MMFAQ61 is a T-AKE sub-float account used for issuing serviceable SECREPs to MAGTF.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="MMFAQ62">
  <ns0:data key="d0">MMFAQ62</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">MMFAQ62 is a T-AKE sub-float account used for issuing serviceable SECREPs to MAGTF.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="CSM Office">
  <ns0:data key="d0">CSM Office</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">CSM Office is the LOGCOM Coordinated SECREP Management Office, determining financial reimbursement for SECREPs.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="MEF">
  <ns0:data key="d0">MEF</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MEF is the Marine Expeditionary Force, with financial reimbursement requirements for SECREP issuances.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="PM Ammo">
  <ns0:data key="d0">PM Ammo</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">PM Ammo coordinates replenishment of Class V(W) stocks after exercises.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Inspection Tags and Labels">
  <ns0:data key="d0">Inspection Tags and Labels</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Inspection Tags and Labels for portable fire extinguishers include verification collars, tamper seals, and maintenance details.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Commercial Service Invoices">
  <ns0:data key="d0">Commercial Service Invoices</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Commercial Service Invoices document maintenance or hydrostatic testing for portable fire extinguishers, including serial numbers and NSNs.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class I">
  <ns0:data key="d0">Class I</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class I supplies are consumables issued to MAGTF from T-AKE during exercises, with replenishment coordinated by Government.&lt;SEP&gt;Class I is a supply class for subsistence items included in USMC supply and distribution methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class III(P)">
  <ns0:data key="d0">Class III(P)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class III(P) is packaged petroleum products, issued and replenished by MCMC from T-AKE sustainment blocks.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class IV">
  <ns0:data key="d0">Class IV</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class IV supplies are construction materials, issued to MAGTF and replenished by MCMC post-exercise.&lt;SEP&gt;Class IV is a supply class for construction materials included in USMC supply support.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class IX(C)">
  <ns0:data key="d0">Class IX(C)</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class IX(C) are repair parts, tracked in post-exercise consumption and discrepancy lists.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class II">
  <ns0:data key="d0">Class II</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class II supplies are non-consumables, issued on temporary loan basis to MAGTF during MPF exercises.&lt;SEP&gt;Class II is a supply class for clothing, individual equipment, and tentage included in USMC supply methodology.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Class VII">
  <ns0:data key="d0">Class VII</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Class VII supplies are major end items, issued on temporary loan basis to MAGTF during MPF exercises.&lt;SEP&gt;Class VII is a supply class for major end items like vehicles included in USMC operations.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="E-Day">
  <ns0:data key="d0">E-Day</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">E-Day is the embarkation day, requiring portable fire extinguishers to be certified within 12 months prior.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="VSTF">
  <ns0:data key="d0">VSTF</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">VSTF locations are designated for warehousing smaller Class IX items aboard T-AKE ships.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Organizational Conflicts of Interest">
  <ns0:data key="d0">Organizational Conflicts of Interest</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Organizational Conflicts of Interest refer to conflicting roles that may bias judgment or provide unfair competitive advantage, requiring avoidance and mitigation by the MCMC.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="H-17 Associate Contractor Agreements">
  <ns0:data key="d0">H-17 Associate Contractor Agreements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-17 Associate Contractor Agreements requires the MCMC to establish written agreements with associate contractors for information exchange, protecting proprietary data and holding the Government harmless.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Associate Contractors">
  <ns0:data key="d0">Associate Contractors</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Associate contractors are companies, individuals, or organizations with whom the MCMC forms relationships to facilitate information exchanges necessary for contract performance.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="H-18 Partnering">
  <ns0:data key="d0">H-18 Partnering</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-18 Partnering describes a voluntary process for mutual commitment between the Government and the MCMC to cooperate, promote open communication, trust, and shared goals without altering contract terms.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="H-19 Common Tools Reimbursement">
  <ns0:data key="d0">H-19 Common Tools Reimbursement</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-19 Common Tools Reimbursement specifies that employees furnish common tools except for shipboard personnel, with estimated costs for reimbursement on CPFF CLINs based on labor categories and references.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="H-20 Publicity">
  <ns0:data key="d0">H-20 Publicity</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-20 Publicity prohibits the MCMC from making publicity releases without prior written approval from the KO.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="H-21 Contract Transition Phase-In Phase-Out Plan Requirements">
  <ns0:data key="d0">H-21 Contract Transition Phase-In Phase-Out Plan Requirements</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-21 Contract Transition Phase-In Phase-Out Plan Requirements details applicability, tasks, period, and goals for transition between incumbent and successor MCMC, including inventories, training, and property accountability.</ns0:data>
  <ns0:data key="d3">chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
<ns0:node id="Section I Contract Clauses">
  <ns0:data key="d0">Section I Contract Clauses</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section I Contract Clauses incorporates various FAR clauses by reference, covering topics such as definitions, gratuities, conflicts of interest, security requirements, and reporting.&lt;SEP&gt;Section I of the Draft RFP dedicated to contract clauses, featuring clauses incorporated by reference from the Federal Acquisition Regulation and Defense Federal Acquisition Regulation Supplement.</ns0:data>
  <ns0:data key="d3">chunk-4c6c8cc3b4b40997aa333b8fb93d6c6b&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841097</ns0:data>
</ns0:node>
