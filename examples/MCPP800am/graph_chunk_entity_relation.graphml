  <ns0:data key="d11">1759841535</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Container Management">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC handles container management with inspections, repairs, and property record updates in AIS.</ns0:data>
  <ns0:data key="d8">accountability updates,maintenance activities</ns0:data>
  <ns0:data key="d9">chunk-8efbcbadad92a347ffdc7b5c1e34b2f7</ns0:data>
