  <ns0:data key="d11">1759841221</ns0:data>
</ns0:edge>
<ns0:edge source="Minimum Insurance Requirements" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Minimum Insurance Requirements obligate the MCMC to obtain and maintain specified insurance types and amounts, providing certification to the Contracting Officer.</ns0:data>
