  <ns0:data key="d11">1759841258</ns0:data>
</ns0:edge>
<ns0:edge source="DMO" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures integration and communication between DMO, warehouse receiving, and document management for receipt processing.</ns0:data>
