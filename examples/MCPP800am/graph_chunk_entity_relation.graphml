<ns0:edge source="Class I Rations Plan" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC prepositions Meals Ready to Eat and First Strike Rations as directed by the government-provided Class I Rations Plan, palletizing and loading into refer containers or break bulk for T-AKE vessels.</ns0:data>
  <ns0:data key="d8">loading,prepositioning</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
