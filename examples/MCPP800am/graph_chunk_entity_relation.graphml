  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Navy Production Assembly and Class IX Inventory Short List (CDRL 6027) uses SOW Attachment C.6-013.</ns0:data>
  <ns0:data key="d8">attachment,format</ns0:data>
