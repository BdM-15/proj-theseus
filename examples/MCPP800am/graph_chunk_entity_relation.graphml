  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841222</ns0:data>
</ns0:edge>
<ns0:edge source="Military Surface Deployment and Distribution Command (SDDC)" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC fulfills SDDC requirements for overseas shipments, including applying for export releases and preparing TCMDs.</ns0:data>
  <ns0:data key="d8">compliance,export</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841412</ns0:data>
</ns0:edge>
