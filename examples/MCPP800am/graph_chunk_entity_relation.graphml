<ns0:edge source="IPACK" target="Dangerous Cargo Manifest">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">IPACK populates specific data elements including NSN, SERIAL NUMBER, DESCRIPTION, WEIGHT, QTY PER CARGO, PKG ID, and UN CODE for ICODES to create the Dangerous Cargo Manifest NLT E-Day.</ns0:data>
  <ns0:data key="d8">data elements,manifest creation</ns0:data>
