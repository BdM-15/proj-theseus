  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Maintenance of Logistics Over-the-Shore (LOTS) Rotational Pool assets follows SOW Attachment C.6-002.</ns0:data>
  <ns0:data key="d8">attachment,maintenance</ns0:data>
