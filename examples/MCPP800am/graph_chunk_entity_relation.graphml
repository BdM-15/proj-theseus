</ns0:edge>
<ns0:edge source="Subic Bay" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides MCPP-PHIL services primarily at facilities in Subic Bay, Philippines.</ns0:data>
  <ns0:data key="d8">location,service delivery</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841525</ns0:data>
</ns0:edge>
<ns0:edge source="Surge Teams" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC shall provide and staff Surge Teams as part of surge support personnel requirements, integrating them into the on-island workforce when not deployed.&lt;SEP&gt;MCMC staffs and deploys Surge Teams to address workload demands in the Marine Corps Prepositioning Program.</ns0:data>
  <ns0:data key="d8">deployment,personnel provision,provision,workload support</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d&lt;SEP&gt;chunk-f736781b685dec5629d8433e71c666e4</ns0:data>
