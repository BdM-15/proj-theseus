  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="USN Watercraft" target="Functional Areas">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Functional Areas cover all systems and sub-components of USN Watercraft, with absent capabilities waived for specific craft types.</ns0:data>
  <ns0:data key="d8">capability assessment,system categorization</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="LARC Maintenance Facility" target="NWAMS Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">LARC Maintenance Facility delivers just-in-time and over-the-shoulder LARC familiarization training to NWAMS Contractor.</ns0:data>
  <ns0:data key="d8">training provision</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="LARC Maintenance Facility" target="AMA NAVMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">LARC Maintenance Facility delivers just-in-time and over-the-shoulder LARC familiarization training to AMA NAVMC.</ns0:data>
  <ns0:data key="d8">training provision</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="Technical Refresh (TR) Alterations" target="Watercraft Master Schedule">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Technical Refresh (TR) Alterations are performed according to the Watercraft Master Schedule directed by NAV-P.</ns0:data>
  <ns0:data key="d8">procurement timing,scheduling</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841410</ns0:data>
</ns0:edge>
<ns0:edge source="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)" target="Operator Level PMCS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Operator Level PMCS is executed on MPE/S assets semi-annually and recorded locally.</ns0:data>
  <ns0:data key="d8">preventive maintenance</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841411</ns0:data>
</ns0:edge>
<ns0:edge source="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)" target="Navy Surveillance/Stock Checks">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy Surveillance/Stock Checks visually inspect MPE/S every 30 days and document defects.</ns0:data>
  <ns0:data key="d8">defect reporting,visual inspection</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841411</ns0:data>
</ns0:edge>
<ns0:edge source="Maritime Prepositioning Navy Equipment and Supplies (MPE/S)" target="Navy Corrective Maintenance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Navy Corrective Maintenance repairs non-mission capable faults on MPE/S to restore mission capability.</ns0:data>
  <ns0:data key="d8">fault correction</ns0:data>
  <ns0:data key="d9">chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841412</ns0:data>
</ns0:edge>
<ns0:edge source="Consolidated Asset Listing (CAL)" target="Navy TAAT OIC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Changes to Consolidated Asset Listing (CAL) are coordinated through Navy TAAT OIC.</ns0:data>
  <ns0:data key="d8">change management,coordination</ns0:data>
