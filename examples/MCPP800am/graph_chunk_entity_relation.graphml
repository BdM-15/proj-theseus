<ns0:edge source="Critical Lift" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC identifies loads meeting Critical Lift requirements per NAVFAC P-307 section 10 and completes associated plans prior to execution.</ns0:data>
