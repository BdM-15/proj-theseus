  <ns0:data key="d11">1759841466</ns0:data>
</ns0:edge>
<ns0:edge source="52.211-11 Liquidated Damages Supplies Services Or Research And Development" target="Termination Clause">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.211-11 Liquidated Damages Supplies Services Or Research And Development references the Termination Clause for additional excess costs upon repurchase.</ns0:data>
  <ns0:data key="d8">cost liability,reference</ns0:data>
