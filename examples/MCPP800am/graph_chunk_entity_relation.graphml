  <ns0:data key="d11">1759841384</ns0:data>
</ns0:edge>
<ns0:edge source="MCPP" target="U.S. Marine Corps">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPP encompasses USMC requirements for supply, maintenance, and manning across various locations and assets.</ns0:data>
  <ns0:data key="d8">operational requirements,program oversight</ns0:data>
