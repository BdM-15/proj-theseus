<ns0:edge source="MCMC" target="Controls System Support (CSS)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes a dedicated CSS to accomplish Machinery Control System Technical Refresh and electronic support.</ns0:data>
  <ns0:data key="d8">establishment,technical support</ns0:data>
  <ns0:data key="d9">chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
