<ns0:edge source="Maintenance Production (Conus)" target="Conus">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Maintenance Production (CONUS) encompasses activities performed within the continental United States.</ns0:data>
  <ns0:data key="d8">geographic scope,operational area</ns0:data>
