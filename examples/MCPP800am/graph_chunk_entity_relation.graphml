<ns0:edge source="Phase-Out Requirements" target="Contract Term Change Clause">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Phase-Out Requirements can lead to contract term changes that invoke the pro-rata cost revision specified in the Contract Term Change Clause.</ns0:data>
  <ns0:data key="d8">cost revision,requirement impact</ns0:data>
