<ns0:edge source="MCMC" target="Navy Production Assembly and Class IX Inventory Short List">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC delivers the completed Navy Production Assembly and Class IX Inventory Short List within three business days of inventory completion.</ns0:data>
  <ns0:data key="d8">delivery,inventory management</ns0:data>
