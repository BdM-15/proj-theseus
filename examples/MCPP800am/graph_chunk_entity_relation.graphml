  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC trains personnel in accordance with NAVMC 1200.1 Military Occupational Specialties Manual.</ns0:data>
  <ns0:data key="d8">training compliance</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841527</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MCO 5510.18B">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC personnel undergo T1 or T3 investigations per MCO 5510.18B for security clearance.</ns0:data>
  <ns0:data key="d8">security investigations</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
