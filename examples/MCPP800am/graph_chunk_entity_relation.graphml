<ns0:edge source="Afloat Phase" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs shipboard logistics, surveillance, and maintenance during the Afloat Phase of the MPF Program IAW MCO P3000.17 and TM 4790-14/2.</ns0:data>
  <ns0:data key="d8">mps operations,support</ns0:data>
