<ns0:edge source="MMV333" target="Prepositioning Objective">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Prepositioning Objective in NAVMC 2907 sets allowances for the MMV333 Maritime Prepositioning Force account.</ns0:data>
  <ns0:data key="d8">account basis,allowance establishment</ns0:data>
