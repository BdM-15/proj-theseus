  <ns0:data key="d11">1759841511</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Marine Corps Prepositioning Program (MCPP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides combat-ready assets and sustainment through supply chain and inventory management for MCPP operations.</ns0:data>
  <ns0:data key="d8">accountability,support</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
