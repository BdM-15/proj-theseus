  <ns0:data key="d11">1759841217</ns0:data>
</ns0:edge>
<ns0:edge source="NSC" target="Navy Plans and Data POC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">NSC appoints Navy Plans and Data POC to handle execution and management of Navy squadron and ship level plans.</ns0:data>
  <ns0:data key="d8">appointment,plan execution</ns0:data>
  <ns0:data key="d9">chunk-38be7e49aefd10e870f45cb648f7d79d</ns0:data>
