  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC follows Military Surface Deployment and Distribution Command (SDDC) requirements for export shipments.</ns0:data>
  <ns0:data key="d8">compliance,export</ns0:data>
