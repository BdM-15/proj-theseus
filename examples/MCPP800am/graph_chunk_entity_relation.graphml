  <ns0:data key="d0">Controlled Unclassified Information</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Controlled Unclassified Information is federal information requiring safeguarding beyond basic controls, as established by Executive Order 13556.</ns0:data>
  <ns0:data key="d3">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
