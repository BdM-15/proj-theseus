  <ns0:data key="d11">1759841456</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contract Authority">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contract Authority requires MCMC to respond only to directives from personnel assigned by the Contracting Officer.</ns0:data>
  <ns0:data key="d8">directive response,personnel assignment</ns0:data>
