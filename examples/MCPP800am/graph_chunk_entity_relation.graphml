</ns0:node>
<ns0:node id="FAR 52.244-2">
  <ns0:data key="d0">FAR 52.244-2</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">FAR 52.244-2 is a Federal Acquisition Regulation clause authorizing open purchases for parts unavailable in the supply system due to constraints.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="SECREP">
  <ns0:data key="d0">SECREP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SECREP refers to secondary reparables issued to MAGTF from T-AKE sub-floats, with exchanges and replenishments managed by MCMC.&lt;SEP&gt;SECREP refers to secure repair parts exchanged to support maintenance operations of prepositioning assets.&lt;SEP&gt;SECREP refers to Class IX Secondary Repairable items prepositioned in designated quantities and units of issue.</ns0:data>
  <ns0:data key="d3">chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-5fcb066f3ce0c1cfffc65441135b96e1&lt;SEP&gt;chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="MMFAU1/MMFAQ9">
  <ns0:data key="d0">MMFAU1/MMFAQ9</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MMFAU1/MMFAQ9 are units designated for receiving transferred unserviceable SECREPs.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841055</ns0:data>
</ns0:node>
<ns0:node id="CMC Msg 051307Z Apr 18">
  <ns0:data key="d0">CMC Msg 051307Z Apr 18</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CMC Msg 051307Z Apr 18 is a message providing instructions on fuel procurement and reconciliation procedures.</ns0:data>
  <ns0:data key="d3">chunk-68739860c42b764e52f9649ea16ed702</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
