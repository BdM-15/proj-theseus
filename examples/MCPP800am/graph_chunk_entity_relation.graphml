  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC uses the Integrated Booking System (IBS) for routing release units in export processes.</ns0:data>
  <ns0:data key="d8">routing,utilization</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
