</ns0:edge>
<ns0:edge source="MCMC" target="Ships PCL">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs maintenance and packaging in accordance with the ship’s PCL.</ns0:data>
  <ns0:data key="d8">compliance,planning</ns0:data>
