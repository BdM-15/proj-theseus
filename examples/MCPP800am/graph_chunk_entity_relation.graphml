  <ns0:data key="d11">1759841513</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MI 11569A-23/1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC installs retrieval hitch on Medium Crawler Tractor per MI 11569A-23/1 to meet production plan requirements.</ns0:data>
  <ns0:data key="d8">hitch,modification installation</ns0:data>
