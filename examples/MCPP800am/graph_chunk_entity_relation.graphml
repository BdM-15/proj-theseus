<ns0:edge source="LARC" target="WMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">WMC includes the LARC Maintenance Facility for maintaining LARC vehicles, with personnel assisting in related functions without impacting production.</ns0:data>
  <ns0:data key="d8">maintenance facility,program support</ns0:data>
