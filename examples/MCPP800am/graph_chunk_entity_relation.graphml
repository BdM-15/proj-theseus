  <ns0:data key="d11">1759841308</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="WIR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits WIR for disposition of unserviceable, obsolete, or excess materiel after Government approval.</ns0:data>
  <ns0:data key="d8">requests,submission</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841308</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="MLSR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides immediate notification and conducts causative research for MLSR reportable items.</ns0:data>
  <ns0:data key="d8">investigation,notification</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841309</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SF-91">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC provides completed SF-91 along with accident LTI for accidents involving Government-owned assets as part of CDRL 5034.&lt;SEP&gt;MCMC provides completed SF-91 along with accident LTI for Government-owned assets involved in accidents.</ns0:data>
  <ns0:data key="d8">accident reporting,accidents,submission</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa&lt;SEP&gt;chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
