  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Regulations issued pursuant to the Atomic Energy Act of 1954 are set forth in Title 10 of the Code of Federal Regulations.</ns0:data>
  <ns0:data key="d8">compliance,regulatory basis</ns0:data>
  <ns0:data key="d9">chunk-411fd0fef03fc3d4fd825823982dd9d7</ns0:data>
