<ns0:node id="52.204-7 System For Award Management">
  <ns0:data key="d0">52.204-7 System For Award Management</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">52.204-7 System For Award Management is a provision included in the solicitation that enables offerors to use annual representations and certifications in the System for Award Management.</ns0:data>
  <ns0:data key="d3">chunk-e63c0b2b2602443bbfc148f7717d7ee5</ns0:data>
