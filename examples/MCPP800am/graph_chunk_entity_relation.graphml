<ns0:edge source="GSE" target="Heavy-Lift Transporters">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Heavy-Lift Transporters are assigned Priority 1 maintenance under GSE for transport tasks.</ns0:data>
  <ns0:data key="d8">criticality,priority assignment</ns0:data>
