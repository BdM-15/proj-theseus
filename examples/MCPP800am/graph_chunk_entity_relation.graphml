<ns0:edge source="L-3 Pre-Award Survey of Prospective Contractor" target="Production Capability">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Production Capability is evaluated as part of the L-3 survey for prospective contractors.</ns0:data>
  <ns0:data key="d8">capability assessment,evaluation area</ns0:data>
  <ns0:data key="d9">chunk-f121013aeb8c98e8b0609d68d89b74e5</ns0:data>
