  <ns0:data key="d11">1759841134</ns0:data>
</ns0:edge>
<ns0:edge source="Subcontract" target="Contractor">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">Contractor includes the substance of clauses in subcontracts exceeding specified thresholds.&lt;SEP&gt;Contractor inserts equal opportunity clause terms in subcontracts above specified thresholds to ensure compliance and enforcement.</ns0:data>
  <ns0:data key="d8">equal opportunity,flow-down,inclusion,terms insertion</ns0:data>
  <ns0:data key="d9">chunk-55bcb4486837a866d3ae601a0bfee839&lt;SEP&gt;chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
