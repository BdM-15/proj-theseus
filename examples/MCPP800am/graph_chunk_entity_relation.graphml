  <ns0:data key="d3">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d2">Section 4.C.5 governs storage and warehousing operations including segregation, security, and handling.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841247</ns0:data>
</ns0:node>
<ns0:node id="Stock Location Database">
  <ns0:data key="d0">Stock Location Database</ns0:data>
  <ns0:data key="d3">chunk-67bad1bd73dd9a9a7549acb855ae5e55</ns0:data>
  <ns0:data key="d2">Section 4.C.5.a requires an updated stock location database with NSN, quantity, and condition code for retail accounts.</ns0:data>
  <ns0:data key="d1">UNKNOWN</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841248</ns0:data>
</ns0:node>
