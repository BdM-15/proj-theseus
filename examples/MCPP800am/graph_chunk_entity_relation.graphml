  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC coordinates delivery, performs maintenance, and follows the MPS Production Schedule for various activities.</ns0:data>
  <ns0:data key="d8">compliance,scheduling</ns0:data>
