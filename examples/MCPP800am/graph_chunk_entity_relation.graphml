</ns0:edge>
<ns0:edge source="MCMC" target="NISPOM">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains compliance with NISPOM for all personnel performing on the contract.</ns0:data>
