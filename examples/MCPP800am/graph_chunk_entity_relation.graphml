  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC prepares Transportation Control and Movement Documents (TCMDs) for shipments.</ns0:data>
  <ns0:data key="d8">documentation,preparation</ns0:data>
