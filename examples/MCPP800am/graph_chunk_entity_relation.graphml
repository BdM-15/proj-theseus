  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Department of Navy policies, instructions, and directives for environmental requirements.</ns0:data>
  <ns0:data key="d8">compliance,policy adherence</ns0:data>
