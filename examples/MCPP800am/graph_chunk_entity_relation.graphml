  <ns0:data key="d2">Technical Proposal is Attachment #8, incorporated at the time of contract award.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841059</ns0:data>
</ns0:node>
<ns0:node id="CDRLs DD Form 1423-1">
  <ns0:data key="d0">CDRLs DD Form 1423-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CDRLs DD Form 1423-1 is Attachment #9.</ns0:data>
  <ns0:data key="d3">chunk-2fcdd71246fc4a058f5f995cbe6b3531</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
