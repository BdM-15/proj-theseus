  <ns0:data key="d11">1759841310</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="C3">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes C3 on CESE according to CmdO 4790.1, MCO 4790.2, and government-approved timelines.</ns0:data>
  <ns0:data key="d8">assessment,execution</ns0:data>
