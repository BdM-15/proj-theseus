  <ns0:data key="d11">1759841144</ns0:data>
</ns0:edge>
<ns0:edge source="Equipment and Materiel Accountability" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains strict materiel accountability for government-owned equipment and various supply accounts under the Equipment and Materiel Accountability section.</ns0:data>
  <ns0:data key="d8">accountability responsibility,supply management</ns0:data>
