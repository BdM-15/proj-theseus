  <ns0:data key="d11">1759841416</ns0:data>
</ns0:edge>
<ns0:edge source="IDIQ Contract" target="Base Ordering Period Year Two">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Base Ordering Period Year Two extends the IDIQ Contract services through CLINs 1001-1007.</ns0:data>
  <ns0:data key="d8">period extension</ns0:data>
  <ns0:data key="d9">chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
