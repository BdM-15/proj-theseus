</ns0:edge>
<ns0:edge source="MCMC" target="Key Personnel">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC manages Key Personnel positions and cannot remove or replace them without Contracting Officer concurrence and submission of nominations.</ns0:data>
  <ns0:data key="d8">management,replacement approval</ns0:data>
