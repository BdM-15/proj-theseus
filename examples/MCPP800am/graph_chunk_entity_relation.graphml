</ns0:edge>
<ns0:edge source="Contracting Officer" target="Section G Contract Administration Data">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section G Contract Administration Data specifies the Contracting Officer as the sole authority for contract changes and modifications.</ns0:data>
  <ns0:data key="d8">administration,authority delegation</ns0:data>
  <ns0:data key="d9">chunk-5e8f1210c8fd617812bffc0e6bfaef07</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
