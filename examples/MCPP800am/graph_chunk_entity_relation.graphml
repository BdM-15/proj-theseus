  <ns0:data key="d11">1759841461</ns0:data>
</ns0:edge>
<ns0:edge source="52.211-11 Liquidated Damages Supplies Services Or Research And Development" target="Default Fixed-Price Supply And Service Clause">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.211-11 Liquidated Damages Supplies Services Or Research And Development references the Default Fixed-Price Supply And Service Clause for determining fault in delays and termination.</ns0:data>
  <ns0:data key="d8">delay conditions,reference</ns0:data>
  <ns0:data key="d9">chunk-7ab97f6224f9bb5da997102b5a8a397f</ns0:data>
