<ns0:edge source="MCMC" target="Navy End of Production Container Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits the Navy End of Production Container Report for MCPIC designated containers within five business days after production completion.</ns0:data>
