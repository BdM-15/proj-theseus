<ns0:edge source="Department of Defense" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC ensures personnel are identifiable as contractors on Department of Defense facilities and does not employ active duty Department of Defense personnel without Contracting Officer approval.&lt;SEP&gt;MCMC complies with Department of Defense policies for environmental management and sustainability.</ns0:data>
  <ns0:data key="d8">employment restriction,environmental,personnel identification,policy adherence</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841336</ns0:data>
</ns0:edge>
<ns0:edge source="Department of Defense" target="H-15 Differential Pay">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Differential pay rates for MCMC personnel equal those paid to Department of Defense civilian employees.</ns0:data>
  <ns0:data key="d8">hazard compensation,pay rate standard</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
