  <ns0:data key="d11">1759841310</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="SUR">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs SUR on all received CESE within 45 calendar days, following technical procedures in equipment TMs and CmdO 4790.1.</ns0:data>
  <ns0:data key="d8">performance,timeline adherence</ns0:data>
  <ns0:data key="d9">chunk-955c2fafc0e5a2a07e97130b42a872b5</ns0:data>
