<ns0:edge source="MCMC" target="Preservation, Packaging, Packing, and Marking">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts Preservation, Packaging, Packing, and Marking of equipment and supplies for storage, embarkation, or shipment.</ns0:data>
  <ns0:data key="d8">compliance,conduct</ns0:data>
  <ns0:data key="d9">chunk-65833c099ebcc7aa1fccc5a1d930a7aa</ns0:data>
