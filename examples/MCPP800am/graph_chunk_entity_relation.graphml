</ns0:edge>
<ns0:edge source="DD Form 1348-1" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC receipts Navy weapons using DD Form 1348-1 and submits signed copies upon receipt.</ns0:data>
  <ns0:data key="d8">documentation,receipting</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
