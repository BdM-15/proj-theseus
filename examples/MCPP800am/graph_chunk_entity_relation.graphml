<ns0:edge source="MCMC" target="DISS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC ensures personnel records in DISS indicate favorable PSI for CAC issuance and ownership by the company.</ns0:data>
  <ns0:data key="d8">security management</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841528</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DBIDS">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC personnel use DBIDS badges for facility and base access without network capabilities.</ns0:data>
  <ns0:data key="d8">access control</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
