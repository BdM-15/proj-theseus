</ns0:edge>
<ns0:edge source="MCMC" target="Section C.4">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC executes supply, container, and distribution operations as outlined in Section C.4 for the Marine Corps Prepositioning Program.</ns0:data>
  <ns0:data key="d8">responsibilities,supply management</ns0:data>
  <ns0:data key="d9">chunk-13a4841aefad66042f059edb023e607b</ns0:data>
