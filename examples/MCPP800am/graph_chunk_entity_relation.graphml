<ns0:edge source="Philippines" target="MCPP">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCPP-PHIL in Philippines involves annual baselined production plans for maintenance and repair activities.</ns0:data>
  <ns0:data key="d8">production scheduling,program location</ns0:data>
