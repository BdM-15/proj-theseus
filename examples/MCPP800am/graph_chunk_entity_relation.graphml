<ns0:edge source="MCMC" target="Financial Liability Investigation of Property Loss">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC initiates the Financial Liability Investigation of Property Loss process using DD Form 200 for property loss situations.</ns0:data>
  <ns0:data key="d8">documentation,initiation</ns0:data>
