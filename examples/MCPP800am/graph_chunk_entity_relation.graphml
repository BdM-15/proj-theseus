<ns0:edge source="Statement of Work" target="Volume II">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Volume II addresses management practices adhering to Statement of Work requirements, including production planning via Microsoft Project and mission essential services per DFARS clauses.</ns0:data>
