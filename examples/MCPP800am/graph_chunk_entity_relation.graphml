  <ns0:data key="d7">IPACK data elements such as NSN, ITEM ID, MSE, LOAD NUMBER, DESCRIPTION, QTY PER CARGO, PKG ID, WEIGHT, and dimensions are populated for ICODES load and staging plan development per MMC Execution Milestones.</ns0:data>
  <ns0:data key="d8">data population,plan development</ns0:data>
