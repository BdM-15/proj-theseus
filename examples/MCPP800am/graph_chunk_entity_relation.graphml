  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">CMC Code POS-10 is a Department of Defense contact point for obtaining antiterrorism/force protection information, reachable at DSN 224-4177 or (703) 614-4177.</ns0:data>
  <ns0:data key="d3">chunk-752a3887d9e623b57dee7c9de056ce5b</ns0:data>
