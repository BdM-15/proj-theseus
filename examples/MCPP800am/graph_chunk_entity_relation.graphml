<ns0:edge source="Small Business Participation and Subcontracting Factor" target="FAR 52.219-9 Small Business Subcontracting Plan">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">FAR 52.219-9 Small Business Subcontracting Plan is assessed in the Small Business Participation and Subcontracting Factor for other-than-small offerors.</ns0:data>
