  <ns0:data key="d11">1759841481</ns0:data>
</ns0:edge>
<ns0:edge source="Full Mission Capable (FMC)" target="Quality Assurance (QA)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Quality Assurance (QA) inspections precede Full Mission Capable (FMC) status to mitigate disassembly needs.</ns0:data>
  <ns0:data key="d8">mitigation,pre-status inspection</ns0:data>
