<ns0:edge source="MCMC" target="Lighterage Maintenance Milestones">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC schedules and completes all maintenance, whether PM or CM, IAW Lighterage Maintenance Milestones and relative projects.</ns0:data>
  <ns0:data key="d8">adherence,scheduling</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
