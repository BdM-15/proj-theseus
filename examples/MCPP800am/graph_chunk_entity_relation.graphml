  <ns0:data key="d7">MCMC submits Post Exercise Cost Estimate totaling exercise-related costs.&lt;SEP&gt;MCMC delivers Post Exercise Cost Estimate to COR detailing all costs associated with exercise support services.</ns0:data>
  <ns0:data key="d8">cost documentation,cost reporting,reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-f918f57232ad428f5920d4c98f0af702&lt;SEP&gt;chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
