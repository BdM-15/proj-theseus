<ns0:edge source="MCMC" target="Air Resources">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Air Resources requirements, including inputting operating data into the Microsoft Access Air database per CDRL 10041.</ns0:data>
  <ns0:data key="d8">compliance,data management</ns0:data>
  <ns0:data key="d9">chunk-fce6cd46a0bc9b7bd7d409339addb37d</ns0:data>
