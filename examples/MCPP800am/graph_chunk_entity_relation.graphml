  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841262</ns0:data>
</ns0:edge>
<ns0:edge source="After Action Report" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides After Action Report on exercise risks and issues within 15 days.</ns0:data>
  <ns0:data key="d8">lessons learned,submission</ns0:data>
  <ns0:data key="d9">chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841262</ns0:data>
</ns0:edge>
<ns0:edge source="CDRL 7002" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides a proposed Resource and Support Plan under CDRL 7002 for Contracting Officer approval after receiving RFP.</ns0:data>
  <ns0:data key="d8">planning,submission</ns0:data>
  <ns0:data key="d9">chunk-5d0f24c6dd1ff5486bfe7491203ea801</ns0:data>
