  <ns0:data key="d11">1759841350</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="NFPA">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC follows NFPA standards for the central management, inspection, maintenance, and testing of portable fire extinguishers.&lt;SEP&gt;MCMC complies with NFPA codes and standards for maintenance, inspections, and hot work.</ns0:data>
  <ns0:data key="d8">fire extinguisher management,fire safety,standards adherence,standards compliance</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841350</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DD Form 1907">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC prepares and retains DD Form 1907 for all TPS shipments of downloaded weapons.</ns0:data>
  <ns0:data key="d8">documentation,shipment security</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841351</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="AA&amp;E">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC adheres to MCO 5530.14 standards for AA&amp;E access and key control when nominating custodians.&lt;SEP&gt;The MCMC adheres to MCO standards for AA&amp;E when nominating custodians and managing armory access.</ns0:data>
  <ns0:data key="d8">access control,compliance,handling standards</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841352</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="REPSHIP">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits REPSHIP for all weapon shipments arranged via transportation protective services.</ns0:data>
  <ns0:data key="d8">reporting requirement,shipment documentation</ns0:data>
  <ns0:data key="d9">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841352</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="H-8.7 Indirect Rate Change Notification">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">H-8.7 Indirect Rate Change Notification requires the MCMC to notify the KO of rate changes within five days.</ns0:data>
  <ns0:data key="d8">notification obligation,rate management</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841352</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="H-13 Base Support">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">H-13 Base Support provides Government facilities, equipment, and utilities to the MCMC at no cost.</ns0:data>
  <ns0:data key="d8">facility access,support provision</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841353</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="H-14 Conditions Applicable to Employment in Foreign Ports">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">H-14 Conditions Applicable to Employment in Foreign Ports requires the MCMC to comply with U.S. foreign government agreements.</ns0:data>
  <ns0:data key="d8">compliance obligation,international agreement</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841353</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="H-15 Differential Pay">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">H-15 Differential Pay entitles MCMC personnel to differential pay in imminent danger areas equal to DoD rates.</ns0:data>
  <ns0:data key="d8">compensation entitlement,hazard pay</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841353</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="H-12 Continuous Process Improvement (CPI) Incentive Program">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC submits process improvements for approval under H-12, sharing 30% of first-year savings and 10% thereafter.</ns0:data>
  <ns0:data key="d8">cost savings,incentive participation</ns0:data>
  <ns0:data key="d9">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
