<ns0:edge source="Site Visit" target="Industry Day Event">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Site Visit precedes the Industry Day Event, where verbal answers from the Site Visit are provided in writing.</ns0:data>
  <ns0:data key="d8">event sequence,question resolution</ns0:data>
