<ns0:edge source="MCMC" target="Production Planning and Execution Team">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC attends and participates in cyclical Production Planning and Execution Team meetings occurring no less than twice a month.</ns0:data>
