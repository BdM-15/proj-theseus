  <ns0:data key="d11">1759841510</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contracting Officer Representative">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer appoints Contracting Officer Representative in writing to assist in technical monitoring of the contract.</ns0:data>
  <ns0:data key="d8">appointment,contract administration</ns0:data>
  <ns0:data key="d9">chunk-2edf7351f7d27be2ca8809d7ac16a11d</ns0:data>
