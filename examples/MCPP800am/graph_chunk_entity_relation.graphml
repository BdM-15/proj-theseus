<ns0:edge source="Care of Supplies in Storage (COSIS)" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">MCMC performs Care of Supplies in Storage (COSIS) on Navy assets in accordance with supply manuals.&lt;SEP&gt;MCMC performs Care of Supplies in Storage services including preventive maintenance and preservation for prepositioned assets.</ns0:data>
  <ns0:data key="d8">maintenance,performance,preservation</ns0:data>
  <ns0:data key="d9">chunk-c2bae9a24e71825050f79fc141b2e181&lt;SEP&gt;chunk-c12bdd730383e0d5968b0354d37c6d8a</ns0:data>
