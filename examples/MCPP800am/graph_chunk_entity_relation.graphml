  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Maritime Prepositioning Ships are linked to the MMV333 account for equipment allowances and supply management.</ns0:data>
  <ns0:data key="d8">location account,prepositioning support</ns0:data>
