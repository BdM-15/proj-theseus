<ns0:edge source="Detailed Report of Findings" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Detailed Report of Findings, including CDRL 6074, within 60 calendar days of MPS offload at locations like WDC-I.</ns0:data>
  <ns0:data key="d8">offload timing,survey reporting</ns0:data>
  <ns0:data key="d9">chunk-48caa545ec007aaf46c9abe9ec8c0c78</ns0:data>
