<ns0:edge source="Minimum Insurance Requirements" target="Automobile Liability Insurance">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Minimum Insurance Requirements specify Automobile Liability Insurance with defined per occurrence and per person limits for the MCMC.</ns0:data>
  <ns0:data key="d8">insurance type,minimum limits</ns0:data>
