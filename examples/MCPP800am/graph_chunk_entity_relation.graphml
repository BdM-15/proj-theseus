<ns0:edge source="MCO 4400.201" target="M6700425R0007">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCO 4400.201 governs property management in Marine Corps possession, applicable to MCMC's responsibilities in M6700425R0007.</ns0:data>
  <ns0:data key="d8">governing reference,property management</ns0:data>
