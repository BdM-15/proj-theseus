  <ns0:data key="d11">1759841489</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Completion Invoice Or Voucher">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer may determine amounts due and issue a unilateral modification if the Contractor fails to submit a completion invoice or voucher timely.</ns0:data>
  <ns0:data key="d8">determination,unilateral modification</ns0:data>
  <ns0:data key="d9">chunk-55bcb4486837a866d3ae601a0bfee839</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841489</ns0:data>
</ns0:edge>
<ns0:edge source="Contracting Officer" target="Contractor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor must notify the Contracting Officer in writing about radioactive materials deliveries or servicing and submit or update Material Safety Data Sheets for hazardous materials.</ns0:data>
  <ns0:data key="d8">notification,submission requirements</ns0:data>
