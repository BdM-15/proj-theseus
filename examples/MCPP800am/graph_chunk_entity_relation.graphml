  <ns0:data key="d11">1759841539</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section 11.G">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section 11.G obligates MCMC to provide annual proof of Information Assurance certifications per NIST, DoD directives, and cyber security manuals.</ns0:data>
  <ns0:data key="d8">assurance,certification</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1</ns0:data>
