<ns0:edge source="LARC" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs Phase Bravo surveys on LARC as part of Navy Watercraft structural, mechanical, electronics, electrical, deck drain, and coating systems.</ns0:data>
  <ns0:data key="d8">phase bravo,survey</ns0:data>
