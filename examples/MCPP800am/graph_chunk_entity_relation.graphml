<ns0:edge source="MCMC" target="Green Procurement">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC complies with Green Procurement processes and submits reports per CDRL 10051.</ns0:data>
  <ns0:data key="d8">procurement,reporting</ns0:data>
