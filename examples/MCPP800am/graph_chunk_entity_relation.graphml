  <ns0:data key="d11">1759841534</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Materiel Accountability">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains maximum materiel accountability through various supply chain and inventory procedures.</ns0:data>
  <ns0:data key="d8">inventory control,management responsibility</ns0:data>
