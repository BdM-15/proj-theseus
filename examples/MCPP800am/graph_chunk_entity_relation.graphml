<ns0:edge source="Department of Defense" target="DoD Office of the Inspector General">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The DoD Office of the Inspector General prepares the hotline poster for display in Department of Defense contract work areas.</ns0:data>
  <ns0:data key="d8">oversight role,poster provision</ns0:data>
