<ns0:edge source="29 CFR 1910" target="10.B.8 Fire Protection and Prevention">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Subsection 10.B.8 requires monthly inspections of fire extinguishers per 29 CFR 1910 and MCO 5100.29.</ns0:data>
  <ns0:data key="d8">fire equipment,inspection requirements</ns0:data>
  <ns0:data key="d9">chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
