<ns0:edge source="52.216-7 Allowable Cost And Payment" target="52.242-4 Certification Of Final Indirect Costs">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">52.216-7 Allowable Cost And Payment requires an adequate indirect cost rate proposal including the Certificate of Final Indirect Costs per 52.242-4 Certification Of Final Indirect Costs.</ns0:data>
  <ns0:data key="d8">certification,reference</ns0:data>
