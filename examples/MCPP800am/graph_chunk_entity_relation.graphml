  <ns0:data key="d11">1759841184</ns0:data>
</ns0:edge>
<ns0:edge source="Section P" target="MCMC">
  <ns0:data key="d6">2.0</ns0:data>
  <ns0:data key="d7">The MCMC follows Section P for hazardous material handling during IT equipment disposition.&lt;SEP&gt;MCMC disposes of unserviceable IT equipment in accordance with Section P for Hazardous Material.</ns0:data>
  <ns0:data key="d8">disposition,disposition compliance,hazardous material</ns0:data>
  <ns0:data key="d9">chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-789ddbe0005097425aa3559f9388ad80</ns0:data>
