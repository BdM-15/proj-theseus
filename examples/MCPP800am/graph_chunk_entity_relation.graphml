<ns0:node id="Vision Enhancer">
  <ns0:data key="d0">Vision Enhancer</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Vision Enhancer is the first entry in the acronym glossary section of the Draft RFP M6700425R0007.</ns0:data>
  <ns0:data key="d3">chunk-46778545759b6a3b0240557a9acb9577</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Priority 1">
  <ns0:data key="d0">Priority 1</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 1 applies to emergency vehicles and utility trucks, requiring immediate start of work and notification if downtime exceeds 24 hours.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Priority 2">
  <ns0:data key="d0">Priority 2</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 2 applies to buses, staff automobiles, emergency service vehicles, cranes, and MHE, requiring completion within two to four hours and notification if downtime exceeds 48 hours.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Priority 3">
  <ns0:data key="d0">Priority 3</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Priority 3 requires completion of work within five working days after reporting.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Allowable Downtime Standards">
  <ns0:data key="d0">Allowable Downtime Standards</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Allowable Downtime Standards limit downtime per shop repair order and per alpha group to 10% of available hours monthly, with computation starting upon reporting down.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Computerized Maintenance Management System">
  <ns0:data key="d0">Computerized Maintenance Management System</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">The Computerized Maintenance Management System is a commercially available tool licensed to the Government for managing service operations, work orders, and asset data.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="Fleet Focus">
  <ns0:data key="d0">Fleet Focus</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Fleet Focus is a system used for dispatching, processing, and recording vehicle and equipment activities.&lt;SEP&gt;Fleet Focus is the Government system of record for GSA and NTVE maintenance records, including inventory and monthly mileage reports.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10002">
  <ns0:data key="d0">CDRL 10002</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CDRL 10002 is the deliverable for submitting copies of permits and licenses required for overweight/oversized loads.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10003">
  <ns0:data key="d0">CDRL 10003</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CDRL 10003 is the deliverable for requesting temporary suspension of downtime accumulation due to material delays.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="CDRL 10004">
  <ns0:data key="d0">CDRL 10004</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">CDRL 10004 is the deliverable for obtaining KO approval for repairs exceeding one-time limits.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA OP-2239">
  <ns0:data key="d0">NAVSEA OP-2239</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVSEA OP-2239 provides regulations for marking and operating vehicles transporting ordnance, hazardous materials, and dangerous articles.&lt;SEP&gt;NAVSEA OP-2239 prescribes rules and regulations for marking and operating vehicles used for transporting ammunition, explosives, or other dangerous/hazardous materials.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841088</ns0:data>
</ns0:node>
<ns0:node id="C.10-02">
  <ns0:data key="d0">C.10-02</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">C.10-02 is the section providing the GSA Fleet Inventory.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="C.10-03">
  <ns0:data key="d0">C.10-03</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">C.10-03 is the section providing the NTVE Fleet Inventory with assigned priorities.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="C.10-04">
  <ns0:data key="d0">C.10-04</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">C.10-04 is the section providing the Material Handling Equipment Fleet Inventory.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="GSA">
  <ns0:data key="d0">GSA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">GSA is the General Services Administration, providing fleet inventory for maintenance records in Fleet Focus.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="NAVFAC">
  <ns0:data key="d0">NAVFAC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVFAC is the Naval Facilities Engineering Systems Command, issuing standards for equipment maintenance and safety.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="NAVSEA">
  <ns0:data key="d0">NAVSEA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NAVSEA is the Naval Sea Systems Command, regulating transport of hazardous materials.&lt;SEP&gt;NAVSEA is the governing organization providing standards, technical manuals, and items for Navy Watercraft maintenance and testing.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Federal Motor Carrier Safety Administration">
  <ns0:data key="d0">Federal Motor Carrier Safety Administration</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Federal Motor Carrier Safety Administration regulates movement of overweight/oversized loads and hazardous materials transport.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="U.S. Department of Transportation">
  <ns0:data key="d0">U.S. Department of Transportation</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The U.S. Department of Transportation oversees federal regulations for vehicle operations and safety.&lt;SEP&gt;U.S. Department of Transportation is the federal agency overseeing transportation safety, including rules for hazardous material transport.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Federal Highway Administration">
  <ns0:data key="d0">Federal Highway Administration</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Federal Highway Administration manages rules for public highway use and permits.&lt;SEP&gt;Federal Highway Administration administers federal highway programs and safety regulations under the U.S. Department of Transportation.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Bureau of Motor Carrier Safety">
  <ns0:data key="d0">Bureau of Motor Carrier Safety</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Bureau of Motor Carrier Safety enforces regulations for motor carrier operations.&lt;SEP&gt;Bureau of Motor Carrier Safety enforces regulations for motor carriers transporting hazardous materials.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Audits Evaluations and Inspections">
  <ns0:data key="d0">Audits Evaluations and Inspections</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Audits Evaluations and Inspections are authorized Government activities requiring Contractor assistance and cooperation for equipment reviews.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Special Vehicle Maintenance and Repair Requirements">
  <ns0:data key="d0">Special Vehicle Maintenance and Repair Requirements</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Special Vehicle Maintenance and Repair Requirements outline priorities, downtime standards, suspensions, excessive repairs, fleet size, and CMMS implementation for NTVE.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Recurring Work">
  <ns0:data key="d0">Recurring Work</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">Recurring Work involves developing a transportation program for NTVE, MHE, and WHE management, operations, maintenance, and compliance with regulations.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="WHE/MHE/NTVE Services">
  <ns0:data key="d0">WHE/MHE/NTVE Services</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">WHE/MHE/NTVE Services include providing equipment and personnel 30 minutes prior to scheduled times, pier side support, and compliance with safety standards.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Fuel Delivery Service">
  <ns0:data key="d0">Fuel Delivery Service</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Fuel Delivery Service section details requirements for dispensing Government procured fuel in NTVE/MHE safely and timely.&lt;SEP&gt;Fuel Delivery Service requires using Government Furnished Equipment and personnel to dispense Government-procured fuel for NTVE and MHE.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="One-Time Repair Limits">
  <ns0:data key="d0">One-Time Repair Limits</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">One-Time Repair Limits are specified in Appendix G of MCO 11240.106 and require KO approval via CDRL 10004 before performing exceeding repairs.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Fleet Size">
  <ns0:data key="d0">Fleet Size</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Fleet Size is determined by actual equipment quantities at any time, allowing up to 5% variance without contract modification and adjusted semiannually.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Records and Reports">
  <ns0:data key="d0">Records and Reports</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Records and Reports encompass individual vehicle history jackets, accident damage repair estimates, vehicle repair status, annual safety inspection checklists, and monthly mileage entries in Fleet Focus, maintained per MCO 11240.106 and NAVFAC P-307.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Workmanship and Material Standards">
  <ns0:data key="d0">Workmanship and Material Standards</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Workmanship and Material Standards mandate applying best commercial practices, complying with safety codes and regulations, ensuring equipment returns to service safely, and maintaining clean work areas free of debris.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Industrialized Transportation Program">
  <ns0:data key="d0">Industrialized Transportation Program</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">The Industrialized Transportation Program is a comprehensive initiative for managing, operating, maintaining, repairing, and altering NTVE, MHE, and WHE to meet ongoing requirements efficiently and safely.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Crane Accident Review Board">
  <ns0:data key="d0">Crane Accident Review Board</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Crane Accident Review Board conducts reviews of crane accidents and incidents, requiring Contractor cooperation and information provision.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Ammunition Operations">
  <ns0:data key="d0">Ammunition Operations</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Ammunition Operations are after-hours activities requiring nonstop 24-hour crane support until completion.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Pier Side Gantry Crane Support">
  <ns0:data key="d0">Pier Side Gantry Crane Support</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Pier Side Gantry Crane Support is provided in accordance with the MMC offload/backload schedule and during ammunition operations, with equipment and personnel ready 30 minutes prior.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Alpha Code">
  <ns0:data key="d0">Alpha Code</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Alpha Code categorizes NTVE for inventory and downtime computations, such as Alpha Code Z for Low Speed Vehicles, with allowable downtime limits per code.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Low Speed Vehicle">
  <ns0:data key="d0">Low Speed Vehicle</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Low Speed Vehicle is a type of NTVE classified under Alpha Code Z, subject to Priority 3 maintenance and specific downtime standards.</ns0:data>
  <ns0:data key="d3">chunk-9fdacd5fbf292ea850730c0c323f0873</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="SL-3 Component Stock Lists">
  <ns0:data key="d0">SL-3 Component Stock Lists</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">SL-3 Component Stock Lists identify components needed for SKOTs and are used in inventories.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Section 4.B.7">
  <ns0:data key="d0">Section 4.B.7</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.B.7 specifies sourcing of materiel in accordance with established procedures.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Section 4.C">
  <ns0:data key="d0">Section 4.C</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.C addresses Inventory Management including rollback or disposition of excess inventory.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Section C.9">
  <ns0:data key="d0">Section C.9</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C.9 covers Port Operations for securing mobile loads.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="P3&amp;M">
  <ns0:data key="d0">P3&amp;M</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">P3&amp;M encompasses Preservation, Packaging, Packing, and Marking operations for various assets during MMC production.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="MDMC">
  <ns0:data key="d0">MDMC</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">MDMC conducts field level maintenance PMCS services on BICmd weapons.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="GCSS-MC vs. MCPIC Discrepancy Report">
  <ns0:data key="d0">GCSS-MC vs. MCPIC Discrepancy Report</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">GCSS-MC vs. MCPIC Discrepancy Report (CDRL 5044) identifies disparities between GCSS-MC and MCPIC for MPE/S, including data elements like TAMCN, nomenclature, NIIN, SN, and O/H quantity, provided NLT the start of the ship's backload.&lt;SEP&gt;GCSS-MC vs. MCPIC Discrepancy Report identifies disparities for MPE/S and is provided NLT the start of ship backload.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="Portable Fire Extinguishers">
  <ns0:data key="d0">Portable Fire Extinguishers</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">Portable Fire Extinguishers associated with ME are managed centrally by MCMC, including inspection, maintenance, testing, and certification per NFPA standards.&lt;SEP&gt;Portable fire extinguishers are SL-3 components associated with ME, requiring serial number recording, storage location identification, and inspections.&lt;SEP&gt;Portable Fire Extinguishers associated with ME must comply with NFPA 10-18 standards for inspection, maintenance, and testing.&lt;SEP&gt;Portable Fire Extinguishers require monthly inspections, annual inventory submission including manufacturer details, and notification if damaged or out of service.</ns0:data>
  <ns0:data key="d3">chunk-13a4841aefad66042f059edb023e607b&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5041">
  <ns0:data key="d0">CDRL 5041</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5041 is the SL-3 Deficiency Report containing data elements for shortfalls.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841089</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5042">
  <ns0:data key="d0">CDRL 5042</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5042 consists of Armory Custodian nomination letters provided to the Government.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5043">
  <ns0:data key="d0">CDRL 5043</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5043 includes Armory Access nomination letters for designated personnel.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="CDRL 5044">
  <ns0:data key="d0">CDRL 5044</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 5044 is the GCSS-MC vs. MCPIC Discrepancy Report for production cycles.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="Section 4.D.6">
  <ns0:data key="d0">Section 4.D.6</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.D.6 outlines supply operations for SKOT and SL-3 requirements during MMC production.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="Section 4.D.10">
  <ns0:data key="d0">Section 4.D.10</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.D.10 details logistics support operations for downloaded weapons during MMC production.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="ISO 17712:2013">
  <ns0:data key="d0">ISO 17712:2013</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">ISO 17712:2013 specifies requirements for high security seals used to secure and seal completed containers.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="MCO 4030.40">
  <ns0:data key="d0">MCO 4030.40</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">MCO 4030.40 is a Marine Corps Order referenced for preservation, packaging, and marking procedures.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1907">
  <ns0:data key="d0">DD Form 1907</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1907 is the Signature and Tally Record prepared and retained for Transportation Protective Services shipments of ammunition.&lt;SEP&gt;DD Form 1907 is the Signature and Tally Record prepared and retained for all Transportation Protective Services shipments of weapons.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="NFPA">
  <ns0:data key="d0">NFPA</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">NFPA is the National Fire Protection Association, issuing standards like NFPA 10-18 for fire extinguisher maintenance.&lt;SEP&gt;NFPA is the National Fire Protection Association that issues standards for portable fire extinguishers inspection, maintenance, and testing.&lt;SEP&gt;NFPA provides codes and standards for fire protection, safety, and maintenance applicable to the contract activities.&lt;SEP&gt;NFPA standards apply to preventive maintenance inspections, testing, and certification of applicable equipment.</ns0:data>
  <ns0:data key="d3">chunk-27cca63c94e6ea85e547a26e12b48a3c&lt;SEP&gt;chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4&lt;SEP&gt;chunk-070bdd3969938da07f8e836e32dfa592</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="Section 4.A">
  <ns0:data key="d0">Section 4.A</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.A specifies procedures for inventory, replacement, and replenishment of weapons SL-3.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="Section 4.B">
  <ns0:data key="d0">Section 4.B</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section 4.B specifies procedures for inventory, replacement, and replenishment of weapons SL-3.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="Frigard Temporary Armory Facility">
  <ns0:data key="d0">Frigard Temporary Armory Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Frigard Temporary Armory Facility requires nomination of primary and alternate armory custodians by MCMC.&lt;SEP&gt;Frigard Temporary Armory Facility is a storage site in Norway for crew served weapons under MCPP-N.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="MCSF-BI Temporary Armory Facility">
  <ns0:data key="d0">MCSF-BI Temporary Armory Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">MCSF-BI Temporary Armory Facility is used for storing weapons downloaded from MPF prior to shipment or backload.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="BICmd Temporary Weapons Facility">
  <ns0:data key="d0">BICmd Temporary Weapons Facility</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">BICmd Temporary Weapons Facility provides temporary storage for weapons when direct shipment between BICmd and LOGCOM is not feasible.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="AA&amp;E">
  <ns0:data key="d0">AA&amp;E</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">AA&amp;E refers to Arms, Ammunition, and Explosives, with access, key control, and custodian nomination standards outlined in MCO 5530.14.&lt;SEP&gt;AA&amp;E refers to arms, ammunition, and explosives requiring adherence to specific access, handling, and security standards.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a&lt;SEP&gt;chunk-abd2ceb311ce78c8a8c1fe38d11ee4f4</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="REPSHIP">
  <ns0:data key="d0">REPSHIP</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">REPSHIP is the Report of Shipment submitted by the MCMC for all weapons transported via protective services.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="NAVMC 2907 (PO)">
  <ns0:data key="d0">NAVMC 2907 (PO)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">NAVMC 2907 (PO) is a naval manual for detailed ship plans and logistics planning.</ns0:data>
  <ns0:data key="d3">chunk-22de15a10ae9bfba6096cca855d5f78a</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.1 Task Order Content">
  <ns0:data key="d0">H-8.1 Task Order Content</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.1 Task Order Content specifies the information to be included in each task order, such as contract number, pay office, work description, schedule, place of performance, CLIN/SLIN details, costs, fees, and accounting data.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.2 Allowable Costs">
  <ns0:data key="d0">H-8.2 Allowable Costs</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.2 Allowable Costs details reimbursement for material, travel, and overtime in accordance with FAR subsections and contract sections.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.3 Fee on Task Orders">
  <ns0:data key="d0">H-8.3 Fee on Task Orders</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.3 Fee on Task Orders describes fixed fee payments for CPFF and profit inclusion for FFP task orders, including adjustments for scope changes.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.4 Release of Claims">
  <ns0:data key="d0">H-8.4 Release of Claims</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.4 Release of Claims requires the MCMC to furnish a release of claims to the KO prior to final invoice submission for each task order.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.5 Task Order Close-Out">
  <ns0:data key="d0">H-8.5 Task Order Close-Out</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.5 Task Order Close-Out intends for closeout procedures on an individual basis, with the MCMC supporting timely internal functions.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-8.7 Indirect Rate Change Notification">
  <ns0:data key="d0">H-8.7 Indirect Rate Change Notification</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-8.7 Indirect Rate Change Notification mandates the MCMC to notify the KO within five working days of any proposed or approved rate changes affecting costs or prices.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-9 Contractor Acquired Property (CAP)/Subcontracts">
  <ns0:data key="d0">H-9 Contractor Acquired Property (CAP)/Subcontracts</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-9 Contractor Acquired Property (CAP)/Subcontracts requires the MCMC to furnish supplies/services, comply with FAR clauses, request authorizations for purchases/subcontracts, and provide lease agreements.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-10 Travel Procedures">
  <ns0:data key="d0">H-10 Travel Procedures</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-10 Travel Procedures governs travel arrangements, approvals, reimbursements, per diem, and restrictions for MCMC employees, including OCONUS personnel.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-11 Over and Above">
  <ns0:data key="d0">H-11 Over and Above</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-11 Over and Above requires negotiation of additional requirements via Work Request against task orders, with flexible pricing structures.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-12 Continuous Process Improvement (CPI) Incentive Program">
  <ns0:data key="d0">H-12 Continuous Process Improvement (CPI) Incentive Program</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-12 Continuous Process Improvement (CPI) Incentive Program requires ISO 9001:2015 certification within 9 months and incentivizes process improvements with shared cost savings.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-13 Base Support">
  <ns0:data key="d0">H-13 Base Support</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-13 Base Support provides Government-furnished workspaces, equipment, facilities, and utilities to the MCMC, with requirements for conservation and compliance.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-14 Conditions Applicable to Employment in Foreign Ports">
  <ns0:data key="d0">H-14 Conditions Applicable to Employment in Foreign Ports</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-14 Conditions Applicable to Employment in Foreign Ports requires the MCMC to comply with U.S. agreements with foreign governments for performance in foreign countries.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-15 Differential Pay">
  <ns0:data key="d0">H-15 Differential Pay</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-15 Differential Pay entitles MCMC personnel in imminent danger areas to differential pay equal to DoD civilian rates, with approvals for additional compensation in contingencies.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="H-16 Avoidance of Organizational Conflicts of Interest">
  <ns0:data key="d0">H-16 Avoidance of Organizational Conflicts of Interest</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">H-16 Avoidance of Organizational Conflicts of Interest restricts the MCMC from conflicting roles, requires safeguarding proprietary data, training, and agreements to prevent biases and unfair advantages.&lt;SEP&gt;H-16 Avoidance of Organizational Conflicts of Interest outlines restrictions on the MCMC to prevent conflicting roles, bias, and unfair competitive advantage, in accordance with FAR Subpart 9.5 and BICmd Order 4200.3.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="SLIN">
  <ns0:data key="d0">SLIN</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">SLIN refers to Subline Item Number associated with CLINs for detailed contract pricing and descriptions.&lt;SEP&gt;SLIN refers to Subline Item Number, detailed in cost breakouts and summaries for base and optional periods.</ns0:data>
  <ns0:data key="d3">chunk-1b912387d0abf83a18f9cd19906dc41e&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="CPFF">
  <ns0:data key="d0">CPFF</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CPFF is Cost Plus Fixed Fee level of effort in accordance with FAR 16.306(d)(2), applied to maintenance production, other logistics support, with fixed fee and total max cost plus fee.&lt;SEP&gt;CPFF is Cost Plus Fixed Fee, involving fixed fee payments and reimbursements for allowable costs in task orders.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FFP">
  <ns0:data key="d0">FFP</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">FFP is Firm Fixed Price applied to program management for 12 months during the base ordering period two.&lt;SEP&gt;FFP is Firm Fixed Price, including profit in the fixed amount for respective CLINs/SLINs.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.216-8">
  <ns0:data key="d0">FAR 52.216-8</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.216-8 is the Fixed Fee clause referenced for CPFF task order payments.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FAR 31.205-26">
  <ns0:data key="d0">FAR 31.205-26</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 31.205-26 governs reimbursement for material costs.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FAR 31.205-46">
  <ns0:data key="d0">FAR 31.205-46</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 31.205-46 governs reimbursement for travel costs.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.208-9">
  <ns0:data key="d0">FAR 52.208-9</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.208-9 requires contractor use of mandatory sources of supply or services.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841090</ns0:data>
</ns0:node>
<ns0:node id="FAR 52.251-1">
  <ns0:data key="d0">FAR 52.251-1</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR 52.251-1 addresses Government supply sources.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="ISO 9001:2015">
  <ns0:data key="d0">ISO 9001:2015</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">ISO 9001:2015 is the Quality Systems Standard requiring certification within 9 months and implementation of a CPI program.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Joint Travel Regulations (JTR)">
  <ns0:data key="d0">Joint Travel Regulations (JTR)</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Joint Travel Regulations (JTR) provides per diem/lodging rates and guidelines for evaluating and reimbursing travel costs.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Public Law 99-234">
  <ns0:data key="d0">Public Law 99-234</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Public Law 99-234 is the regulatory basis for travel cost reimbursements under FAR 31.205-46.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="BICmd Order 4200.3">
  <ns0:data key="d0">BICmd Order 4200.3</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">BICmd Order 4200.3 sets forth restrictions on organizational conflicts of interest in accordance with FAR Subpart 9.5.&lt;SEP&gt;BICmd Order 4200.3 provides guidelines for restrictions on the MCMC to prevent organizational conflicts of interest.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="FAR Subpart 9.5">
  <ns0:data key="d0">FAR Subpart 9.5</ns0:data>
  <ns0:data key="d1">clause</ns0:data>
  <ns0:data key="d2">FAR Subpart 9.5, entitled Organizational and Consultant Conflicts of Interest, sets principles for the MCMC to avoid conflicts, including restrictions on use and disclosure of proprietary data.&lt;SEP&gt;FAR Subpart 9.5 is entitled Organizational and Consultant Conflicts of Interest and provides principles for the MCMC to avoid conflicts in performing the contract.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70&lt;SEP&gt;chunk-b6f17f0fbf6c678da23e588ab57f6900</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Work Request">
  <ns0:data key="d0">Work Request</ns0:data>
  <ns0:data key="d1">requirement</ns0:data>
  <ns0:data key="d2">Work Request is submitted as CDRL 10025 prior to startups for new personnel, equipment requests, or changes in work hours/schedules to comply with ammunition operations.&lt;SEP&gt;Work Request is the mechanism used to negotiate and authorize over and above requirements against task orders.</ns0:data>
  <ns0:data key="d3">chunk-070bdd3969938da07f8e836e32dfa592&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Red Cross">
  <ns0:data key="d0">Red Cross</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Red Cross verifies emergencies for travel reimbursements and personnel separations in the context of contract performance.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Department of State">
  <ns0:data key="d0">Department of State</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Department of State sets standards for compensation to retain personnel in contingency operations.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="PKO">
  <ns0:data key="d0">PKO</ns0:data>
  <ns0:data key="d1">person</ns0:data>
  <ns0:data key="d2">PKO is the approving authority for additional compensation costs above Department of State standards in declared contingencies.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="OCONUS">
  <ns0:data key="d0">OCONUS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">OCONUS denotes locations outside the continental United States, relevant to travel and personnel support under CPFF CLINs.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="CONUS">
  <ns0:data key="d0">CONUS</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">CONUS refers to locations within the continental United States where Navy Watercraft monitoring and maintenance are performed regardless of specific site.&lt;SEP&gt;CONUS denotes locations within the continental United States, referenced in travel and medical return provisions.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Government Audit Agency">
  <ns0:data key="d0">Government Audit Agency</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Government Audit Agency receives notifications from the MCMC regarding proposed or approved indirect rate changes.</ns0:data>
  <ns0:data key="d3">chunk-d89c19e067243fa311d34bfc3fa99c70</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Statement of Work">
  <ns0:data key="d0">Statement of Work</ns0:data>
  <ns0:data key="d1">statement_of_work</ns0:data>
  <ns0:data key="d2">Statement of Work outlines the requirements for program management, maintenance production, logistics support, and other services under the contract.&lt;SEP&gt;The Statement of Work outlines requirements for logistics services supporting the Marine Corps Prepositioning Program, including maintenance, supply, and operations.&lt;SEP&gt;Statement of Work is an attached document that outlines tasks, responsibilities, standards, and sections such as C.1, C.2.A, C.2.B, C.2.C, C.2.D for services provided by MCMC.&lt;SEP&gt;The Statement of Work outlines the requirements for services, which contractors must understand through the Site Visit and submission of questions.&lt;SEP&gt;Statement of Work outlines requirements for MCPP operations, including attachments like C.1-3 MMC Notional POAM and C.1-7 Employee Qualifications.&lt;SEP&gt;The Statement of Work outlines the work requirements for the contract and is referenced for understanding during the site visit and proposal preparation.</ns0:data>
  <ns0:data key="d3">chunk-6b04b67f7f379aa858c2a82b29df69a0&lt;SEP&gt;chunk-33458028830a7ae0043a51d8a7a1e726&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-f121013aeb8c98e8b0609d68d89b74e5&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c&lt;SEP&gt;chunk-8aa129e6fff6d48e4dab5ab9c9d8c169</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="United States Marine Corps">
  <ns0:data key="d0">United States Marine Corps</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The United States Marine Corps manages the Marine Corps Prepositioning Program and oversees prepositioned equipment and supplies.&lt;SEP&gt;United States Marine Corps oversees MCPP objectives for equipment readiness and prepositioning programs.&lt;SEP&gt;United States Marine Corps operates the GOGO-CS Enterprise Network and directs overall NetOps/Cyber Network Operations through entities like MCCOG.&lt;SEP&gt;The United States Marine Corps issues the solicitation and manages the acquisition process through Blount Island Command.&lt;SEP&gt;United States Marine Corps establishes orders and instructions such as MCO series for safety, vehicle, and environmental compliance.</ns0:data>
  <ns0:data key="d3">chunk-33458028830a7ae0043a51d8a7a1e726&lt;SEP&gt;chunk-b825754de20bbf2c5befd6a79730280e&lt;SEP&gt;chunk-93752a7bd8aca85ef0ce5fea3701dc32&lt;SEP&gt;chunk-cf666a8ded534eb47b7eede4412a01f1&lt;SEP&gt;chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Section C">
  <ns0:data key="d0">Section C</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section C provides descriptions and specifications for the Marine Corps Prepositioning Program Logistics Services Contract.&lt;SEP&gt;Section C provides the Description/Specifications/Work Statement, including details on program management and maintenance activities in the SOW.&lt;SEP&gt;Section C of the Statement of Work includes subsections C.1, C.2.A, C.2.B, C.2.C, and C.2.D outlining program and risk management support requirements.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Item 9004">
  <ns0:data key="d0">Item 9004</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Item 9004 specifies hours for Other Logistics Support under CPFF for Base Ordering Period Two, providing Contingency/Exercise/Emerging Requirements support.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Item 9005">
  <ns0:data key="d0">Item 9005</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Item 9005 specifies tasks for Travel under COST for Base Ordering Period Two, with no fee or markups applied to Travel.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Item 9006">
  <ns0:data key="d0">Item 9006</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Item 9006 specifies units for Other Direct Costs under COST for Base Ordering Period Year Two, with no fee applied to Other Direct Costs.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Item 9007">
  <ns0:data key="d0">Item 9007</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">Item 9007 specifies units for Data Requirements / CDRLs under NSP for Base Ordering Period Year Two, providing data using DD Form 1423-1 as established in the SOW.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Norwegian Ministry of Defense">
  <ns0:data key="d0">Norwegian Ministry of Defense</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">The Norwegian Ministry of Defense provides personnel for logistics services in Norway through the Norwegian Defense Logistics Organization.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Air Mobility Command">
  <ns0:data key="d0">Air Mobility Command</ns0:data>
  <ns0:data key="d1">organization</ns0:data>
  <ns0:data key="d2">Air Mobility Command is the U.S. Air Force entity responsible for airlifting Marine Corps personnel to rendezvous with prepositioned ships during deployments.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Operation Iraqi Freedom">
  <ns0:data key="d0">Operation Iraqi Freedom</ns0:data>
  <ns0:data key="d1">event</ns0:data>
  <ns0:data key="d2">Operation Iraqi Freedom was a conflict that prompted the withdrawal of prepositioned assets from Norway between 2003 and 2005.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Humanitarian Assistance/Disaster Relief">
  <ns0:data key="d0">Humanitarian Assistance/Disaster Relief</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Humanitarian Assistance/Disaster Relief encompasses prepositioned equipment sets designed for rapid response to disasters and relief operations.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="DD Form 1423-1">
  <ns0:data key="d0">DD Form 1423-1</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">DD Form 1423-1 is the form used by MCMC for providing data requirements, reports, and submittals as established in the Statement of Work.&lt;SEP&gt;DD Form 1423-1 is the standard form used to define and deliver contract data requirements, reports, and submittals.&lt;SEP&gt;DD Form 1423-1 is the standard form used to define and establish Contract Data Requirements Lists (CDRLs) in the SOW.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-8aa129e6fff6d48e4dab5ab9c9d8c169&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Contract Attachment #9">
  <ns0:data key="d0">Contract Attachment #9</ns0:data>
  <ns0:data key="d1">annex</ns0:data>
  <ns0:data key="d2">Contract Attachment #9 establishes data requirements using DD Form 1423-1 in the Statement of Work.&lt;SEP&gt;Attachment referenced for data requirements established in the Statement of Work.&lt;SEP&gt;Contract Attachment #9 specifies the data requirements and CDRLs to be provided using DD Form 1423-1.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f&lt;SEP&gt;chunk-f0bef8ac155e28eb1ccd0095250383c3&lt;SEP&gt;chunk-f6510cadeb544a78c12488882601935c</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Fly-in Echelon">
  <ns0:data key="d0">Fly-in Echelon</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Fly-in Echelon refers to the Marine Corps personnel airlifted to integrate with prepositioned equipment and supplies for rapid force assembly.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Memorandum of Understanding Governing Pre-Stockage and Reinforcement of Norway">
  <ns0:data key="d0">Memorandum of Understanding Governing Pre-Stockage and Reinforcement of Norway</ns0:data>
  <ns0:data key="d1">document</ns0:data>
  <ns0:data key="d2">Memorandum of Understanding Governing Pre-Stockage and Reinforcement of Norway is the bilateral agreement signed in 2005 between the U.S. Secretary of Defense and the Norwegian Minister of Defense.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Section H -8.3">
  <ns0:data key="d0">Section H -8.3</ns0:data>
  <ns0:data key="d1">section</ns0:data>
  <ns0:data key="d2">Section H -8.3 outlines the methodology for determining fixed fees in task orders, maintaining the ratio from the initial contract award.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Trondelog">
  <ns0:data key="d0">Trondelog</ns0:data>
  <ns0:data key="d1">location</ns0:data>
  <ns0:data key="d2">Trondelog is the region in Norway where most MCPP-N services are provided using government-furnished facilities and equipment.</ns0:data>
  <ns0:data key="d3">chunk-73f90f99a53e4953f841f6b0275ecb2f</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="LARCs">
  <ns0:data key="d0">LARCs</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">LARCs are amphibious vehicles subject to the same maintenance, corrosion control, and operational procedures as Navy Watercraft, including spot preservation and high pressure washing.&lt;SEP&gt;LARCs are amphibious vehicles included in weekly/bi-weekly reporting requirements and eligible for familiarization training.&lt;SEP&gt;LARCs are amphibious lighterage vehicles subject to POL replacement, maintenance, inspections, and fueling by MCMC.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-e73c8ab3a0b248cdeedb8496a5c6f8a9</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="LCM-8">
  <ns0:data key="d0">LCM-8</ns0:data>
  <ns0:data key="d1">technology</ns0:data>
  <ns0:data key="d2">LCM-8 is a Landing Craft Mechanized model requiring 520 gallons of JP-5 fuel per tank.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Phase Delta">
  <ns0:data key="d0">Phase Delta</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Phase Delta involves organizational level maintenance to prepare watercraft for MPS embarkation, aligned with USMC MMC process, ending with backload.&lt;SEP&gt;Phase Delta requires MCMC to perform advanced maintenance tasks, submit reports, stage ship sets, and conduct operational checks for Navy Watercraft embarkation and backload.&lt;SEP&gt;Phase Delta involves tasks such as POL replacement, load testing, maintenance, fueling, and delivery of Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Phase Bravo">
  <ns0:data key="d0">Phase Bravo</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Phase Bravo starts the ashore maintenance cycle with offload, inspections, tests, and docking, lasting 45 days, involving joint efforts by RST, OST, and others.&lt;SEP&gt;Phase Bravo involves MCMC performing organizational level maintenance, high pressure washing, and other tasks on Navy Watercraft, LARCs, and ABLTS as part of the maintenance model.&lt;SEP&gt;Phase Bravo includes oil sampling, inventory of equipage, and movement services for Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-7659b0abfc62a3f8f0edbf4a1fee058e&lt;SEP&gt;chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="Phase Charlie">
  <ns0:data key="d0">Phase Charlie</ns0:data>
  <ns0:data key="d1">concept</ns0:data>
  <ns0:data key="d2">Phase Charlie is the longest ashore phase for intermediate and depot level Corrective Maintenance, lasting about 12 months or more, involving outsourcing and quality control.&lt;SEP&gt;Phase Charlie encompasses corrective maintenance, corrosion control, and coating repairs on Navy Watercraft.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8&lt;SEP&gt;chunk-b8875a30a8284afacba5893b8971b2b3</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6044">
  <ns0:data key="d0">CDRL 6044</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6044 is the Navy Watercraft Oil Analysis Report provided within 5 business days of lab receipt.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6045">
  <ns0:data key="d0">CDRL 6045</ns0:data>
  <ns0:data key="d1">deliverable</ns0:data>
  <ns0:data key="d2">CDRL 6045 consists of Navy Watercraft and ABLTS Load Test Certification(s) for periodic and situational requirements.</ns0:data>
  <ns0:data key="d3">chunk-d6887833d0f1a6398bb6c8fd6f72d5c8</ns0:data>
  <ns0:data key="d4">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d5">1759841091</ns0:data>
</ns0:node>
<ns0:node id="CDRL 6046">
  <ns0:data key="d0">CDRL 6046</ns0:data>
