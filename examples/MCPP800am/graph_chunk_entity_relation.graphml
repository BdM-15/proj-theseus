<ns0:edge source="Class of Supply (COS)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC identifies and reports deficiencies in Class of Supply (COS) categories for ship production.</ns0:data>
  <ns0:data key="d8">attainment,reporting</ns0:data>
