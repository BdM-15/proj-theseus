  <ns0:data key="d7">MCMC reconciles GCSS-MC supply data against NEIMS UICs monthly and submits reports.</ns0:data>
  <ns0:data key="d8">data reconciliation</ns0:data>
  <ns0:data key="d9">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841331</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="DLA Troop Support">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC conducts MRE stock rotation with DLA Troop Support to acquire replacement stocks for sustainment blocks.</ns0:data>
  <ns0:data key="d8">collaboration,stock rotation</ns0:data>
  <ns0:data key="d9">chunk-bd3a05bb896b89de7fd366c654ad4a6b</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841331</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Contracting Officer Technical Representative">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Contracting Officer Technical Representative monitors MCMC performance, provides technical guidance, approves deliverables, and reports issues.</ns0:data>
  <ns0:data key="d8">guidance,monitoring</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841332</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Task Order">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Task Order authorizes MCMC to proceed with work, specifies performance periods, and obligates funds.</ns0:data>
  <ns0:data key="d8">authorization,performance</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841333</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Contract Cost and Status Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides monthly Contract Cost and Status Report concurrent with invoices, detailing costs, funding, and variances.</ns0:data>
  <ns0:data key="d8">reporting,submission</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841334</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Marine Corps">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Marine Corps is an equipment ownership group for which MCMC segregates and reports costs monthly.</ns0:data>
  <ns0:data key="d8">cost segregation,funding</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841335</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section G-3">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section G-3 requires MCMC to submit monthly invoices with specific content for labor, property, and travel.</ns0:data>
  <ns0:data key="d8">compliance,invoicing requirements</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841335</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section H-1">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H-1 defines standard workday for MCMC and requires government approval for alterations.</ns0:data>
  <ns0:data key="d8">approval,workday definition</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841336</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Section H-2">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">Section H-2 specifies holidays and limits MCMC reimbursement for holiday work to normal compensation without premiums.</ns0:data>
  <ns0:data key="d8">compensation,holiday observance</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841336</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Government Holidays">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC personnel may work on government holidays without premium compensation beyond normal rates, with flexible scheduling to avoid overtime.</ns0:data>
  <ns0:data key="d8">compensation limits,observance</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841337</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Release of Claims">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC furnishes a release of claims to the Contracting Officer after each task order completion prior to final invoicing.</ns0:data>
  <ns0:data key="d8">submission requirement,task completion</ns0:data>
  <ns0:data key="d9">chunk-386066b546b82c7b89bda0ef90b3a5f2</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841337</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Watercraft Maintenance Center (WMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC establishes and maintains Navy Watercraft Maintenance Center (WMC) with dedicated personnel for Navy Watercraft maintenance.</ns0:data>
  <ns0:data key="d8">establishment,maintenance responsibility</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841337</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Maintenance Requirements Package (MRP)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC performs organizational and selective intermediate maintenance on Navy Watercraft IAW Maintenance Requirements Package (MRP).</ns0:data>
  <ns0:data key="d8">adherence,performance</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841338</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy Master Schedule">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC produces and maintains Navy Master Schedule, delivering revisions for approval within specified business days.</ns0:data>
  <ns0:data key="d8">delivery,production</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841338</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Tailored Navy Watercraft Production Schedule">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC produces, maintains, and adheres to Tailored Navy Watercraft Production Schedule for each ship, submitting for approval NLT WDC-III.</ns0:data>
  <ns0:data key="d8">adherence,production</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841341</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Pre-MAT">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC schedules, provides packages, and documents joint Pre-MATs for Navy Watercraft within 45 calendar days of download.</ns0:data>
  <ns0:data key="d8">documentation,scheduling</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841342</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Post-MAT">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC accomplishes Post-MAT waterborne tests NLT E-45 day as part of milestones.</ns0:data>
  <ns0:data key="d8">performance,timing</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841342</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Work Definition Conference (WDC-I)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC schedules and leads Work Definition Conference (WDC-I) NLT Offload + 90 O Day to identify conditions and recommend maintenance.</ns0:data>
  <ns0:data key="d8">leadership,scheduling</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841342</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Work Definition Conference (WDC-III)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC schedules, leads, and presents projects at Work Definition Conference (WDC-III) including requirements from prior WDCs.</ns0:data>
  <ns0:data key="d8">presentation,scheduling</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841343</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Boat Information Book (BIB)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC produces and maintains Boat Information Book (BIB) for each Watercraft and ABLTS, submitting NLT E-4.</ns0:data>
  <ns0:data key="d8">production,submission</ns0:data>
