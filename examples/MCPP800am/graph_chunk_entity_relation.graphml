<ns0:edge source="Contractor" target="Simplified Acquisition Threshold">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Contractor includes clause substances in subcontracts exceeding the Simplified Acquisition Threshold for services within the United States.</ns0:data>
  <ns0:data key="d8">inclusion,subcontract threshold</ns0:data>
