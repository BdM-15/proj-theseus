  <ns0:data key="d11">1759841219</ns0:data>
</ns0:edge>
<ns0:edge source="DD Form 1149" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC prepares DD Form 1149 for release and shipment of materiel, including manifests.</ns0:data>
  <ns0:data key="d8">documentation,shipping</ns0:data>
