<ns0:edge source="Association Reference Table" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC configures Principle End Items and associated equipment, including SL-3, SSRI, CM, and UURI, in accordance with the government-provided Association Reference Table.</ns0:data>
  <ns0:data key="d8">PEI assembly,configuration guidance</ns0:data>
  <ns0:data key="d9">chunk-5fcb066f3ce0c1cfffc65441135b96e1</ns0:data>
