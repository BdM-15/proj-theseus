<ns0:edge source="Request for Proposal (RFP)" target="Cost/Price Factor">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The Cost/Price Factor is evaluated in accordance with procedures outlined in the Request for Proposal (RFP) and FAR 15.404.</ns0:data>
  <ns0:data key="d8">evaluation procedure,solicitation compliance</ns0:data>
