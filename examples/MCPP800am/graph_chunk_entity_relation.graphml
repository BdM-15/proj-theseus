<ns0:edge source="MCMC" target="OSHA 3162-01R">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC follows OSHA 3162-01R for medical screening and surveillance programs.</ns0:data>
  <ns0:data key="d8">compliance,medical surveillance</ns0:data>
  <ns0:data key="d9">chunk-b825754de20bbf2c5befd6a79730280e</ns0:data>
