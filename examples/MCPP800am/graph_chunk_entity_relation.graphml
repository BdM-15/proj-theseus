  <ns0:data key="d11">1759841344</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Navy EOS CESE Maintenance Report">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC submits complete and accurate Navy EOS CESE Maintenance Report (CDRL 6038) within five business days after production period completion.</ns0:data>
  <ns0:data key="d8">accuracy,submission</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841344</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Accident LTI">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides Accident LTI with investigation within 15 calendar days after accident, accurately documenting damages.</ns0:data>
  <ns0:data key="d8">documentation,provision</ns0:data>
  <ns0:data key="d9">chunk-85b50b451f72c11f155dc39b516d8dd3</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841344</ns0:data>
</ns0:edge>
<ns0:edge source="MCMC" target="Onboard Watercraft Technical Library">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC maintains onboard hardcopy technical library for each Navy Watercraft in Phase Delta, updating prior to Stage 4.</ns0:data>
  <ns0:data key="d8">maintenance,updates</ns0:data>
