<ns0:edge source="Transportation Control and Movement Documents (TCMDs)" target="Marine Corps Maintenance Coordinator (MCMC)">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC prepares TCMDs for overseas and export shipments per SDDC guidelines.</ns0:data>
  <ns0:data key="d8">export,preparation</ns0:data>
  <ns0:data key="d9">chunk-30ad74540c8224cf4aff1f3de36d3780</ns0:data>
  <ns0:data key="d10">M6700425R0007 MCPP II DRAFT RFP 23 MAY 25.pdf</ns0:data>
  <ns0:data key="d11">1759841413</ns0:data>
</ns0:edge>
<ns0:edge source="Cargo Handling Equipment (CHE)" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">The MCMC oversees the licensing program for Cargo Handling Equipment (CHE) in distribution operations.</ns0:data>
  <ns0:data key="d8">licensing,operation</ns0:data>
  <ns0:data key="d9">chunk-5e151c7682b4ed7c6cd2fcdc2e29ec22</ns0:data>
