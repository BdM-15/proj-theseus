<ns0:edge source="Armory Plan" target="MCMC">
  <ns0:data key="d6">1.0</ns0:data>
  <ns0:data key="d7">MCMC provides designated equipment and supplies for prepositioned weapon systems as directed by the government-provided Armory Plan, packaging and marking for specific MSEs.</ns0:data>
  <ns0:data key="d8">packaging,provision</ns0:data>
