  <data key="d11">1759836301</data>
</edge>
<edge source="Government" target="Liquidated Damages">
  <data key="d6">1.0</data>
  <data key="d7">Liquidated damages compensate the Government for costs arising from the Contractor's nonperformance or delays.</data>
  <data key="d8">compensation mechanism,penalty enforcement</data>
  <data key="d9">chunk-96e30762ee04dbe2af303802d3d2a936</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836301</data>
</edge>
