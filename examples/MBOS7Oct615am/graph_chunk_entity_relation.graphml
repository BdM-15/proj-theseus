<edge source="52.222-38 Compliance With Veterans Employment Reporting Requirements" target="Simplified Acquisition Threshold">
  <data key="d6">1.0</data>
  <data key="d7">Simplified Acquisition Threshold is exceeded for 52.222-38 applicability in non-commercial contracts.</data>
  <data key="d8">reporting requirement,threshold applicability</data>
