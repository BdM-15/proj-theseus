  <data key="d0">NAVFAC Maximo</data>
  <data key="d1">technology</data>
  <data key="d2">NAVFAC Maximo is a data system critical for government planning, requiring maintenance of service provider, asset, specification, and characteristic meter reading data fields.</data>
  <data key="d3">chunk-b1019473eb9ce96e37dbd7a39cfdf02d</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759836290</data>
