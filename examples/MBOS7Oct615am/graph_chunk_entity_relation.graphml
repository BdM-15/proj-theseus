  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836302</data>
</edge>
<edge source="Government" target="52.216-19 Order Limitations">
  <data key="d6">1.0</data>
  <data key="d7">The Government adheres to minimum and maximum order limits specified in clause 52.216-19.</data>
  <data key="d8">order constraints,purchasing limits</data>
  <data key="d9">chunk-96e30762ee04dbe2af303802d3d2a936</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836302</data>
</edge>
<edge source="Government" target="52.217-8 Option To Extend Services">
  <data key="d6">1.0</data>
  <data key="d7">The Government may exercise the option to extend services under clause 52.217-8 up to 6 months.</data>
  <data key="d8">extension option,service continuation</data>
  <data key="d9">chunk-96e30762ee04dbe2af303802d3d2a936</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836302</data>
</edge>
<edge source="Government" target="52.217-9 Option To Extend The Term Of The Contract">
  <data key="d6">1.0</data>
  <data key="d7">The Government may extend the contract term under clause 52.217-9, not exceeding 96 months total.</data>
  <data key="d8">duration limit,term extension</data>
  <data key="d9">chunk-96e30762ee04dbe2af303802d3d2a936</data>
  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836303</data>
</edge>
<edge source="Government" target="Default-Fixed-Price Supply And Service Clause">
  <data key="d6">1.0</data>
  <data key="d7">The Government may terminate the contract under the Default-Fixed-Price Supply And Service clause, triggering liquidated damages liability.</data>
  <data key="d8">contract enforcement,termination authority</data>
