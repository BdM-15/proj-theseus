  <data key="d0">Fully Loaded Pricing</data>
  <data key="d1">requirement</data>
  <data key="d2">Fully Loaded Pricing requires all pricing, including ELINs, to be fully loaded with no additional allocations, fees, overhead, G&amp;A, or profits applied later.</data>
  <data key="d3">chunk-4bcb91b404a9ca74c18944c1ba7f80a2</data>
  <data key="d4">_N6945025R0003.pdf</data>
  <data key="d5">1759836285</data>
</node>
