<edge source="52.204-8 Annual Representations And Certifications" target="Women-Owned Small Business">
  <data key="d6">1.0</data>
  <data key="d7">Women-Owned Small Business set-aside or sole-source awards are covered in 52.204-8.</data>
  <data key="d8">award type,set-aside category</data>
