  <data key="d10">_N6945025R0003.pdf</data>
  <data key="d11">1759836323</data>
</edge>
<edge source="Small Business Size Standard" target="NAICS 541519">
  <data key="d6">1.0</data>
  <data key="d7">NAICS 541519 has a small business size standard of 150 employees for information technology value-added resellers in specific set-aside acquisitions.</data>
  <data key="d8">classification standard,employee threshold</data>
