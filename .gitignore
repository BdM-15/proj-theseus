# ============================================================================
# Project-Specific: RAG Storage and Processing
# ============================================================================
# Knowledge graph storage (regenerated from RFPs)
rag_storage/
rag_storage_*/

# Log files (not used by current code, regenerated if needed)
logs/*.log
logs/*.log.*

# Temporary processing files
*.tmp
*.temp
*.bak
*.backup
*.swp
*.cache
deps-backup-*/

# ============================================================================
# Project-Specific: Input Documents
# ============================================================================
# Uploaded documents (should not be committed - may contain sensitive data)
inputs/__enqueued__/*.pdf
inputs/__enqueued__/*.docx
inputs/__enqueued__/*.doc
inputs/__enqueued__/*.pptx
inputs/__enqueued__/*.ppt
inputs/__enqueued__/*.xlsx
inputs/__enqueued__/*.xls
inputs/__enqueued__/*.txt
inputs/__enqueued__/*.rtf
inputs/__enqueued__/*.odt
inputs/__enqueued__/*.html
inputs/__enqueued__/*.xml
inputs/__enqueued__/*.json

inputs/uploaded/**/*
!inputs/uploaded/.gitkeep

# Keep directory structure
!inputs/__enqueued__/.gitkeep
!logs/.gitkeep
!rag_storage/.gitkeep

